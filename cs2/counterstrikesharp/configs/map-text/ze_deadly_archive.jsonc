    }
  },
  "到底发生了什么…": {
    "translation": "",
    "MultiLang": {
      "US": "What on earth happened…",
      "JP": "いったい何が起きたのか…",
      "CN": "",
      "KR": "대체 무슨 일이…",
      "TW": "到底發生了什麼事…"
    }
  },
  "AFK玩家将会在5秒后传送": {
    "translation": "",
    "MultiLang": {
      "US": "AFK players will be teleported in 5 seconds.",
      "JP": "AFKプレイヤーは5秒後にテレポートされます",
      "CN": "",
      "KR": "AFK 플레이어는 5초 후에 텔레포트됩니다",
      "TW": "AFK玩家在5秒後傳送"
    }
  },
  "我需要想办法打碎这块玻璃才能过去": {
    "translation": "",
    "MultiLang": {
      "US": "I need to find a way to break this glass to proceed.",
      "JP": "このガラスを壊して先へ進む必要がある",
      "CN": "",
      "KR": "이 유리창을 깨야 지나갈 수 있겠군",
      "TW": "我需要想辦法打碎這塊玻璃才能過去"
    }
  },
  "这道门被锁住了，我需要找到钥匙": {
    "translation": "",
    "MultiLang": {
      "US": "This door is locked. I need to find the key.",
      "JP": "この扉は施錠されている、鍵を見つけなければならない",
      "CN": "",
      "KR": "이 문은 잠겨 있고 열쇠가 필요해",
      "TW": "這道門被鎖住了，我需要找到鑰匙"
    }
  },
  "旁边的厕所会不会有线索": {
    "translation": "",
    "MultiLang": {
      "US": "Maybe there are clues in the nearby restroom?",
      "JP": "隣のトイレに手がかりがあるかも",
      "CN": "",
      "KR": "옆 화장실에 단서가 있을까?",
      "TW": "旁邊的廁所會不會有線索？"
    }
  },
  "这道门将会在15秒后打开": {
    "translation": "",
    "MultiLang": {
      "US": "This door will open in 15 seconds.",
      "JP": "この扉は15秒後に開きます",
      "CN": "",
      "KR": "이 문은 15초 후에 열립니다",
      "TW": "這道門將在15秒後開啟"
    }
  },
  "正好地上有门卡，看看能不能用上": {
    "translation": "",
    "MultiLang": {
      "US": "There happens to be a keycard on the ground. Let's see if it works.",
      "JP": "たまたま床に鍵カードが落ちてる。もしかしたら使えるかも",
      "CN": "",
      "KR": "따다 보니까 바닥에 열쇠카드가 있군, 써볼까?",
      "TW": "正好地上有門卡，看看能不能用上"
    }
  },
  "这是？！别…别过来！": {
    "translation": "",
    "MultiLang": {
      "US": "What is this?! D-Don't come any closer!",
      "JP": "これは…？！行か…行くんじゃ無い！",
      "CN": "",
      "KR": "이건 뭐…? 가… 가지 마!",
      "TW": "這是？！別…別過來！"
    }
  },
  "这道门将会在25秒后打开": {
    "translation": "",
    "MultiLang": {
      "US": "This door will open in 25 seconds.",
      "JP": "この門は25秒後に開きます",
      "CN": "",
      "KR": "이 문은 25초 후에 열립니다",
      "TW": "這道門將會在 25 秒後打開"
    }
  },
  "这一定与博士的实验有关！": {
    "translation": "",
    "MultiLang": {
      "US": "This must be connected to the Doctor's experiments!",
      "JP": "これは間違いなく博士の実験に関係している！",
      "CN": "",
      "KR": "반드시 박사의 실험과 관련이 있겠군!",
      "TW": "這一定與博士的實驗有關！"
    }
  },
  "提示：通风管道里会有补给，请及时拾取": {
    "translation": "",
    "MultiLang": {
      "US": "Tip: Supplies can be found inside the ventilation shafts. Please pick them up promptly.",
      "JP": "ヒント：換気口には補給物資があります。お早めに回収してください",
      "CN": "",
      "KR": "알림: 환기구에 보급품이 있으니 빨리 챙기세요",
      "TW": "提示：通風管道裡會有補給，請及時拾取"
    }
  },
  "这座医院的人看来都感染了病毒！": {
    "translation": "",
    "MultiLang": {
      "US": "It seems everyone in this hospital has been infected by the virus!",
      "JP": "この病院の人々は全員、ウイルスに感染しているようだ！",
      "CN": "",
      "KR": "이 병원 사람들은 모두 바이러스에 감염된 거야!",
      "TW": "這家醫院的人看來都感染了病毒！"
    }
  },
  "我还能逃出这个地方吗？": {
    "translation": "",
    "MultiLang": {
      "US": "Can I still escape from this place?",
      "JP": "私はここから逃がれることができるだろうか？",
      "CN": "",
      "KR": "나는 여기서 탈출할 수 있을까?",
      "TW": "我還能逃出這個地方嗎？"
    }
  },
  "我还不能死！": {
    "translation": "",
    "MultiLang": {
      "US": "I can't die yet!",
      "JP": "私は死んではいけない！",
      "CN": "",
      "KR": "나는 죽을 수 없어!",
      "TW": "我還不能死！"
    }
  },
  "钥匙应该就在附近": {
    "translation": "",
    "MultiLang": {
      "US": "The key should be nearby.",
      "JP": "鍵はすぐ近くにあるはずだ",
      "CN": "",
      "KR": "열쇠는 아마도 근처에 있을 거야",
      "TW": "鑰匙應該就在附近"
    }
  },
  "我需要一点时间来推动这个柜子": {
    "translation": "",
    "MultiLang": {
      "US": "I need a moment to push this cabinet.",
      "JP": "このキャビネットを動かすまでに、少し時間が必要だ",
      "CN": "",
      "KR": "이 캐비넷을 밀어내려면 시간이 좀 필요해.",
      "TW": "我需要一點時間來推動這個柜子"
    }
  },
  "附近好像都没有找到，难道是在水里？": {
    "translation": "",
    "MultiLang": {
      "US": "I couldn't find it anywhere nearby. Could it be in the water?",
      "JP": "近くでどこを探しても見つからない。水中にあるのか？",
      "CN": "",
      "KR": "근처를 모두 뒤져봤는데 없네, 물속에 있을까?",
      "TW": "附近好像都沒有找到，難道是在水裡？"
    }
  },
  "这道门将会在20秒后打开": {
    "translation": "",
    "MultiLang": {
      "US": "This door will open in 20 seconds.",
      "JP": "このドアは20秒後に開きます",
      "CN": "",
      "KR": "이 문은 20초 후에 열릴 거야.",
      "TW": "這道門將會在20秒後打開"
    }
  },
  "啊啊啊啊！": {
    "translation": "",
    "MultiLang": {
      "US": "Ahhhh!",
      "JP": "あああ！",
      "CN": "",
      "KR": "아악!",
      "TW": "啊啊啊啊！"
    }
  },
  "这道门也被锁住了，找找附近有没有钥匙卡": {
    "translation": "",
    "MultiLang": {
      "US": "This door is also locked. Look for a keycard nearby.",
      "JP": "このドアも施錠されている。近くのキーカードを探そう",
      "CN": "",
      "KR": "이 문도 잠겨 있네. 근처에 열쇠카드가 있는지 찾아봐야 해.",
      "TW": "這道門也被鎖住了，找找附近有沒有鑰匙卡"
    }
  },
  "前面的路被大火挡住了，我需要找到灭火器": {
    "translation": "",
    "MultiLang": {
      "US": "The path ahead is blocked by fire. I need to find a fire extinguisher.",
      "JP": "先の道は炎で塞がれている。消火器を見つけなければならない",
      "CN": "",
      "KR": "앞길은 큰 불길에 막혔어. 소화기를 찾아야 해.",
      "TW": "前面的路被大火擋住了，我需要找到滅火器"
    }
  },
  "大火将会在40秒后被扑灭": {
    "translation": "",
    "MultiLang": {
      "US": "The fire will be extinguished in 40 seconds.",
      "JP": "大火災は40秒後に鎮火します",
      "CN": "",
      "KR": "40초 후에는 큰 불이 꺼질 거야.",
      "TW": "大火將會在40秒後被撲滅"
    }
  },
  "啊……头又开始痛了": {
    "translation": "",
    "MultiLang": {
      "US": "Ugh... my head is starting to hurt again.",
      "JP": "あ……頭がまた痛み出す",
      "CN": "",
      "KR": "아…… 다시 머리가 아프기 시작했어.",
      "TW": "啊……頭又开始痛了"
    }
  },
  "感觉想起来了一点什么！": {
    "translation": "",
    "MultiLang": {
      "US": "I think I'm remembering something!",
      "JP": "何か思い出したような気がした！",
      "CN": "",
      "KR": "무언가 떠오르는 느낌이 들어!",
      "TW": "感觉想起来了一点什么！"
    }
  },
  "当时研究所发生了爆炸，很多用于实验的绝密药剂泄露了…": {
    "translation": "",
    "MultiLang": {
      "US": "At that time, an explosion occurred at the laboratory, and many classified experimental drugs leaked...",
      "JP": "当時研究所で爆発が発生し、実験用だった機密の薬剤が多数漏れ出した……",
      "CN": "",
      "KR": "당시 연구소에서 폭발이 발생해, 실험에 사용된 극비 약제들이 다수 유출되었지…",
      "TW": "当时研究所发生了爆炸，很多用于实验的绝密药剂泄露了…"
    }
  },
  "阻止危险传播的关键是研究样本…这应该是最后的希望！": {
    "translation": "",
    "MultiLang": {
      "US": "The key to stopping the spread of danger lies in researching these samples... this must be our last hope!",
      "JP": "危険な拡散を防ぐ鍵は研究標本にある……これが最後の希望だ！",
      "CN": "",
      "KR": "위험한 감염의 확산을 막는 핵심은 연구 샘플이야… 이것이 마지막 희망이 될 거야!",
      "TW": "阻止危险传播的关键是研究样本…这应该是最后的希望！"
    }
  },
  "通过样本来制作疫苗，治疗他们，可以防止更多的人受害": {
    "translation": "",
    "MultiLang": {
      "US": "We need to create a vaccine using the samples to treat them and prevent more people from suffering.",
      "JP": "標本を用いてワクチンを作り、彼らを治すことで、さらに多くの被害を防ぐことができる",
      "CN": "",
      "KR": "샘플을 통해 백신을 제조해 그들을 치료하면, 더 이상의 피해자를 막을 수 있어.",
      "TW": "通过样本来制作疫苗，治疗他们，可以防止更多的人受害"
    }
  },
  "我要先想办法从这里逃出去！上方的通风管道似乎可以通过？": {
    "translation": "",
    "MultiLang": {
      "US": "I first need to figure out how to escape from here. It seems like the ventilation pipe above is passable?",
      "JP": "まずはここから逃げる方法を考えないといけない！上の換気口なら抜けられるようだ？",
      "CN": "",
      "KR": "일단 여기서 탈출하는 방법을 생각해 봐야지! 위의 환기구로 이동할 수 있을까?",
      "TW": "我要先想办法从这里逃出去！上方的通风管道似乎可以通过？"
    }
  },
  "下方的大门T阵营玩家可以正常通过了": {
    "translation": "",
    "MultiLang": {
      "US": "That's right... I need to protect the samples and escape from here.",
      "JP": "その通りだ……標本を保護して、ここから抜け出さなければならない",
      "CN": "",
      "KR": "맞아… 하方的의 문은 T진영 플레이어가 정상적으로 통과할 수 있어.",
      "TW": "下方的大门T阵营玩家可以正常通过了"
    }
  },
  "没错…我要保护样本从这里逃出去": {
    "translation": "",
    "MultiLang": {
      "US": "That's right... I need to protect the sample and escape from here.",
      "JP": "そうだ……標本を護衛して、ここから逃げるんだ",
      "CN": "",
      "KR": "그래… 샘플을 보호하며 여기서 탈출해야 해.",
      "TW": "没错…我要保护样本从这里逃出去"
    }
  },
  "让我缓一缓，我需要用全力才能推开这个柜子": {
    "translation": "",
    "MultiLang": {
      "US": "Let me catch my breath. I have to push this cabinet open with all my might.",
      "JP": "少し休ませて…この棚を開けるには全力が必要だ",
      "CN": "",
      "KR": "잠시만요. 이 찬장을 열려면 힘을 좀 써야 해요.",
      "TW": "讓我喘口氣，我得使出全力才能推開這組櫃子"
    }
  },
  "AKF玩家将会在5秒后传送": {
    "translation": "",
    "MultiLang": {
      "US": "Player AKF will be teleported in 5 seconds.",
      "JP": "5秒後にAKFプレイヤーがテレポートされます",
      "CN": "",
      "KR": "AKF 플레이어가 5초 후 텔레포트됩니다.",
      "TW": "AKF玩家將在5秒後傳送"
    }
  },
  "整个医院似乎只有我是幸存者了…": {
    "translation": "",
    "MultiLang": {
      "US": "It seems like I'm the only survivor in the entire hospital...",
      "JP": "この病院で私だけが生き残ったようだ…",
      "CN": "",
      "KR": "이 병원에서는 나 혼자만 살아남은 것 같아요…",
      "TW": "整間醫院似乎只有我是倖存者……"
    }
  },
  "对不起…你们变成这样我也有错…": {
    "translation": "",
    "MultiLang": {
      "US": "I'm sorry... It's partly my fault that you've become like this...",
      "JP": "ごめん…こうなったのは私のせいです…",
      "CN": "",
      "KR": "죄송합니다… 여러분이 이런 꼴이 된 데에는 저도 잘못이 있어요…",
      "TW": "對不起……你們變成這樣我也有錯……"
    }
  },
  "我不会再让相同的事再发生！": {
    "translation": "",
    "MultiLang": {
      "US": "I won't let something like this happen again!",
      "JP": "もう、同じことを繰り返さない！",
      "CN": "",
      "KR": "다시는 이런 일이 벌어지지 않도록 할게요!",
      "TW": "我不會讓相同的事情再發生！"
    }
  },
  "这座城市的市民和警察们都遭殃了…": {
    "translation": "",
    "MultiLang": {
      "US": "The citizens and police of this city have all suffered...",
      "JP": "この街の市民も警官も大きな被害を受けた…",
      "CN": "",
      "KR": "이 도시의 시민들과 경찰들까지 피해를 입었어요…",
      "TW": "這座城市的市民和警方都遭殃了……"
    }
  },
  "前面的道路也被大火挡住了，我需要找到灭火器": {
    "translation": "",
    "MultiLang": {
      "US": "The path ahead is blocked by fire. I need to find a fire extinguisher.",
      "JP": "先の道は火災で塞がれている。消火器を見つけなければならない",
      "CN": "",
      "KR": "앞길은 불길에 막혀 있어요. 소화기를 찾아야 해요.",
      "TW": "前方的道路也被大火阻擋，我需要找到滅火器"
    }
  },
  "我需要30秒的时间来扑灭大火！": {
    "translation": "",
    "MultiLang": {
      "US": "It will take me 30 seconds to put out the fire!",
      "JP": "火災を鎮火するまでに30秒かかります！",
      "CN": "",
      "KR": "화재를 진압하는 데 30초가 필요해요!",
      "TW": "我需要30秒的時間來撲滅大火！"
    }
  },
  "对讲机的声音：全体队员请注意！": {
    "translation": "",
    "MultiLang": {
      "US": "Walkie-talkie voice: All team members, please listen!",
      "JP": "無線機の音声：全队员请注意！",
      "CN": "",
      "KR": "인터콤 음성: 전체 대원님들의 주시 바랍니다!",
      "TW": "對講機的聲音：全體隊員注意！"
    }
  },
  "对讲机的声音：作战失败！马上从该地区撤离！": {
    "translation": "",
    "MultiLang": {
      "US": "Walkie-talkie voice: Mission failed! Evacuate from this area immediately!",
      "JP": "無線機の音声：作戦失敗！ただちにこの地域から撤退せよ！",
      "CN": "",
      "KR": "인터콤 음성: 작전 실패! 즉시 해당 지역에서 철수하십시오!",
      "TW": "對講機的聲音：作戰失敗！立刻從該地區撤離！"
    }
  },
  "对讲机的声音：重复一遍！马上撤离！": {
    "translation": "",
    "MultiLang": {
      "US": "Walkie-talkie voice: Repeat, evacuate immediately!",
      "JP": "無線機の音声：繰り返し！ただちに撤退せよ！",
      "CN": "",
      "KR": "인터콤 음성: 반복합니다! 즉시 철수하십시오!",
      "TW": "對講機的聲音：再次警告！立刻撤離！"
    }
  },
  "噢！对讲机那边是谁？得到他的帮助，我应该就能生存下去": {
    "translation": "",
    "MultiLang": {
      "US": "Oh! Who's on the other end of the walkie-talkie? With their help, I should be able to survive.",
      "JP": "おっと！無線機の方からは誰だ？彼らの助けを得られれば、生き延びられるかもしれない",
      "CN": "",
      "KR": "오! 인터콤 상대방은 누구일까? 그의 도움을 받으면 생존할 수 있을 것 같아.",
      "TW": "噢！對講機那頭是誰？若能獲得他的幫助，我應該就能生存下去。"
    }
  },
  "对讲机的声音：停车场的门将会在45秒打开！": {
    "translation": "",
    "MultiLang": {
      "US": "Walkie-talkie voice: The parking lot door will open in 45 seconds!",
      "JP": "無線機の音声：駐車場出入口が45秒後に開きます！",
      "CN": "",
      "KR": "인터콤 음성: 주차장 문이 45초 후에 열립니다!",
      "TW": "對講機的聲音：停車場的大門將在45秒後開啟！"
    }
  },
  "对讲机的声音：请各位幸存人员做好准备！": {
    "translation": "",
    "MultiLang": {
      "US": "Walkie-talkie voice: All surviving personnel, please prepare yourselves!",
      "JP": "無線機の音声：生存者は皆様、準備をしろ！",
      "CN": "",
      "KR": "인터콤 음성: 살아계신 모든 분들, 준비하십시오!",
      "TW": "對講機的聲音：請各位倖存者做好準備！"
    }
  },
  "这里就是刚才对讲机里提到的地方吗？": {
    "translation": "",
    "MultiLang": {
      "US": "Is this the place mentioned on the walkie-talkier?",
      "JP": "ここがさっきの無線機で言われていた場所か？",
      "CN": "",
      "KR": "방금 인터콤에서 언급했던 곳이 여기 맞나?",
      "TW": "這裡就是剛才對講機裡提到的地方嗎？"
    }
  },
  "前方的大门似乎打不开，需要找齐钥匙卡？": {
    "translation": "",
    "MultiLang": {
      "US": "The gate ahead seems locked. Do I need to collect keycards?",
      "JP": "前方の扉が開かないようだ。キーカードを全部集めないといけないのか？",
      "CN": "",
      "KR": "앞문의 도어는 열리지 않는 것 같아. 열쇠 카드들을 모두 모아야 하나?",
      "TW": "前方的大門似乎無法開啟，需要集齊鑰匙卡嗎？"
    }
  },
  "现在应该可以出去了……": {
    "translation": "",
    "MultiLang": {
      "US": "I should be able to get out now...",
      "JP": "「外に出られそうだ……」",
      "CN": "",
      "KR": "지금은 빠져나갈 수 있을 거야…",
      "TW": "現在應該可以出去了……"
    }
  },
  "啊啊啊！还没有结束！": {
    "translation": "",
    "MultiLang": {
      "US": "Ahhh! It's not over yet!",
      "JP": "まだ、終わってない！",
      "CN": "",
      "KR": "아아아! 아직 끝나지 않았어!",
      "TW": "啊啊啊！還沒有結束！"
    }
  },
  "120秒后将结束第一关": {
    "translation": "",
    "MultiLang": {
      "US": "Stage 1 ends in 120 seconds",
      "JP": "第一関門は120秒後に終了します",
      "CN": "",
      "KR": "120초 후 1타이어 종료",
      "TW": "120秒後將結束第一關"
    }
  }
}
