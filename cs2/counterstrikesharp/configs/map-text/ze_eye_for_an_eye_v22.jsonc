    }
  },
  "<<<The left glass will shatter in 5 seconds>>>": {
    "translation": "<<<左侧玻璃将在5秒后破碎>>>",
    "MultiLang": {
      "US": "",
      "JP": "<<<5秒後に左側のガラスが割れます>>>",
