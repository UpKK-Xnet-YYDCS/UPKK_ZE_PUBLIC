  "***Submarine leaving in 30secs!***": {
    "translation": "***潜艇将在30秒后离开！***",
    "MultiLang": {
      "US": "",
      "JP": "***30秒で潜水開始！***",
      "CN": "***潜艇将在30秒后离港！***",
