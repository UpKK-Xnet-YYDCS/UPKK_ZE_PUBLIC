  "**...Are you surprised?...**": {
    "translation": "**...你惊讶吗？...**",
    "MultiLang": {
      "US": "",
      "JP": "……驚きましたか？……",
      "CN": "**...你感到惊讶吗？**",
      "KR": "...놀라셨나요?...",
      "TW": "**……你感到驚訝嗎？...**"
    }
  },
  "**...Didn't you expect me?...**": {
    "translation": "**...你没想到我会来吗？...**",
    "MultiLang": {
      "US": "",
      "JP": "……私が現れるとは予想していませんでしたね？……",
      "CN": "**...没料到是我吧？**",
      "KR": "...예상하지 못하셨죠?...",
      "TW": "**…你不是 expected 我會出現嗎？…**"
    }
  },
  "**...Oh okay i'm disappearing...**": {
