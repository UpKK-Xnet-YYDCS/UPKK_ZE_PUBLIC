{
  "*cathy*Ah, sinful people": {
    "translation": "*cathy*:啊，罪恶的人们",
    "MultiLang": {
      "US": "",
      "JP": "*cathy*ああ、罪深い人々よ",
      "CN": "*cathy*啊，罪人",
      "KR": "*cathy*아, 죄인이어라",
      "TW": "*cathy*啊，罪惡的人們"
    }
  },
  "*cathy*Ah, you found it": {
    "translation": "*cathy*:啊，你找到了",
    "MultiLang": {
      "US": "",
      "JP": "*cathy*あら、見つけたわね",
      "CN": "*cathy*啊，你找到了它",
      "KR": "*cathy*아, 너는 그것을 찾았구나",
      "TW": "*cathy*啊，你找到了"
    }
  },
  "*cathy*And I am the one who has been given this right": {
    "translation": "*cathy*:我就是被赋予这个权利的人",
    "MultiLang": {
      "US": "",
      "JP": "*cathy*そして、この特権を授かったのは私なの",
      "CN": "*cathy*而我正是被授予此权利的人",
      "KR": "*cathy*그리고 그 권리를 가진 것은 나야",
      "TW": "*cathy*而我就是被賦予這個權利的人"
    }
  },
  "*cathy*Are you really not going to be my pastime prop?": {
    "translation": "*cathy*:你真的不打算成为我的消遣道具吗？",
    "MultiLang": {
      "US": "",
      "JP": "*cathy*本当に、私の娯楽用の小道具になってくれないの？",
      "CN": "*cathy*你真的不想成为我的消遣道具吗？",
      "KR": "*cathy*진짜로 내 놀거리가 되어주지 않을 거야?",
      "TW": "*cathy*你真的不會成為我的消遣玩具嗎？"
    }
  },
  "*cathy*As a special service, I've opened the door": {
    "translation": "*cathy*:作为特别服务，我已经打开了门",
    "MultiLang": {
      "US": "",
      "JP": "*cathy*特別サービスとして、扉を開けてあげたわ",
      "CN": "*cathy*作为特别服务，我已经打开了门",
      "KR": "*cathy*특별서비스로, 나는 문을 열었어",
      "TW": "*cathy*作為特別服務，我已經為你們開啟了道路"
    }
  },
  "*cathy*But her heart was dark": {
    "translation": "*cathy*:但她的心是黑暗的",
    "MultiLang": {
      "US": "",
      "JP": "*cathy*でも彼女の心は暗かった",
      "CN": "*cathy*但她的心是黑暗的",
      "KR": "*cathy*하지만 그녀의 마음은 어둡다",
      "TW": "*cathy*但她的心臟是黑暗的"
    }
  },
  "*cathy*But it's past the time limit, and you can't get out": {
    "translation": "*cathy*:时间已经过了，你逃不出去",
    "MultiLang": {
      "US": "",
      "JP": "*cathy*でも時間切れだから、もう出られないの",
      "CN": "*cathy*但已经过了时限，你出不去了",
      "KR": "*cathy*하지만 시간 초과야, 너는 나갈 수 없어",
      "TW": "*cathy*但這已經超過了時間限制，你無法離開"
    }
  },
  "*cathy*But who is the real prop": {
    "translation": "*cathy*:但谁才是真正的道具",
    "MultiLang": {
