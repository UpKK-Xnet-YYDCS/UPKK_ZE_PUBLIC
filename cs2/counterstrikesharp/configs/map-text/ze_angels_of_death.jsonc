    "MultiLang": {
      "US": "",
      "JP": "*zack*これ何？",
      "CN": "*zack*这是什么",
      "KR": "*zack*이게 뭐야",
      "TW": "*zack*這是什麼"
    }
  },
  "*zack*Whatever. Let's do it": {
    "translation": "*zack* 无所谓。我们干吧",
