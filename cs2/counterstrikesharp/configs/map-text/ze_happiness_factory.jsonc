{
  "你们要进入工厂": {
    "translation": "",
    "MultiLang": {
      "US": "You are about to enter the factory",
      "JP": "工場に進入しろ",
      "CN": "",
      "KR": "공장에 진입하십시오",
      "TW": "你們要進入工廠"
    }
  },
  "找到违规的证据": {
    "translation": "",
    "MultiLang": {
      "US": "Find evidence of violations",
      "JP": "違反の証拠を見つけろ",
      "CN": "",
      "KR": "위반 증거를 찾아라",
      "TW": "找到違規的證據"
    }
  },
  "后面就是老板的追兵": {
    "translation": "",
    "MultiLang": {
      "US": "Behind them are the boss's pursuers",
      "JP": "追手が来るぞ",
      "CN": "后面的追兵就是老板的",
      "KR": "뒤에는 사장님의 추격자가 있다",
      "TW": "後面就是老闆的追兵"
    }
  },
  "祝，武运昌隆": {
    "translation": "",
    "MultiLang": {
      "US": "Wishing you great fortune in battle",
      "JP": "武運を祈る",
      "CN": "",
