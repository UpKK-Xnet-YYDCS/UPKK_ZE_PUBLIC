  "[Listen to the sound,And pick the right one.]": {
    "translation": "[听声音，选择正确的]",
    "MultiLang": {
      "US": "",
      "JP": "【音を頼りに、正しいものを選べ。】",
      "CN": "[听声音，选出正确的那个。]",
      "KR": "[소리에 귀 기울여, 올바른 걸 고르라.]",
      "TW": "[聽聽聲音，選擇正確的一個。]"
    }
  },
  "[This is the only way.]": {
    "translation": "这是唯一路",
