    }
  },
  "[Those houses...is fake,just model..]": {
    "translation": "[那些房子... 是假的，只是模型而已...］",
    "MultiLang": {
      "US": "",
      "JP": "【あの家は…全て偽物で模型だ…】",
      "CN": "[那些房子是假的，只是模型……]",
      "KR": "[그 집들은... 가짜다, 단지 모형일 뿐..]",
      "TW": "[那些房子……是假的，只是模型而已……]"
    }
  },
  "[There has to be a real one,go find it.]": {
    "translation": "[一定有真的，快去找吧］",
    "MultiLang": {
      "US": "",
      "JP": "【本物の家が存在するはずだ。見つけ出せ。】",
      "CN": "[肯定有一个是真的，去找找看。]",
      "KR": "[진짜 하나는 반드시 있을 거야, 가서 찾아라.]",
      "TW": "[一定有一個是真的，去找找看。]"
    }
  },
