  "[What was that on the wall?]": {
    "translation": "[墙上是什么？ ]",
    "MultiLang": {
      "US": "",
      "JP": "[壁に何かが？]",
      "CN": "[墙上那是什么？]",
      "KR": "벽에 있던 건 뭐였지?",
      "TW": "[牆上的是什麼？]"
    }
  },
  "[Is that...Blood?...]": {
    "translation": "[那是......血？］",
    "MultiLang": {
      "US": "",
      "JP": "[これは…血？…]",
      "CN": "那是……血吗？",
      "KR": "저건... 피야?...",
      "TW": "[那是……血？……]"
    }
  },
  "[I got a bad feeling,Keep your eyes around here.]": {
    "translation": "[我有不祥的预感，盯紧这里］",
    "MultiLang": {
      "US": "",
      "JP": "[気分が良くない。周辺をしっかり確認しろ。]",
      "CN": "我感觉不对劲，保持警惕。",
      "KR": "감 좋은 기분이 들어. 주변을 잘 살피도록 해.",
      "TW": "我有種不好的預感，這裡別乱看。"
    }
  },
  "Defend < 10 >": {
    "translation": "防御 < 10 >",
    "MultiLang": {
      "US": "",
      "JP": "<10> を防衛",
      "CN": "防御 < 10 >",
      "KR": "< 10 > 방어",
      "TW": "防禦 < 10 >"
    }
  },
  "[...Don't move.]": {
    "translation": "别动",
    "MultiLang": {
      "US": "",
      "JP": "[…動くな。]",
      "CN": "……别动。",
      "KR": "...움직이지 마.",
      "TW": "[……別動。]"
    }
  },
  "[..Stay still...]": {
    "translation": "别动",
    "MultiLang": {
      "US": "",
      "JP": "[…動かずにいろ…]",
      "CN": "……待着别动……",
      "KR": "..가만히 있어...",
      "TW": "[……別动…]"
    }
  },
  "[Oh fuxk,Something behind us!]": {
    "translation": "[有东西在我们后面！］",
    "MultiLang": {
      "US": "",
      "JP": "[クソ、背後に何かが！]",
      "CN": "操！我们后面有东西！",
      "KR": "이봐, 우리 뒤에 뭔가가 나타났다!",
      "TW": "[該死，背後有東西！]"
    }
  },
  "[Run!Just follow the damn LIGHT!We got no where to hide now!]": {
    "translation": "[快跑，跟着那该死的光跑，我们没地方躲了］",
    "MultiLang": {
      "US": "",
      "JP": "[走れ！とにかく光に従え！今や隠れる場所はないぞ！]",
      "CN": "跑！只要跟着那该死的光就行！现在没地方躲了！",
      "KR": "도망쳐! 단지 빛을 따라가! 이제 숨을 곳은 없어!",
      "TW": "[跑！就照著那鬼 LIGHT 跑！現在沒地方躲了！]"
    }
  },
  "[This thing is too fast!Use your gun to shoot it.]": {
    "translation": "[这东西太快了 用你的枪打它］",
    "MultiLang": {
      "US": "",
      "JP": "【この怪物は極めて機敏だ！銃で撃ち止めろ】",
      "CN": "这东西太快了！用枪打它。",
      "KR": "[이건 너무 빠르다! 총으로 쏴라!]",
      "TW": "[這東西速度太快了！用槍射擊它。]"
    }
  },
  "[Guns won't kill it,But will slow it down.]": {
    "translation": "[枪是杀不死它的 但能让它慢下来］",
    "MultiLang": {
      "US": "",
      "JP": "【銃では倒せぬが、制圧は可能だ。】",
      "CN": "[枪杀不死它，但能减缓它的行动。]",
      "KR": "[총으로는 죽일 수 없겠지만, 속도는 늦출 수 있어.]",
      "TW": "[槍無法殺死它，但會減慢它的速度。]"
    }
  },
  "[Hide,Don't let it find you...]": {
    "translation": "[快躲起来，别让它发现你］",
    "MultiLang": {
      "US": "",
      "JP": "【潜みよ……見つからぬよう…】",
      "CN": "[躲藏起来，别让它发现你……]",
      "KR": "[숨어라. 발견당하지 않도록...]",
      "TW": "[藏好別讓它找到你……]"
    }
  },
