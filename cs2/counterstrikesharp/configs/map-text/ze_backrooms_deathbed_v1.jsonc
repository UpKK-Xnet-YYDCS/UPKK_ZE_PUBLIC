{
  "> Platform starts in 5 sec. <": {
    "translation": "平台 5 秒后启动。<",
    "MultiLang": {
      "US": "",
      "JP": "> プラットフォームは5秒後に起動します。 <",
      "CN": ">平台将在5秒后开始。<",
      "KR": "플랫폼이 5초 후에 시작됩니다.",
      "TW": "> 平台5秒後啟動。<"
    }
  },
  "|Speaker|: Portal is ready.": {
    "translation": "传送门准备就绪。",
    "MultiLang": {
      "US": "",
      "JP": "|Speaker|: ポータルが準備完了しました。",
      "CN": "|Speaker|：传送门已就绪。",
      "KR": "|Speaker|: 포털이 준비되었습니다.",
      "TW": "|Speaker|：傳送門已就緒。"
    }
  },
  "|Speaker|: Bring up the equipment you need.": {
    "translation": "带上您需要的装备。",
    "MultiLang": {
      "US": "",
      "JP": "|Speaker|: 必要な装備を呼び出してください。",
      "CN": "|Speaker|：请准备好所需的装备。",
      "KR": "|Speaker|: 필요한 장비를 가져오세요.",
      "TW": "|Speaker|：請備妥所需裝備。"
    }
  },
  "|Speaker|: and check the information of this Level before you enter.": {
    "translation": "并在进入前检查本关卡的信息。",
    "MultiLang": {
      "US": "",
      "JP": "|Speaker|: そして、このレベルに入る前に情報を確認してください。",
      "CN": "|Speaker|：并在进入关卡前检查相关信息。",
      "KR": "|Speaker|: 진입 전에 이 레벨의 정보를 확인하세요.",
      "TW": "|Speaker|：並在此關卡進入前查閱相關資訊。"
    }
  },
  "|Speaker|: Operation begin in 10 sec.": {
    "translation": "10秒后开始",
    "MultiLang": {
      "US": "",
      "JP": "|Speaker|: 作戦開始まで10秒",
      "CN": "|Speaker|：行动将在10秒后开始。",
      "KR": "|Speaker|: 작전 개시가 10초 후입니다.",
      "TW": "|Speaker|：行動將於10秒後開始。"
    }
  },
  "|Speaker|: Stay safe.": {
    "translation": "注意安全。",
    "MultiLang": {
      "US": "",
      "JP": "|Speaker|: 安全に気をつけて。",
      "CN": "|Speaker|：注意自身安全。",
      "KR": "|Speaker|: 안전에 유의하세요.",
      "TW": "|Speaker|：請注意安全。"
    }
  },
  "> Backrooms Deathbed < ver 1.3": {
