{
  "你们再次来到了这个地方": {
    "translation": "",
    "MultiLang": {
      "US": "You have returned to this place once again.",
      "JP": "再びこの場所に戻ってきた",
      "CN": "",
      "KR": "다시 그 장소에 도달했다",
      "TW": "你們再次來到了這裡"
    }
  },
  "这次一定要找到真相": {
    "translation": "",
    "MultiLang": {
      "US": "This time, you must uncover the truth.",
      "JP": "今回は必ず真実を見つけ出すぞ",
      "CN": "",
      "KR": "이번에는 반드시 진실을 밝혀내야 해",
      "TW": "這次一定要找到真相"
    }
  },
  "后面就是老板的追兵": {
    "translation": "",
    "MultiLang": {
      "US": "Behind us are the boss's pursuers.",
      "JP": "背後は社長を追う者たちだ",
      "CN": "",
      "KR": "뒤쪽은 사장의 추격자들이 있다",
      "TW": "後面就是老闆的追兵"
    }
  },
  "祝，武运昌隆": {
    "translation": "",
    "MultiLang": {
      "US": "Good luck in battle.",
      "JP": "武運長久をお祈りします",
      "CN": "",
      "KR": "승리를 기원한다",
      "TW": "祝，武運昌隆"
    }
  },
  "*门将在 30 秒后打开*": {
