  },
  "watch out for the train!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "電車に注意！",
      "CN": "注意火车！",
      "KR": "열차에 주의하세요!",
      "TW": "注意火車！"
    }
  },
  "find for four keys and survive until the help comes": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "鍵を4つ集め、救助が来るまで生き延びろ",
      "CN": "收集四把钥匙并存活至援军到来",
      "KR": "키 4개를 찾아 구조대가 올 때까지 생존하세요",
      "TW": "收集四把鑰匙，並撐到援軍抵達"
    }
  },
  "teleport in 10 seconds": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "10秒後にテレポート",
      "CN": "10秒后传送",
      "KR": "10초 후 텔레포트",
      "TW": "10秒後傳送"
    }
  },
  "we got a signal from another team": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "他のチームからシグナルを受信",
      "CN": "收到来自其他队伍的信号",
      "KR": "다른 팀의 신호를 포착했습니다",
      "TW": "我們收到另一支隊組的信號"
    }
  },
  "deploy all drone,if only one,and find them!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "全てのドローンを展開、一つ見つけろ！",
      "CN": "部署所有无人机，如果仅剩一台，立即将其寻找出来！",
      "KR": "모든 드론을 발사하십시오. 하나가 남아 있다면, 그들을 찾아내십시오!",
      "TW": "部署所有無人機，若只剩一支，立即搜索！"
    }
  },
  "99 seconds to mission failure": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "任務失敗まで99秒",
