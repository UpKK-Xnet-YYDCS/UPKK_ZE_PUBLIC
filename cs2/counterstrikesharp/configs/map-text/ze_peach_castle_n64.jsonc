  "*** DON'T STAY CLOSE TO HIM ! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 近づかないで！ ***",
      "CN": "*** 不要靠近他！***",
      "KR": "*** 가까이 붙지 마라! ***",
      "TW": "*** 別靠近他！***"
    }
  },
  "*** LOOK UP ! BALLOON IS COMING ! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 上を見ろ！風船が来ている！ ***",
      "CN": "*** 抬头看！气球来了！***",
      "KR": "*** 위를 봐! 풍선이 다가온다! ***",
      "TW": "*** 往上看！氣球要來了！***"
    }
  },
  "*** ALL ABOARD THE BALLOON ! THIS IS THE LAST DEFENSE ! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** すべての敵が風船に乗った！これが最後の防衛だ！ ***",
