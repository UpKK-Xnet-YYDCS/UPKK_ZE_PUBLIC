      "TW": "*** 守護氣球！***"
    }
  },
  "*** LET'S A GO ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "さあ、行こう！",
      "CN": "*** 开始！ ***",
      "KR": "*** 시작! ***",
      "TW": "*** 啟動！***"
