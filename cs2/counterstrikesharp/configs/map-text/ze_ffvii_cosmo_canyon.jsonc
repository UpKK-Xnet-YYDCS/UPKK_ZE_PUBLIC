{
  "**ZE_FFVII_COSMO_CANYON**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ZE_FFVII_COSMO_CANYON",
      "CN": "ZE_FFVII_COSMO_CANYON",
      "KR": "ZE_FFVII_COSMO_CANYON",
      "TW": "ZE_FFVII_COSMO_CANYON"
    }
  },
  "**Map by Headshooter.SC & HaRyDe**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Headshooter.SC & HaRyDeによるマップ",
      "CN": "地图由Headshooter.SC & HaRyDe制作",
      "KR": "Headshooter.SC 및 HaRyDe 제작",
      "TW": "地圖由Headshooter.SC & HaRyDe製作"
    }
  },
  "**NORMAL MODE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ノーマルモード",
      "CN": "普通模式",
      "KR": "일반 모드",
      "TW": "普通模式"
    }
  },
  "**Thanks to Weed-Lancer for tons of grammar errors fix**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Weed-Lancerに文法修正の多大なご協力に感謝します",
      "CN": "感谢Weed-Lancer修复了大量的语法错误",
      "KR": "Weed-Lancer 님께 문법 오류 수정에 대한 감사를 드립니다.",
      "TW": "感謝Weed-Lancer修正了大量的語法錯誤"
    }
  },
  "**A player has picked up HEAL materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが「ヒール」マテリアを入手しました",
      "CN": "一名玩家拾取了HEAL魔石",
      "KR": "한 플레이어가 HEAL 마테리아를 획득했습니다.",
      "TW": "一位玩家拾取了「癒」魔法石"
    }
  },
  "**Cover here for 5 seconds before we clear this obstacle**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "この障害物を突破する前に、5秒間ここに隠れてください",
      "CN": "在这里掩护5秒，然后我们清除这个障碍",
      "KR": "이 장애물을 지나기 전에 5초 동안 이곳에서 엄폐하십시오.",
      "TW": "在這裡掩護5秒，然後我們清除這個障礙"
    }
  },
  "**We are near Cosmo Canyon**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "私たちはコスモキャニオンの近くにいます",
      "CN": "我们靠近宇宙峡谷",
      "KR": "우리는 코스모 캐니언 근처에 있습니다.",
      "TW": "我們靠近宇宙峽谷"
    }
  },
  "**The gates will open in 20 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートは20秒後に開きます",
      "CN": "大门将在20秒后打开",
      "KR": "게이트가 20초 후에 열립니다.",
      "TW": "大門會在20秒後開啟"
    }
  },
  "**A player has picked up SLEEP materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが「SLEEP」マテリアを入手しました。",
      "CN": "一名玩家拾取了 SLEEP 魔法。",
      "KR": "플레이어가 SLEEP 마테리아를 획득했습니다.",
      "TW": "一位玩家已拾取了「睡眠」魔導珠。"
    }
  },
  "**Welcome to Cosmo Canyon**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "コスモキャニオンへようこそ。",
      "CN": "欢迎来到宇宙峡谷。",
      "KR": "코스모 캐니언에 오신 것을 환영합니다.",
      "TW": "歡迎來到宇宙峽谷。"
    }
  },
  "**The barman will open the door in 5 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バーテンダーが5秒後にドアを開けます。",
      "CN": "酒保将在 5 秒后打开门。",
      "KR": "바텐더가 5초 후에 문을 열 것입니다.",
      "TW": "酒保會在 5 秒後打開門。"
    }
  },
  "**Zombies are coming. Defend Cosmo Bar for 25 seconds before we open the back door** ": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビが迫っています。バックドアを開ける前に、25秒間コスモバーを守りましょう。",
      "CN": "僵尸正在来袭。在后门打开前，请保护宇宙酒吧 25 秒。",
      "KR": "좀비들이 몰려옵니다. 뒷문이 열리기 전에 25초 동안 코스모 바를 방어하십시오.",
      "TW": "殭屍即將到來。在我們打開後門之前，請在 25 秒內守護宇宙酒吧。"
    }
  },
  "**5 SECONDS LEFT**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り5秒",
      "CN": "剩余 5 秒。",
      "KR": "5초 남았습니다.",
      "TW": "剩餘 5 秒。"
    }
  },
  "**FALL BACK**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "退避",
      "CN": "撤退！",
      "KR": "후퇴하십시오.",
      "TW": "撤退！"
    }
  },
  "**The rock will explode in 25 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "岩が25秒後に爆発します。",
      "CN": "这块岩石将在 25 秒后爆炸。",
      "KR": "바위가 25초 후에 폭발합니다.",
      "TW": "這塊岩石會在 25 秒後爆炸。"
    }
  },
  "**The gates will open in 25 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートが25秒後に開きます。",
      "CN": "大门将在 25 秒后打开。",
      "KR": "문이 25초 후에 열립니다.",
      "TW": "大門會在 25 秒後打開。"
    }
  },
  "**The Cave of the GI gates will open in 15 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "GIのゲートが15秒後に開きます。",
      "CN": "GI大门将会在15秒后打开。",
      "KR": "GI 게이트 동굴이 15초 후에 열립니다.",
      "TW": "「GI」閘道將在 15 秒後開啟。"
    }
  },
  "**Wait until something happens**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "何か起こるまで待ちましょう。",
      "CN": "请等待，直到发生一些事情。",
      "KR": "무언가가 일어날 때까지 기다리세요.",
      "TW": "請等待，直到發生一些事情。"
    }
  },
  "**GI Nattak arena will open in 35 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "GIナッタカのアリーナが35秒後に開きます。",
      "CN": "GI Nattak竞技场将在35秒后开放。",
      "KR": "GI 나타크 경기장이 35초 후에 열립니다.",
      "TW": "「GI」納塔克競技場將在 35 秒後開啟。"
    }
  },
  "**Nades do more damage. Use them!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ナデスはより多くのダメージを与えます。使いましょう！",
      "CN": "手雷造成更多伤害。请使用它们！",
      "KR": "나데스 공격력은 더 높습니다. 사용하세요!",
      "TW": "投擲物造成更多傷害。請使用它們！"
    }
  },
  "**Some of the items can affect him. Use them!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "いくつかのアイテムが彼に影響を与える可能性があります。使いましょう！",
      "CN": "某些道具可以影响他。请使用它们！",
      "KR": "일부 아이템은 그에게 영향을 줄 수 있습니다. 사용하세요!",
      "TW": "部分道具可以影響他。請使用它們！"
    }
  },
  "**Gi Nattak is using poison**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "GIナッタカが毒を使用しています。",
      "CN": "Gi Nattak正在使用毒。",
      "KR": "GI 나타크가 독을 사용하고 있습니다.",
      "TW": "「GI」納塔克正在使用毒。"
    }
  },
  "**Gi Nattck is using silence**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "GIナッタカが沈黙を使用しています。",
      "CN": "Gi Nattak正在使用沉默。",
      "KR": "GI 나타크가 침묵을 사용하고 있습니다.",
      "TW": "「GI」納塔克正在使用沉默。"
    }
  },
  "**Gi Nattak is using wind**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "GIナッタカが風を使用しています。",
      "CN": "Gi Nattak正在使用风。",
      "KR": "GI 나타크가 바람을 사용하고 있습니다.",
      "TW": "「GI」納塔克正在使用風。"
    }
  },
  "**Gi Nattak is spawning minions. Watch out for them**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattak がミニオンを召喚しています。注意してください。",
      "CN": "Gi Nattak 正在召唤小怪。小心它们！",
      "KR": "Gi Nattak이 미니언을 소환하고 있습니다. 조심하세요.",
      "TW": "Gi Nattak 正在生成小怪。小心它们。"
    }
  },
  "**Gi Nattak is using aspil**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattak が「アスピル」を使用しています。",
      "CN": "Gi Nattak 正在使用吸力。",
      "KR": "Gi Nattak이 'aspil' 스킬을 사용합니다.",
      "TW": "Gi Nattak 正在使用吸力。"
    }
  },
  "**Gi Nattak is using gravity**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattak が「重力」を使用しています。",
      "CN": "Gi Nattak 正在使用重力。",
      "KR": "Gi Nattak이 'gravity' 스킬을 사용합니다.",
      "TW": "Gi Nattak 正在使用重力。"
    }
  },
  "**Gi Nattack is dead**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattack は死亡しました。",
      "CN": "Gi Nattack 已死亡。",
      "KR": "Gi Nattak이 사망했습니다.",
      "TW": "Gi Nattak 已死亡。"
    }
  },
  "**Now you can get out of Cave of Gi**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "これで Gi の洞窟から出ることができます。",
      "CN": "现在您可以离开 Gi 的洞穴。",
      "KR": "이제 Gi 동굴에서 나갈 수 있습니다.",
      "TW": "现在你可以从 Gi 的洞穴中出来了。"
    }
  },
  "**DOOR OPENS IN 35 SECONDS**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "扉は 35 秒後に開きます。",
      "CN": "门将在 35 秒后打开。",
      "KR": "문이 35초 후에 열립니다.",
      "TW": "門將在 35 秒後打開。"
    }
  },
  "**10 SECONDS LEFT**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り 10 秒です。",
      "CN": "剩余 10 秒。",
      "KR": "10초 남았습니다.",
      "TW": "剩余 10 秒。"
    }
  },
  "**This is your last hold point**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ここは最後の待機ポイントです。",
      "CN": "这是您最后的防御点。",
      "KR": "이곳이 마지막 방어 지점입니다.",
      "TW": "這是你最後的防守點。"
    }
  },
  "**Get on the rocks and hold 25 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "岩の上で25秒キープ",
      "CN": "抓住岩石，坚持25秒",
      "KR": "바위에 올라서서 25초 동안 버티세요.",
      "TW": "在岩石上进行支撑，保持 25 秒。"
    }
  },
  "**NORMAL mode was beaten. Unlocking HARD mode **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ノーマルモードをクリアしました。ハードモードをアンロックします",
      "CN": "普通模式已通关。解锁困难模式。",
      "KR": "NORMAL 모드를 클리어했습니다. HARD 모드를 해제합니다.",
      "TW": "已通关普通模式。解锁困难模式。"
    }
  },
  "**A player has picked up BIO materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーが「BIO」マテリアを入手しました",
      "CN": "一位玩家获得了BIO魔元。",
      "KR": "한 플레이어가 BIO 마테리아를 획득했습니다.",
      "TW": "一位玩家获得了 BIO 物质。"
    }
  },
  "**HARD MODE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ハードモード",
      "CN": "困难模式",
      "KR": "HARD MODE",
      "TW": "困难模式"
    }
  },
  "**A player has picked up EARTH materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーが「EARTH」マテリアを入手しました",
      "CN": "一位玩家获得了EARTH魔元。",
      "KR": "한 플레이어가 EARTH 마테리아를 획득했습니다.",
      "TW": "一位玩家获得了 EARTH 物质。"
    }
  },
  "**A player has picked up ULTIMA materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーが「ULTIMA」マテリアを入手しました",
      "CN": "一位玩家获得了ULTIMA魔元。",
      "KR": "한 플레이어가 ULTIMA 마테리아를 획득했습니다.",
      "TW": "一位玩家获得了 ULTIMA 物质。"
    }
  },
  "**A player has picked up FIRE materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーが「FIRE」マテリアを入手しました",
      "CN": "一位玩家获得了FIRE魔元。",
      "KR": "한 플레이어가 FIRE 마테리아를 획득했습니다.",
      "TW": "一位玩家获得了 FIRE 物质。"
    }
  },
  "**Gi Nattak has healed 150 hp**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattakが150 HPを回復しました",
      "CN": "Gi Nattak 回复了 150 HP",
      "KR": "Gi Nattak이 150 HP를 회복했습니다.",
      "TW": "Gi Nattak 回复了 150 HP。"
    }
  }
}
