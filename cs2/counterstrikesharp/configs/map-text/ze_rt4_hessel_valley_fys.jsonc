{
  "*第一关*": {
    "translation": "",
    "MultiLang": {
      "US": "*Stage 1*",
      "JP": "*第1關*",
      "CN": "",
      "KR": "*첫 번째 장*",
      "TW": "*第一關*"
    }
  },
  ">>> 一位人类习得了医疗魔法 <<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>> A human has learned healing magic <<<",
      "JP": ">>> 人類習得了醫療魔法 <<<",
      "CN": "",
      "KR": ">>> 한 인간의 치료 마법 습득 <<<",
      "TW": ">>> 一位人類習得了醫療魔法 <<<"
    }
  },
  "\"僵尸获得了《烟雾弹》\"": {
    "translation": "",
    "MultiLang": {
      "US": "\"A zombie has acquired Smoke Grenade\"",
      "JP": "\"殭屍獲得了《煙幕彈》\"",
      "CN": "",
      "KR": "저승사이가 <스모크 글렌드>를 습득했습니다.",
      "TW": "\"殭屍獲得了《煙霧彈》\""
    }
  },
  ">>> 一位人类习得了卡尔的智慧 <<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>> A human has acquired Cael's Wisdom <<<",
      "JP": ">>> 人類習得了卡爾的智慧 <<<",
      "CN": "",
      "KR": ">>> 한 인간의 칼의 지혜 습득 <<<",
      "TW": ">>> 一位人類習得了卡爾的智慧 <<<"
    }
  },
