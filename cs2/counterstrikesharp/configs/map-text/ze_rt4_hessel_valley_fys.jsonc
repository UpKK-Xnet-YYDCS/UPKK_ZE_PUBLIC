{
  "*第一关*": {
    "translation": "",
    "MultiLang": {
      "US": "*Level 1*",
      "JP": "*第一关*",
      "CN": "",
      "KR": "*1단계*",
      "TW": "*第一關*"
    }
  },
  ">>> 一位人类习得了医疗魔法 <<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>> A human has learned a healing spell. <<<",
      "JP": "ある人間が治療魔法を習得しました。",
      "CN": "",
      "KR": "한 명의 인간이 치료 마법을 익혔습니다.",
      "TW": ">>> 一位人類習得了醫療魔法 <<<"
    }
  },
  "\"僵尸获得了《烟雾弹》\"": {
    "translation": "",
    "MultiLang": {
      "US": "\"The zombie has learned the skill: 'Smoke Bomb'.\"",
      "JP": "ゾンビが「煙幕」を手に入れた。",
      "CN": "",
      "KR": "좀비가 \"연막탄\"을 얻었습니다.",
      "TW": "\"殭屍獲得了《煙霧彈》\""
    }
  },
  ">>> 一位人类习得了卡尔的智慧 <<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>> A human has learned the skill: 'Karl's Wisdom'. <<<",
      "JP": "ある人間がカールの知恵を習得しました。",
      "CN": "",
      "KR": "한 명의 인간이 칼의 지혜를 익혔습니다.",
      "TW": ">>> 一位人類習得了卡爾的智慧 <<<"
    }
  },
