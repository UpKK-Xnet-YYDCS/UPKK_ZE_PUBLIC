{
  "\"这地怎么如此的邪乎\"": {
    "translation": "",
    "MultiLang": {
      "US": "Why does this place feel so eerie?",
      "JP": "ここは一体どうしてこんなにも不気味なんだ",
      "CN": "",
      "KR": "이곳이 왜 이렇게 기이한가?",
      "TW": "这地方怎么如此诡异？"
    }
  },
  "\"飞机刚飞到上空就坠机了\"": {
    "translation": "",
    "MultiLang": {
      "US": "The plane crashed right after it flew overhead.",
      "JP": "飛行機が頭上を通過した直後に墜落した",
      "CN": "",
      "KR": "비행기가 막 하늘로 올라가려던 순간 추락했습니다.",
      "TW": "飞机刚飞到上空就坠毁了。"
    }
  },
  "\"Man!!!\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "うわっ！",
      "CN": "喂!!!",
      "KR": "맙소사!!",
      "TW": "Man!!!"
    }
  },
  "\"寻找我们失踪的队员吧\"": {
    "translation": "",
    "MultiLang": {
      "US": "Let's go find our missing teammate.",
      "JP": "行方不明になった仲間を探しましょう",
      "CN": "",
      "KR": "우리 실종된 팀원을 찾아봅시다.",
      "TW": "让我们寻找失踪的队员吧。"
    }
  },
  "\"需在此地等待20s\"": {
    "translation": "",
    "MultiLang": {
      "US": "You must wait here for 20 seconds.",
      "JP": "ここで20秒待ちます",
      "CN": "",
      "KR": "이 장소에서 20초 동안 기다려야 합니다.",
      "TW": "需在此地等待20秒。"
    }
  },
  "\"远处那是什么？\"": {
    "translation": "",
    "MultiLang": {
      "US": "What is that in the distance?",
      "JP": "遠くに見えているのは何だろう？",
      "CN": "",
      "KR": "저 멀리 있는 것은 무엇인가?",
      "TW": "远处那是什么？"
    }
  },
  "\"是不听指挥话的鸡哥么?\"": {
    "translation": "",
    "MultiLang": {
      "US": "Is that Jige, who doesn't listen to instructions?",
      "JP": "まさか、命令を聞かないチーゴか？",
      "CN": "",
      "KR": "혹시 말을 안 듣는 닭 형인가?",
      "TW": "难道是那个不听指挥的鸡哥吗？"
    }
  },
  "\"那好吧我们听清楚指挥说的话吧\"": {
    "translation": "",
    "MultiLang": {
      "US": "Alright, let's listen carefully to the instructions.",
      "JP": "好吧、我々は何とせよ、命令されたことをしっかり聞き、実行しよう",
      "CN": "",
      "KR": "좋습니다. 저희는 지시받은 말을 명확하게 이해하겠습니다.",
      "TW": "好吧，我们听清楚指挥说的话吧。"
    }
  },
  "\"拿好我们的枪，该上路了\"": {
    "translation": "",
    "MultiLang": {
      "US": "Hold your guns, it's time to go.",
      "JP": "武器をしっかり持って、出発しましょう。",
      "CN": "",
      "KR": "총을 잘 챙기고, 출발합시다.",
      "TW": "拿起我們的槍，該出發了。"
    }
  },
  "\"还需在此地等待10s\"": {
    "translation": "",
    "MultiLang": {
      "US": "You still need to wait here for 10 seconds.",
      "JP": "この場所でさらに10秒待つ必要があります。",
      "CN": "",
      "KR": "여전히 여기서 10초 더 기다려야 합니다.",
      "TW": "還需要在此地等待10秒。"
    }
  },
  "\"解决此处的拦路问题，需要30s\"": {
    "translation": "",
    "MultiLang": {
      "US": "It will take 30 seconds to resolve the obstacle here.",
      "JP": "この場所の障害を解決するには、30秒かかります。",
      "CN": "",
      "KR": "이곳의 장애물을 해결하려면 30초가 필요합니다.",
      "TW": "解決這裡的障礙，需要30秒。"
    }
  },
  "“水也可以走，挺安全的。\"": {
    "translation": "",
    "MultiLang": {
      "US": "“We can walk through the water, it's pretty safe.”",
      "JP": "“水も通れるし、結構安全だよ。\"",
      "CN": "",
      "KR": "“물도 가는 거야, 괜찮아.”",
      "TW": "也可以選擇水路，比較安全。"
    }
  },
  "“路上还有不知名的补给\"": {
    "translation": "",
    "MultiLang": {
      "US": "“There are some unknown supplies along the way.”",
      "JP": "“道中にも未知の補給があるぞ。\"",
      "CN": "",
      "KR": "“길에 모르는 보급품이 있어.”",
      "TW": "路上還有未知的補給。"
    }
  },
  "“带上吧，对我们有帮助.\"": {
    "translation": "",
    "MultiLang": {
      "US": "“Take it with us, it'll help us.”",
      "JP": "持っていってください。私たちに役立ちます。",
      "CN": "",
      "KR": "“가져가자, 우리에게 도움이 될 거야.”",
      "TW": "帶上吧，對我們有幫助。"
    }
  },
  "\"进入庭院还需20s\"": {
    "translation": "",
    "MultiLang": {
      "US": "It will take 20 seconds to enter the courtyard.",
      "JP": "中庭に入るまであと20秒です。",
      "CN": "",
      "KR": "안뜰로 들어가려면 20초가 더 필요합니다.",
      "TW": "進入庭院還需要20秒。"
    }
  },
  "\"怎么左手边还有个传送装置\"": {
    "translation": "",
    "MultiLang": {
      "US": "What's this teleportation device on the left?",
      "JP": "なぜ左側にテレポート装置があるんだ？",
      "CN": "",
      "KR": "왼쪽에 또 텔레포터 장치가 있네.",
      "TW": "怎麼左邊還有個傳送裝置？"
    }
  },
  "\"注意身位!\"": {
    "translation": "",
    "MultiLang": {
      "US": "Watch your position!",
      "JP": "注意！位置について！",
      "CN": "",
      "KR": "방향에 주의하세요!",
      "TW": "注意隊形！"
    }
  },
  "\"这又是什么破地形啊\"": {
    "translation": "",
    "MultiLang": {
      "US": "What kind of terrain is this?",
      "JP": "これは一体何の地形なんだ？",
      "CN": "",
      "KR": "이게 또 무슨 끔찍한 지형이야.",
      "TW": "這是什麼鬼樣的地形啊"
    }
  },
  "\"兵分两路别让僵尸跑到我们的前面\"": {
    "translation": "",
    "MultiLang": {
      "US": "Split into two groups, don't let the zombies get ahead of us.",
      "JP": "兵士は二手に分かれ、ゾンビが我々の前に進まないように。",
      "CN": "",
      "KR": "병력을 두 갈래로 나누어, 좀비들이 우리 앞에 지나가지 않도록 하세요.",
      "TW": "兵分兩路，別讓殭屍跑到我們前面"
    }
  },
  "\"前方的路将在10s后开启\"": {
    "translation": "",
    "MultiLang": {
      "US": "The path ahead will open in 10 seconds.",
      "JP": "前方の道は10秒後に開通します。",
      "CN": "",
      "KR": "앞쪽 길은 10초 후에 열립니다.",
      "TW": "前方道路将在10秒后开启"
    }
  },
  "\"前方的路将在25s后开启\"": {
    "translation": "",
    "MultiLang": {
      "US": "The path ahead will open in 25 seconds.",
      "JP": "前方の道は25秒後に開通します。",
      "CN": "",
      "KR": "앞쪽 길은 25초 후에 열립니다.",
      "TW": "前方道路将在25秒后开启"
    }
  },
  "\"注意前方有不明物体飞来！\"": {
    "translation": "",
    "MultiLang": {
      "US": "Warning! An unidentified object is approaching from ahead!",
      "JP": "前方から不明な物体が飛来しています！注意してください！",
      "CN": "",
      "KR": "주의! 앞쪽에 정체불명의 물체가 날아오고 있습니다!",
      "TW": "注意前方有不明物体飞来！"
    }
  },
  "\"没路走了\"": {
    "translation": "",
    "MultiLang": {
      "US": "There's no way forward.",
      "JP": "進む道がありません。",
      "CN": "",
      "KR": "더 이상 갈 곳이 없습니다.",
      "TW": "沒有路可走了"
    }
  },
  "\"这块板子好像能移动\"": {
    "translation": "",
    "MultiLang": {
      "US": "This panel seems to be movable.",
      "JP": "この板は動かせそうです。",
      "CN": "",
      "KR": "이 판은 움직일 수 있는 것 같습니다.",
      "TW": "這塊板子好像可以移動"
    }
  },
  "\"上去试试!\"": {
    "translation": "",
    "MultiLang": {
      "US": "Try going up!",
      "JP": "試してみましょう！",
      "CN": "",
      "KR": "한 번 올라가 보세요!",
      "TW": "上去试试！"
    }
  },
  "\"希望能有一条生路\"": {
    "translation": "",
    "MultiLang": {
      "US": "I hope there's another way.",
      "JP": "何とかして生路を見つけられるといい。",
      "CN": "",
      "KR": "살아남을 수 있는 방법이 있기를 바랍니다.",
      "TW": "希望能找到一条出路。"
    }
  },
  "\"板子还有10s离开\"": {
    "translation": "",
    "MultiLang": {
      "US": "The panel will move away in 10 seconds.",
      "JP": "床板残り10秒で破壊されます",
      "CN": "",
      "KR": "판이 10초 후에 사라집니다.",
      "TW": "地板还有10秒就会脱落。"
    }
  },
  "\"我们很快就能进入教堂底下了\"": {
    "translation": "",
    "MultiLang": {
      "US": "We will soon be able to enter the bottom of the church.",
      "JP": "我々は間もなく教会の地下へ到達します",
      "CN": "",
      "KR": "곧바로 교회 지하로 들어갈 수 있습니다.",
      "TW": "我们很快就能进入教堂的地下室了。"
    }
  },
  "\"脚下的玻璃还有10s碎裂\"": {
    "translation": "",
    "MultiLang": {
      "US": "The glass under your feet will shatter in 10 seconds.",
      "JP": "足元のガラスが残り10秒で破壊されます",
      "CN": "",
      "KR": "발 아래의 유리가 10초 후에 부서집니다.",
      "TW": "脚下的玻璃还有10秒就会破碎。"
    }
  },
  "\"很快清干净这些拦路的东西，给我25s\"": {
    "translation": "",
    "MultiLang": {
      "US": "Clear these obstacles quickly. I need it done in 25 seconds.",
      "JP": "この障害物をすぐに排除してください。25秒で",
      "CN": "",
      "KR": "이 길을 막는 것들을 금방 치워주세요. 25초 안에.",
      "TW": "尽快清理掉这些障碍物，给我25秒。"
    }
  },
  "\"该死\"": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it!",
      "JP": "くそっ",
      "CN": "",
      "KR": "젠장.",
      "TW": "该死！"
    }
  },
  "\"这什么门\"": {
    "translation": "",
    "MultiLang": {
      "US": "What kind of door is this?",
      "JP": "これは何のドアだ",
      "CN": "",
      "KR": "이게 무슨 문이지?",
      "TW": "这是什么门？"
    }
  },
  "\"用枪都打不坏。\"": {
    "translation": "",
    "MultiLang": {
      "US": "It's impossible to break with a gun.",
      "JP": "銃でも壊せません。",
      "CN": "",
      "KR": "총으로도 부술 수 없어요.",
      "TW": "即使用槍也打不壞。"
    }
  },
  "\"兄弟们继续守住\"": {
    "translation": "",
    "MultiLang": {
      "US": "Hold your positions, everyone.",
      "JP": "仲間たち、持ち場を守り続けろ",
      "CN": "",
      "KR": "여러분, 계속 방어 위치를 지키세요.",
      "TW": "兄弟們，繼續堅守。"
    }
  },
  "\"我试试能不能撞开\"": {
    "translation": "",
    "MultiLang": {
      "US": "I'll try to ram it open.",
      "JP": "試してみるか、突破できるかどうか。",
      "CN": "",
      "KR": "제가 한 번 부딪혀볼게요.",
      "TW": "我試試能不能撞開。"
    }
  },
  "\"旁边的玻璃怎么要碎了\"": {
    "translation": "",
    "MultiLang": {
      "US": "What's happening with the glass next to it? It's about to break.",
      "JP": "隣のガラスが割れそうになっている。",
      "CN": "",
      "KR": "옆의 유리벽이 어떻게 깨질 뻔했어.",
      "TW": "旁邊的玻璃怎麼快要碎了？"
    }
  },
  "\"保持火力！\"": {
    "translation": "",
    "MultiLang": {
      "US": "Maintain your firepower!",
      "JP": "火力を維持！",
      "CN": "",
      "KR": "사격을 멈추지 마!",
      "TW": "保持火力！"
    }
  },
  "\"快要撞开了，再给我20s\"": {
    "translation": "",
    "MultiLang": {
      "US": "We're about to break through, give me another 20 seconds!",
      "JP": "もうすぐ突破できる、あと20秒。",
      "CN": "",
      "KR": "문이 거의 열리려고 해, 20초만 더 버텨.",
      "TW": "快要撞開了，再給我20秒。"
    }
  },
  "\"这楼路在哪啊\"": {
    "translation": "",
    "MultiLang": {
      "US": "Where is this building's entrance?",
      "JP": "この建物の入口はどこにあるんだ？",
      "CN": "",
      "KR": "이 건물 입구는 어디에 있지?",
      "TW": "這棟樓的入口在哪裡？"
    }
  },
  "\"怎么能这么绕的\"": {
    "translation": "",
    "MultiLang": {
      "US": "Why is this route so convoluted?",
      "JP": "なんでこんな回りくどいんだ？",
      "CN": "",
      "KR": "왜 이렇게 돌아가야 하는 거지?",
      "TW": "怎麼會這麼繞？"
    }
  },
  "\"右手边那两个小门里怎么全是僵尸\"": {
    "translation": "",
    "MultiLang": {
      "US": "Why are there so many zombies in those two small doors on the right?",
      "JP": "右側の小さなドアの中にはなぜゾンビばかりいるんだ？",
      "CN": "",
      "KR": "오른쪽에 있는 두 개의 작은 문 안에는 왜 좀비가 가득한 거야?",
      "TW": "右手邊那兩個小門裡怎麼全是殭屍"
    }
  },
  "\"保持火力\"": {
    "translation": "",
    "MultiLang": {
      "US": "Maintain your firepower!",
      "JP": "火力を維持。",
      "CN": "",
      "KR": "사격을 멈추지 마.",
      "TW": "保持火力"
    }
  },
  "\"找到生路了\"": {
    "translation": "",
    "MultiLang": {
      "US": "I've found a way out!",
      "JP": "脱出への道を見つけた",
      "CN": "",
      "KR": "생존의 길을 찾았어.",
      "TW": "找到了生路"
    }
  },
  "\"另一边的破门是死路\"": {
    "translation": "",
    "MultiLang": {
      "US": "The broken door on the other side is a dead end.",
      "JP": "反対側の壊れた扉は行き止まりだ",
      "CN": "",
      "KR": "다른 쪽의 부서진 문은 막다른 길입니다.",
      "TW": "另一邊的破門是死路"
    }
  },
  "\"兄弟们坚持住\"": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on, brothers!",
      "JP": "みんな、頑張れ",
      "CN": "",
      "KR": "형제들, 버텨내세요.",
      "TW": "兄弟們堅持住"
    }
  },
  "\"曙光就在前方\"": {
    "translation": "",
    "MultiLang": {
      "US": "Dawn is just ahead.",
      "JP": "希望はすぐそこだ",
      "CN": "",
      "KR": "희망은 바로 앞에 있습니다.",
      "TW": "希望就在前方"
    }
  },
  "\"另一边的管道也下来僵尸了\"": {
    "translation": "",
    "MultiLang": {
      "US": "The zombies on the other side of the pipe are also falling.",
      "JP": "反対側のパイプからもゾンビが出てくるぞ",
      "CN": "",
      "KR": "다른 쪽 파이프에서도 좀비가 튀어나왔습니다.",
      "TW": "另一邊的管道也下來殭屍了"
    }
  },
  "\"注意保护好自己！\"": {
    "translation": "",
    "MultiLang": {
      "US": "Protect yourselves!",
      "JP": "身を守ってくれ！",
      "CN": "",
      "KR": "자신을 잘 보호하세요!",
      "TW": "注意保護好自己！"
    }
  },
  "\"门将在10s后破坏\"": {
    "translation": "",
    "MultiLang": {
      "US": "The door will be destroyed in 10 seconds.",
      "JP": "扉は10秒後に破壊される",
      "CN": "",
      "KR": "문은 10초 후에 파괴됩니다.",
      "TW": "门将在10秒后被破坏"
    }
  },
  "\"好像快出去了\"": {
    "translation": "",
    "MultiLang": {
      "US": "It looks like it's about to open.",
      "JP": "もうすぐ脱出できそうだ",
      "CN": "",
      "KR": "이제 곧 나갈 수 있을 것 같습니다.",
      "TW": "好像快要出来了"
    }
  },
  "\"我已经闻到新鲜空气了\"": {
    "translation": "",
    "MultiLang": {
      "US": "I can smell fresh air.",
      "JP": "新鮮な空気が感じられる。",
      "CN": "",
      "KR": "저는 이미 신선한 공기를 맡을 수 있습니다.",
      "TW": "我已经闻到新鲜空气了"
    }
  },
  "\"这一路上失去了不少兄弟\"": {
    "translation": "",
    "MultiLang": {
      "US": "We've lost quite a few brothers along the way.",
      "JP": "道中、多くの仲間を失った。",
      "CN": "",
      "KR": "이 길을 따라 많은 동료들을 잃었습니다.",
      "TW": "一路上失去了不少兄弟"
    }
  },
  "\"兄弟们你们觉得怎么样\"": {
    "translation": "",
    "MultiLang": {
      "US": "Guys, what do you think?",
      "JP": "みんな、どう思う？",
      "CN": "",
      "KR": "여러분, 어떻게 생각하세요?",
      "TW": "兄弟们，你们觉得怎么样？"
    }
  },
  "\"我们一定要出去！\"": {
    "translation": "",
    "MultiLang": {
      "US": "We have to get out of here!",
      "JP": "必ず外に出なければ！",
      "CN": "",
      "KR": "우리는 반드시 밖으로 나가야 합니다!",
      "TW": "我们一定要出去！"
    }
  },
  "\"玻璃怎么有裂纹了\"": {
    "translation": "",
    "MultiLang": {
      "US": "How did the glass crack?",
      "JP": "どうして窓にヒビが入ったんだ？",
      "CN": "",
      "KR": "유리가 어떻게 갈라졌지?",
      "TW": "玻璃怎么出现了裂纹？"
    }
  },
  "\"远离玻璃!\"": {
    "translation": "",
    "MultiLang": {
      "US": "Stay away from the glass!",
      "JP": "窓から離れて！",
      "CN": "",
      "KR": "유리에서 떨어져!",
      "TW": "远离玻璃！"
    }
  },
  "\"快走！左右两边的门已经快碎了！\"": {
    "translation": "",
    "MultiLang": {
      "US": "Hurry! The doors on both sides are about to break!",
      "JP": "急げ！左右のドアがもうすぐ壊れるぞ！",
      "CN": "",
      "KR": "빨리 가세요! 양쪽 문의 파손이 임박했습니다!",
      "TW": "快跑！左右两边的门快要破了！"
    }
  },
  "\"怎么没路了\"": {
    "translation": "",
    "MultiLang": {
      "US": "Why is there no way forward?",
      "JP": "どうして道がないんだ？",
      "CN": "",
      "KR": "길이 막혔어?",
      "TW": "怎么前面没有路了？"
    }
  },
  "\"这有台装甲车\"": {
    "translation": "",
    "MultiLang": {
      "US": "There's an armored vehicle over there.",
      "JP": "こちらに装甲車があります",
      "CN": "",
      "KR": "여기 장갑차가 있습니다.",
      "TW": "这里有一辆装甲车。"
    }
  },
  "\"我们用它来撞出一条路\"": {
    "translation": "",
    "MultiLang": {
      "US": "Let's use it to break through a path.",
      "JP": "これで道を開けるんだ",
      "CN": "",
      "KR": "이걸로 길을 뚫어낼 겁니다.",
      "TW": "我们用它来撞出一个通道。"
    }
  },
  "\"快要撞开了!\"": {
    "translation": "",
    "MultiLang": {
      "US": "We're about to crash!",
      "JP": "もうすぐ突破できそうだ！",
      "CN": "",
      "KR": "뚫으려는 듯 합니다!",
      "TW": "快要撞开了！"
    }
  },
  "\"兄弟们准备撤！\"": {
    "translation": "",
    "MultiLang": {
      "US": "Brothers, prepare to retreat!",
      "JP": "みんな、退避！",
      "CN": "",
      "KR": "여러분, 철수합니다!",
      "TW": "兄弟们，准备撤退！"
    }
  },
  "\"坚持到电梯上升\"": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on until the elevator ascends.",
      "JP": "エレベーターが上昇するまで持ちこたえる",
      "CN": "",
      "KR": "엘리베이터가 올라갈 때까지 버텨요.",
      "TW": "坚持到电梯上升。"
    }
  },
  "\"有种不祥的预感\"": {
    "translation": "",
    "MultiLang": {
      "US": "I have a bad feeling.",
      "JP": "何か不吉な予感がする",
      "CN": "",
      "KR": "왠지 안 좋은 예감이 듭니다.",
      "TW": "总觉得有什么不祥的预感。"
    }
  },
  "\"电梯上升还有10s\"": {
    "translation": "",
    "MultiLang": {
      "US": "Elevator ascending in 10 seconds.",
      "JP": "エレベーター上昇まで残り10秒",
      "CN": "",
      "KR": "엘리베이터 상승까지 10초 남았습니다.",
      "TW": "电梯上升还剩10秒"
    }
  },
  "\"神秘的声音：接受挑战吧!\"": {
    "translation": "",
    "MultiLang": {
      "US": "Mysterious voice: Accept the challenge!",
      "JP": "謎の声：挑戦を受け入れろ！",
      "CN": "",
      "KR": "신비로운 목소리: 도전을 받아들이세요!",
      "TW": "神秘的声音：接受挑战吧！"
    }
  },
  "\"除你武器!\"": {
    "translation": "",
    "MultiLang": {
      "US": "Discard your weapons!",
      "JP": "武器を捨てろ！",
      "CN": "",
      "KR": "무기를 버리세요!",
      "TW": "解除你的武器！"
    }
  },
  "\"僵尸30s出笼\"": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies will be released in 30 seconds.",
      "JP": "ゾンビが30秒後に脱出。",
      "CN": "",
      "KR": "좀비가 30초 후에 등장합니다.",
      "TW": "僵尸将在30秒后出现"
    }
  },
  "\"坚持4分钟\"": {
    "translation": "",
    "MultiLang": {
      "US": "Hold for 4 minutes",
      "JP": "4分間持ちこたえろ。",
      "CN": "",
      "KR": "4분 동안 버텨보세요.",
      "TW": "坚持4分钟"
    }
  },
  "\"最后60s低重力\"": {
    "translation": "",
    "MultiLang": {
      "US": "Last 60 seconds in low gravity",
      "JP": "残り60秒で低重力。",
      "CN": "",
      "KR": "마지막 60초는 저중력 상태입니다.",
      "TW": "最后60秒进入低重力状态"
    }
  },
  "\"这地怎么如此的邪乎.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Why is this place so eerie?",
      "JP": "ここは一体どうしてこんなに不気味なんだ。",
      "CN": "",
      "KR": "이곳이 왜 이렇게 기이한가요.",
      "TW": "这地方怎么如此邪异。"
    }
  },
  "\"飞机刚飞到上空就坠机了.\"": {
    "translation": "",
    "MultiLang": {
      "US": "The plane crashed just after taking off.",
      "JP": "飛行機がまだ上空にいるのに墜落した。",
      "CN": "",
      "KR": "비행기가 상공에 올라가자마자 추락했습니다.",
      "TW": "飞机刚刚飞到上空就坠机了。"
    }
  },
  "\"寻找我们失踪的队员吧.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Let's find our missing teammate.",
      "JP": "行方不明になった仲間を探し出そう。",
      "CN": "",
      "KR": "우리 팀의 실종된 멤버들을 찾아보세요.",
      "TW": "讓我們一起尋找失蹤的隊員吧。"
    }
  },
  "\"需在此地等待20s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "You must wait here for 20 seconds.",
      "JP": "この場所で20秒待機してください。",
      "CN": "",
      "KR": "이 장소에서 20초 동안 기다려야 합니다.",
      "TW": "需在此地等待20秒。"
    }
  },
  "\"解决此处的拦路问题，需要30s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Solving the obstacle in this area will take 30 seconds.",
      "JP": "この場所の障害を解決するには、30秒かかります。",
      "CN": "",
      "KR": "이곳의 장애물을 해결하려면 30초가 필요합니다.",
      "TW": "解決這裡的障礙，需要30秒。"
    }
  },
  "“水也可以走，挺安全的.\"": {
    "translation": "",
    "MultiLang": {
      "US": "You can also walk through the water; it's quite safe.",
      "JP": "水路を通ることもできます。比較的安全です。",
      "CN": "",
      "KR": "물도 지나갈 수 있습니다. 꽤 안전합니다.",
      "TW": "水路也是可以通行，相當安全。"
    }
  },
  "“路上还有不知名的补给.\"": {
    "translation": "",
    "MultiLang": {
      "US": "There are still unknown supplies on the road.",
      "JP": "道中には、名前のわからない補給物があります。",
      "CN": "",
      "KR": "길에는 정체를 알 수 없는 보급품이 있습니다.",
      "TW": "路上還有未知的補給。"
    }
  },
  "\"进入庭院还需20s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "It will take 20 seconds to enter the courtyard.",
      "JP": "中庭に入るまで、さらに20秒かかります。",
      "CN": "",
      "KR": "안으로 들어가려면 20초가 더 필요합니다.",
      "TW": "進入庭院還需要20秒。"
    }
  },
  "\"怎么左手边还有个传送装置.\"": {
    "translation": "",
    "MultiLang": {
      "US": "What's this teleportation device on the left?",
      "JP": "なぜか左側にテレポート装置がある。",
      "CN": "",
      "KR": "왼쪽에 왜 텔레포트 장치가 있는 거죠?",
      "TW": "怎麼左邊還有一個傳送裝置。"
    }
  },
  "\"这又是什么破地形啊!\"": {
    "translation": "",
    "MultiLang": {
      "US": "What kind of terrain is this!",
      "JP": "これは一体何の地形だ！",
      "CN": "",
      "KR": "이게 또 무슨 끔찍한 지형이야!",
      "TW": "這是什麼鬼地形啊！"
    }
  },
  "\"兵分两路别让僵尸跑到我们的前面.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Split into two groups, don't let the zombies get ahead of us.",
      "JP": "兵を2つに分けて、ゾンビが我々の前に進まないように。",
      "CN": "",
      "KR": "병력을 두 갈래로 나누어 좀비가 우리 앞에 못 가게 하세요.",
      "TW": "兵分两路，别让僵尸跑到我们的前面。"
    }
  },
  "\"前方的路将在10s后开启.\"": {
    "translation": "",
    "MultiLang": {
      "US": "The path ahead will open in 10 seconds.",
      "JP": "前方の道は、10秒後に開通します。",
      "CN": "",
      "KR": "앞쪽 길은 10초 후에 열립니다.",
      "TW": "前方道路将在10秒后开启。"
    }
  },
  "\"前方的路将在25s后开启.\"": {
    "translation": "",
    "MultiLang": {
      "US": "The path ahead will open in 25 seconds.",
      "JP": "前方の道は25秒後に開通します。",
      "CN": "",
      "KR": "앞쪽 길은 25초 후에 열립니다.",
      "TW": "前方道路将在25秒后开启。"
    }
  },
  "\"没路走了!\"": {
    "translation": "",
    "MultiLang": {
      "US": "No way forward!",
      "JP": "進む道がありません！",
      "CN": "",
      "KR": "길이 막혔다!",
      "TW": "没有路可走了！"
    }
  },
  "\"这块板子好像能移动.\"": {
    "translation": "",
    "MultiLang": {
      "US": "This panel seems to be movable.",
      "JP": "この板は動かせそうです。",
      "CN": "",
      "KR": "이 판은 움직일 수 있는 것 같다.",
      "TW": "这块板子好像可以移动。"
    }
  },
  "\"希望能有一条生路.\"": {
    "translation": "",
    "MultiLang": {
      "US": "I hope there's a way out.",
      "JP": "何とかして道を開こう。",
      "CN": "",
      "KR": "살아남을 방법이 있기를.",
      "TW": "希望能找到一条生路。"
    }
  },
  "\"板子还有10s离开.\"": {
    "translation": "",
    "MultiLang": {
      "US": "The panel will retract in 10 seconds.",
      "JP": "板が動くのは残り10秒です。",
      "CN": "",
      "KR": "판이 10초 후에 움직임을 멈춘다.",
      "TW": "板子还有10秒离开。"
    }
  },
  "\"我们很快就能进入教堂底下了!\"": {
    "translation": "",
    "MultiLang": {
      "US": "We'll be able to enter the church basement soon!",
      "JP": "すぐに教会の地下に入れるぞ！",
      "CN": "",
      "KR": "곧바로 교회 지하로 들어갈 수 있을 거예요!",
      "TW": "我们很快就能进入教堂地底！"
    }
  },
  "\"脚下的玻璃还有10s碎裂.\"": {
    "translation": "",
    "MultiLang": {
      "US": "The glass beneath your feet will shatter in 10 seconds.",
      "JP": "足元のガラスが砕けるまで残り10秒です。",
      "CN": "",
      "KR": "발 아래의 유리 조각이 10초 후에 부서질 겁니다.",
      "TW": "腳下的玻璃還剩 10 秒會碎裂。"
    }
  },
  "\"很快清干净这些拦路的东西，给我25s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Clear these obstacles quickly, give me 25 seconds.",
      "JP": "この邪魔なものをすぐに片付けてください。25秒でお願いします。",
      "CN": "",
      "KR": "이 앞을 가로막는 것들을 빠르게 치워줘. 25초 안에 해내.",
      "TW": "請盡快清理這些阻礙物，給我 25 秒。"
    }
  },
  "\"该死!\"": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it!",
      "JP": "くそっ！",
      "CN": "",
      "KR": "빌어먹을!",
      "TW": "該死！"
    }
  },
  "\"这什么门.\"": {
    "translation": "",
    "MultiLang": {
      "US": "What kind of door is this.",
      "JP": "これは何のドアだ。",
      "CN": "",
      "KR": "이 문은 뭐지.",
      "TW": "這是什麼門？"
    }
  },
  "\"用枪都打不坏.\"": {
    "translation": "",
    "MultiLang": {
      "US": "It's impossible to break with bullets.",
      "JP": "銃で撃っても壊れない。",
      "CN": "",
      "KR": "총으로도 부술 수 없어.",
      "TW": "連槍都打不壞。"
    }
  },
  "\"兄弟们继续守住!\"": {
    "translation": "",
    "MultiLang": {
      "US": "Brothers, hold the line!",
      "JP": "みんな、引き続き守り抜いてくれ！",
      "CN": "",
      "KR": "형제들, 계속 방어해!",
      "TW": "兄弟們繼續堅守！"
    }
  },
  "\"我试试能不能撞开.\"": {
    "translation": "",
    "MultiLang": {
      "US": "I'll try to break through.",
      "JP": "試してみよう、開けられるかどうか。",
      "CN": "",
      "KR": "한 번 시도해 볼까, 열릴 수 있는지.",
      "TW": "我試試能不能撞開。"
    }
  },
  "\"旁边的玻璃怎么要碎了.\"": {
    "translation": "",
    "MultiLang": {
      "US": "The glass on the side is about to shatter.",
      "JP": "隣のガラスが割れそう。",
      "CN": "",
      "KR": "옆의 유리도 곧 깨질 것 같아.",
      "TW": "旁邊的玻璃怎麼快要碎了。"
    }
  },
  "\"快要撞开了，再给我20s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "It's almost broken, give me another 20 seconds.",
      "JP": "もうすぐ開くはずだ、あと20秒。",
      "CN": "",
      "KR": "거의 열리려고 해, 20초만 더.",
      "TW": "快要撞开了，再给我20秒。"
    }
  },
  "\"这楼路在哪啊.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Where is the entrance to this building?",
      "JP": "この建物の入り口はどこだ。",
      "CN": "",
      "KR": "이 건물 출구는 어디 있지.",
      "TW": "这栋楼的入口在哪里啊。"
    }
  },
  "\"怎么能这么绕的.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Why is this route so circuitous?",
      "JP": "どうしてこんな回りくどいことになるんだ。",
      "CN": "",
      "KR": "왜 이렇게 돌아가야 하지.",
      "TW": "怎么会这么绕。"
    }
  },
  "\"右手边那两个小门里怎么全是僵尸.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Why are there so many zombies in those two small doors on the right?",
      "JP": "右側の小さな扉の奥には、どうしてこんなにたくさんのゾンビがいるんだ。",
      "CN": "",
      "KR": "오른손 쪽 두 개의 작은 문 안에는 왜 이렇게 많은 좀비들이 있는 거지.",
      "TW": "右手边那两个小门里怎么全是僵尸。"
    }
  },
  "\"保持火力!\"": {
    "translation": "",
    "MultiLang": {
      "US": "Maintain your firepower!",
      "JP": "火力を維持しろ！",
      "CN": "",
      "KR": "화력을 유지해!",
      "TW": "保持火力！"
    }
  },
  "\"找到生路了!\"": {
    "translation": "",
    "MultiLang": {
      "US": "We've found a way out!",
      "JP": "脱出路を見つけた！",
      "CN": "",
      "KR": "생존의 길을 찾았어!",
      "TW": "找到生路了！"
    }
  },
  "\"另一边的破门是死路.\"": {
    "translation": "",
    "MultiLang": {
      "US": "The door on the other side leads to a dead end.",
      "JP": "もう一方の壊れた扉は行き止まりだ。",
      "CN": "",
      "KR": "다른 쪽의 부서진 문은 막다른 길이야.",
      "TW": "另一边的破门是死路。"
    }
  },
  "\"兄弟们坚持住.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on, brothers!",
      "JP": "みんな、持ちこたえてくれ。",
      "CN": "",
      "KR": "형제들, 버텨내자.",
      "TW": "兄弟们坚持住。"
    }
  },
  "\"曙光就在前方!\"": {
    "translation": "",
    "MultiLang": {
      "US": "The dawn is just ahead!",
      "JP": "希望はすぐそこだ！",
      "CN": "",
      "KR": "희망은 바로 저 앞에 있어!",
      "TW": "曙光就在前方！"
    }
  },
  "\"另一边的管道也下来僵尸了!\"": {
    "translation": "",
    "MultiLang": {
      "US": "More zombies are coming through the pipes on the other side!",
      "JP": "もう一方のパイプからもゾンビが現れた！",
      "CN": "",
      "KR": "다른 쪽 파이프에서도 좀비들이 쏟아져 나오고 있어!",
      "TW": "另一边的管道也出现了僵尸！"
    }
  },
  "\"门将在10s后破坏.\"": {
    "translation": "",
    "MultiLang": {
      "US": "The door will be destroyed in 10 seconds.",
      "JP": "扉は10秒後に破壊されます。",
      "CN": "",
      "KR": "문은 10초 후에 파괴됩니다.",
      "TW": "门将在10秒后破坏。"
    }
  },
  "\"好像快出去了!\"": {
    "translation": "",
    "MultiLang": {
      "US": "It looks like we're almost out!",
      "JP": "どうやら、もうすぐ脱出できそうだ！",
      "CN": "",
      "KR": "好像就要出来了!",
      "TW": "好像快要出来了！"
    }
  },
  "\"我已经闻到新鲜空气了.\"": {
    "translation": "",
    "MultiLang": {
      "US": "I can smell the fresh air.",
      "JP": "新鮮な空気が感じられる。",
      "CN": "",
      "KR": "이미 신선한 공기가 느껴져요.",
      "TW": "我已经闻到新鲜空气了。"
    }
  },
  "\"这一路上失去了不少兄弟.\"": {
    "translation": "",
    "MultiLang": {
      "US": "We lost quite a few brothers along the way.",
      "JP": "道中、多くの仲間を失った。",
      "CN": "",
      "KR": "이 길을 따라 오면서 많은 동료들을 잃었어요.",
      "TW": "一路上失去了不少兄弟。"
    }
  },
  "\"兄弟们你们觉得怎么样.\"": {
    "translation": "",
    "MultiLang": {
      "US": "What do you guys think?",
      "JP": "みんな、どう思う？",
      "CN": "",
      "KR": "동료들, 어떻게 생각하세요?",
      "TW": "兄弟们，你们觉得怎么样。"
    }
  },
  "\"玻璃怎么有裂纹了.\"": {
    "translation": "",
    "MultiLang": {
      "US": "How did the glass crack?",
      "JP": "どうしてガラスにひびが入ったんだ？",
      "CN": "",
      "KR": "유리가 어떻게 갈라졌지?",
      "TW": "玻璃怎么会出现裂纹了。"
    }
  },
  "\"怎么没路了.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Why is there no road?",
      "JP": "どうして進めないんだ？",
      "CN": "",
      "KR": "길이 막혔어.",
      "TW": "怎麼沒有路了。"
    }
  },
  "\"这有台装甲车.\"": {
    "translation": "",
    "MultiLang": {
      "US": "There's an armored vehicle over there.",
      "JP": "ここに装甲車がある。",
      "CN": "",
      "KR": "여기 장갑차가 있어요.",
      "TW": "這裡有一輛裝甲車。"
    }
  },
  "\"我们用它来撞出一条路.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Let's use it to break through and make a path.",
      "JP": "私たちは、これを使って道を切り開きます。",
      "CN": "",
      "KR": "이걸로 길을 뚫어 봅시다.",
      "TW": "我們用它來撞出一條路。"
    }
  },
  "\"坚持到电梯上升!\"": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on until the elevator ascends!",
      "JP": "エレベーターが上昇するまで、辛抱強く！",
      "CN": "",
      "KR": "엘리베이터가 올라갈 때까지 버텨!",
      "TW": "堅持到電梯上升！"
    }
  },
  "\"有种不祥的预感.\"": {
    "translation": "",
    "MultiLang": {
      "US": "I have a bad feeling about this.",
      "JP": "何か不吉な予感がする。",
      "CN": "",
      "KR": "왠지 안 좋은 예감이 든다.",
      "TW": "有種不祥的預感。"
    }
  },
  "\"电梯上升还有10s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Elevator will start ascending in 10 seconds.",
      "JP": "エレベーター上昇まで残り10秒。",
      "CN": "",
      "KR": "엘리베이터 작동까지 10초 남았습니다.",
      "TW": "電梯上升還有10秒。"
    }
  },
  "\"僵尸30s出笼.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies will be released in 30 seconds.",
      "JP": "ゾンビは30秒後に脱出します。",
      "CN": "",
      "KR": "좀비들이 30초 후에 등장합니다.",
      "TW": "殭屍30秒後會出來。"
    }
  },
  "\"坚持4分钟.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on for 4 minutes.",
      "JP": "4分間、持ちこたえてください。",
      "CN": "",
      "KR": "4분 동안 버텨라.",
      "TW": "堅持4分鐘。"
    }
  },
  "\"最后60s低重力.\"": {
    "translation": "",
    "MultiLang": {
      "US": "Last 60 seconds of low gravity.",
      "JP": "残り60秒、低重力状態です。",
      "CN": "",
      "KR": "마지막 60초 동안 저중력 상태입니다.",
      "TW": "最后60秒，低重力。"
    }
  }
}
