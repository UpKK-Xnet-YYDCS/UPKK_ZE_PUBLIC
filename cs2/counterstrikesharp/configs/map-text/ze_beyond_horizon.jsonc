  },
  "It takes 10 seconds for the large dolphin to start moving.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "大型イルカは、開始までに10秒かかります。",
      "CN": "大型海豚需要 10 秒才能开始移动。",
      "KR": "큰 돌고래가 움직이기 시작하는 데 10초가 걸립니다.",
      "TW": "大型海豚开始移动需要 10 秒。"
    }
  },
  "The Right trigger activated.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "右トリガーが作動しました。",
      "CN": "右侧扳机已激活。",
      "KR": "오른쪽 트리거가 활성화되었습니다.",
      "TW": "右側扳機已啟動。"
    }
  },
  "The left trigger activated.": {
    "translation": "",
