    }
  },
  "**A zombie is spotted in the boss arena**": {
    "translation": "**在Boss竞技场里发现一只僵尸**",
    "MultiLang": {
      "US": "",
      "JP": "ボスエリアにゾンビが確認されました",
      "CN": "在Boss区域发现一只僵尸",
      "KR": "보스 전장에 좀비가 출현했습니다.",
      "TW": "Boss 場域發現殭屍"
    }
  },
  "**At 5 seconds zombie tp**": {
    "translation": "**5秒后僵尸传送**",
    "MultiLang": {
      "US": "",
      "JP": "5秒後にゾンビTP",
      "CN": "5秒时僵尸传送",
      "KR": "**5초 후 좀비 텔레포트",
      "TW": "5 秒後殭強制傳送"
    }
  },
  "**Be careful, you can easily fall here**": {
    "translation": "**小心，这里很容易摔倒**",
    "MultiLang": {
      "US": "",
      "JP": "ここは簡単に落ちてしまうので注意してください",
      "CN": "小心，这里很容易掉下去",
      "KR": "**조심하세요, 여기서 쉽게 추락할 수 있습니다.",
      "TW": "請小心，您很容易在此處跌落"
    }
  },
  "**Boss died**": {
    "translation": "**Boss死了**",
    "MultiLang": {
      "US": "",
      "JP": "ボスが死亡しました",
      "CN": "Boss已死亡",
      "KR": "**보스 시체 처리 중**",
      "TW": "Boss 已消亡"
    }
  },
  "**Drop the cans on your way**": {
    "translation": "**在路上放下罐子**",
    "MultiLang": {
      "US": "",
      "JP": "道中に缶を落としていきます",
      "CN": "沿途丢弃罐头",
      "KR": "**길을 따라 캔을 던지세요.",
      "TW": "沿途留下罐子"
    }
  },
  "**Get inside this box to escape**": {
    "translation": "**进入这个箱子逃跑**",
    "MultiLang": {
      "US": "",
      "JP": "脱出するにはこの箱に入ってください",
      "CN": "进入这个箱子以逃脱",
      "KR": "**도주하려면 이 상자에 들어가세요.",
      "TW": "進入此箱子以逃離"
    }
  },
  "**Give me 29 seconds, I'll stretch the rope**": {
    "translation": "**给我29秒，我会拉绳子**",
    "MultiLang": {
      "US": "",
      "JP": "29秒待って、綱を伸ばします",
      "CN": "给我29秒，我来接绳索",
      "KR": "\"29초만 주세요. 밧줄을 늘어뜨리겠습니다.\"",
      "TW": "請給我 29 秒，我會拉長繩索"
    }
  },
  "**Give me 29 seconds.**": {
    "translation": "**给我29秒。**",
    "MultiLang": {
      "US": "",
      "JP": "29秒だけ待って",
      "CN": "给我29秒。",
      "KR": "29초만 주세요.",
      "TW": "給我29秒。"
    }
  },
  "**Give me a few seconds.**": {
    "translation": "**给我几秒钟。**",
    "MultiLang": {
      "US": "",
      "JP": "少し待って",
      "CN": "给我几秒。",
      "KR": "잠시만 기다려 주세요.",
      "TW": "給我幾秒鐘。"
    }
  },
  "**Go down carefully on the black wire**": {
    "translation": "**小心地沿着黑色电线往下**",
    "MultiLang": {
      "US": "",
      "JP": "黒いケーブルを慎重に降りて",
      "CN": "顺着黑色电线小心爬下去",
      "KR": "검은 철사를 따라 조심스럽게 내려갑니다",
      "TW": "小心沿著黑色電線下去"
    }
  },
  "**Good job, go ahead to the elevator**": {
    "translation": "**干得好，继续前往电梯**",
    "MultiLang": {
      "US": "",
      "JP": "よくやった、エレベーターへ進んで",
      "CN": "做得好，前往电梯",
      "KR": "잘했습니다, 엘리베이터로 가세요",
      "TW": "做得好，前往電梯吧"
    }
  },
  "**Good job, the water level has started to decrease**": {
    "translation": "**干得好，水位开始下降了**",
    "MultiLang": {
      "US": "",
      "JP": "よくやった、水位が下がりはじめた",
      "CN": "做得好，水位已经开始下降",
      "KR": "잘했습니다. 수위가 감소하기 시작했습니다",
      "TW": "做得好，水位已經開始下降"
    }
  },
  "**Good job, the water level is decreasing**": {
    "translation": "**干得好，水位正在下降**",
    "MultiLang": {
      "US": "",
      "JP": "よくやった、水位が下がりつつある",
      "CN": "做得好，水位正在下降",
      "KR": "잘했습니다. 수위가 감소 중입니다",
      "TW": "做得好，水位正在下降"
    }
  },
  "**Great job, get out of the attic!**": {
    "translation": "**干得好，离开阁楼！**",
    "MultiLang": {
      "US": "",
      "JP": "よくやった、小屋から抜け出せ！",
      "CN": "干得好，快离开阁楼！",
      "KR": "훌륭합니다, 다락방에서 빠져나오세요!",
      "TW": "乾得漂亮，離開閣樓！"
    }
  },
  "**Great, the pipe is open, jump down!**": {
    "translation": "**太好了，管子开了，跳下去！**",
    "MultiLang": {
      "US": "",
      "JP": "いいぞ、パイプが開いた、飛び降りろ！",
      "CN": "太好了，管道已打开，跳下去！",
      "KR": "좋아요, 파이프가 열렸으니 뛰어내리세요!",
      "TW": "太好了，管道已打開，跳下去！"
    }
  },
