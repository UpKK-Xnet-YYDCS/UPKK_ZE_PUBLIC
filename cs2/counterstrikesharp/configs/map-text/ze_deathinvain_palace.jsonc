    }
  },
  "<LYCAN:The road on the left is opennyan.>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<LYCAN:左の道は開けてるよ。>",
      "CN": "<狼人：左边的路是畅通的。>",
      "KR": "<로마: 왼쪽 길은 열려있어냥.>",
      "TW": "<狼人: 左邊的路是開放的喵>"
    }
  },
  "<Let's go on the rightnyan!>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<右にゃんにゃんに行こう！>",
      "CN": "<一起nyan啊！>",
      "KR": "<가자, 릿님!>",
      "TW": "<讓我們一起喵喵吧！>"
    }
  },
  "<The barrier will disappear in 30 seconds>": {
