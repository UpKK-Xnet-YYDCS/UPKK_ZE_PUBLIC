  "<The barrier will disappear in 20 seconds>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<壁は20秒で消えます>",
      "CN": "<屏障将在20秒后消失>",
      "KR": "<장벽은 20초 후에 사라집니다>",
