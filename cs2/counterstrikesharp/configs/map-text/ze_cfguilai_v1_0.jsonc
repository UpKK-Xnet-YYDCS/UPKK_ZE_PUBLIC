{
  "第一关": {
    "translation": "",
    "MultiLang": {
      "US": "Stage 1",
      "JP": "第1關",
      "CN": "",
      "KR": "1관",
      "TW": "第一關"
    }
  },
  "map by 樱花染": {
    "translation": "",
    "MultiLang": {
      "US": "Map created by Sakura Stain",
      "JP": "地图制作者：櫻花染",
      "CN": "",
      "KR": "map by 樱花染",
      "TW": "地圖 by 櫻花染"
    }
  },
  "特别鸣谢黑岩，aizha,楽14,傅屿,学长老司机,gekki,心情": {
    "translation": "",
    "MultiLang": {
      "US": "Special thanks to BlackRock, aizha, Raku14, Fu Yu, Xue Lao Shuai Ji Sai, gekki, and Xin Qing.",
      "JP": "特別感謝：黑岩、aizha、楽14、傅屿、学长老司機、gekki、心情",
      "CN": "",
      "KR": "특별thanks: 흑암, aizha,楽14,傅屿,学长老司机,gekki,心情",
      "TW": "特別感謝黑岩、aizha、楽14、傅嶼、學長老司機、gekki、心情"
    }
  },
  "地图目前测试中，有问题和建议可以给作者反馈一下，这张地图算是我真正意义上的第一张ze地图": {
    "translation": "",
    "MultiLang": {
      "US": "The map is currently under testing. Please provide feedback to the author if you find any issues or have suggestions. This map marks my first true attempt at creating a Zombie Escape (ZE) map.",
      "JP": "地图目前仍在測試中，如有問題或建議請反饋給作者。這是我真正意義上的第一張 ZE 地图。",
      "CN": "",
      "KR": "지도는 현재 테스트 중이며, 문제나 제안이 있으면 저자에게 피드백해 주시기를 바랍니다. 이 지도는 제 진정한 의미에서의 첫 번째 ze지도입니다.",
      "TW": "地圖目前測試中，如有問題與建議可反饋給作者。這張地圖算是我正式製作的第一張 ze 模式地圖。"
    }
  },
  "感谢傅屿，朝田诗乃测试": {
    "translation": "",
    "MultiLang": {
      "US": "Thanks to Fu Yu and Asada Shinano for playtesting.",
      "JP": "感谢傅屿、朝田詩乃的測試。",
      "CN": "",
      "KR": "傅屿, 朝田诗乃 테스트 감사합니다.",
      "TW": "感謝傅嶼、朝田詩乃協助測試"
    }
  },
  "地图存在隐藏机制请自行探索,地图还有不少bug如有发现请反馈作者，谢谢": {
    "translation": "",
    "MultiLang": {
      "US": "There are hidden mechanics in the map; please explore them yourself. There are also still some bugs, so please report any you find to the author. Thank you.",
      "JP": "地图中存在隐藏机制，请自行探索。地图尚有不少 Bug，如有发现请反馈给作者，谢谢。",
      "CN": "",
      "KR": "지도에는 숨겨진 메커니즘이 있으니 직접 탐험해 주시기 바랍니다. 또한 많은 버그가 있을 수 있으므로 발견 시 저자에게 피드백해 주시면 감사하겠습니다.",
      "TW": "地圖內含隱藏機制，請自行探索。此外地圖尚有部分 Bug，若發現問題請反饋給作者，謝謝。"
    }
  },
  "其余终结者猎手等还未完成,敬请期待": {
    "translation": "",
    "MultiLang": {
      "US": "Other hunters, such as Terminators, are not yet finished. Please stay tuned.",
      "JP": "其余终结者、猎手等内容尚未完成，敬請期待。",
      "CN": "",
      "KR": "기타 터미네이터 헌터 등은 아직 완료되지 않았으며, 기대해 주시기 바랍니다.",
      "TW": "其他終結者、獵手等模式尚未完成，敬請期待。"
    }
  },
