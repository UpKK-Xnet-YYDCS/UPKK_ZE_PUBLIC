  "这扇大门将在15s后开启 ": {
    "translation": "",
    "MultiLang": {
      "US": "This door will open in 15 seconds.",
      "JP": "この扉は15秒後に開きます。",
      "CN": "",
      "KR": "이 문은 15초 후에 열립니다.",
      "TW": "这扇大门将在15秒后开启"
