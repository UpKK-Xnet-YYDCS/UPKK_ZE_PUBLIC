{
  "*** Defend both sides***": {
    "translation": "***防守两侧***",
    "MultiLang": {
      "US": "",
      "JP": "両側を護衛しろ",
      "CN": "*** 同时守卫两侧***",
      "KR": "*** 좌측과 우측 모두 방어하세요 ***",
      "TW": "*** 守衛兩側***"
    }
  },
  "*** GET OFF THE ELEVATOR!!!***": {
    "translation": "***快下电梯！！！***",
    "MultiLang": {
      "US": "",
      "JP": "エレベーターから降りろ！！！！",
      "CN": "*** 立即离开电梯!!!***",
      "KR": "*** 엘리베이터에서 내려요!!!***",
      "TW": "*** 離開電梯！！！***"
    }
  },
  "*** KILL IT BEFORE IT DOES SOMETHING***": {
    "translation": "***在它做出反应之前杀了它***",
    "MultiLang": {
      "US": "",
      "JP": "何かをする前に殺せ",
      "CN": "*** 在它做出任何行动前击杀它***",
      "KR": "*** 뭔가를 하기 전에 죽이세요***",
      "TW": "*** 在它採取行動前消滅它***"
    }
  },
  "*** OH NO! ITS UKA UKA!!!***": {
    "translation": "***哦不！是UKA UKA！！！***",
    "MultiLang": {
      "US": "",
      "JP": "おや！ウカウカだ！！！",
      "CN": "*** 哦不！是乌卡乌卡!!!***",
      "KR": "*** 오_no! 우카 우카예요!!!***",
      "TW": "*** 噢不！是烏卡烏卡！！！***"
    }
  },
  "*** SHOOT THE WALL ***": {
    "translation": "***射击墙壁***",
    "MultiLang": {
      "US": "",
      "JP": "壁を撃て",
      "CN": "*** 射击墙壁 ***",
      "KR": "*** 벽을 쏘세요 ***",
      "TW": "*** 射擊牆壁 ***"
    }
  },
  "*** UKA UKA IS DEFEATED! RUN TO SAFETY!***": {
    "translation": "***UKA UKA被击败了！快跑去安全地方！***",
    "MultiLang": {
      "US": "",
      "JP": "ウカウカは撃破された！安全地帯へ逃げろ！",
      "CN": "*** 乌卡乌卡已被击败！逃向安全地带！***",
      "KR": "*** 우카 우카가 무찌러졌습니다! 안전하게 도주하세요!***",
      "TW": "*** 已擊敗烏卡烏卡！逃離至安全處！***"
    }
  },
  "***--- YOU WILL DIE WHEN BALLOON STARTS MOVING***": {
    "translation": "***---当气球开始移动时你会死***",
    "MultiLang": {
      "US": "",
      "JP": "---バルーンの移動開始時、あなたはお死亡します",
      "CN": "*** 当气球开始移动时，你将会死亡***",
      "KR": "***--- 풍선이 움직이면 죽습니다***",
      "TW": "*** 當氣球開始移動時，你將死亡***"
    }
  },
  "***APPLE-CANNON UNLOCKED FOR NEXT ROUNDS***": {
    "translation": "***苹果大炮在下回合解锁***",
    "MultiLang": {
      "US": "",
      "JP": "次回ラウンドよりアップルカノンが使用可能",
      "CN": "*** 苹果加农炮将在后续轮次解锁***",
      "KR": "*** 다음 라운드부터 애플 캐논 사용 가능***",
      "TW": "*** 下輪次解鎖蘋果大炮 ***"
    }
  },
  "***CORTEX DOESNT TAKE DAMAGE FROM BULLETS***": {
    "translation": "***CORTEX不受子弹伤害***",
