  "***STAY ON GLOWING AREA OR...***": {
    "translation": "***待在发光区域内，否则...***",
    "MultiLang": {
      "US": "",
      "JP": "発光区域内に留まれ、さもないと……",
      "CN": "***停留在发光区域，否则……***",
      "KR": "*** glowing 영역에 남아 있지 않으면...***",
