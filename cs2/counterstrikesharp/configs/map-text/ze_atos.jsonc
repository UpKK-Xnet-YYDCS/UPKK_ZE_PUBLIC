  "▲FIND A PLACE AND PLAY WITH YOUR PARTNER▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲場所を決めてパートナーと遊ぼう▲",
      "CN": "▲找一个地方和你的伙伴一起玩耍▲",
