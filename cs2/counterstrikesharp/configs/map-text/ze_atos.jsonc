  "▲BOMB WILL EXPLODE IN 20 SECONDS▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲20秒後に爆発▲",
      "CN": "▲炸弹将在20秒后爆炸▲",
      "KR": "▲폭발 20초 전▲",
      "TW": "▲炸彈將在 20 秒後引爆▲"
    }
  },
  "▲OMG!WE NEED FIND ANOTHER WAY▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲おや！別のルートを見つけなきゃ！▲",
      "CN": "▲糟糕！我们需要寻找另一条路▲",
      "KR": "▲위험! 다른 길을 찾아야 합니다▲",
      "TW": "▲天哪！我們得找另一條路！▲"
    }
  },
  "▲GREAT!NEW WAY WILL OPEN IN 30S▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲すごい！次のルートは30秒後に開く▲",
      "CN": "▲太棒了！新路线将在30秒后开启▲",
      "KR": "▲대단해! 30초 후 새로운 길이 열린다▲",
      "TW": "▲太棒了！30秒後將開啟新路線▲"
    }
  },
  "▲DAMN!IT'S GOING TO RAIN▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲くそ、雨が降ってきたな▲",
      "CN": "▲该死！要下雨了▲",
      "KR": "▲젠장! 비가 오겠다▲",
      "TW": "▲糟了！快要下雨了▲"
    }
  },
  "▲WE NEED FIND A PLACE FOR SHELTER ON THE SHIP▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲船の中で雨よけの場所を探す必要がある▲",
      "CN": "▲我们需要在船上找个避雨的地方▲",
      "KR": "▲배 위에서 피할 장소를 찾아야 해▲",
      "TW": "▲我們需要在船上找到遮雨的地方▲"
    }
  },
  "▲HOLD FOR 60S UNTIL RAIN STOPS▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲雨が止むまで60秒間耐えろ▲",
      "CN": "▲等待60秒，直到雨停▲",
      "KR": "▲비가 그칠 때까지 60초간 버텨▲",
      "TW": "▲堅持60秒，直到雨停▲"
    }
  },
  "▲HOLD FOR 20 SECONDS▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲20秒間耐えろ▲",
      "CN": "▲按住20秒▲",
      "KR": "▲20초간 버텨▲",
      "TW": "▲堅持20秒▲"
    }
  },
  "▲HOLD FOR 10 SECONDS▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲10秒間耐えろ▲",
      "CN": "▲按住10秒▲",
      "KR": "▲10초간 버텨▲",
      "TW": "▲堅持10秒▲"
    }
  },
  "▲IT'S GETTING DARK▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲暗くなってきたな▲",
      "CN": "▲天色渐暗▲",
      "KR": "▲어둑해지고 있어▲",
      "TW": "▲天色變暗了▲"
    }
  },
  "▲IT SEEMS SOMETHING IS UNDER THE SEA▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲海の底に何かがあるらしい▲",
      "CN": "▲海底似乎有什么东西▲",
      "KR": "▲바다 아래 뭔가 있는 것 같아▲",
      "TW": "▲似乎海底有東西▲"
    }
  },
  "▲SO CLOSE!SO CLOSE▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲あと一歩！あと一歩だ！▲",
      "CN": "▲差一点！就差一点！▲",
      "KR": "▲근접! 근접!▲",
      "TW": "▲好險！好險▲"
    }
  },
  "▲DAMN!IT'S THE SEA WITCH▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲くそっ！シーウィッチャーだ！▲",
      "CN": "▲该死！是海巫！▲",
      "KR": "▲젠장! 바다의 마녀야!▲",
      "TW": "▲糟糕！是海巫婆▲"
    }
  },
  "▲NO WAY BACK FOR US▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲もう後がなくなっとる▼",
      "CN": "▲我们要无路可退了▲",
      "KR": "▲우리는 후퇴할 수가 없어▲",
      "TW": "▲我們回不去了▲"
    }
  },
  "▲WE MUST BEAT THIS BIG GUY▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲このデカいやつをやっつけなアカラン！▲",
      "CN": "▲我们必须打败这个大家伙▲",
      "KR": "▲이 거대 적을 반드시 물리쳐야 해▲",
      "TW": "▲我們必須打敗這個大個頭▲"
    }
  },
  "▲HOLD FOR 40 SECONDS▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲40秒間持ちこたえろ！▲",
      "CN": "▲坚持40秒▲",
      "KR": "▲40초 동안 버티기▲",
      "TW": "▲堅持40秒▲"
    }
  },
  "▲HURRY UP▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲急げ！！▲",
      "CN": "▲快点▲",
      "KR": "▲빨리 다녀!▲",
      "TW": "▲快點▲"
    }
  },
  "▲WE MUST GET ON THE PAPER PLANE▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲紙飛行機に乗らんと！！！▲",
      "CN": "▲我们必须坐上纸飞机▲",
      "KR": "▲종이 비행기 위에 타야 해▲",
      "TW": "▲我們必須上紙飛機▲"
    }
  },
  "▲OH!FISH ATTACKS▲": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲うお！魚が襲ってこよった！！！▲",
      "CN": "▲哦！鱼攻击了▲",
      "KR": "▲어치킨 어공격!▲",
      "TW": "▲注意！魚群攻擊▲"
    }
  },
  "\"▲YOU ARE THE BEST▲\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "▲あなたが最高の存在です▲",
      "CN": "▲你是最棒的▲",
      "KR": "▲당신은 최고야▲",
      "TW": "▲你是最棒的▲"
    }
  },
