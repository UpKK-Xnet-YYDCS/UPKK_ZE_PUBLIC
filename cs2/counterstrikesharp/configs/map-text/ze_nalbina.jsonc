  },
  "** 想到街上吗？ **": {
    "translation": "",
    "MultiLang": {
      "US": "** 想到街上吗？ **",
      "JP": "街に行きたい？",
      "CN": "",
      "KR": "거리로 나가시겠습니까?",
      "TW": "** 想去街上嗎？ **"
    }
  },
  "** 一般民众只能进入城内的部分区域，我来为你开门吧 **": {
    "translation": "",
    "MultiLang": {
      "US": "** 一般民众只能进入城内的部分区域，我来为你开门吧 **",
      "JP": "一般市民は城内の一部地域しか入れない。私が扉を開けてあげよう。",
      "CN": "",
      "KR": "일반 시민은 성내의 일부 구역만 출입할 수 있습니다. 제가 문을 열어드리겠습니다.",
      "TW": "一般民眾只能進入城內的部分區域，我來為你開門吧。"
    }
  },
  "** 你好，是你来接受我的委托吗？**": {
    "translation": "",
    "MultiLang": {
      "US": "** 你好，是你来接受我的委托吗？**",
      "JP": "こんにちは、私が委託を受けた方にきてくれたのですね？",
      "CN": "",
      "KR": "안녕하세요, 제 의뢰를 받으러 오신 분이세요?",
      "TW": "你好，是你來接受我的委託嗎？"
    }
  },
  "** 我的仙人掌花在上次旅游的途中丢失了。**": {
    "translation": "",
    "MultiLang": {
      "US": "** 我的仙人掌花在上次旅游的途中丢失了。**",
      "JP": "私のサボテンの花が、前の旅行の帰りに紛失してしまいました。",
      "CN": "",
      "KR": "제 선인장 꽃이 지난 여행 중에 분실되었습니다.",
      "TW": "我的仙人掌花在上次旅遊的途中丟失了。"
    }
  },
  "** 可以麻烦你帮我找到它吗？**": {
    "translation": "",
    "MultiLang": {
      "US": "** 可以麻烦你帮我找到它吗？**",
      "JP": "それを見つけてもらえませんか？",
      "CN": "",
      "KR": "찾아주실 수 있나요?",
      "TW": "可以麻煩你幫我找到它嗎？"
    }
  },
  "** 城塞大门需要30秒才能开启 **": {
    "translation": "",
    "MultiLang": {
      "US": "** 城塞大门需要30秒才能开启 **",
      "JP": "城門を開閉するには30秒かかります。",
      "CN": "",
      "KR": "성문 개방까지 30초가 소요됩니다.",
      "TW": "城塞大門需要30秒才能開啟。"
    }
  },
  "** 找到仙人掌的1/6": {
    "translation": "",
    "MultiLang": {
      "US": "** 找到仙人掌的1/6",
      "JP": "サボテンの花を1/6見つけました。",
      "CN": "",
      "KR": "선인장 관련 아이템 1/6 수집",
      "TW": "找到仙人掌的 1/6"
    }
  },
  "** 道路将在45秒后开放 **": {
    "translation": "",
    "MultiLang": {
      "US": "** 道路将在45秒后开放 **",
      "JP": "道路は45秒後に開放されます。",
      "CN": "",
      "KR": "도로가 45초 후에 개방됩니다.",
      "TW": "道路將在45秒後開放。"
    }
  },
  "**等待贴门打开**": {
    "translation": "",
    "MultiLang": {
      "US": "**Waiting for the door to open**",
      "JP": "ドアが開くのを待機",
      "CN": "",
      "KR": "문이 열릴 때까지 대기 중",
      "TW": "**等待貼門打開**"
    }
  },
  "**还剩下35秒**": {
    "translation": "",
    "MultiLang": {
      "US": "**35 seconds remaining**",
      "JP": "残り35秒",
      "CN": "",
      "KR": "35초 남음",
      "TW": "**還剩下35秒**"
    }
  },
  "**道路即将开放**": {
    "translation": "",
    "MultiLang": {
      "US": "**Road will open shortly**",
      "JP": "道路がまもなく開放されます",
      "CN": "",
      "KR": "도로가 곧 개방됩니다",
      "TW": "**道路即將開放**"
    }
  },
  "**easy模式已破，过关的人类获得100分**": {
    "translation": "",
    "MultiLang": {
      "US": "**Easy mode cleared. Human player earns 100 points.**",
      "JP": "イージーモードクリア。通過したプレイヤーに100ポイント付与",
      "CN": "",
      "KR": "아쉬즈 모드 클리어, 성공한 인류에게 100점 부여",
      "TW": "**easy模式已破，過關的人類獲得100分**"
    }
  },
