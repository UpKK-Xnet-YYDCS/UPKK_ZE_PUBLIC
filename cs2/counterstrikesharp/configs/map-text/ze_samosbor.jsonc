  ">> Elevator's doors are closing in 10 seconds <<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">> エレベーターのドアが10秒後に閉まります <<",
      "CN": ">> 电梯门将在10秒后关闭 <<",
      "KR": ">> 엘리베이터 문이 10초 후에 닫힙니다 <<",
      "TW": ">> 電梯門即將關閉，倒數10秒 <<"
    }
  },
