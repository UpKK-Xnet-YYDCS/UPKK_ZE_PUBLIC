      "JP": "25秒後にメインドアが開く",
      "CN": "大门将在25秒后打开",
      "KR": "주출입문이 25초 후 열림",
      "TW": "大門將在 25 秒後開啟"
    }
  },
  "The path seems to be...separate?": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "道は…分かれているようだ？",
      "CN": "这条路似乎是……分开的？",
      "KR": "길이... 떨어져 보이는가?",
      "TW": "這條路似乎……是分開的？"
    }
  },
  "a random door will open in 5s": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "5秒後にランダムなドアが開く",
      "CN": "一扇随机门将在5秒后打开",
      "KR": "무작위 문이 5초 후 열림",
