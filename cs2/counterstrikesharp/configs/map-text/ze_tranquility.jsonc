    }
  },
  "One": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "一",
      "CN": "一",
      "KR": "일",
      "TW": "一"
    }
  },
  "DU CULPUS ENGRATIOD.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "DU CULPUS ENGRATIOD.",
      "CN": "此行为令人作呕，感谢关注。",
      "KR": "DU CULPUS ENGRATIOD.",
      "TW": "DU CULPUS ENGRATIOD。"
    }
  },
  "The new world is complete.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "新世界は完成した。",
      "CN": "新世界已准备就绪。",
      "KR": "새로운 세상이 완성되었습니다.",
      "TW": "新世界已經完成。"
    }
  },
  "Per the lascivious demented there are, I showing risque.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "淫らで狂気の彼らに捧ぐ、私は risqué を披露する。",
      "CN": "为了满足那些病态的贪婪之心，我将展示禁忌的画面。",
      "KR": "도덕적이지 못한 미치광이들을 위해 선정적인 모습을 보여줍니다.",
      "TW": "正如那些淫亂而瘋狂的人所示，我展現挑逗風情。"
    }
  },
  "You will be nothing if you really wanna.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "本当に望むなら、あなたは無となるだろう。",
      "CN": "若你执意如此，你将一无所有。",
      "KR": "진정으로 원한다면 아무것도 될 수 없습니다.",
      "TW": "若你真的想成為虛無，你便將一無所有。"
    }
  },
  "For the world, you are about to enter...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あなたは入りようとしている世界のために...",
      "CN": "为了这个世界，你即将踏入……",
      "KR": "당신이 진입하려 하는 세계를 위해...",
      "TW": "對於這個即將進入的世界……"
    }
  },
  "And unlock the future.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "未来を解き放て。",
      "CN": "并开启未来。",
      "KR": "그리고 미래를 풀어놓으세요.",
      "TW": "並解鎖未來。"
    }
  },
  "ARE YOU READY?": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "準備はいいか？",
      "CN": "你准备好了吗？",
      "KR": "준비되셨나요?",
      "TW": "你準備好了嗎？"
    }
  },
  "DONT BE AFRAID.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "恐れるな。",
      "CN": "不要害怕。",
      "KR": "무서워하지 마세요.",
      "TW": "別怕。"
    }
  },
  "DANGER IS IMMINENT.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "危険が目前に迫っている。",
      "CN": "危险迫在眉睫。",
      "KR": "위험이 임박했습니다.",
      "TW": "危險迫在眉睫。"
    }
  }
}
