  ">>>>> GREEN ELEVATOR: FOR HUMANS": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>>> 緑のエレベーター：人間専用",
      "CN": ">>>> 绿色电梯：供人类使用",
