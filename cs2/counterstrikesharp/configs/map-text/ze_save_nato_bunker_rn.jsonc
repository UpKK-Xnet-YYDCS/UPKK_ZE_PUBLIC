{
  ">>>>> MAP MADE BY S7": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>>> S7 が作成したマップ",
      "CN": ">>>> 由 S7 制作",
      "KR": ">>> S7 제작",
      "TW": ">>> 由 S7 製作的地圖"
    }
  },
  ">>>>> GO! GO! GO!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>>> よー！レッツゴー！",
      "CN": ">>>> GO! GO! GO!",
      "KR": ">>> 가자! 가자! 가자!",
      "TW": ">>> 前進！前進！前進！"
    }
  },
  ">>>>> STAY MIDDLE IN NATO SYMBOL!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>>> NATOシンボルの中央に留まる！",
      "CN": ">>>> 在北约符号区域保持在中部！",
      "KR": ">>> NATO 기호에 맞춰 중앙을 유지하세요!",
      "TW": ">>> 請在 NATO 符號區域保持在中央！"
    }
  },
