  "\"< 60 >\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "\">>>我正在想办法关闭这个破门<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": "<<<I'm working on a way to close this breach<<<",
      "JP": ">>>このドアを閉じる方法を考え中だ<<<",
      "CN": "",
      "KR": ">>>이 문을 닫는 방법을 찾고 있어<<<",
      "TW": ">>>我正在想辦法關閉這扇門<<<"
    }
  },
  "\">>>这个门看样子支撑不了多久<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": "<<<This door won't hold much longer<<<",
      "JP": ">>>このドアは長持ちしなさそうだ<<<",
      "CN": ">>>这个门看起来撑不了多久<<<",
      "KR": ">>>이 문은 오래 버티지 못할 것 같아<<<",
      "TW": ">>>這扇門看起來撐不了多久了<<<"
    }
  },
  "\">>>不管了，我们先撤<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": "<<<Forget it, let's fall back for now<<<",
      "JP": ">>>もうどうだっていい、先に戻る <<<",
      "CN": "",
      "KR": ">>>어찌됐든, 우리는 후퇴해<<<",
      "TW": ">>>算了，我們先撤退<<<"
    }
  },
  "\">>>我们的权限不够打开这扇门<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": "<<<We don't have the clearance to open this door<<<",
      "JP": ">>>このドアを開ける権限が足りない<<<",
      "CN": ">>我们权限不足，无法开启此门<<",
      "KR": ">>>우리는 이 문을 열 권한이 부족해<<<",
      "TW": ">>>我們的權限不足以打開這扇門<<<"
    }
  },
  "\">>>看我大力出奇迹<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": "<<<Watch me pull off a miracle with sheer strength<<<",
      "JP": "<<<見よ、私の大技で奇跡を起こさん<<<",
      "CN": "",
      "KR": ">>> 강력한 힘으로 기적을 보여줘 <<<",
      "TW": ">>>看我大力出奇蹟<<<"
    }
  },
  "\">>>快去控制室启动开关<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>> Go quickly to the control room and activate the switch <<<",
      "JP": ">>>すみやかに管制室へ行き、スイッチを起動せよ<<<",
      "CN": "",
      "KR": ">>> 신속하게 관제실로 가서 스위치를 켜<<<",
      "TW": ">>>快去控制室啟動開關<<<"
    }
  },
  "\">>>备用供电系统正在开启<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>> Backup power system is activating <<<",
      "JP": ">>>予備電力システムが稼働開始中<<<",
      "CN": "",
      "KR": ">>> 비상 전원 시스템 가동 중 <<<",
      "TW": ">>>備用供電系統正在開啟<<<"
    }
  },
