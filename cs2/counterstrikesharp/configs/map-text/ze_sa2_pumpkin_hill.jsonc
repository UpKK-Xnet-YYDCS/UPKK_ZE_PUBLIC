{
  "Knuckles: Knife Fight!!!": {
    "translation": "纳克鲁斯：刀战！！！",
    "MultiLang": {
      "US": "",
      "JP": "ナックルズ：ナイフ・ファイト!!!",
      "CN": "纳克鲁斯：刀具乱斗！！！",
      "KR": "나글스: 칼싸움!!!",
      "TW": "音克：刀戰！！！"
    }
  },
  "Knuckles: Okay, nice work! We have to kill the rest of Eggman's zombies before their internal nuke blows!": {
    "translation": "纳克鲁斯：好的，干得不错！我们得在蛋头博士僵尸内部核弹爆炸之前杀死剩下的僵尸！",
    "MultiLang": {
      "US": "Knuckles: Alright, good job! We have to kill the rest of Eggman's zombies before their internal nuke blows!",
      "JP": "ナックルズ：よし、よくやったぞ！エッグマンのゾンビたちは体内の核爆発を起こす前に片付けなきゃ！",
      "CN": "纳克鲁斯：好极了！在蛋头博士的僵尸自爆之前，我们必须干掉剩下的僵尸！",
      "KR": "나글스: 좋아, 훌륭해! 에그맨의 좀비들을 없애기 전까지 그들의 내부 핵폭발이 일어나지 않게 해야 해!",
      "TW": "音克：好，幹得漂亮！我們必須在蛋頭博士的殭屍內核爆炸前消滅所有的殭屍！"
    }
  },
  "Knuckles: We gotta find the chaos emerald shards!": {
    "translation": "纳克鲁斯：我们得找到混沌翡翠碎片！",
    "MultiLang": {
      "US": "",
      "JP": "ナックルズ：チャオスエメラルドの欠片を見つけなきゃ！",
      "CN": "纳克鲁斯：我们得找到混沌翡翠碎片！",
      "KR": "나글스: 차오스 에메랄드 조각들을 찾아야 해!",
      "TW": "音克：我們必須找到混沌翡翠碎片！"
    }
  },
  "Knuckles: We have to survive for 3 minutes until Sonic gets here!": {
    "translation": "纳克鲁斯：我们必须坚持180秒，直到索尼克到达！",
    "MultiLang": {
      "US": "",
      "JP": "ナックルズ：ソニックが着くまで3分間は生き延びなきゃ！",
      "CN": "纳克鲁斯：我们要撑过3分钟，直到索尼克赶到！",
      "KR": "나글스: 소닉이 도착할 때까지 3분간 버텨야 해!",
      "TW": "音克：我們必須撐過3分鐘，直到索尼克到達！"
    }
  },
  "Knuckles: We only have 30 seconds until the zombie's nukes blow, hurry!": {
    "translation": "纳克鲁斯：我们只有30秒的时间，赶快！僵尸核弹就要爆炸了！",
    "MultiLang": {
      "US": "",
      "JP": "ナックルズ：ゾンビの核爆発まであと30秒しかない、急いで！",
      "CN": "纳克鲁斯：僵尸的核弹30秒后就会引爆，快！",
      "KR": "나글스: 좀비들의 핵폭발까지 30초밖에 남지 않았어, 빨리!",
      "TW": "音克：我們只有30秒的時間，殭屍的內核即將爆炸，快點！"
    }
  }
}
