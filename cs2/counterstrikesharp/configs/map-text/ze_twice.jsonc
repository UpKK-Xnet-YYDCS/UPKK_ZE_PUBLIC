{
  "**Hold on for 20 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "20秒間維持してください",
      "CN": "**保持20秒**",
      "KR": "20초 동안 유지하세요",
      "TW": "堅持 20 秒"
    }
  },
  "**Don't touch the same light twice consecutively**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "同じ光を連続で2回触れないでください",
      "CN": "**不要连续触碰两次相同的光源**",
      "KR": "같은 등에 연속으로 두 번 타지 마세요",
      "TW": "不要連續觸碰同一盞燈光"
    }
  },
  "**French zombie TP in 10 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "フランス人ゾンビが10秒後にテレポートします",
      "CN": "**法国僵尸传送在10秒内**",
      "KR": "프렌치 좀비 TP, 10초 후",
      "TW": "法國殭屍 10 秒後進行 TP"
    }
  },
  "**Don't jump twice on the same fruit consecutively**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "同じ果物を連続で2回ジャンプしないようにしてください",
      "CN": "**不要连续两次在同一果实上跳跃**",
      "KR": "같은 묘목에 연속으로 두 번 뛰어오르지 마세요",
      "TW": "不要連續在同一個果實上跳兩次"
    }
  },
  "**Zombie TP in 10 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビが10秒後にテレポートします",
      "CN": "**僵尸传送在10秒内**",
      "KR": "좀비 TP, 10초 후",
      "TW": "殭屍 10 秒後進行 TP"
    }
  },
  "**Hold on for 25 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "25秒間維持してください",
      "CN": "**保持25秒**",
      "KR": "25초 동안 유지하세요",
      "TW": "堅持 25 秒"
    }
  },
  "**French zombie TP in 10 seconds !**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "フランス人ゾンビが10秒後にテレポートします！",
      "CN": "**法国僵尸传送在10秒内！**",
      "KR": "프렌치 좀비 TP, 10초 후!",
      "TW": "法國殭屍 10 秒後進行 TP！"
    }
  },
  "**Wall breaks in 15 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "壁が15秒後に崩壊します",
      "CN": "**墙壁在15秒后破裂**",
      "KR": "벽 파괴, 15초 후",
      "TW": "牆壁 15 秒後崩塌"
    }
  },
  "**Destroy all crystals but don't shoot the same twice in a row !**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "クリスタルをすべて破壊するが、連続して同じものを撃ってはいけない！",
      "CN": "**摧毁所有水晶，但不能连续射击同一个两次！**",
      "KR": "결정을 모두 부수되, 같은 것을 연속으로 두 번 타격하지 마십시오!",
      "TW": "摧毀所有水晶，但連續射擊同一個兩次以上無效！"
    }
  },
  "**ALL crystals are destroyed !**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "すべてのクリスタルが破壊された！",
      "CN": "**所有水晶均已被摧毁！**",
      "KR": "모든 결정이 파괴되었습니다!",
      "TW": "所有水晶皆已摧毀！"
    }
  },
  "**You passed by the \"doorhug\" word. Don't touch it again before you touch anything else !**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あなたは「Doorhug」という言葉を通り過ぎました。他のものに触れるまで、これ以上それには触れないでください！",
      "CN": "**你经过了“门框”字样。在触碰任何其他东西之前，不要再碰它！**",
      "KR": "\"doorhug\" 단어를 경유했습니다. 다른 것에 접촉할 때까지 이 단어는 만지지 마십시오!",
      "TW": "您掠過「門環」單詞。請先觸碰其他事物，不要再碰觸它！"
    }
  },
  "**The shortcut will be open in 10 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ショートカットは10秒後に開放されます",
      "CN": "**捷径将在10秒后开启**",
      "KR": "지름길이 10초 후에 개방됩니다.",
      "TW": "捷徑將在 10 秒後開啟"
    }
  },
  "**The wall will break in 35 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "壁は35秒後に壊れます",
      "CN": "**墙壁将在35秒后崩塌**",
      "KR": "벽이 35초 후에 파괴됩니다.",
      "TW": "牆壁將在 35 秒後破裂"
    }
  },
  "**Keep zombies away from the boss room 20 seconds !**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ボス部屋にゾンジが20秒以上近づかないようにしてください！",
      "CN": "**在20秒内将僵尸阻挡在大Boss房间之外！**",
      "KR": "보스 방에서 20초간 좀비에게 접근하지 못하게 하십시오!",
      "TW": "在 20 秒內將殭屍阻擋於 Boss 房間外！"
    }
  },
  "**Shoot the boss !**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ボスを撃つ！",
      "CN": "**射击大Boss！**",
      "KR": "보스를 쏘세요!",
      "TW": "射擊 Boss！"
    }
  },
  "**Pull Attack !**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "引き寄せ攻撃！",
      "CN": "**拉动攻击！**",
      "KR": "당기기 공격!",
      "TW": "拉動攻擊！"
    }
  }
}
