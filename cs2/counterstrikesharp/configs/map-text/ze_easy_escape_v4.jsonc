  "** BHOP/KZ PLAYERS YOU FAIL ME **": {
    "translation": "** BHOP/KZ玩家们，你们让我失望了 **",
    "MultiLang": {
      "US": "",
      "JP": "** BHOP/KZのプレイヤー達、お前らには失望した **",
      "CN": "** BHOP/KZ玩家，你让我失望 **",
      "KR": "** BHOP/KZ 플레이어들, 너희는 나를 실망시켰다 **",
      "TW": "** BHOP/KZ 玩家你讓我失望 **"
    }
  },
  "** Defend for 30 second **": {
    "translation": "** 防守30秒 **",
    "MultiLang": {
      "US": "",
      "JP": "30秒間防衛せよ",
      "CN": "** 坚守30秒 **",
      "KR": "** 30초 동안 방어하라 **",
      "TW": "防守 30 秒"
    }
  },
  "** FALL BACK **": {
    "translation": "** 撤退 **",
    "MultiLang": {
      "US": "",
      "JP": "** 後退 **",
      "CN": "** 撤退 **",
      "KR": "** 후퇴하라 **",
      "TW": "** 後退 **"
    }
  },
  "** Get in side the second room **": {
    "translation": "** 进入第二个房间 **",
    "MultiLang": {
      "US": "",
      "JP": "2番目のルームの中に入れ",
      "CN": "** 进入第二个房间内部 **",
      "KR": "** 두 번째 방 안에 들어가라 **",
      "TW": "進入第二個房間"
    }
  },
  "** If surf is not completed in 60 sec the zombies will be released **": {
    "translation": "** 如果滑翔在60秒内未完成，僵尸将被释放 **",
    "MultiLang": {
      "US": "",
      "JP": "もし60秒以内にサーフが完了しない場合、ゾンビが解放される",
      "CN": "** 若60秒内未完成冲浪，僵尸将被释放 **",
      "KR": "** 60초 안에 서핑이 완료되지 않으면 좀비들이 해제된다 **",
      "TW": "若 60 秒內未完成衝浪關卡，殭屍將被釋放"
    }
  },
  "** Make sure that you're on the block **": {
    "translation": "** 确保你站在平台上 **",
    "MultiLang": {
      "US": "",
      "JP": "ブロックの上にいることを確認しろ",
      "CN": "** 确保你站在方块上 **",
      "KR": "** 반드시 블록 위에 서있음을 확인하라 **",
      "TW": "確認你處於掩體後"
    }
  },
  "** Map made by li-ion **": {
    "translation": "** 地图作者：li-ion 翻译：Asteri3m**",
    "MultiLang": {
      "US": "",
      "JP": "マップ製作者：li-ion",
      "CN": "** 地图由 li-ion 制作 **",
      "KR": "** 맵 제작자: li-ion **",
      "TW": "地圖由 li-ion 製作"
    }
  },
  "** My first map hope you like it, enjoy **": {
    "translation": "** 这是我的第一张地图，希望你喜欢，尽情享受吧 **",
    "MultiLang": {
      "US": "",
      "JP": "私の最初のマップです。気に入ってください、楽しんでください",
      "CN": "** 我的第一张地图，希望你喜欢，玩得开心 **",
      "KR": "** 내 첫 번째 맵입니다. 즐기시길 바랍니다. **",
      "TW": "我的第一張地圖，希望你們喜歡"
    }
  },
  "** NUKE IN 5 **": {
    "translation": "** 核弹在5秒后爆炸 **",
    "MultiLang": {
      "US": "",
      "JP": "** 爆発まであと5秒 **",
      "CN": "** 核弹将在5秒后发射 **",
      "KR": "** 핵폭발 5초 후 **",
      "TW": "** 核彈五秒後發射 **"
