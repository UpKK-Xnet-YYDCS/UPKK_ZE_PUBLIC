  },
  "***QUICK, CLIMB THE LADDER!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***急げ！梯子を登れ！***",
      "CN": "***快，爬上梯子！***",
      "KR": "***어서, 사다리를 올라타세요!***",
