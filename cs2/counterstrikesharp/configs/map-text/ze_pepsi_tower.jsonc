  "\u000fMEDJED: SAY WALLAHI": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "\u000fMEDJED: ワラヒと言ってみろ",
      "CN": "\u000f梅杰德：说阿拉作证",
      "KR": "\u000f메제드: 왈라히라고 말해",
