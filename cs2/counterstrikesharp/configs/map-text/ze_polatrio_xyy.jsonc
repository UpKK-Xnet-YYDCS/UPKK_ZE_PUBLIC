  },
  "*** ......Ah... ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ……ああっ…… ***",
      "CN": "*** ……啊…… ***",
      "KR": "*** ......아... ***",
      "TW": "*** ……啊…… ***"
    }
  },
  "*** Where are we...? ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ここはどこだ……？ ***",
      "CN": "*** 我们在哪里……? ***",
      "KR": "*** 여긴 어디지...? ***",
      "TW": "*** 我們在哪裡……？ ***"
    }
  },
  "*** We just killed by zombies... ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 俺たちはゾンビに殺されたはずだ…… ***",
      "CN": "*** 我们刚被僵尸杀了…… ***",
      "KR": "*** 우린 좀비에게 죽었는데... ***",
      "TW": "*** 我們剛被殭屍殺了…… ***"
    }
  },
  "*** Why are we still alive...? ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** なぜ俺たちはまだ生きている……？ ***",
      "CN": "*** 我们为什么还活着……? ***",
      "KR": "*** 왜 우린 아직 살아있는 거지...? ***",
      "TW": "*** 為什麼我們還活著……？ ***"
    }
  },
  "*** We must reserch this place. ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** この場所を調査しなければならない。 ***",
      "CN": "*** 我们必须调查这个地方。 ***",
      "KR": "*** 이곳을 조사해야 해. ***",
      "TW": "*** 我們必須調查這個地方。 ***"
    }
  },
  "*** Gear up. We are on the move.  ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 装備を整えろ。移動するぞ。  ***",
      "CN": "*** 全副武装。我们要出发了。 ***",
      "KR": "*** 장비 챙겨. 이동한다. ***",
      "TW": "*** 全副武裝。我們要出發了。 ***"
    }
  },
  "MESSAGE : HOLD 15 SECONDS": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "メッセージ：15秒間持ちこたえろ",
      "CN": "消息：坚持15秒",
      "KR": "MESSAGE : 15초간 버티세요",
      "TW": "訊息：堅守 15 秒"
    }
  },
  "MESSAGE : HOLD 20 SECONDS": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "メッセージ：20秒間持ちこたえろ",
      "CN": "消息：坚持20秒",
      "KR": "MESSAGE : 20초간 버티세요",
      "TW": "訊息：堅守 20 秒"
    }
  },
  "MESSAGE : HOLD 30 SECONDS": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "メッセージ：30秒間待機",
      "CN": "消息 : 坚守 30 秒",
      "KR": "메시지 : 30초간 버티시오",
      "TW": "訊息 : 堅守 30 秒"
    }
  },
  "*** It seems like... ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** どうやら…… ***",
      "CN": "*** 看来…… ***",
      "KR": "*** 그런 것 같군... ***",
      "TW": "*** 看起來像是... ***"
    }
  },
  "*** We have reached dead end. ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 行き止まりだ。 ***",
      "CN": "*** 我们走到了死路。 ***",
      "KR": "*** 막다른 길이다. ***",
      "TW": "*** 我們走到死路了。 ***"
    }
  },
  "*** Hold on, AST radar detects huge hallway below us. ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 待て、ASTレーダーが真下に巨大な通路を検知した。 ***",
      "CN": "*** 稍等，AST 雷达检测到我们脚下有巨大的走廊。 ***",
      "KR": "*** 잠깐, AST 레이더가 우리 아래 거대한 복도를 감지했다. ***",
      "TW": "*** 等一下，AST雷達偵測到我們下方有巨大走廊。 ***"
    }
  },
  "*** Breach this floor, and make our way. ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** この床を突破して、道を切り開け。 ***",
      "CN": "*** 突破这层楼板，继续前进。 ***",
      "KR": "*** 이 바닥을 폭파하고 나아간다. ***",
      "TW": "*** 突破這層地板，繼續前進。 ***"
    }
  },
  "*** Explosive planted. ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 爆薬設置完了。 ***",
      "CN": "*** 炸药已安放。 ***",
      "KR": "*** 폭약 설치 완료. ***",
      "TW": "*** 炸藥已設置。 ***"
    }
  },
  "*** Breaching in 20 seconds. ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 20秒後に突破。 ***",
      "CN": "*** 20 秒后突破。 ***",
      "KR": "*** 20초 후 돌입. ***",
      "TW": "*** 20秒後突破。 ***"
    }
  },
  "MESSAGE : ALL LIVING KINDS WILL PUNISHED IN 50 SECONDS": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "メッセージ：すべての生物は50秒後に処刑される",
      "CN": "消息 : 所有生物将在 50 秒后受到惩罚",
      "KR": "메시지 : 50초 후 모든 생물종이 처단된다",
      "TW": "訊息 : 所有生物將在 50 秒後受到懲罰。"
    }
  },
  "MESSAGE : ONLY THE DEAD WILL ALIVE": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "メッセージ : 死者のみが生き残る",
      "CN": "MESSAGE : 唯有死者方能存活",
      "KR": "메시지 : 오직 죽은 자만이 살아날 것이다",
      "TW": "訊息：唯有死者將生存"
    }
  },
  "MESSAGE : MAP MADE BY SATOKA": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "メッセージ : マップ制作：サトカ",
      "CN": "MESSAGE : 地图由 SATOKA 制作",
      "KR": "메시지 : 맵 제작자 사토카",
      "TW": "訊息：地圖由 SATOKA 製作"
