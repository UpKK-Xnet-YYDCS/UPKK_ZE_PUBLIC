  "< Objective : Light up the First Temple >": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "< 目的：最初の神殿を点灯させる >",
      "CN": "< 目标：点亮第一神殿 >",
      "KR": "< 목표: 첫 번째 사원 밝히기 >",
      "TW": "< 任務目標：點亮第一寺 >"
    }
  },
  "> Barrier shatter in 20 sec. <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> 20秒以内にバリア破壊 <",
      "CN": "> 结界将于 20 秒后碎裂 <",
      "KR": "방패 20초 후 깨짐",
      "TW": "> 護盾將在20秒後破碎。<"
    }
  },
  "有冒险者找到了治疗术.": {
    "translation": "",
    "MultiLang": {
      "US": "An adventurer discovered Heal.",
      "JP": "冒険者が治癒魔法を発見しました。",
      "CN": "",
      "KR": "모험가가 치료술을 찾아냈다.",
      "TW": "有冒險者尋獲了治療術。"
    }
  },
  "A player has pickup Heal.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが治愈アイテムを入手しました。",
      "CN": "玩家已拾取治疗道具。",
      "KR": "플레이어가 힐을 획득했습니다.",
      "TW": "一名玩家拾取了治療術。"
    }
  },
  "[治疗术] 放置治疗区域7秒,恢复225血量,50秒冷却.": {
    "translation": "",
    "MultiLang": {
      "US": "[Heal] Places a healing area for 7 seconds, restoring 225 HP. 50-second cooldown.",
      "JP": "[治癒魔法] 治療区域を7秒間設置、225のHPを回復、クールダウン50秒。",
      "CN": "",
      "KR": "[치료 스킬] 치료 지역을 7초 동안 배치하면 체력을 225 회복하고, 재사용 대기시간은 50초입니다.",
      "TW": "[治療術] 放置治療區域7秒，恢復225血量，冷卻時間50秒。"
    }
  },
  "[Heal] Crate a heal area for 7 sec,255 max health,50 cd.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[回復]7秒間最大HP255の回復エリアを作成、クールタイム50秒。",
      "CN": "[治疗药水] 创建一个持续7秒的治疗区域，最大生命值255，冷却时间50。",
      "KR": "[치유] 7초 동안 치유 구역을 생성하며, 최대 체력 255, 재사용 대기 시간 50초.",
      "TW": "[治癒] 建立持續 7 秒、最大生命值 255 的治癒區域，冷卻時間 50 秒。"
    }
  },
  "> Barrier shatter in 25 sec. <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> バリアーが25秒後に破壊されます。 <",
      "CN": ">护盾将在25秒后破碎。<",
      "KR": "> 방패가 25초 후에 파괴됩니다. <",
      "TW": "> 屏障將在 25 秒後碎裂。<"
    }
  },
  "有冒险者找到了飓风.": {
    "translation": "",
    "MultiLang": {
      "US": "An adventurer discovered Hurricane.",
      "JP": "ある冒険者が突風を発見しました。",
      "CN": "",
      "KR": "모험가들이 태풍을 발견했습니다.",
      "TW": "有冒險者找到了颶風。"
    }
  },
  "A player has pickup Wind.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが突風を拾いました。",
      "CN": "一名玩家已拾取旋风药水。",
      "KR": "플레이어가 바람 아이템을 수집했습니다.",
      "TW": "一名玩家撿取了風。"
    }
  },
  "[飓风] 释放跟随飓风推开僵尸5秒,50秒冷却.": {
    "translation": "",
    "MultiLang": {
      "US": "[Hurricane] Releases a following hurricane that pushes back zombies for 5 seconds. 50-second cooldown.",
      "JP": "[突風]ゾンビを吹き飛ばす暴風を発生させ、5秒間効果が続く。クールタイム50秒。",
      "CN": "",
      "KR": "[태풍] 5초 동안 태풍을 발사하여 좀비를 밀어내고, 재사용 대기 시간 50초.",
      "TW": "[颶風] 召喚隨行的颶風將僵尸推開 5 秒，冷卻時間 50 秒。"
    }
  },
  "[Wind] Crate storm to push zombie away for 5 sec,50 cd.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[Wind]ゾンビを吹き飛ばす暴風を発生させ、5秒間効果が続く。クールタイム50秒。",
      "CN": "[旋风药水] 召唤风暴将僵尸推开，持续5秒，冷却时间50。",
      "KR": "[Wind] 좀비를 5초간 밀어내는 폭풍을 생성하며, 재사용 대기 시간 50초.",
      "TW": "[Wind] 召�風暴將僵尸推開 5 秒，冷卻時間 50 秒。"
    }
  },
  "有冒险者找到了冥水.": {
    "translation": "",
    "MultiLang": {
      "US": "An adventurer discovered Netherwater.",
      "JP": "ある冒険者が冥水を発見しました。",
      "CN": "",
      "KR": "모험가들이 명수 아이템을 발견했습니다.",
      "TW": "有冒險者找到了冥水。"
    }
  },
  "A player has pickup Water.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが冥水を拾いました。",
      "CN": "一名玩家拾取了水。",
      "KR": "플레이어가 물 아이템을 수집했습니다.",
      "TW": "一名玩家撿取了水。"
    }
  },
  "[冥水] 放置旋涡区域强减速僵尸7秒,50秒冷却.": {
    "translation": "",
    "MultiLang": {
      "US": "[Netherwater] Places a vortex area that strongly slows zombies for 7 seconds. 50-second cooldown.",
      "JP": "[冥水]旋渦エリアに設置し、7秒間強力なスロー効果でゾンビを遅らせる。50秒のクールダウン。",
      "CN": "",
      "KR": "[명수] 소용돌이 구역을 강하게 7초 동안 감속, 쿨타임 50초.",
      "TW": "[冥水] 放置旋渦區域，使僵尸強减速7秒，冷卻時間50秒。"
    }
  },
  "[Water] Crate water area,strong slow zombie for 7 sec,50 cd.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[Water] Water Crateを設置し、7秒間強力なスロー効果でゾンビを遅らせる。50秒のクールダウン。",
      "CN": "[水] 水桶区域：强力减缓僵尸7秒，冷却时间50。",
      "KR": "[Water] Crate water area,strong slow zombie for 7 sec,50 cd.",
      "TW": "[冥水] 放置旋渦區域，使僵尸強减速7秒，冷卻時間50秒。"
    }
  },
  "[冥水] 能对Boss造成伤害.": {
    "translation": "",
    "MultiLang": {
      "US": "[Abyss Water] Can deal damage to the Boss.",
      "JP": "[冥水]ボスにダメージを与えられる。",
      "CN": "",
      "KR": "[명수] 보스에게 피해를 입힐 수 있습니다.",
      "TW": "[冥水] 能對Boss造成傷害。"
    }
  },
  "[Water] It will deal damage to Bosses.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[Water] ボスにダメージを与えることができる。",
      "CN": "[水] 它会对Boss造成伤害。",
      "KR": "[Water] It will deal damage to Bosses.",
      "TW": "[冥水] 能對Boss造成傷害。"
    }
  },
  "> Shrine platform will seal off in 20 sec. <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> シゃくりい平台将在20秒后关闭。<",
      "CN": ">祭坛平台将在20秒后封闭。<",
      "KR": "> 성전 플랫폼이 20초 후 봉쇄됩니다. <",
      "TW": "神廟平台將在20秒後關閉。"
    }
  },
  "有僵尸习得了庇护.": {
    "translation": "",
    "MultiLang": {
      "US": "A zombie has learned Sanctuary.",
      "JP": "あるゾンビがシールドを習得した。",
      "CN": "",
      "KR": "갑옷을 습득한 좀비가 있습니다.",
      "TW": "有僵尸習得了庇護能力。"
    }
  },
  "A zombie has learn Shield.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "A zombie has learn Shield.",
      "CN": "一只僵尸学会了护盾。",
      "KR": "A zombie has learn Shield.",
      "TW": "有僵尸習得了庇護能力。"
    }
  },
  "<Byakko>: Outsider,You should not step inside this temple.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<白虎>: よそ者、この神殿に入るべきではない。",
      "CN": "<白虎>：外来者，你不该踏入这座神庙。",
      "KR": "<백호>: 외부인, 이 사원에 들어서는 안 됩니다.",
      "TW": "<白虎>：外來者，你不應踏入這座神廟。"
    }
  },
  "[庇护] 生成跟随护盾使周围僵尸免疫子弹5秒,50秒冷却.": {
    "translation": "",
    "MultiLang": {
      "US": "[Sanctuary] Summons a shield-bearer minion that makes nearby zombies immune to bullets for 5 seconds. 50s cooldown.",
      "JP": "[シールド] シールドを生成し、周囲のゾンビを5秒間弾から免疫化。クールタイム50秒。",
      "CN": "",
      "KR": "[비호] 생성된 스킬이 주위 좀비를 5초간 총알 무적 상태로 만듦. 재사용 대기시간 50초.",
      "TW": "[庇護] 召喚跟隨護盾，使附近殭屍免疫子彈5秒，冷卻時間50秒。"
    }
  },
  "[Shield] Use shield block bullet for 5 sec,50 cd.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[シールド] 5秒間弾をブロック、クールタイム50。",
      "CN": "[护盾] 使用护盾格挡子弹5秒，冷却时间50。",
      "KR": "[실드] 5초간 총알 방어. 재사용 대기시간 50초.",
      "TW": "[護盾] 展開護格擋子彈，持續5秒，冷卻時間50秒。"
    }
  },
  "<Byakko>: Turn back,now.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<白虎>：戻れ、今すぐだ。",
      "CN": "<白虎>：现在回头。",
      "KR": "<백호>: 물러나라, 당장.",
      "TW": "<白虎>：回頭吧，就是現在。"
    }
  },
  "<Byakko>: Or you will face my fury.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<白虎>：さもなくば、わが憤怒に直面するがよい。",
      "CN": "<白虎>：否则你将面对我的怒火。",
      "KR": "<백호>: 안 그럼 내 분노를 볼게.",
      "TW": "<白虎>：否則你將面對我的怒火。"
    }
  },
  "<Byakko>: I warn you...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<白虎>：警告する……",
      "CN": "<白虎>：我警告你……",
      "KR": "<백호>: 경고한다…",
      "TW": "<白虎>：我警告過你了……"
    }
  },
  "> Shrine platform is seal off. <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> 神社プラットフォーム封鎖。 <",
      "CN": ">神龛平台已封锁。<",
      "KR": "> 신사 플랫폼 접근 금지. <",
      "TW": "> 神社平台已封印。 <"
    }
  },
  "> Zombie Item Locked! <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> ゾンビのアイテムロック解除！ <",
      "CN": ">僵尸物品已锁定！<",
      "KR": "> 좀비 아이템 잠금! <",
      "TW": "> 殭屍物品已鎖定！ <"
    }
  },
  "<Genbu>: No.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<玄武>：否。",
      "CN": "<玄武>：不。",
      "KR": "<현무>: 아니.",
      "TW": "<玄武>：不。"
    }
  },
  "<Genbu>: Leave it to me,Byakko.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<ゲンブ>任せとけ、白虎。",
      "CN": "<玄武>：交给我吧，白虎。",
      "KR": "<겐부>: 맡겨, 백oku.",
      "TW": "<玄武>：就拜託你了，白虎。"
    }
  },
  "<Byakko>: ...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<白虎>…",
      "CN": "<白虎>：……",
      "KR": "<백옥>: ...",
      "TW": "<白虎>：……"
    }
  },
  "<Byakko>: Stay safe,old man.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<白虎>元気でな、じいさん。",
      "CN": "<白虎>：保重，老人家。",
      "KR": "<백옥>: 조심해요, 할아버지.",
      "TW": "<白虎>：好自為之，老頭。"
    }
  },
  "> Genbu is casting Caduceus. <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> ゲンブがカドゥケウスを唱えた。 <",
      "CN": "玄武正在施放卡迪修斯技能。<",
      "KR": "> 겐부가 카두케이우스를 시전합니다. <",
      "TW": "> 玄武正在施放『卡杜修斯』。<"
    }
  },
  "> Genbu is casting Hell of Waste. <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> ゲンブが死海の地獄を唱えた。 <",
      "CN": "玄武正在施放荒火地狱。<",
      "KR": "> 겐부가 폐허의 지옥을 시전합니다. <",
      "TW": "> 玄武正在施放『廢墟地獄』。<"
    }
  },
  "> Genbu is casting Hell of Water. <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> ゲンブが水死の地獄を唱えた。 <",
      "CN": "玄武正在施放水狱。<",
      "KR": "> 겐부가 물의 지옥을 시전합니다. <",
      "TW": "> 玄武正在施放『水獄』。<"
    }
  },
  "> Genbu is casting Divine Cararact. <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> ゲンブが天啓の白内障を唱えた。 <",
      "CN": "玄武正在施放神目术。<",
      "KR": "> 겐부가 신성한 백내장을 시전합니다. <",
      "TW": "> 玄武正在施放『神聖白內障』。<"
    }
  },
  "> Hurry,Break the shield before Genbu kill us all! <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> 急げ、ゲンブが全員倒す前に盾を壊せ！<",
      "CN": "快，在玄武杀死我们之前打破护盾！",
      "KR": "> 빨리! 겐부가 우리를 모조리 죽이기 전에 방패를 부수세요!",
      "TW": "> 快點！在玄武屠殺我們之前打破防禦！"
    }
  },
  "> 快!在他杀死我们全部人前击碎他的水盾! <": {
    "translation": "",
    "MultiLang": {
      "US": "> Quick! Smash his water shield before he kills us all! <",
      "JP": "速く！彼ら全員を殺す前に彼のウォーターシールドを砕け！",
      "CN": "",
      "KR": "> 빨리! 우리가 모두 죽기 전에 그의 물방패를 부수자! <",
      "TW": "快！在他殺光我們之前打破他的水盾！"
    }
  },
  "有冒险者找到了岩狱.": {
    "translation": "",
    "MultiLang": {
      "US": "An adventurer has found the Rock Prison.",
      "JP": "冒険者が石牢を見つけた。",
      "CN": "",
      "KR": "모험가가 석감옥을 발견했습니다.",
      "TW": "有冒險者找到了岩獄。"
    }
  },
  "A player has pickup Stone Jail.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが石牢を獲得しました。",
      "CN": "一名玩家拾取了石牢。",
      "KR": "플레이어가 Stone Jail을 픽업했습니다.",
      "TW": "有玩家拾取了石牢。"
    }
  },
  "[岩狱] 直线禁锢路线上的僵尸7秒,能被挠碎,50秒冷却.": {
    "translation": "",
    "MultiLang": {
      "US": "[Rock Prison] Impounds zombies in a straight line for 7 seconds. Can be shattered by claws. 50s cooldown.",
      "JP": "[石牢] 直線上のゾンビを7間固定し、破壊可能。クールダウン50秒。",
      "CN": "",
      "KR": "[석감옥] 직선 경로상의 좀비를 7초간 석화하며, 긁어서 깨뜨릴 수 있으며, 재사용 대기시간은 50초입니다.",
      "TW": "[岩獄] 對直線路徑上的殭屍造成7秒定身，可被擊碎，冷卻時間50秒。"
    }
  },
  "[Stone Jail] Stone the zombie in a line for 7 sec,Breakable,50 cd.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[Stone Jail] 直線上のゾンビを7秒間石にする。破壊可能、クールダウン50秒。",
      "CN": "[石牢] 将直线上的僵尸石化7秒，可被打破，冷却时间50秒。",
      "KR": "[Stone Jail] 직선 경로상의 좀비를 7초간 석화하며, 파괴 가능, 재사용 대기시간 50초.",
      "TW": "[石牢] 將直線上的殭屍石化7秒，可破壞，冷卻時間50秒。"
    }
  },
  "[岩狱] 能对BOSS造成定身效果.": {
    "translation": "",
    "MultiLang": {
      "US": "[Rock Prison] Can root the Boss.",
      "JP": "[石牢] ボスの動きを停止させる効果がある。",
      "CN": "",
      "KR": "[석감옥] 보스에게 정지 효과를 부여합니다.",
      "TW": "[岩獄] 可對BOSS造成定身效果。"
    }
  },
  "[Stone Jail] It will Freeze Bosses movement.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[Stone Jail] ボスの移動を凍結する。",
      "CN": "[石牢] 将冻结Boss的移动能力。",
      "KR": "[Stone Jail] 보스의 움직임을 묶습니다.",
      "TW": "[石牢] 會凍結BOSS的移動。"
    }
  },
  "有僵尸习得了灭绝.": {
    "translation": "",
    "MultiLang": {
      "US": "A zombie has learned Extinction.",
      "JP": "あるゾンビが『絶滅』を習得した。",
      "CN": "",
      "KR": "좀비가 멸종 기술을 습득했습니다.",
      "TW": "有殭屍學會了滅絕。"
    }
  },
  "A zombie has learn Doom.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビが『ドゥーム』を覚えた。",
      "CN": "一只僵尸学会了末日技能。",
      "KR": "좀비가 도엄을 습득했습니다.",
      "TW": "殭屍學到了末日斬殺。"
    }
  },
  "[灭绝] 直接斩杀附近的人类,50秒冷却.": {
    "translation": "",
    "MultiLang": {
      "US": "[Extinction] Instantly executes nearby humans. 50s cooldown.",
      "JP": "[ジューシャースラッシュ] 周辺にいるプレイヤーを瞬間殺害、クールタイム50秒。",
      "CN": "",
      "KR": "[멸종] 주변 인간을 즉시 사살, 50초 쿨타임.",
      "TW": "[滅絕] 直接斬殺附近的人類，冷卻時間50秒。"
    }
  },
  "[Doom] Slay all human around you,50 cd.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[Doom] 周辺に存在する全てのプレイヤーを瞬間殺害、クールタイム50秒。",
      "CN": "[末日] 斩杀周围所有人类，冷却50秒。",
      "KR": "[Doom] 주변 모든 인간을 사살, 50초 쿨타임.",
      "TW": "[Doom] 消滅周圍所有人類，冷卻時間50秒。"
    }
  },
  "有冒险者找到了晶体墙.": {
    "translation": "",
    "MultiLang": {
      "US": "An adventurer has found the Crystal Wall.",
      "JP": "冒険者がクリスタルウォールを見つけた。",
      "CN": "",
      "KR": "모험가가 결정체 벽을 찾았습니다.",
      "TW": "有冒險者找到了晶體牆。"
    }
  },
  "A player has pickup Crystal.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーがクリスタルを獲得した。",
      "CN": "一名玩家拾取了水晶。",
      "KR": "선수가 수정체를 수집했습니다.",
      "TW": "玩家拾取了水晶。"
    }
  },
  "[晶体墙] 向前方生成水晶墙5秒,50秒冷却.": {
    "translation": "",
    "MultiLang": {
      "US": "[Crystal Wall] Generates a crystal wall in front for 5 seconds. 50s cooldown.",
      "JP": "[クリスタルウォール] 前方にクリスタルの壁を5秒間生成、クールタイム50秒。",
      "CN": "",
      "KR": "[결정체 벽] 앞쪽으로 5초간 수정체 벽 생성, 50초 쿨타임.",
      "TW": "[晶體牆] 向前方生成水晶牆持續5秒，冷卻時間50秒。"
    }
  },
  "[Crystal] Crate crystal wall for 5 sec,50 cd.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[Crystal] 前方にクリスタルの壁を5秒間生成、クールタイム50秒。",
      "CN": "[水晶] 召唤水晶墙，持续5秒，冷却50秒。",
      "KR": "[Crystal] 5초간 수정체 벽 생성, 50초 쿨타임.",
      "TW": "[Crystal] 生成水晶牆持續5秒，冷卻時間50秒。"
    }
  },
  "[晶体墙] 能对Boss造成定身效果.": {
    "translation": "",
    "MultiLang": {
      "US": "[Crystal Wall] Stuns Bosses.",
      "JP": "[クリスタルウォール] ボスに対して行動停止効果を付与可能。",
      "CN": "[水晶墙] 可以对Boss造成眩晕效果。",
      "KR": "[결정체 벽] 보스에게 체포 효과를 발휘합니다.",
      "TW": "[晶體牆] 能對Boss造成定身效果。"
    }
  },
  "[Crystal] It will Freeze Bosses movement.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[クリスタル] ボスの動きを凍結します。",
      "CN": "[水晶] 可以冻结Boss的移动。",
      "KR": "[크리스탈] 보스의 움직임을 얼립니다.",
      "TW": "[水晶] 能凍結Boss的行動。"
    }
  },
  "有冒险者找到了赤陨.": {
    "translation": "",
    "MultiLang": {
      "US": "An adventurer has found the Red Meteor.",
      "JP": "冒険者が「赤隕」を見つけました。",
      "CN": "",
      "KR": "모험가들이 적응을 발견했습니다.",
      "TW": "有冒險者找到了赤隕。"
    }
  },
  "A player has pickup Gravity.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが「グラビティ」をピックアップしました。",
      "CN": "一名玩家拾取了重力。",
      "KR": "선수가 중력 아이템을 획득했습니다.",
      "TW": "玩家已拾取重力道具。"
    }
  },
  "[赤陨] 向前方生成黑洞6秒,50秒冷却.": {
    "translation": "",
    "MultiLang": {
      "US": "[Red Meteor] Generates a black hole in front for 6 seconds. 50s cooldown.",
      "JP": "[赤隕] 前方に6秒間黒-holeを生成します。クールダウン50秒。",
      "CN": "",
      "KR": "[적응] 앞으로 6초 동안 블랙홀 생성, 50초 재사용 대기 시간.",
      "TW": "[赤隕] 向前方生成持續6秒的黑洞，冷卻時間50秒。"
    }
  },
  "[Gravity] Crate a blackhole pull zombie into for 6 sec,50 cd.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[Gravity] 6秒間黒-holeを生成してゾンビを引き寄せます。クールダウン50秒。",
      "CN": "[重力] 召唤黑洞将僵尸吸入，持续6秒，冷却50秒。",
      "KR": "[중력] 6초간 좀비를 끌어들이는 블랙홀 생성, 재사용 대기 시간 50초.",
      "TW": "[Gravity] 生成黑洞將殭屍吸入持續6秒，冷卻時間50秒。"
    }
  },
  "[赤陨] 能对Boss造成定身效果.": {
    "translation": "",
    "MultiLang": {
      "US": "[Red Meteor] Stuns Bosses.",
      "JP": "[赤隕] ボスに硬直効果を与えます。",
      "CN": "[赤陨] 能够对Boss造成眩晕效果。",
      "KR": "[적응] 보스에게 정지 효과를 줄 수 있습니다.",
      "TW": "[赤隕] 能對Boss造成定身效果。"
    }
  },
  "[Gravity] It will Freeze Bosses movement.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[Gravity] ボスの動きを凍結します。",
      "CN": "[重力] 可以冻结Boss的移动。",
      "KR": "[중력] 보스의 움직임을 얼립니다.",
      "TW": "[Gravity] 能凍結Boss的行動。"
    }
  },
  "> Genbu shield breaks! <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> 玄武のシールドが壊れた！ <",
      "CN": "> 玄武盾已破碎！ <",
      "KR": "> 현무 방패가 파괴되었습니다! <",
