    }
  },
  "**请守住靠过来的僵尸**": {
    "translation": "",
    "MultiLang": {
      "US": "\"Hold off the approaching zombies.\"",
      "JP": "**寄ってくるゾンビを撃ち止めて！**",
      "CN": "",
      "KR": "다가오는 좀비를 막아주세요",
      "TW": "**請守住逐漸靠近的殭屍**"
    }
  },
  "**门开了，我们走**": {
    "translation": "",
    "MultiLang": {
      "US": "\"The door's open, let's go.\"",
      "JP": "**開いた！中へ入って！**",
      "CN": "",
      "KR": "문이 열렸습니다, 갑시다",
      "TW": "**門開了，我們走**"
    }
  },
  "**挂机的玩家即将在10秒后传送**": {
    "translation": "",
    "MultiLang": {
      "US": "\"AFK players will be teleported in 10 seconds.\"",
      "JP": "**AFKのプレイヤーは10秒後に変移します**",
