{
  "\">>> 通往深渊实验室的大门将在 10 秒后打开 <<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>> The door to the Abyss Lab will open in 10 seconds <<<",
      "JP": ">>> 10秒後に深淵研究所への扉が開く <<<",
      "CN": "",
      "KR": ">>> 10 초 후 어둠의 실험실 문이 열립니다 <<<",
      "TW": ">>> 通往深渊實驗室的大門將在 10 秒後打開 <<<"
    }
  },
  "\">>> 电梯将于 20 秒后启动 <<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>> Elevator will start in 20 seconds <<<",
      "JP": ">>> エレベーターは 20 秒後に起動します <<<",
      "CN": "",
      "KR": ">>> 엘리베이터가 20초 후에 작동합니다 <<<",
      "TW": ">>> 電梯將於 20 秒後啟動 <<<"
    }
  },
  ">>> 通往深渊实验室的大门将在 10 秒后打开 <<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>> The door to the Abyssal Lab will open in 10 seconds <<<",
      "JP": ">>> 深淵実験室への扉は10秒後に開く <<<",
      "CN": "",
      "KR": ">>> 10초 후 어둠의 실험실로 통하는 문이 열립니다 <<<",
      "TW": ">>> 通往深淵實驗室的大門將在 10 秒後打開 <<<"
    }
  },
  ">>> 电梯将于 20 秒后启动 <<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>> The elevator will start in 20 seconds <<<",
      "JP": ">>> エlevatorは20秒後に起動する <<<",
      "CN": "",
      "KR": ">>> 20초 후 엘리베이터가 작동합니다 <<<",
      "TW": ">>> 電梯將於 20 秒後啟動 <<<"
    }
  },
  "...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "弟兄们, 这是继 Polaris 行动后最大胆的一次尝试..": {
    "translation": "",
    "MultiLang": {
      "US": "Brothers and sisters, this is the boldest attempt since Operation Polaris...",
      "JP": "兄弟们，这是继“极光行动”之后，最大胆的一次尝试...",
      "CN": "",
      "KR": "형제들, 이것은 폴라리스 작전 이후 가장 대담한 시도입니다...",
      "TW": "各位兄弟姐妹，这是继“极光行动”之后，最具胆识的一次尝试..."
    }
  },
  "丧尸病毒爆发, 深渊实验室失控多年": {
    "translation": "",
    "MultiLang": {
      "US": "The zombie virus outbreak, the Abyss Laboratory has been out of control for many years.",
      "JP": "丧尸病毒爆发，深渊实验室已经失控多年。",
      "CN": "",
      "KR": "좀비 바이러스 발생, 심연 연구소는 수년간 통제 불능 상태였습니다.",
      "TW": "丧尸病毒爆发，深渊实验室已经失控多年。"
    }
  },
  "唯有全力以赴, 方可揭露其真实面目": {
    "translation": "",
    "MultiLang": {
      "US": "Only by giving it our all can we reveal its true nature.",
      "JP": "只有全力以赴，才能揭露其真实面目。",
      "CN": "",
      "KR": "진실을 밝히려면 모든 힘을 다해야 합니다.",
      "TW": "唯有全力以赴，方可揭露其真实面目。"
    }
  },
  "这里曾有我们最精英的研究人员": {
    "translation": "",
    "MultiLang": {
      "US": "This place once housed our most elite researchers.",
      "JP": "这里曾是我们最精英的研究人员的所在地。",
      "CN": "",
      "KR": "여기는 우리 최고의 연구 인력이 있던 곳입니다.",
      "TW": "这里曾是我们最精英的研究人员的所在地。"
    }
  },
  "我们最重要的秘密武器埋藏此地": {
    "translation": "",
    "MultiLang": {
      "US": "Our most important secret weapon is buried here.",
      "JP": "我们最重要的秘密武器就埋藏于此。",
      "CN": "",
      "KR": "우리에게 가장 중요한 비밀 무기가 이곳에 숨겨져 있습니다.",
      "TW": "我们最重要的秘密武器就埋藏在此地。"
    }
  },
  "万万不可使其失控!": {
    "translation": "",
    "MultiLang": {
      "US": "We must not let it fall into the wrong hands!",
      "JP": "千万不可使其失控！",
      "CN": "",
      "KR": "절대로 통제 불능 상태로 만들 수 없습니다!",
      "TW": "千万不可使其失控！"
    }
  },
  "出发吧战士们, 务必珍重.": {
    "translation": "",
    "MultiLang": {
      "US": "Go forth, warriors, and be careful.",
      "JP": "出发吧，战士们，务必珍重。",
      "CN": "",
      "KR": "출발하십시오, 전사 여러분, 부디 안전하게 다녀오십시오.",
      "TW": "出发吧，战士们，务必珍重。"
    }
  }
}
