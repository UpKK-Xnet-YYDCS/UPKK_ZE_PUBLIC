    }
  },
  "**Ascent to Device C is being prepared**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "デバイスCへの登壇準備中",
      "CN": "正在准备通往装置C的登道",
      "KR": "장비 C 접근 준비 중",
      "TW": "前往裝置C的路線正在準備中"
    }
  },
  "**Allagan Device C Reached**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "アラガン・デバイスC到達",
      "CN": "已达到亚拉戈装置C",
      "KR": "아발란 장비 C 도달",
      "TW": "阿爾加恩裝置C已抵達"
    }
  },
  "**All allagan devices connected. Please wait.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "すべてのアラガン・デバイスが接続されました。お待ちください。",
      "CN": "所有亚拉戈装置已连接。请稍候。",
      "KR": "모든 아발란 장치가 연결되었습니다. 기다려 주세요.",
      "TW": "所有阿爾加恩裝置已連接。請稍候。"
    }
  },
  "**Defend for 30 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "30秒間防衛せよ",
      "CN": "防御30秒",
      "KR": "30초간 방어하세요",
      "TW": "防禦30秒"
    }
  },
  "**FINAL DEFENCE -- Defend for 15 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "最終防衛 -- 15秒間防衛せよ！",
      "CN": "**最终防御——坚持防守15秒！**",
      "KR": "**최후의 방위 -- 15초간 방어하라!**",
      "TW": "**最終防禦 -- 守衛 15 秒！**"
    }
  },
  "**THE COIL OF BAHAMUT -- CLEARED. LEVEl 1 WIN**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バハマットの巻貝 -- クリア。レベル1達成」",
      "CN": "**巴哈姆特之卵——已清除。关卡1 胜利**",
      "KR": "**바하무트의 고리 -- 클리어. 레버l 1 승리**",
      "TW": "**巴哈姆特線圈 -- 已清除。一關勝利**"
    }
  },
  "**LEVEL 2 - ALEXANDER**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "レベル2 - アレクサンドル",
      "CN": "**关卡2 - 亚历山大**",
      "KR": "**레벨 2 - 알렉산더**",
      "TW": "**二關 - 亞歷山大**"
    }
  },
  "**Defend for 20 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "20秒間防衛せよ！」",
      "CN": "坚持防守20秒！",
      "KR": "20초간 방어하라!",
      "TW": "守衛 20 秒！"
    }
  },
  "**Bottom  door opening in 20 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "底部の扉が20秒後に開く」",
      "CN": "底部门户将在20秒后开启",
      "KR": "하부 문이 20초 후 열립니다",
      "TW": "底部門戶將在 20 秒後開啟"
    }
  },
  "**2B HAS CASTED REGEN!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "2Bが再生を展開した！」",
      "CN": "2B已释放再生效果！",
      "KR": "2B가 재생 spells을 시전했습니다!",
      "TW": "2B 已施放再生！"
    }
  },
  "**We have captured the Generator. Defend it until all energy is spent**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "我々はジェネレーターを占拠した。エネルギーが尽きるまで防衛せよ」",
      "CN": "我们已经捕获了发电机。请在此处防守，直到所有能源耗尽",
      "KR": "우리가 발전소를 점령했습니다. 모든 에너지가 소진될 때까지 방어하세요",
      "TW": "我們已佔領發電機。守衛它直到能量耗盡"
    }
  },
  "**Zombies have taken the generator. Capture it back!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビがジェネレーターを占拠した。奪還せよ！」",
      "CN": "僵尸已占领发电机。将其夺回！",
      "KR": "좀비들이 발전소를 점령했습니다. 되찾으십시오!",
      "TW": "殭屍已佔領發電機。奪回它！"
    }
  },
  "**Hold here until all paths are clear!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "全経路が安全になるまでここに待機せよ！",
      "CN": "等待所有路径清除！",
      "KR": "모든 경로가 확보될 때까지 여기서 대기하세요!",
      "TW": "**按住此處，直到所有路徑暢通**"
    }
  },
  "**IFRIT INTERRUPTED**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "イフリット中断",
      "CN": "伊弗利特被打断",
      "KR": "이프리트 강제 중단됨**",
      "TW": "**伊夫利特中斷**"
    }
  },
  "**Upper boulders explosion set in 30 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "上部の岩爆発まであと30秒！",
      "CN": "上方巨石爆炸倒计时：30秒！",
      "KR": "상부 암석 폭발 30초 뒤!",
      "TW": "**上部巨石爆破倒數 30 秒！**"
    }
  },
  "**Upper Pipes Reached. Defend for 30 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "上部のパイプ到達。30間防衛せよ。",
      "CN": "已到达上层水管，坚守30秒。",
      "KR": "상부 파이프 도달. 30초간 방어하십시오.",
      "TW": "**已抵達上部管道。防禦 30 秒。**"
    }
  },
  "**Upper path opening in 15 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "上部経路開放まであと15秒",
      "CN": "上层通路即将开启（15秒）",
      "KR": "상부 경로 개방 15초 후",
      "TW": "**上部通道即將於 15 秒後開啟**"
    }
  },
  "**Both Paths Reached...please wait**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "両方の経路到達...お待ちください",
      "CN": "两条路径均已到达...请稍等",
      "KR": "두 경로를 모두 도달했습니다... 잠시 기다려주세요.",
      "TW": "**已抵達兩條路徑……請稍候**"
    }
  },
  "**Upper elevator leaving in 10 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "上部エレベーターは10秒後に発車！",
      "CN": "上层电梯10秒后离开！",
      "KR": "상부 엘리베이터 10초 후 출발!",
      "TW": "**上部電梯即將於 10 秒後出發！**"
    }
  },
  "**Survive until ADS is defeated**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ADSを倒すまで生存せよ",
      "CN": "坚持到击败ADS为止",
      "KR": "ADS가 격파될 때까지 생존하십시오",
      "TW": "**存活至擊破 ADS**"
    }
  },
  "**THE ADS TEAM HAS WIPED. MISSION FAIL**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ADSチームは撃滅された。ミッション失敗",
      "CN": "广告团队已被清除。任务失败。",
      "KR": "**ADS 팀이 전멸했습니다. 임무 실패**",
      "TW": "ADS團隊全滅。任務失敗"
    }
  },
  "**IFRIT HAS DIED**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "イフリートが死亡した",
      "CN": "伊弗利特已死亡。",
      "KR": "**이프리트는 사망했습니다**",
      "TW": "伊芙利特已陣亡"
    }
  }
