{
  "**Welcome to EORZEA**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**EORZEAへようこそ**",
      "CN": "欢迎来到伊尔美格",
      "KR": "**EORZEA에 오신 것을 환영합니다**",
      "TW": "歡迎來到艾歐澤亞"
    }
  },
  "**LEVEL 1 - THE COIL OF BAHAMUT**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**レベル 1 - バハムットの渦**",
      "CN": "LEVEL 1 - 巴哈姆特的涡流",
      "KR": "**Lv. 1 - 바ハムートの渦**",
      "TW": "等級 1 - 巴哈姆特之環"
    }
  },
  "**Reached Allagan Door. Defend for 30 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**アラガン・ドアに到達。30秒間防衛せよ**",
      "CN": "已到达阿拉拉门。防守30秒",
      "KR": "**アガルタの門に着きました. 30秒間防衛してください**",
      "TW": "已抵達阿爾吉恩門。防禦 30 秒"
    }
  },
  "**Allagan Door opened. Lets Mosey!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**アラガン・ドア開扉。行け！**",
      "CN": "阿拉拉门已打开！出发！",
      "KR": "**アガルタの門が開きました. さあ、進もう！**",
      "TW": "阿爾吉恩門已開啟。前進！"
    }
  },
  "**Allagan Lift reached. Defend for 60 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**アラガン・リフトに到達。60秒間防衛せよ**",
      "CN": "已到达阿拉拉升降机。防守60秒",
      "KR": "**アガルタの昇降機に着きました. 60秒間防衛してください**",
      "TW": "已抵達阿爾吉恩升降梯。防禦 60 秒"
    }
  },
  "**Allagan Lift raising!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**アラガン・リフト稼働！**",
      "CN": "阿拉拉升降机启动！",
      "KR": "**アガルタの昇降機が上昇中！**",
      "TW": "阿爾吉恩升降梯啟動！"
    }
  },
  "**We have reached the Allagan Bridge. Defend for 45 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**アラガン・ブリッジに到達。45秒間防衛せよ！**",
      "CN": "已到达阿拉拉桥。防守45秒！",
      "KR": "**アガルタの橋に到着しました. 45秒間防衛してください！**",
      "TW": "已抵達阿爾吉恩橋樑。防禦 45 秒！"
    }
  },
  "**The way forward is clear! Lets move!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**進路は安全！行け！**",
      "CN": "前路畅通！前进！",
      "KR": "**先へ進む道が開けました. さあ、進もう！**",
      "TW": "前路已開！前進！"
    }
  },
  "**Allagan button reached. Bottom floor opening in 60 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**アラグンボタン到達。床面開門まであと60秒**",
      "CN": "阿尔加诺按钮已触发。底层入口将在60秒后开启",
      "KR": "알라간 버튼 도달. 바닥층 개방까지 60초",
      "TW": "阿爾吉農按鈕已達。底層入口60秒後開啟"
    }
  },
  "**Bottom floor open!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**底層開！**",
      "CN": "底层入口已开启！",
      "KR": "바닥층 개방!",
      "TW": "底層已開啟！"
    }
  },
  "**Allagan platform moving to Bahamut's Claw in 30 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**アラグンプラットフォームがバハムットの爪へ移動開始まであと30秒！**",
      "CN": "阿尔加诺平台将在30秒后移动至巴哈姆特之爪！",
      "KR": "알라간 플랫폼 발사까지 30초!",
      "TW": "阿爾吉農平台正在移動至巴哈姆特之爪，距離30秒！"
    }
  },
  "**Top floor door open!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**上層ドア解放！**",
      "CN": "顶层门已开启！",
      "KR": "1층 문 개방!",
      "TW": "頂層門已開啟！"
    }
  },
  "**2B IS READY**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**2B 戦闘準備完了**",
      "CN": "2B 准备就绪",
      "KR": "2B 준비됨",
      "TW": "2B 準備就緒"
    }
  },
  "**BLACK MAGE IS READY**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**黒魔道士 戦闘準備完了**",
      "CN": "黑魔法师 准备就绪",
      "KR": "블랙 마법사 준비됨",
      "TW": "黑魔導士準備就緒"
    }
  },
  "**2B HAS DIED**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**2B 死亡**",
      "CN": "2B 已阵亡",
      "KR": "2B 사망",
      "TW": "2B 已陣亡"
    }
  },
  "**BLACK MAGE HAS CASTED FLARE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**黒魔道士がフレアの�唱完了**",
      "CN": "黑魔法师 已施放耀光",
      "KR": "블랙 마법사 플레어 시전 완료",
      "TW": "黑魔導士已施放星爆"
    }
  },
  "**BLACK MAGE HAS DIED**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バクマジオンが死亡した",
      "CN": "黑魔导师已阵亡",
      "KR": "흑마비가 패배했습니다",
