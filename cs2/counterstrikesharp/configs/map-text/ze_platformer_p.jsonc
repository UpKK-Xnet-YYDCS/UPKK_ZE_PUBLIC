    }
  },
  "Thanks to Enviolinador & Darnias": {
    "translation": "感谢Enviolinador 和 Darnias",
    "MultiLang": {
      "US": "",
      "JP": "Enviolinador & Darnias ご協力感謝",
      "CN": "感谢 Enviolinador & Darnias",
      "KR": "Thanks to Enviolinador & Darnias",
      "TW": "感謝 Enviolinador 和 Darnias"
    }
  },
  "Zombies have secured a checkpoint.": {
    "translation": "僵尸激活了一处传送点",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビがチェックポイントを獲得しました。",
      "CN": "僵尸已占领检查点。",
      "KR": "Zombies have secured a checkpoint.",
      "TW": "殭屍已確保檢查點。"
    }
  },
  "Added extra shininess to the coins.": {
    "translation": "给硬币添加高亮",
    "MultiLang": {
      "US": "",
      "JP": "コインの光沢を強化しました。",
      "CN": "增加了额外的金币光泽。",
      "KR": "Added extra shininess to the coins.",
      "TW": "為硬幣增加了額外的光澤。"
    }
  },
  "You have collected enough coins. Nuke inbound in 70 seconds.": {
    "translation": "你收集了足够的硬币，核爆在70s来临",
    "MultiLang": {
      "US": "",
      "JP": "コインが十分な量集まりました。70秒後に核爆発です。",
      "CN": "你已收集足够的金币。70秒后核弹到达。",
      "KR": "You have collected enough coins. Nuke inbound in 70 seconds.",
      "TW": "您已收集足夠的硬幣。70 秒後核彈即將到來的。"
    }
  },
  "Proceed to find a safehouse if you want to survive.": {
    "translation": "如果想活下来，就找个安全屋",
    "MultiLang": {
      "US": "",
      "JP": "生存したいなら安全地帯を探して移動してください。",
      "CN": "若想生存，请前往前往下一个安全屋。",
      "KR": "Proceed to find a safehouse if you want to survive.",
      "TW": "若你想生存，請前往下一個安全屋。"
    }
  },
  "Some items have spawned on top of safehouses.": {
    "translation": "安全屋屋顶生成部分神器",
    "MultiLang": {
      "US": "",
      "JP": "一部のアイテムが安全地帯の上にスポーンしました。",
      "CN": "部分道具生成在安全屋内。",
      "KR": "Some items have spawned on top of safehouses.",
      "TW": "部分物品已刷新的於安全屋頂部。"
    }
  },
  "CT flags can now teleport humans back to spawn.": {
    "translation": "人类旗帜现在可以传送回出生岛",
    "MultiLang": {
      "US": "",
      "JP": "CTのフラッグで人間を spawn にテレポートできるようになりました。",
      "CN": "反恐组旗帜现在可将人类传送回出生点。",
      "KR": "CT flags can now teleport humans back to spawn.",
      "TW": "反恐小組旗子現在可以將人類傳送回出生點。"
    }
  },
  "Platforms are now breakable!": {
    "translation": "平台现在可被打碎！",
    "MultiLang": {
      "US": "",
      "JP": "プラットフォームが破壊可能になった！",
      "CN": "平台现在可以被摧毁了！",
      "KR": "플랫폼이 이제 부서집니다!",
      "TW": "平台現在可以被破壞了！"
    }
  },
  "Meteors are raining from the sky!": {
    "translation": "陨石来袭！",
    "MultiLang": {
      "US": "",
      "JP": "空から隕石が降り注ぐ！",
      "CN": "陨石如雨般从天而降！",
      "KR": "하늘에서 운석이 쏟아집니다!",
      "TW": "天空中正下著流星雨！"
    }
  }
