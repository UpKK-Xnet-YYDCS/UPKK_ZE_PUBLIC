    }
  },
  "break these glasses!": {
    "translation": "打破这玻璃！",
    "MultiLang": {
      "US": "",
      "JP": "これらの眼鏡を割ってください！",
      "CN": "打破这些眼镜！",
      "KR": "이 유리창을 부수세요!",
      "TW": "打破這些眼鏡！"
    }
  },
  "Oh, I forgot to retrieve my storybook. Can you help me retrieve it？": {
    "translation": "哦，我忘了拿回我的故事书了，你能帮我把它拿回来吗？",
    "MultiLang": {
      "US": "",
      "JP": "あぁ、物語の本を取り忘れていたわ。拾ってきてもらえますか？",
      "CN": "哦，我忘了取回我的故事书。你能帮我取回来吗？",
      "KR": "아, 이야기책을 가져오는 걸 깜빡했네요. 가져다 줄 수 있나요?",
      "TW": "哦，我忘記取回我的故事書了。你能幫我拿回來嗎？"
    }
  },
  "AFK players will teleport in 5 seconds": {
    "translation": "ATK玩家将在5s后传送",
    "MultiLang": {
      "US": "",
      "JP": "AFKプレイヤーは5秒後にテレポートします",
      "CN": "AFK玩家将在5秒后传送",
      "KR": "AFK 상태인 플레이어들이 5초 후에 워프됩니다",
      "TW": "AFK玩家將 teleport 5秒後傳送"
    }
  },
  "Please pass through that glowing door": {
    "translation": "请穿过那扇发光的大门吧",
    "MultiLang": {
      "US": "",
      "JP": "輝くその門を抜けてください",
      "CN": "请通过那扇发光的门",
      "KR": "빛나는 문을 통해 이동하세요",
      "TW": "請穿過那扇發光的門"
    }
  },
  "AFK players will teleport in 3 seconds": {
    "translation": "ATK玩家将在3s后传送",
    "MultiLang": {
      "US": "",
      "JP": "AFKプレイヤーは3秒後にテレポートします",
      "CN": "AFK玩家将在3秒后传送",
      "KR": "AFK 상태인 플레이어들이 3초 후에 워프됩니다",
      "TW": "AFK玩家將 teleport 3秒後傳送"
    }
  },
  "Please here for 30 seconds": {
    "translation": "请稍等30s",
    "MultiLang": {
      "US": "",
      "JP": "30秒間、こちらにお待ちください",
      "CN": "请在此停留30秒",
      "KR": "여기서 30초간 대기하세요",
      "TW": "請在此停留 30 秒"
    }
  },
  "You have found my book, and now I can tell you stories！": {
    "translation": "你找回我的书了！现在我可以给你说那个故事了",
    "MultiLang": {
      "US": "",
      "JP": "私の本を見つけてくれたね。これで私が物語を語れるようになったよ！",
      "CN": "你找到了我的书，现在我可以给你讲故事了！",
      "KR": "당신은 나의 책을 발견했고, 이제 내가 이야기를 들려줄 수 있습니다!",
      "TW": "你找到了我的書，現在我可以講故事給你了！"
    }
  },
  "Please wait for 5 seconds and return to the house through the front illuminated door": {
    "translation": "请等待5s后穿过前面发光的门回到房子里去吧",
    "MultiLang": {
      "US": "",
      "JP": "5秒お待ちいただき、正面の照明のあるドアから館へ戻ってください",
      "CN": "请等待5秒，然后通过前方发光的门返回房屋",
      "KR": "5초간 대기한 뒤, 앞쪽의 밝은 문을 통해 집으로 돌아가세요",
      "TW": "請等待 5 秒鐘，然後通過前方有照明的大門回到屋內"
    }
  },
  "Soon, a random road will open": {
    "translation": "马上一条随机的道路将会打开",
    "MultiLang": {
      "US": "",
      "JP": "まもなくランダムな道が開きます",
      "CN": "很快，一条随机道路将会开放",
      "KR": "곧 무작위로 길이 열릴 것입니다",
      "TW": "隨即，一條隨機的道路將開啟"
    }
  },
  "Please defend here for 40 seconds": {
    "translation": "请在这里防守40s",
    "MultiLang": {
      "US": "",
      "JP": "40秒間、こちらを守ってください",
      "CN": "请在这里坚守40秒",
      "KR": "여기서 40초간 방어하세요",
      "TW": "請在此防禦 40 秒"
    }
  },
  "now,Please listen to the first story...": {
    "translation": "现在，请听序章...",
    "MultiLang": {
      "US": "",
      "JP": "では、最初の物語をお聞きください……",
      "CN": "现在，请聆听第一个故事……",
      "KR": "이제 첫 번째 이야기를 들으세요...",
      "TW": "現在，請聆聽第一個故事……"
    }
  },
  "Thank you for playing": {
    "translation": "感谢您的游玩！",
