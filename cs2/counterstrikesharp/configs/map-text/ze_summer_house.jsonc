      "CN": "地图:夏日小屋",
      "KR": "지도: 여름 별장",
      "TW": "地圖：夏季小屋"
    }
  },
  "Thanks to Darivan、 Geraral、打酱油的企鹅 ": {
    "translation": "感谢Darivan、 Geraral、打酱油的企鹅",
    "MultiLang": {
      "US": "Thanks to Darivan, Geraral, and 打酱油的企鹅",
      "JP": "Darivan、Geraral、打酱油の企鹅さんへ感謝",
      "CN": "感谢Darivan、 Geraral、打酱油的企鹅",
      "KR": "Darivan, Geraral,打酱油的企鹅 덕분에 감사합니다",
      "TW": "感謝 Darivan、Geraral、打醬油的企鵝"
    }
  },
  "Wait here for 35 seconds": {
    "translation": "请等待35s",
    "MultiLang": {
      "US": "",
      "JP": "ここに35秒間待機してください",
      "CN": "在此等待35秒",
      "KR": "여기에서 35초간 기다리십시오.",
      "TW": "在此停留 35 秒"
    }
  },
  "welcome to the summer house，enjoy yourself！": {
    "translation": "欢迎来到盛夏豪宅，玩得开心！",
    "MultiLang": {
      "US": "",
      "JP": "サマーハウスへようこそ、楽しんでください！",
      "CN": "欢迎来到夏日小屋，尽情享受！",
      "KR": "여름 별장에 오신 것을 환영합니다. 즐기세요!",
      "TW": "歡迎來到夏季小屋，盡情享受！"
    }
  },
  "The road will open in 25 seconds": {
    "translation": "道路将在25s后打开",
