      "US": "",
      "JP": "25秒後に道路が開きます",
      "CN": "道路将在25秒后开启",
      "KR": "25초 후에 길이 열립니다.",
      "TW": "道路將在 25 秒後開啟"
    }
  },
  "soon randomly select a road": {
    "translation": "稍后将随机选择一条路",
