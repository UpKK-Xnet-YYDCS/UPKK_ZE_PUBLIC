    }
  },
  "STEAM OFF": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "蒸気を停止",
      "CN": "蒸汽关闭",
      "KR": "증기 멈춤",
      "TW": "蒸汽关闭"
    }
  },
  "RESIST 53 SECONDS": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "53秒間耐える",
      "CN": "抵抗 53 秒",
      "KR": "53초 동안 저항",
      "TW": "持续 53 秒"
    }
  },
  "Wait for power off": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "電源が切れるまで待つ",
      "CN": "等待断电",
      "KR": "전원 꺼지기를 기다립니다",
      "TW": "等待电源关闭"
    }
  },
  "WHEN THE STEAM IS OFF GET AWAY FROM THE MIDDLE OR YOU WILL GET ASPIRED BY THE TURBINE": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "蒸気が止まったら、中央から離れてください。さもないと、タービンに吸い込まれます。",
      "CN": "当蒸汽关闭时，远离中央区域，否则你会被涡轮吸入。",
      "KR": "증기가 멈추면 중앙에서 멀리 떨어지세요, 그렇지 않으면 터빈에 빨려 들어갈 수 있습니다.",
      "TW": "当蒸汽关闭时，远离中央区域，否则您会被涡轮吸入。"
    }
  },
  "LIFT LEAVE IN 10 SEC": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "10秒後に離脱",
      "CN": "电梯即将离开，倒计时10秒",
      "KR": "엘리베이터, 10초 후 출발",
      "TW": "上升，10 秒后离开"
    }
  },
  "【OUROBOROS】\"RAMPAGE!终于联系上你们了!我们已经突破敌军封锁,正在快速接近!\"": {
    "translation": "",
    "MultiLang": {
      "US": "【OUROBOROS】\"RAMPAGE! Finally, we're connected! We've broken through the enemy blockade and are rapidly approaching!\"",
      "JP": "【OUROBOROS】「暴走開始！ついにあなたたちと連絡が取れた！我々は敵軍の封鎖を突破し、急速に接近中だ！」",
      "CN": "",
      "KR": "【OUROBOROS】\"폭주! 드디어 연락이 닿았군요! 저희는 적군의 봉쇄를 돌파했고, 빠르게 접근 중입니다!",
      "TW": "【OUROBOROS】“疯狂！终于联系上你们了！我们已经突破敌军封锁，正在快速接近！”"
    }
  },
  "【OUROBOROS】\"悬崖已经布满了感染者,战机即将抵达为你们开拓一条直抵终点的道路!\"": {
    "translation": "",
    "MultiLang": {
      "US": "【OUROBOROS】\"The cliff is swarming with infected. Fighter support is arriving to clear a path directly to your destination!\"",
      "JP": "【OUROBOROS】「崖は既に感染者で溢れかえっており、戦闘機があなたたちのために、終点まで続く道を開拓する！」",
      "CN": "",
      "KR": "【OUROBOROS】절벽은 이미 감염자들로 가득 차 있으며, 전투기가 여러분을 위해 최종 지점까지 연결되는 길을 열어줄 것입니다!",
      "TW": "【OUROBOROS】“悬崖已经被感染者布满，战机会为你们开辟一条直抵终点的道路！”"
    }
  },
  "【RAMPAGE】......": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "【RAMPAGE】......",
      "CN": "【狂暴】......",
      "KR": "【RAMPAGE】......",
      "TW": "【RAMPAGE】......"
    }
  },
  "【RAMPAGE】所以，我们也算是故地重游了....不是吗?": {
    "translation": "",
    "MultiLang": {
      "US": "【RAMPAGE】\"So, we're revisiting old territory... aren't we?\"",
      "JP": "【RAMPAGE】つまり、私たちも旧地を再訪している、というわけですね？",
      "CN": "",
      "KR": "【RAMPAGE】그래서, 우리도 일종의 추억 여행을 하게 된 거겠죠...? 그렇죠?",
      "TW": "【RAMPAGE】所以，我们也可以说是重游故地了...不是吗？"
    }
  },
  "【RAMPAGE】…再一次地揭开我们的旧伤.": {
    "translation": "",
    "MultiLang": {
      "US": "【RAMPAGE】\"...Once again, exposing our old wounds.\"",
      "JP": "【RAMPAGE】…またしても、私たちの古い傷をえぐり出す。",
      "CN": "",
      "KR": "…다시 한번 우리의 낡은 상처를 드러내는군요.",
      "TW": "【RAMPAGE】…再一次地揭示我们的旧伤。"
    }
  },
  "【OUROBOROS】愿我们在XEN星相见!": {
    "translation": "",
    "MultiLang": {
      "US": "【OUROBOROS】May we meet on the XEN star!",
      "JP": "【OUROBOROS】では、XEN星でまた会いましょう！",
      "CN": "",
      "KR": "【OUROBOROS】XEN 행성에서 다시 만나요!",
      "TW": "【OUROBOROS】愿我们在XEN星相见！"
    }
  },
  "【RAMPAGE】如果在法国大使馆我们没能通过测试,那么世界会变成什么样子?": {
    "translation": "",
    "MultiLang": {
      "US": "【RAMPAGE】If we fail the test at the French Embassy, what will the world become?",
      "JP": "【RAMPAGE】もしフランス大使館でテストに合格できなかった場合、世界はどうなってしまうのでしょうか？",
      "CN": "",
      "KR": "만약 프랑스 대사관에서 테스트를 통과하지 못했다면, 세상은 어떤 모습이 되었을까요?",
      "TW": "【RAMPAGE】如果我们在法国大使馆未能通过测试，世界会变成什么样子？"
    }
  },
  "Bomb actived": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "爆弾作動",
      "CN": "炸弹已启动",
      "KR": "폭탄 작동",
      "TW": "引爆装置已启动"
    }
  },
  "【RAMPAGE】技术官,如果当时,你们没前往X13基地,原地等待支援,是不是会有更好的结果?": {
    "translation": "",
    "MultiLang": {
      "US": "【RAMPAGE】Technical Officer, if you hadn't gone to the X13 base and had instead waited for reinforcements, would the outcome have been better?",
      "JP": "【RAMPAGE】技術官殿、もし当時、皆さんがX13基地へ向かわず、その場で増援を待っていれば、より良い結果になったでしょうか？",
      "CN": "",
      "KR": "【RAMPAGE】기술 담당관님, 만약 당시, 여러분이 X13 기지로 가지 않고, 현장에서 지원을 기다렸다면, 더 나은 결과가 있었을까요?",
      "TW": "【RAMPAGE】技术人员，如果当时，你们没有前往X13基地，而是原地等待支援，结果会更好吗？"
    }
  },
  "【RAMPAGE】如果尼赫伦斯没耍这些小把戏,是不是现在一切已经结束了?": {
    "translation": "",
    "MultiLang": {
      "US": "【RAMPAGE】If Nihilans hadn't played these tricks, wouldn't everything be over by now?",
      "JP": "【RAMPAGE】もしネヘレンスがそんな小細工をしていなければ、今頃は全て終わっていたのに？",
      "CN": "",
      "KR": "만약 니헬렌스가 그런 꼼수를 부리지 않았다면, 지금쯤 모든 게 끝났을까요?",
      "TW": "【RAMPAGE】如果尼赫伦斯没有耍这些小伎俩，现在一切是不是已经结束了？"
    }
  },
  "【RAMPAGE】如果当时FILTH和VERTIGO都活下来,我们是不是还能一起参战NPST?": {
    "translation": "",
    "MultiLang": {
      "US": "【RAMPAGE】If FILTH and VERTIGO had both survived, would we still be able to participate in NPST together?",
      "JP": "【RAMPAGE】もし当時、FILTHとVERTIGOが生き残っていたら、私たちはNPSTに一緒に参加できていたでしょうか？",
      "CN": "",
