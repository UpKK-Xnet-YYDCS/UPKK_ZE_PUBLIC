  "Hold on until the rescue helicopter arrives!": {
    "translation": "坚持到救援直升机赶到！",
    "MultiLang": {
      "US": "",
      "JP": "救助ヘリコプターが到着するまで、ここで待機してください！",
      "CN": "坚持到救援直升机到达！",
      "KR": "구조 헬기가 도착할 때까지 버티세요!",
      "TW": "撑到救援直升機抵達！"
    }
  },
  "Move to the helipad now!": {
    "translation": "现在前往直升机停机坪！",
    "MultiLang": {
      "US": "",
      "JP": "今すぐヘリポートへ移動してください！",
      "CN": "立即前往停机坪！",
      "KR": "지금 헥파드로 이동하세요!",
      "TW": "立即前往直升机停机坪！"
    }
  },
  "Move upstairs to avoid the flames!": {
    "translation": "快上楼，避开火焰！",
    "MultiLang": {
