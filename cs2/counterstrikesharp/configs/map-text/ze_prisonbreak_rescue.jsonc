  "Find and rescue First Lieutenant Sas!": {
    "translation": "找到并解救赛斯中尉！",
    "MultiLang": {
      "US": "",
      "JP": "サス二等兵士を見つけ、救出してください！",
      "CN": "找到并营救萨斯中尉！",
      "KR": "사스 중위를 찾고 구출하세요!",
      "TW": "搜尋並營救薩斯中尉！"
