  "[ Admin ] -> I had a sensation of falling": {
    "translation": "[ 管理员 ] -> 我有一种坠落的感觉",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> 落下する感覚がありました",
      "CN": "[ Admin ] -> 我有一种坠落感",
      "KR": "[ 관리자 ] -> 떨어짐이 느껴지는 순간",
      "TW": "[ 管理員 ] -> 我有墜落的感覺"
    }
  },
  "[ Admin ] -> Killed all zombie items.": {
    "translation": "[ 管理员 ] -> 消灭所有僵尸神器。",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> すべてのゾンビアイテムを排除しました。",
      "CN": "[ Admin ] -> 清除所有僵尸物品。",
      "KR": "[ 관리자 ] -> 모든 좀비 아이템을 처치.",
      "TW": "[ 管理員 ] -> 消滅所有殭屍物品。"
    }
  },
  "[ Admin ] -> Killed the current boss.": {
    "translation": "[ 管理员 ] -> 杀死当前Boss。",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> 現在のボスを倒しました。",
      "CN": "[ Admin ] -> 消灭当前 Boss。",
      "KR": "[ 관리자 ] -> 현재 보스를 처치.",
      "TW": "[ 管理員 ] -> 消滅當前首領。"
    }
  },
  "[ Admin ] -> Selected Easy Mode for next round.": {
    "translation": "[ 管理员 ] -> 下一轮为简单模式。",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> 次のラウンドにイージーモードを選択しました。",
      "CN": "[ Admin ] -> 下一轮选择简单模式。",
      "KR": "[ 관리자 ] -> 다음 라운드에 쉬움 모드를 선택함.",
      "TW": "[ 管理員 ] -> 下回合選擇簡單模式。"
    }
  },
  "[ Admin ] -> Selected Extreme Mode for next round.": {
    "translation": "[ 管理员 ] -> 下一轮为极限模式。",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> 次のラウンドにエクスートリームモードを選択しました。",
      "CN": "[ Admin ] -> 下一轮选择极限模式。",
      "KR": "[ 관리자 ] -> 다음 라운드에 극난도 모드를 선택함.",
      "TW": "[ 管理員 ] -> 下回合選擇極限模式。"
    }
  },
  "[ Admin ] -> Selected Hard Mode for next round.": {
    "translation": "[ 管理员 ] -> 下一轮为困难模式。",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> 次のラウンドにハードモードを選択しました。",
      "CN": "[ Admin ] -> 下一轮选择困难模式。",
      "KR": "[ 관리자 ] -> 다음 라운드에 하드 모드를 선택함.",
      "TW": "[ 管理員 ] -> 下回合選擇困難模式。"
    }
  },
  "[ Admin ] -> Selected Normal Mode for next round.": {
    "translation": "[ 管理员 ] -> 下一轮为普通模式。",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> 次のラウンドには通常モードが選択されました。",
      "CN": "[管理员] -> 下一轮选择普通模式。",
      "KR": "[ 관리 ] -> 다음 라운드에 일반 모드를 선택했습니다.",
      "TW": "[ 管理員 ] -> 已選擇下一回合的普通模式。"
    }
  },
  "[ Admin ] -> Selected Refrain Mode for next round.": {
    "translation": "[ 管理员 ] -> 下一轮为禁绝模式。",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> 次のラウンドには自制モードが選択されました。",
      "CN": "[管理员] -> 下一轮选择节制模式。",
      "KR": "[ 관리 ] -> 다음 라운드에 자제 모드를 선택했습니다.",
      "TW": "[ 管理員 ] -> 已選擇下一回合的勸阻模式。"
    }
  },
  "[ Admin ] -> Spawned Dream Breaker & Dream Weaver.": {
    "translation": "[ 管理员 ] -> 生成梦境破坏者和梦境编织者。",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> ドリームブレイカーとドリームウィーバーをスポーンしました。",
      "CN": "[管理员] -> 生成梦境破坏者与织梦者。",
      "KR": "[ 관리 ] -> 드림 브레이커 & 드림 위버를 소환했습니다.",
      "TW": "[ 管理員 ] -> 已生成夢魘破壞者與織夢者。"
    }
  },
  "[ Admin ] -> Spawned all S items.": {
    "translation": "[ 管理员 ] -> 生成所有S系神器。",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> すべてのSアイテムをスポーンしました。",
      "CN": "[管理员] -> 生成所有S级物品。",
      "KR": "[ 관리 ] -> 모든 S급 아이템을 소환했습니다.",
      "TW": "[ 管理員 ] -> 已生成所有 S 級物品。"
    }
  },
  "[ Admin ] -> as if in a dream.": {
    "translation": "[ 管理员 ] -> 宛如梦境.",
    "MultiLang": {
      "US": "",
      "JP": "[ 管理者 ] -> まるで夢の中のように。",
      "CN": "[混沌] -> 如梦似幻。",
      "KR": "[ 관리자 ] -> 꿈속인 양...",
      "TW": "[ 管理員 ] -> 彷彿置身夢中。"
    }
  },
  "[ Chaos ] -> I thirst for carnage.": {
    "translation": "[ 混沌体现 ] -> 我渴望屠杀。",
    "MultiLang": {
      "US": "",
      "JP": "[ カオス ] -> 血の香りに渇いているのだ。",
      "CN": "[混沌] -> 我渴望屠杀。",
      "KR": "[카오스] -> 학살을 갈구하느니라.",
      "TW": "[ 混沌 ] -> 我渴求屠殺。"
    }
  },
  "[ Chaos ] -> Like lambs to the slaughter!": {
    "translation": "[ 混沌体现 ] -> 你们应当像羔羊一样被宰杀！",
    "MultiLang": {
      "US": "",
      "JP": "[ カオス ] -> 屠畜場に送られる子羊のように！",
      "CN": "[混沌] -> 如同待宰的羔羊！",
      "KR": "[카오스] -> 도살장으로 향하는 양떼들!",
      "TW": "[ 混沌 ] -> 如羔羊赴屠宰場！"
    }
  },
  "[ Chaos ] -> Show me power befitting your station.": {
    "translation": "[ 混沌体现 ] -> 让我看看你的身份该有怎样的力量!",
    "MultiLang": {
      "US": "",
      "JP": "[ カオス ] -> 相応しい実力を見せよ。",
      "CN": "[混沌] -> 展示与你地位相配的力量。",
      "KR": "[카오스] -> 너의 지위에 걸맞은 힘을 보여다오.",
      "TW": "[ 混沌 ] -> 展現配得上你地位的實力。"
    }
  },
  "[ Lishang ] -> All good things must come to an end.": {
    "translation": "[ Lishang ] -> 天下无不散之宴席.",
    "MultiLang": {
      "US": "",
      "JP": "[Lishang] -> 良いことにも終わりがある。",
      "CN": "[ 李商隐 ] 天下没有不散的筵席。",
      "KR": "[리샹] -> 모든 좋은 것은 끝이 있게 마련이다.",
      "TW": "[ 黎商 ] -> 好事總有結束的時候。"
    }
  },
