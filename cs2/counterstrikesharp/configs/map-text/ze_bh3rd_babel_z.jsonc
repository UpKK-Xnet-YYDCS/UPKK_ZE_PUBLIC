{
  "我们已经进入了琪亚娜的记忆中": {
    "translation": "",
    "MultiLang": {
      "US": "We have entered Kiana's memories.",
      "JP": "既にキアナの記憶に入っている",
      "CN": "",
      "KR": "우리는 키아나의 기억 속에 들어왔습니다.",
      "TW": "我們已經進入了琪亞娜的記憶。"
    }
  },
  "环境数据匹配中.....": {
    "translation": "",
    "MultiLang": {
      "US": "Matching environmental data...",
      "JP": "環境データを照合中・・・・・・。",
      "CN": "",
      "KR": "환경 데이터 매칭 중.....",
      "TW": "環境數據匹配中......"
    }
  },
  "环境数据匹配完成": {
    "translation": "",
    "MultiLang": {
      "US": "Environmental data matching complete.",
      "JP": "環境データ照合完了",
      "CN": "",
      "KR": "환경 데이터 매칭 완료",
      "TW": "環境數據匹配完成。"
    }
  },
  "匹配结果:巴比伦实验室!!!!!": {
    "translation": "",
    "MultiLang": {
      "US": "Match result: Babylab laboratory!!!!!",
      "JP": "照合結果：バビロン研究所！！！",
      "CN": "",
      "KR": "매칭 결과: 바빌론 연구실!!!!!",
      "TW": "匹配結果：巴比倫實驗室！"
    }
  },
  "该死,琪亚娜怎么会有巴比伦实验室的记忆?": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it, why does Kiana have memories of the Babylab laboratory?",
      "JP": "くっ、キアナはどうしてバビロン研究所の記憶を持っている？",
      "CN": "",
      "KR": "미쳐! 키아나가 어째서 바빌론 연구실의 기억을 가지고 있지?",
      "TW": "該死，琪亞娜怎麼會有巴比倫實驗室的記憶？"
    }
  },
  "检测到大量死士出没!": {
    "translation": "",
    "MultiLang": {
      "US": "Multiple Death Knights detected!",
      "JP": "大量の死士を確認！",
      "CN": "大量死士出没！",
      "KR": "대량의 시아스 출몰 감지!",
      "TW": "偵測到大量死士出沒！"
    }
  },
  "准备迎战坚守到舱门关闭!": {
    "translation": "",
    "MultiLang": {
      "US": "Prepare to hold our ground until the door is sealed!",
      "JP": "迎撃準備！貨物扉が閉まるまで押し留めろ！",
      "CN": "",
      "KR": "출혈구 폐쇄까지 방어 대기!",
      "TW": "準備迎戰，堅持到艙門關閉！"
    }
  },
  "舱门已成功关闭!": {
    "translation": "",
    "MultiLang": {
      "US": "The door has been successfully sealed!",
      "JP": "貨物扉の完全な閉鎖を確認！",
      "CN": "",
      "KR": "출혈구가 성공적으로 폐쇄되었습니다!",
      "TW": "艙門已成功關閉！"
    }
  },
  "检测到大量死士从后方接近中......": {
    "translation": "",
    "MultiLang": {
      "US": "Large numbers of Death's Hand detected approaching from behind...",
      "JP": "後方から大量の死士が接近中......",
      "CN": "",
      "KR": "후방에서 시신이 다수 접근 중임을 감지했습니다...",
      "TW": "檢測到大量死士從後方接近中……"
    }
  },
  "该死!这些死士到底是从哪里来的?": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it, where are these Death's Hand coming from?",
      "JP": "くそ、この死士たちはいったいどこから現れたんだ？",
      "CN": "",
      "KR": "미쳤다, 이 시신들은 대체 어디서 나온 거야?",
      "TW": "該死！這些死士到底是從哪裡來的？"
    }
  },
  "是第二律者,她正向我们这边传送死士!": {
    "translation": "",
    "MultiLang": {
      "US": "It's the Second Eruption; she's teleporting Death's Hand towards us!",
      "JP": "第二律者だ！彼女が死士をこちらに転送している！",
      "CN": "",
      "KR": "제2의 여왕님입니다, 그녀가 시신을 우리 쪽으로 소환하고 있습니다!",
      "TW": "是第二律者，她正向我們這邊傳送死士！"
    }
  },
  "往上跑,快快快!": {
    "translation": "",
    "MultiLang": {
      "US": "Head upwards, quickly!",
      "JP": "上へ逃げろ、さっさと！",
      "CN": "",
      "KR": "위로 올라가, 빨리! 빨리!",
      "TW": "往上跑，快快快！"
    }
  },
  "该死,上面也有死士出现!": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it, Death's Hand have appeared above as well!",
      "JP": "くそ、上にも死士が出現したぞ！",
      "CN": "",
      "KR": "미쳤다, 위쪽에도 시신이 나타났어!",
      "TW": "該死，上面也有死士出現！"
    }
  },
  "快到桥上!": {
    "translation": "",
    "MultiLang": {
      "US": "Reach the bridge quickly!",
      "JP": "橋まで急げ！",
      "CN": "",
      "KR": "다리의 쪽으로 이동해!",
      "TW": "快到橋上！"
    }
  },
  "趁下一波攻击到来前,赶紧离开这里": {
    "translation": "",
    "MultiLang": {
      "US": "We need to get out of here before the next wave of attacks arrives.",
      "JP": "次の攻撃が来る前に、ここを離れよう。",
      "CN": "等待下一波攻击到来之前，赶紧离开这里",
      "KR": "다음 파도의 공격이 오기 전에, 빠르게 이곳을 떠나라",
      "TW": "趁下一波攻擊到來前，趕緊離開這裡"
    }
  },
  "门被锁住了,我们没有磁卡需要时间破解!": {
    "translation": "",
    "MultiLang": {
      "US": "The door is locked, and we don't have the magstripe to bypass it in time!",
      "JP": "扉は施錠されている、磁気カードを持っていないと解読に時間がかかる！",
      "CN": "",
      "KR": "문이 잠겼습니다. 자기 인식 카드가 없어서 풀어내는 데 시간이 필요합니다!",
      "TW": "門被鎖住了，我們沒有磁卡需要時間破解！"
    }
  },
  "闸门破解完成!": {
    "translation": "",
    "MultiLang": {
      "US": "The gate has been successfully breached!",
      "JP": "ゲート解除完了！",
      "CN": "",
      "KR": "차문 해독 완료!",
      "TW": "閘門破解完成！"
    }
  },
  "这么高的崩坏能浓度是怎么回事!": {
    "translation": "",
    "MultiLang": {
      "US": "How is the Honkai energy level this high!?",
      "JP": "これほど高い崩壊能濃度是怎么回事だ！",
      "CN": "这种高崩坏浓度是怎么回事！",
      "KR": "이렇게 높은 붕괴 에너지 농도는 대체什么情况인가!",
      "TW": "這麼高的崩壞能濃度是怎麼回事！"
    }
  },
  "快启动安全系统降低崩坏能浓度不然我们无法继续前进!": {
    "translation": "",
    "MultiLang": {
      "US": "Hurry and activate the safety systems to reduce Honkai energy levels, or we won't be able to proceed!",
      "JP": "速やかに安全システムを起動して崩壊能濃度を下げろ、さもなくば先には進めん！",
      "CN": "",
      "KR": "빨리 안전 시스템을 가동해서 붕괴 에너지 농도를 낮추지 않으면 앞서 나갈 수 없어!",
      "TW": "快啟動安全系統降低崩壞能濃度，否則我們無法繼續前進！"
    }
  },
  "系统启动中.......崩坏能浓度正在下降......": {
    "translation": "",
    "MultiLang": {
      "US": "System activating... Honkai energy levels are decreasing...",
      "JP": "システム起動中.......崩壊能濃度が低下中......",
      "CN": "",
      "KR": "시스템 가동 중....... 붕괴 에너지 농도 감소 중......",
      "TW": "系統啟動中.......崩壞能濃度正在下降......"
    }
  },
  "崩坏能浓度已降低至安全水平!": {
    "translation": "",
    "MultiLang": {
      "US": "Honkai energy levels have been reduced to a safe level!",
      "JP": "崩壊能濃度が安全レベルまで低下した！",
      "CN": "",
      "KR": "붕괴 에너지 농도가 안전 수준으로 낮아졌습니다!",
      "TW": "崩壞能濃度已降低至安全水平！"
    }
  },
  "ok!现在我们去把那个该死的崩坏炉关掉否者第二律者会更加强大": {
    "translation": "",
    "MultiLang": {
      "US": "Alright! Now let's shut down that damn Honkai reactor, or the Second Eruption will only grow stronger.",
      "JP": "ok!さて、あの忌々しい崩壊炉を止めるか、さもなくば第二律者がいっそう強くなるぞ",
      "CN": "",
      "KR": "좋아! 이제 저 쓰레기 같은 붕괴炉를 끄자. 안 그러면 제2律자가 더 강해질 거야.",
      "TW": "ok!現在我們去把那個該死的崩壞爐關掉，否則第二律者會變得更加強大。"
    }
  },
  "崩坏炉关闭程序启动中!": {
    "translation": "",
    "MultiLang": {
      "US": "Honkai reactor shutdown sequence initiating!",
      "JP": "崩壊炉停止手続き開始中！",
      "CN": "",
      "KR": "붕괴爐 폐쇄 절차 가동 중!",
      "TW": "崩壞爐關閉程序啟動中！"
    }
  },
  "守住这里,直到崩坏炉彻底关闭!": {
    "translation": "",
    "MultiLang": {
      "US": "Hold this position until the Honkai reactor is completely offline!",
      "JP": "ここを守れ、崩壊炉が完全に停止するまで！",
      "CN": "",
      "KR": "붕괴爐가 완전히 닫힐 때까지 여기를 지켜라!",
      "TW": "守住這裡，直到崩壞爐徹底關閉！"
    }
  },
  "崩坏炉已关闭": {
    "translation": "",
    "MultiLang": {
      "US": "Honkai Furnace is offline",
      "JP": "崩壊炉が閉鎖されました",
      "CN": "",
      "KR": "하크렌 엔진이 종료되었습니다",
      "TW": "崩壞爐已關閉"
    }
  },
  "已呼叫电梯！等待40秒": {
    "translation": "",
    "MultiLang": {
      "US": "Elevator summoned! 40-second wait",
      "JP": "エレベーターを呼び出しました。40秒お待ちください",
      "CN": "",
      "KR": "엘리베이터를 호출했습니다! 40초간 대기하십시오",
      "TW": "已呼叫電梯！等待40秒"
    }
  },
  "检测到虚数空间波动大量死士接近中!": {
    "translation": "",
    "MultiLang": {
      "US": "Imaginary Space fluctuation detected.大量 Death Marches are approaching!",
      "JP": "虚数空間の波動を検出。大量の死士が接近中！",
      "CN": "检测到虚数空间波动，大量死士正在接近！",
      "KR": "허수 공간 변동 감지! 다수의 시위가 접근 중입니다!",
      "TW": "檢測到虛數空間波動，大量死士接近中！"
    }
  },
  "守住!等待电梯到来!": {
    "translation": "",
    "MultiLang": {
      "US": "Hold the line! Wait for the elevator's arrival!",
      "JP": "堅持！エレベーター到着まで待ちなさい！",
      "CN": "",
      "KR": "버티세요! 엘리베이터가 올 때까지 기다리십시오!",
      "TW": "守住！等待電梯到來！"
    }
  },
  "里面就是控制中心了坚持到闸门破解完成!": {
    "translation": "",
    "MultiLang": {
      "US": "The Control Center is ahead. Hold out until the gate decryption completes!",
      "JP": "この先は制御センターです。ゲート解除完了まで持堪えてください！",
      "CN": "",
      "KR": "안쪽에 제어 센터가 있습니다. 방독문 해독이 완료될 때까지 버텨라!",
      "TW": "裡面就是控制中心了，堅持到閘門破解完成！"
    }
  },
  "去控制中心调查一下是怎么回事!": {
    "translation": "",
    "MultiLang": {
      "US": "Investigate what's happening at the Control Center!",
      "JP": "制御センターで何が起きているか調べてこい！",
      "CN": "",
      "KR": "제어 센터로 가서 상황을 확인하십시오!",
      "TW": "去控制中心調查一下是怎麼回事！"
    }
  },
  "闸门已关闭数据传输中......": {
    "translation": "",
    "MultiLang": {
      "US": "Gate closed. Data transfer in progress...",
      "JP": "ゲートが閉鎖されました。データ転送中……",
      "CN": "",
      "KR": "방독문이 닫혔습니다. 데이터 전송 중......",
      "TW": "閘門已關閉，數據傳輸中……"
    }
  },
  "该死!她发现我们了": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it! She found us.",
      "JP": "くそっ！彼女に私たちが見つかったぞ！",
      "CN": "该死！她发现了我们。",
      "KR": "시끄러운 녀석! 그녀가 우리를 발견했다!",
      "TW": "該死！她發現我們了"
    }
  },
  "快利用控制台关闭闸门": {
    "translation": "",
    "MultiLang": {
      "US": "Use the console to close the gate!",
      "JP": "早くコンソールでゲートを閉鎖しなさい",
      "CN": "",
      "KR": "컨솔을 이용해 격문을 닫아라",
      "TW": "快利用控制台關閉閘門"
    }
  },
  "守住,等待数据传输完成": {
    "translation": "",
    "MultiLang": {
      "US": "Hold them off while data transfers.",
      "JP": "ここを守り、データ転送が完了するのを待って",
      "CN": "",
      "KR": "방어하라, 데이터 전송이 완료될 때까지 기다려라",
      "TW": "守住，等待數據傳輸完成"
    }
  },
  "数据传输已完成!": {
    "translation": "",
    "MultiLang": {
      "US": "Data transfer complete!",
      "JP": "データ転送完了！",
      "CN": "",
      "KR": "데이터 전송이 완료되었습니다!",
      "TW": "數據傳輸已完成！"
    }
  },
  "守住这里!等待电梯到来": {
    "translation": "",
    "MultiLang": {
      "US": "Hold this position! Wait for the elevator.",
      "JP": "ここを守り、エレベーターが来るのを待って",
      "CN": "",
      "KR": "저기를 방어하라! 엘리베이터가 올 때까지 기다려라",
      "TW": "守住這裡！等待電梯到來"
    }
  },
  "上面被不知名的力量封锁了,正在尝试破解": {
    "translation": "",
    "MultiLang": {
      "US": "The upper level is sealed by an unknown force. I'm trying to crack it.",
      "JP": "上の階は正体不明の力によって封鎖されています。解除を試みています",
      "CN": "上方被未知力量封锁，正在尝试破解。",
      "KR": "상단이 정체不明的한 힘에 의해 봉쇄되었습니다. 해독을 시도 중입니다",
      "TW": "上面被不知名的力量封鎖了，正在嘗試破解"
    }
  },
  "快撤!快撤!赶紧进电梯!": {
    "translation": "",
    "MultiLang": {
      "US": "Run! Get into the elevator!",
      "JP": "逃げるんだ、早く！エレベーターに乗って！",
      "CN": "快撤！快撤！赶紧进电梯！",
      "KR": "빠히 철수하라! 빨리 엘리베이터로 들어가라!",
      "TW": "快撤！快撤！趕緊進電梯！"
    }
  },
  "是琪亚娜!": {
    "translation": "",
    "MultiLang": {
      "US": "It's Kiana!",
      "JP": "キリヤだ！",
      "CN": "",
      "KR": "키아나야!",
      "TW": "是琪亞娜！"
    }
  },
  "她的情况不对劲！": {
    "translation": "",
    "MultiLang": {
      "US": "Something's wrong with her!",
      "JP": "彼女の状況に異常がある！",
      "CN": "",
      "KR": "그녀의 상태가 이상해!",
      "TW": "她的手機狀況不對勁！"
    }
  },
  "她向我们发动攻击了！ ": {
    "translation": "",
    "MultiLang": {
      "US": "She attacked us!",
      "JP": "彼女が攻撃してきた！",
      "CN": "",
      "KR": "그녀가 우리에게 공격을 가했다!",
      "TW": "她向我們發動了攻擊！"
    }
  },
  "快还击她是第二律者！": {
    "translation": "",
    "MultiLang": {
      "US": "Fight back, she's the Second Eruption!",
      "JP": "速やかに反撃。彼女は第2のバーストだ！",
      "CN": "",
      "KR": "빨리 반격해! 그녀는 제2의 비스트입니다!",
      "TW": "快還擊，她是第二律者！"
    }
  },
  "封锁已解除！ ": {
    "translation": "",
    "MultiLang": {
      "US": "The lockdown has been lifted!",
      "JP": "封鎖解除完了！",
      "CN": "",
      "KR": "봉쇄가 해제되었습니다!",
      "TW": "封鎖已解除！"
    }
  },
  "我们击败她了": {
    "translation": "",
    "MultiLang": {
      "US": "We defeated her.",
      "JP": "彼女を倒した",
      "CN": "我们击败了她",
      "KR": "우리가 그녀를 물리쳤습니다.",
      "TW": "我們擊潰了她"
    }
  },
  "现在,守住这里!": {
    "translation": "",
    "MultiLang": {
      "US": "Now, hold your ground!",
      "JP": "今、ここを守れ！",
      "CN": "现在，守住这里！",
      "KR": "지금은 이 곳을 방어하라!",
      "TW": "現在，守住這裡！"
    }
  },
  "返回请求已应答！": {
    "translation": "",
    "MultiLang": {
      "US": "Return request acknowledged!",
      "JP": "帰還リクエスト応答済み！",
      "CN": "",
      "KR": "복귀 요청에 응답합니다!",
      "TW": "返回請求已回應！"
    }
  },
  "赶紧上飞机！": {
    "translation": "",
    "MultiLang": {
      "US": "Get on the plane, quickly!",
      "JP": "急いで機内に乗り込め！",
      "CN": "",
      "KR": "당장 비행기에 탑승하세요!",
      "TW": "趕緊上飛機！"
    }
  },
  "我们成功活下来了": {
    "translation": "",
    "MultiLang": {
      "US": "We made it out alive.",
      "JP": "無事に生き延びた",
      "CN": "",
