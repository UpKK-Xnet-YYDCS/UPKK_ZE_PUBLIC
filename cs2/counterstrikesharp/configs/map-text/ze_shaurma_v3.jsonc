{
  "=== Game Mode : Harmonious Mode ===": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "=== ゲームモード：ハーモニアスモード ===",
      "CN": "=== 游戏模式：和谐模式 ===",
      "KR": "=== 게임 모드 : 하모니 모드 ===",
      "TW": "=== 遊戲模式：和諧模式 ==="
    }
  },
  "=== LEVEL 1: Sewers and Bridge ===": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "=== レベル 1：下水道と橋 ===",
      "CN": "=== 第1关：下水道与桥梁 ===",
      "KR": "=== 레벨 1: 하수구와 교량 ===",
      "TW": "=== 第一關：下水道與橋樑 ==="
    }
  },
  "*** Map By [CygaPb] RoadRunner ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** [CygaPb] RoadRunner によるマップ ***",
      "CN": "*** [CygaPb] RoadRunner 制作地图 ***",
      "KR": "*** 맵 제작: [CygaPb] RoadRunner ***",
      "TW": "*** 地圖設計者 [CygaPb] RoadRunner ***"
    }
  },
  "*** CS2 Version Port By Shana ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** Shana によるCS2版移植 ***",
      "CN": "*** Shana 移植至 CS2 版本 ***",
      "KR": "*** CS2 버전 포팅: Shana ***",
      "TW": "*** CS2 版本移植 Shana ***"
    }
  },
  "*** They're waiting for us at the door. Get out through the windows at the top! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 彼らはドアで待っている。上の窓から抜け出せ！ ***",
      "CN": "*** 他们正在门口等着我们。从顶部的窗户出去！***",
      "KR": "*** 문 앞까지 따라왔어. 위쪽 창문으로 빠져! ***",
      "TW": "*** 他們在門口等著我們，從上方的窗戶逃出！***"
    }
  },
  "*** Follow Vanya. He will lead us to safety ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ヴァーニャに従え。彼が我々を安全な場所へ導いてくれる ***",
      "CN": "*** 跟随瓦尼亚。他会带领我们到达安全地带 ***",
      "KR": "*** 바냐를 따라가. 무사히 데려다 줄 거야 ***",
      "TW": "*** 跟隨瓦尼亞，他會帶我們前往安全地帶 ***"
    }
  },
  "*** Defend in the sewers for 40 seconds ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 40秒間、下水道で防衛せよ ***",
      "CN": "*** 在下水道防御40秒 ***",
      "KR": "*** 40초 동안 하수구에서 방어해 ***",
      "TW": "*** 在下水道守衛40秒 ***"
    }
  },
  "*** 5 SECONDS!!! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 5秒だ！！！ ***",
      "CN": "*** 5秒！！！***",
      "KR": "*** 5초!!! ***",
      "TW": "*** 倒數5秒！！！***"
    }
  },
  "*** Meet Vanya outside ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ヴァーニャと外で落ち合う ***",
      "CN": "*** 在瓦妮娅外面集合 ***",
      "KR": "*** 바니를 밖에서 만나세요 ***",
      "TW": "*** 在瓦妮亞外面集合 ***"
    }
  },
  "*** Defend near the garage for 25 seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ガレージ近くを25秒間防衛！ ***",
      "CN": "*** 在汽车库附近防御25秒！***",
      "KR": "*** 차고 근처에서 25초간 방어하세요! ***",
      "TW": "*** 在車庫附近防守25秒！***"
    }
  },
  "*** 5 Seconds left! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 残り5秒！ ***",
      "CN": "*** 剩余5秒！***",
      "KR": "*** 남은 시간: 5초! ***",
      "TW": "*** 剩餘5秒！ ***"
    }
  },
  "*** Fall back! Get to the parking lot. ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 後退せよ！駐輪場へ向かえ。 ***",
      "CN": "*** 撤退！前往停车场。***",
      "KR": "*** 후퇴하세요. 주차장으로 이동하세요. ***",
      "TW": "*** 撤退！前往停車場。***"
    }
  },
  "*** Teleporting everyone to the parking lot in 15 seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 全員を15秒後に駐車場にテレポート！ ***",
      "CN": "*** 15秒后传送所有人到停车场！***",
      "KR": "*** 15초 내에 모든 사람을 주차장으로 순간이동합니다! ***",
      "TW": "*** 15秒後傳送所有人到停車場！***"
    }
  },
  "*** Player picked up Shaurma (Heal) ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** プレイヤーがシャウルマ（回復アイテム）を拾った ***",
      "CN": "*** 玩家拾取了沙尔玛卷（治疗）***",
      "KR": "*** 플레이어가 샤우르마(체력 회복)를 주웠습니다 ***",
      "TW": "*** 玩家撿起shawarma (回血) ***"
    }
  },
  "*** Hold for 30 seconds ! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 30秒間保持せよ！ ***",
      "CN": "*** 坚守30秒！***",
      "KR": "*** 30초간 버티세요! ***",
      "TW": "*** 堅持30秒！***"
    }
  },
  "*** Run! Get to the warehouse! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 走れ！倉庫へ向かえ！ ***",
      "CN": "*** 快跑！前往仓库！***",
      "KR": "*** 도주하세요. 창고로 이동하세요! ***",
      "TW": "*** 快跑！前往倉庫！***"
    }
  },
  "*** Teleporting everyone to the warehouse in 15 seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 全員を15秒以内に倉庫へテレポート！ ***",
      "CN": "*** 15秒后传送所有人到仓库！ ***",
      "KR": "*** 15초 내에 모든 사람을 창고로 텔레포트합니다! ***",
      "TW": "*** 15 秒後將所有人傳送到倉庫！***"
    }
  },
  "*** Defend the warehouse for 10 seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 倉庫を10秒間防衛せよ！ ***",
      "CN": "*** 防守仓库10秒！ ***",
      "KR": "*** 10초 동안 창고를 방어하십시오! ***",
      "TW": "*** 為期 10 秒的倉庫防禦戰！***"
    }
  },
  "*** Fall back! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 後退だ！ ***",
      "CN": "*** 撤退！ ***",
      "KR": "*** 후퇴하라! ***",
      "TW": "*** 撤退！***"
    }
  },
  "*** We have to keep defending here while train is coming through ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 通過する列車の間、ここで防衛を維持する必要がある ***",
      "CN": "*** 火车经过时，我们必须在此防守 ***",
      "KR": "*** 열차가 통과하는 동안 여기서 방어해야 합니다. ***",
      "TW": "*** 火車經過時，我們必須在此持續防禦 ***"
    }
  },
  "*** 5 more seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** あと5秒！ ***",
      "CN": "*** 还剩5秒！ ***",
      "KR": "*** 5초 남았습니다! ***",
      "TW": "*** 剩餘 5 秒！***"
    }
  },
  "*** Shoot the APC ! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** APCを撃て！ ***",
      "CN": "*** 攻击装甲运兵车！ ***",
      "KR": "*** 장갑차(APC)을 사격하세요! ***",
      "TW": "*** 攻擊裝甲運兵車！***"
    }
  },
  "*** Dodge its shots! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 攻撃を回避しろ！ ***",
      "CN": "*** 躲避它的攻击！ ***",
      "KR": "*** 그 발사를 피하십시오! ***",
      "TW": "*** 躲避它的射擊！***"
    }
  },
  "***TIP: Nades do NOT do extra damage on this boss! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** TIPS: このボス戦では、ナデは追加ダメージを与えません！ ***",
      "CN": "***提示：手雷对 Boss 不会造成额外伤害！***",
      "KR": "***팁: 이 보스에게는 네이프탄이 추가 피해를 주지 않습니다!***",
      "TW": "*** 提示：對這款 Boss 使用手榴彈不會造成額外傷害！***"
    }
  },
  "*** It's dead! Run across the bridge to safety! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 敵を倒せ！橋を渡って安全地帯へ抜けろ！ ***",
      "CN": "***它死了！快跑过桥到安全地带！***",
      "KR": "*** 죽었어! 다리 건너서 안전한 곳으로 도망가! ***",
      "TW": "*** 它已經死了！快跑過橋到安全地帶！***"
    }
  },
  "*** Bridge will be destroyed in 25 seconds ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 橋が爆発するまで残り25秒 ***",
      "CN": "***桥梁将在25秒后爆炸***",
      "KR": "*** 25초 후 다리 파괴 ***",
      "TW": "*** 橋樑將在 25 秒後毀滅 ***"
    }
  },
  "*** Break the railing on the sides for easier defence! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 側面の柵を壊せば防御しやすくなる！ ***",
      "CN": "***拆下两侧的护栏以便更好地防御！***",
      "KR": "*** 양쪽 난간을 부수면 방어하기 더 쉬워져! ***",
      "TW": "*** 破壞兩側的護欄，便於防禦！***"
    }
  },
  "*** 5 Seconds left! Get back! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** あと5秒だ！引き返せ！ ***",
      "CN": "***剩余5秒！快撤退！***",
      "KR": "*** 5초 남음! 물러서! ***",
      "TW": "*** 剩餘 5 秒！快回去！***"
    }
  },
  "*** YOU BEAT LEVEL 1! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** レベル1クリア！ ***",
      "CN": "***你赢了第一关！***",
      "KR": "*** 레벨 1 클리어! ***",
      "TW": "*** 您已通關第 1 關！***"
    }
  },
  "=== LEVEL 2 : Boat and Metro ===": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "=== レベル2：ボート＆地下鉄 ===",
      "CN": "=== 第二关：船与地铁 ===",
      "KR": "=== 레벨 2 : 배와 지하철 ===",
      "TW": "=== 第 2 關：船隻與地鐵 ==="
    }
  },
  "*** They're waiting for us at the door. Get out through the windows at the 2nd floor! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 敵はドアで待ち構えている！2階の窓から逃げろ！ ***",
      "CN": "***他们正在门口埋伏。从二楼的窗户逃走！***",
      "KR": "*** 문 앞에서 우리를 기다리고 있어. 2층 창문으로 빠져나가! ***",
      "TW": "*** 他們在門口等我們。從二樓的窗戶出去！***"
    }
  },
  "*** The gate will open in 15 seconds ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 15秒後に門が開く ***",
      "CN": "***闸门将在15秒后开启***",
      "KR": "*** 15초 후 문 열림 ***",
      "TW": "*** 大門將在 15 秒後開啟 ***"
    }
  },
  "*** Defend for 40 seconds while Vanya is trying to open the door for us! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バニャが扉を開けてくれる間、40秒間防衛しなさい！",
      "CN": "*** 瓦尼亚正在为我们开门，坚持防守40秒！***",
      "KR": "*** 바니아가 문을 열어주는 동안 40초간 방어하세요! ***",
      "TW": "*** 在瓦尼亞試圖為我們開門時，防禦40秒！ ***"
    }
  },
  "*** 5 Seconds remaining! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り5秒！",
      "CN": "*** 剩余5秒！***",
      "KR": "*** 남은 시간 5초! ***",
      "TW": "*** 剩餘5秒！ ***"
    }
  },
  "*** We have no choice. Get in the train and hold for 20 seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "仕方ない。電車に乗って20秒間持ちこたえて！",
      "CN": "*** 我们别无选择。上火车坚持20秒！***",
      "KR": "*** 어쩔 수 없습니다. 기차에 타서 20초간 버텨야 합니다! ***",
      "TW": "*** 我們別無選擇。上車並防禦20秒！ ***"
    }
  },
  "*** 5 Seconds! Get in now! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "5秒！今すぐ乗れ！",
      "CN": "*** 只剩5秒！快上车！***",
      "KR": "*** 5초! 지금 탑승하세요! ***",
      "TW": "*** 5秒內就上車！ ***"
    }
  },
  "***  We should be fine for now ****": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "今は大丈夫だろう",
      "CN": "*** 我们暂时应该安全了。***",
      "KR": "*** 당분간은 괜찮을 것입니다. ***",
      "TW": "*** 我們目前應該沒事了。***"
    }
  },
  "*** [Cop] I think I heard something over there! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[警官] あっちで何か聞こえたぞ！",
      "CN": "*** [警察] 我好像听到那边有动静！***",
      "KR": "*** [경찰관] 저쪽에서 뭔가가 들린 것 같네요! ***",
      "TW": "*** [警察] 我好像聽到那邊有聲音！ ***"
    }
  },
  "*** [Cop] They are here! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[警官] 奴らが現れた！",
      "CN": "*** [警察] 他们来了！***",
      "KR": "*** [경찰관] 그들이 여기 있습니다! ***",
      "TW": "*** [警察] 他們在那裡！ ***"
    }
  },
  "*** Shit! They found us! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "くそ！見つかっちまったぞ！",
      "CN": "*** 该死！他们找到我们了！***",
      "KR": "*** 썩을 놈들! 우리를 찾아냈어! ***",
      "TW": "*** 該死！他們發現我們了！ ***"
    }
  },
  "*** Quick! Get out through that vent in the ceiling! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** すぐその換気口から抜けなさい！ ceiling ***",
      "CN": "*** 快！从天花板的通风口出去！***",
      "KR": "*** 빠르게! 천장 환기구로 빠져라! ***",
      "TW": "*** 快！從天花板的那個通風口出去！ ***"
    }
  },
  "*** [Cop] Kill them all! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** [警察官] 全員始末しろ！ ***",
      "CN": "*** [警察] 杀光他们！***",
      "KR": "*** [경찰] 그들을 모두 죽여라! ***",
      "TW": "*** [警察] 格殺勿論！ ***"
    }
  },
  "*** They cut off the railroad! We need to find another way out. ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 鉄道が分断された。別の脱出経路を探す必要がある。 ***",
      "CN": "*** 他们切断了铁路！我们需要找到另一条出路。***",
      "KR": "*** 철도를 끊겼어! 다른 탈출구를 찾아야 해. ***",
      "TW": "*** 鐵路由他們切斷了！我們得想辦法找其他出路。 ***"
    }
  },
  "*** There is a boat down there! This is our only chance": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 下にボートがある！ これが最後のチャンスだ。 ***",
      "CN": "*** 下面有一艘船！这是我们唯一的机会***",
      "KR": "*** 저기에 배가 있어! 이건 우리의 마지막 chance야.",
      "TW": "*** 下面就有一艘船！這是我們唯一的機會 ***"
    }
  },
  "*** Starting the engine in 10 seconds! Hold on. ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** エンジン始動、10秒後！ 待っててくれ。 ***",
      "CN": "*** 10秒后启动引擎！抓紧。***",
      "KR": "*** 엔진 시동 10초 후 시작! 붙잡고 있어. ***",
      "TW": "*** 引擎啟動倒計時十秒！抓緊了。 ***"
    }
  },
  "*** Jump on the boat now! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 今すぐボートに乗り込め！ ***",
      "CN": "*** 现在跳上船！***",
      "KR": "*** 지금 바로 배로 점프해! ***",
      "TW": "*** 現在上船！ ***"
    }
  },
  "*** They're attacking from both sides. Defend! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 両側から攻撃されている。守れ！ ***",
      "CN": "*** 他们从两侧进攻。防御！***",
      "KR": "*** 양쪽에서 공격해. 방어해! ***",
      "TW": "*** 他們從兩側發動攻擊。防禦！ ***"
    }
  },
  "*** Get off the boat now!!! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 今すぐボートから降りろ！！！ ***",
      "CN": "*** 立刻离开船！！！***",
      "KR": "*** 지금 바로 배에서 내려!!! ***",
      "TW": "*** 立刻離開船！！！ ***"
    }
  },
  "*** Defend here for 25 seconds until garage door opens ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ガレージの扉が開くまで25秒間ここで防衛せよ ***",
      "CN": "***在此防守25秒，直到车库门打开***",
      "KR": "*** 25초 후 차량고장이 열립니다! 여기에서 방어하세요 ***",
      "TW": "*** 在此防守25秒，直到車庫門開啟 ***"
    }
  },
  "*** 5 Seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 残り5秒！ ***",
      "CN": "***仅剩5秒！***",
      "KR": "*** 5초!!! ***",
      "TW": "*** 剩餘5秒！***"
    }
  },
  "*** Dammit! The door is locked! FIND THE KEY! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** くそっ！扉が開かない！キーを探せ！ ***",
      "CN": "***妈的！门被锁住了！找到钥匙！***",
      "KR": "*** 저승사자! 문이 잠겨있네! 열쇠를 찾아!!! ***",
      "TW": "*** 該死！門被鎖住了！找到鑰匙！***"
    }
  },
  "*** We found the key! Excellent! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** キーを発見したぞ！素晴らしい！ ***",
      "CN": "***我们找到钥匙了！太棒了！***",
      "KR": "***열쇠를 찾았습니다! 훌륭합니다!***",
      "TW": "*** 我們找到鑰匙了！太棒了！***"
    }
  },
  "*** Door will open in 10 seconds! Defend! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 10秒後に扉が開く！守れ！ ***",
      "CN": "***门将在10秒后打开！防守！***",
      "KR": "*** 10초 후 문이 열립니다! 방어하세요! ***",
      "TW": "*** 門將在10秒後開啟！防守！***"
    }
  },
  "*** It's open! Run! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 開いた！走れ！ ***",
      "CN": "***门开了！快跑！***",
      "KR": "***문이 열렸습니다! 도망치세요!***",
      "TW": "*** 門開了！快跑！***"
    }
  },
  "***Those guys are shooting at us! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 奴らが俺らに発砲してる！ ***",
      "CN": "***那些人正在向我们射击！***",
      "KR": "*** 저 사람들이 우리를 향해 사격합니다! ***",
      "TW": "*** 那些傢伙在朝我們開槍！***"
    }
  },
  "*** AVOID THE ROCKETS! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ロケット弾を避けろ！ ***",
      "CN": "***躲避火箭弹！***",
      "KR": "*** 미사일을 피하세요! ***",
      "TW": "*** 躲避飛彈！***"
    }
  },
  "*** We beat them! Keep moving! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 成功した！ 急げ！ ***",
      "CN": "*** 我们赢了！继续前进！***",
      "KR": "*** 우리 이겼어! 계속 나아가! ***",
      "TW": "*** 我們打敗他們了！繼續前進！***"
    }
  },
  "*** There is a subway under that road crossing. I will plant the bomb so we can get down there. ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** あの交差点の下に地下鉄がある。爆弾を仕掛けるから、そこから降りてこい。 ***",
      "CN": "*** 那个路口地下有一条地铁隧道。我要在那里安置炸弹，这样我们就能下去。***",
      "KR": "*** 그 도로 건너에 지하철이 있어. 내가 폭탄을 설치해서 내려가자. ***",
      "TW": "*** 那個路口地下有地鐵。我要在那裡安裝炸藥，這樣我們就能下去。***"
    }
  },
  "*** Defend for 20 seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 20秒間守れ！ ***",
      "CN": "*** 坚守20秒！***",
      "KR": "*** 20초 동안 방어해! ***",
      "TW": "*** 防守20秒！***"
    }
  },
  "*** Get down there now! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** そこで待機しろ！ ***",
      "CN": "*** 赶紧下去！***",
      "KR": "*** 지금 내려가! ***",
      "TW": "*** 趕緊下去！***"
    }
  },
  "*** INCOMING TRAINS! GET TO THE SIDE! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 列車接近！ 壁際へ退け！ ***",
      "CN": "*** 火车进站了！躲到旁边去！***",
      "KR": "*** 기차 도착! 옆으로 피해! ***",
      "TW": "*** 火車即將到達！閃開！***"
    }
  },
  "*** Defend for 35 seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 35秒間守れ！ ***",
      "CN": "*** 坚守35秒！***",
      "KR": "*** 35초 동안 방어해! ***",
      "TW": "*** 防守35秒！***"
    }
  },
  "*** Get back! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 下がれ！ ***",
