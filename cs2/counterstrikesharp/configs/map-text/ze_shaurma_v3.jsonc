      "KR": "*** 어쨌든 쏴!! ***",
      "TW": "*** 總之，射他！***"
    }
  },
  "=== RUN BACK! PUTIN CASTED GRAVITY! ===": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "=== 後退しろ！プーチンが重力を唱えた！ ===",
      "CN": "== 快往回跑！普京使用了重力！==",
      "KR": "=\\= 뒤로 바로 도망쳐! 푸틴이 중력을 시전했어! =\\=",
