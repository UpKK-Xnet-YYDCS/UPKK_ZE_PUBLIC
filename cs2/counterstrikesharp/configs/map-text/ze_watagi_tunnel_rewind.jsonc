  "<!> エレベータを動かす -- Move the elevator 30 sec <!>": {
    "translation": "",
    "MultiLang": {
      "US": "<!> Move the elevator 30 sec <!>",
      "JP": "<!> エレベータを動かす -- 30秒でエレベータを動かす <!>",
      "CN": "<!> 移动电梯 -- Move the elevator 30 sec <!>",
