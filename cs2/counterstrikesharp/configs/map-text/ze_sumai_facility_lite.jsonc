  },
  "[Comms]: Seems like the power is out, try looking for a switch.": {
    "translation": "[通讯]:看起来电源断了，试着找个开关。",
    "MultiLang": {
      "US": "",
      "JP": "[通信] 電源が入っていないようです。スイッチを探してください。",
      "CN": "[通讯]: 似乎断电了，请尝试寻找开关。",
      "KR": "[통신]: 전원이 나간 것 같습니다. 스위치를 찾아보세요.",
      "TW": "[通訊]：似乎斷電了，試著找找看開關。"
    }
  },
  "[Comms]: You've got the keycard, now call the elevator asap.": {
    "translation": "[通讯]:你有了钥匙卡，现在尽快呼叫电梯。",
    "MultiLang": {
      "US": "",
      "JP": "[通信] キーカードをお持ちです。エレベーターを呼び出してください。",
      "CN": "[通讯]: 你已获取钥匙卡，请尽快呼叫电梯。",
      "KR": "[통신]: 키카드를 얻었으니 빨리 엘리베이터를 호출하세요.",
      "TW": "[通訊]：你已拿到鑰匙卡，請盡快呼叫電梯。"
    }
  },
  "[Comms]: Zombies picked up the keycard, elevator speed reduced by 75%": {
    "translation": "[通讯]:僵尸拾取了钥匙卡，电梯速度降低75%",
    "MultiLang": {
      "US": "[Comms]: Zombies grabbed the keycard, elevator speed decreased by 75%.",
      "JP": "[通信] ゾンビーがキーカードを持ち去りました。エレベーターの速度が75%減少しました。",
      "CN": "[通讯]: 丧尸拾取了钥匙卡，电梯速度降低75%",
      "KR": "[통신]: 좀비가 키카드를 챙겨갔습니다. 엘리베이터 속도가 75% 감소했습니다.",
      "TW": "[通訊]：殭屍撿到了鑰匙卡，電梯速度降低75%"
    }
  },
  "[Item]: Human picked up Ammo Crate. (1 time use)": {
    "translation": "[物品]:人类拾取了弹药箱。（一次性）",
    "MultiLang": {
      "US": "",
      "JP": "[アイテム] 人間が弾薬箱を持ちました。（1回限り使用）",
      "CN": "[物品]: 人类拾取了弹药箱。 (1次使用)",
      "KR": "[아이템]: 인간이 탄약 상자를 획득했습니다. (1회 사용)",
      "TW": "[物品]：玩家撿取了子彈箱。（一次性使用）"
    }
  },
  "[Item]: Human picked up Bear Trap. (30s CD)": {
    "translation": "[物品]:人类拾取了捕熊器。（冷却30）",
    "MultiLang": {
      "US": "",
      "JP": "[アイテム] 人間がクマ罟を持ちました。（30秒クールダウン）",
      "CN": "[物品]: 人类拾取了熊陷阱。 (30秒冷却)",
      "KR": "[아이템]: 인간이 곰덫을 획득했습니다. (30초 쿨다운)",
      "TW": "[物品]：玩家撿取了熊爪陷阱。（冷卻時間30秒）"
    }
  },
  "[Item]: Human picked up Claymore. (45s CD)": {
    "translation": "[物品]:人类拾取了定时炸弹。（冷却45）",
    "MultiLang": {
      "US": "",
      "JP": "[アイテム] 人間がクレイモアを持ちました。（45秒クールダウン）",
      "CN": "[物品]: 人类拾取了阔剑地雷。 (45秒冷却)",
      "KR": "[아이템]: 인간이 클레이모어를 획득했습니다. (45초 쿨다운)",
      "TW": "[物品]：玩家撿取了闊劍地雷。（冷卻時間45秒）"
    }
  },
  "[Item]: Human picked up Medic Bag. (150s cd)": {
    "translation": "[物品]:人类拾取了医疗包。（冷却150）",
    "MultiLang": {
      "US": "",
      "JP": "[アイテム] ヒューマンが medic bag を拾った (クールタイム 150秒)",
      "CN": "[物品]：玩家拾取了医疗包。(冷却时间：150秒)",
      "KR": "[아이템]: 인간이 의료 가방을 수거했습니다. (150초 CD)",
      "TW": "[物品]：玩家拾取了急救包。（冷卻時間 150 秒）"
    }
  },
  "[Item]: Zombie picked up Breach Charge. (30s CD)": {
    "translation": "[物品]:僵尸拾取了爆破炸药。（冷却30）",
    "MultiLang": {
      "US": "",
      "JP": "[アイテム] ゾンビが breach charge を拾った (クールタイム 30秒)",
      "CN": "[物品]：僵尸拾取了爆破筒。(冷却时间：30秒)",
      "KR": "[아이템]: 좀비가 무전기 폭약을 수거했습니다. (30초 CD)",
      "TW": "[物品]：殭屍拾取了爆破裝藥。（冷卻時間 30 秒）"
    }
  },
  "[Item]: Zombie picked up Poison Grenade. (45s CD)": {
    "translation": "[物品]:僵尸拾取了毒气手雷。（冷却45）",
    "MultiLang": {
      "US": "",
      "JP": "[アイテム] ゾンビが poison grenade を拾った (クールタイム 45秒)",
