      "KR": "[통신]: 게이트가 30초 후 열립니다.",
      "TW": "[通訊]：閘門將在 30 秒後開啟。"
    }
  },
  "[Comms]: Gate will open in 35 seconds.": {
    "translation": "[通讯]:大门将在35秒后打开。",
    "MultiLang": {
