    }
  },
  "[Comms]: Gate will open in 40 seconds.": {
    "translation": "[通讯]:大门将在40秒后打开。",
    "MultiLang": {
      "US": "",
      "JP": "[通信]：ゲートが35秒後に開きます。",
      "CN": "[通讯]：闸门将在40秒后开启。",
      "KR": "[통신]: 게이트가 40초 후 열립니다.",
      "TW": "[通訊]：閘門將在 40 秒後開啟。"
    }
  },
  "[Comms]: Gate will open in 5 seconds.": {
    "translation": "[通讯]:大门将在5秒后打开。",
    "MultiLang": {
      "US": "",
      "JP": "[通信]：ゲートが40秒後に開きます。",
      "CN": "[通讯]：闸门将在5秒后开启。",
      "KR": "[통신]: 게이트가 5초 후 열립니다.",
      "TW": "[通訊]：閘門將在 5 秒後開啟。"
    }
  },
  "[Comms]: Get up to the tower and radio in evac!": {
    "translation": "[通讯]:快到塔顶并呼叫撤离！",
    "MultiLang": {
      "US": "",
      "JP": "[通信] タワーへ上がり、避難場所へ連絡しろ！",
      "CN": "[通讯] 前往塔台并呼叫撤离！",
      "KR": "[통신]: 탑까지 올라가서 대피 요청하세요!",
      "TW": "[通訊]：趕緊登上塔台並回報撤離！"
    }
  },
  "[Comms]: Heli is departing.": {
    "translation": "[通讯]:直升机正在起飞。",
    "MultiLang": {
      "US": "",
      "JP": "[通信] ヘリコプターが出発する。",
      "CN": "[通讯] 直升机已起飞。",
      "KR": "[통신]: 헬기가 출항합니다.",
      "TW": "[通訊]：直升機已離開。"
    }
  },
  "[Comms]: Heli is leaving in 20 seconds.": {
    "translation": "[通讯]:直升机将在20秒后离开。",
    "MultiLang": {
      "US": "",
      "JP": "[通信] ヘリコプターは20秒後に離陸する。",
      "CN": "[通讯] 直升机将在20秒后离开。",
      "KR": "[통신]: 헬기가 20초 후 출발합니다.",
      "TW": "[通訊]：直升機將於20秒後離開。"
    }
  },
  "[Comms]: I've located the keycard, retrieve it.": {
    "translation": "[通讯]:我找到了钥匙卡，取回来。",
    "MultiLang": {
      "US": "",
      "JP": "[通信] キーカードの場所を特定した。取得せよ。",
      "CN": "[通讯] 已定位到门禁卡，请前往回收。",
      "KR": "[통신]: 키카드 위치를 확인했습니다. 회수하세요.",
      "TW": "[通訊]：我已經找到鑰匙卡，請去取回。"
    }
  },
  "[Comms]: Infiltration has been successfully evacuated.": {
    "translation": "[通讯]:渗透已成功撤离。",
    "MultiLang": {
      "US": "",
      "JP": "[通信] 潜入作戦は正常に終了した。",
      "CN": "[通讯] 渗透人员已成功撤离。",
      "KR": "[통신]: 침투 작전, 성공적으로 대피 완료.",
      "TW": "[通訊]：潛入人員已成功撤離。"
    }
  },
  "[Comms]: Infiltration squad has successfully escaped.": {
    "translation": "[通讯]:渗透小队已成功逃脱。",
    "MultiLang": {
      "US": "",
      "JP": "[通信] 潜入班は無事に脱出成功。",
      "CN": "[通讯] 渗透小队已成功逃脱。",
      "KR": "[통신]: 침투 부대, 무사히 탈출 성공.",
      "TW": "[通訊]：潛入小隊已成功逃脫。"
    }
  },
  "[Comms]: Inquiring evac ETA.": {
    "translation": "[通讯]:查询撤离预计时间。",
    "MultiLang": {
      "US": "",
      "JP": "[通信] 避難手段の到着予定時間を照会中。",
      "CN": "[通讯] 询问撤离预计抵达时间（ETA）。",
      "KR": "[통신]: 대피 예상 도착 시간 문의 중.",
      "TW": "[通訊]：詢問撤離預計抵達時間 (ETA)。"
    }
  },
  "[Comms]: Mission failed, infected detected in rescue zone.": {
    "translation": "[通讯]:任务失败，救援区域检测到感染者。",
    "MultiLang": {
      "US": "",
      "JP": "[通信] 任務失敗、救助区域で感染者を確認。",
      "CN": "[通讯] 任务失败，救援区检测到感染者。",
      "KR": "[통신]: 작전 실패. 구조 구역에 감염체 감지.",
      "TW": "[通訊]：任務失敗，救援區內檢測到感染者。"
    }
  },
  "[Comms]: Mission failed, infected detected onboard helicopter.": {
    "translation": "[通讯]:任务失败，直升机上检测到感染者。",
    "MultiLang": {
      "US": "",
      "JP": "[通信]：ミッション失敗、ヘリコプター内で感染者が検出されました。",
      "CN": "[通讯]：任务失败，检测到机库直升机上有感染者。",
      "KR": "[통신]: 임무 실패, 헬기 내에서 감염체 감지.",
      "TW": "[通訊]：任務失敗，機上直升機偵測到感染。"
    }
  },
  "[Comms]: Mission failed, no squad members evacuated.": {
    "translation": "[通讯]:任务失败，没有小队成员撤离。",
    "MultiLang": {
      "US": "",
      "JP": "[通信]：ミッション失敗、部隊員の避難がありませんでした。",
      "CN": "[通讯]：任务失败，没有小队成员被撤离。",
      "KR": "[통신]: 임무 실패, 구출된 편대원이 없음.",
      "TW": "[通訊]：任務失敗，沒有小隊成員撤離。"
    }
  },
  "[Comms]: Mission failed, no squad members reached the next stage.": {
    "translation": "[通讯]:任务失败，没有小队成员达到下个关卡。",
    "MultiLang": {
      "US": "",
      "JP": "[通信]：ミッション失敗、部隊員が次のステージに到達しませんでした。",
      "CN": "[通讯]：任务失败，没有小队成员到达下一阶段。",
      "KR": "[통신]: 임무 실패, 편대원이 다음 단계에 도달하지 못함.",
      "TW": "[通訊]：任務失敗，沒有小隊成員到達下一關卡。"
    }
  },
  "[Comms]: Ok, the power should be on, the gate button should be active.": {
    "translation": "[通讯]:好的，电源应该已开启，门按钮应该已激活。",
    "MultiLang": {
      "US": "",
      "JP": "[通信]：了解、電源が入っているはずです。ゲートのボタンが有効になっているでしょう。",
      "CN": "[通讯]：好的，电源应该接通了，闸门按钮应该已激活。",
      "KR": "[통신]: 알겠어, 전원은 들어갔을 거야. 게이트 버튼도 작동할 것이다.",
      "TW": "[通訊]：好的，電源應該已經開啟，閘門按鈕應該已激活。"
    }
  },
  "[Comms]: Platform has arrived.": {
    "translation": "[通讯]:平台已到达。",
    "MultiLang": {
      "US": "",
      "JP": "[通信]：プラットフォーム到着。",
      "CN": "[通讯]：平台已到达。",
      "KR": "[통신]: 플랫폼 도착.",
      "TW": "[通訊]：平台已到達。"
    }
  },
  "[Comms]: Platform is on its way.": {
    "translation": "[通讯]:平台正在前往中。",
    "MultiLang": {
      "US": "",
      "JP": "[通信]：プラットフォームは移動中です。",
      "CN": "[通讯]：平台正在途中。",
      "KR": "[통신]: 플랫폼 이동 중.",
      "TW": "[通訊]：平台正在前往途中。"
    }
  },
  "[Comms]: Platform will start moving in 10 seconds.": {
    "translation": "[通讯]:平台将在10秒后开始移动。",
    "MultiLang": {
      "US": "",
      "JP": "[通信]：プラットフォームは10秒後に移動を開始します。",
      "CN": "[通讯]：平台将在10秒后开始移动。",
      "KR": "[통신]: 플랫폼이 10초 후 이동을 시작합니다.",
      "TW": "[通訊]：平台將在10秒後開始移動。"
    }
  },
  "[Comms]: Platform will start moving in 20 seconds.": {
    "translation": "[通讯]:平台将在20秒后开始移动。",
    "MultiLang": {
      "US": "",
      "JP": "[通信]：プラットフォームは20秒後に移動を開始します。",
