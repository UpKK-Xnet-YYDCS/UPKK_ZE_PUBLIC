    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> 40秒以内に封印 <",
      "CN": "> 40秒后封印完成 <",
      "KR": "40초 후 봉쇄됩니다.",
      "TW": "40秒內封印。"
    }
  },
  "> ACT I CLEARED <": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "> アクトI クリア <",
      "CN": "第一章 通关",
      "KR": "<b>ACT I 클리어</b>",
      "TW": "第一章通過！"
    }
  },
