  },
  "***Don't let the zombies come inside or we're doomed!***": {
    "translation": "***不要让僵尸闯入，否则我们就完蛋了！***",
    "MultiLang": {
      "US": "",
      "JP": "***ゾンビが内部に入ったら全員アウト！***",
      "CN": "别让丧尸进来，否则我们全完了！***",
      "KR": "***좀비들이 안으로 들어오게 하면 우리가 끝장납니다!***",
      "TW": "別讓殭屍進到裡面，否則我們就死定了！"
    }
  },
  "***Don't let zombies break the bars!***": {
    "translation": "***不要让僵尸破坏栅栏！***",
    "MultiLang": {
      "US": "",
      "JP": "***ゾンビに格子を壊されぬよう守れ！***",
      "CN": "***别让丧尸破坏栅栏！***",
      "KR": "***좀비가 막대를 부수지 못하게 하세요!***",
      "TW": "別讓殭屍撞斷欄杆！"
    }
  },
  "***GO! The door is opening!***": {
    "translation": "***快跑！门正在开启！***",
    "MultiLang": {
      "US": "",
      "JP": "******GO！ 扉が開く！***",
