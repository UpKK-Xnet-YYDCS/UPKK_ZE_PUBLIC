  },
  "***Lift is leaving in 5 seconds!***": {
    "translation": "***电梯将在5秒后离开！***",
    "MultiLang": {
      "US": "",
      "JP": "***エレベーターが5秒後に発進する！***",
      "CN": "***电梯5秒后出发！***",
      "KR": "***엘리베이터 5초 후 발진!***",
      "TW": "***電梯五秒後離開！***"
    }
  },
  "***Make your way to the cockpit and start the engines!***": {
    "translation": "***赶紧到驾驶舱启动引擎！***",
    "MultiLang": {
      "US": "",
      "JP": "***コックットへ向かい、エンジンを始動させろ！***",
      "CN": "***前往驾驶舱，启动引擎！***",
      "KR": "***조종석으로 이동해 엔진 시동을 거는 게 중요해!***",
      "TW": "***前往駕駛艙並啟動引擎！***"
    }
  },
  "***RUN into the ark! Hurry!***": {
    "translation": "***跑进方舟！快点！***",
    "MultiLang": {
      "US": "",
      "JP": "***箱舟へ走れ！急げ！***",
      "CN": "***快跑进方舟！快！***",
      "KR": "***아크 호로 빨리 달려! 얼른!***",
      "TW": "***衝進方舟！快！***"
    }
  },
  "***Ruuuuun!***": {
    "translation": "***快跑！***",
    "MultiLang": {
      "US": "",
      "JP": "***走れっ！***",
      "CN": "***快跑！***",
      "KR": "***달려!!!***",
      "TW": "***快跑！***"
    }
  },
  "***Start the engine by pressing the button!***": {
    "translation": "***按下按钮启动引擎！***",
    "MultiLang": {
      "US": "",
      "JP": "***ボタンを押してエンジンを始動しろ！***",
      "CN": "***按按钮启动引擎！***",
      "KR": "***버튼을 눌러 엔진 시동을 걸거나!***",
      "TW": "***按下按鈕啟動引擎！***"
    }
  },
  "**Arc door 4 opening!": {
    "translation": "**4号方舟门正在打开！**",
    "MultiLang": {
      "US": "",
      "JP": "**箱舟の扉4番、開く！**",
      "CN": "**4号弧形舱门开启！**",
      "KR": "**아크 호 4호실 문 열림!",
      "TW": "**弧門4即將打開！"
    }
  },
  "**Keep zombies on a distance! Shoot between the bars!": {
    "translation": "**与僵尸保持安全距离！去栏杆之间开枪！**",
    "MultiLang": {
      "US": "",
      "JP": "**ゾンビを近づくな！鉄格子の間から撃て！***",
      "CN": "**保持与丧尸的距离，隔着栏杆射击！***",
      "KR": "**좀거리를 멀리서 조종해야 해! 빗장 사이로 쏴!",
      "TW": "**保持殭屍在遠處！對著欄杆射擊！**"
    }
  },
  "**Only a few persons can pass to break what is jamming the gears!***": {
    "translation": "**只有少数人可以通过去解除卡住齿轮的东西！***",
    "MultiLang": {
      "US": "",
      "JP": "歯車の詰まりを解消するには、たった数人しか通れません！*",
      "CN": "只有少数人能通过！打破卡住的齿轮！",
      "KR": "**기계를 틀어막는 장애물을 제거하려면 몇 명만이 통과할 수 있습니다!**",
      "TW": "**只有少數人能夠突破，解決齒輪卡住的問題！**"
    }
  },
  "**Stay fucking defending untill the gears are broken!***": {
    "translation": "**防守到齿轮被破坏！***",
    "MultiLang": {
      "US": "",
      "JP": "歯車が壊れるまでファックしろ、防御を続けるんだ！*",
      "CN": "他妈的死守直到齿轮被破坏！",
      "KR": "**기계가 망가지는 동안 절대 방어하세요!***",
      "TW": "**他媽的死守到齒輪被修好為止！**"
    }
  },
  "**Stay fucking defending untill you are told to run in !***": {
    "translation": "**防守，等待撤退指令！***",
    "MultiLang": {
      "US": "",
      "JP": "走れと命じるまでファックしろ、防御を続けるんだ！*",
      "CN": "他妈的死守直到你接到冲锋指令！",
      "KR": "**점멸 신호가 올 때까지 절대 방어하세요!***",
      "TW": "**他媽的死守到接到突襲指令為止！**"
    }
  },
  "**You got 60 Damn seconds to close the arkdoor!": {
    "translation": "**你有60秒的时间关闭方舟门！**",
    "MultiLang": {
      "US": "",
      "JP": "方舟の扉を閉じるのに60秒しかないぞ！",
      "CN": "你有60秒的该死时间来关闭方舟门！",
      "KR": "**아크 문을 닫을 시간이 딱 60초뿐입니다!",
      "TW": "**你只有60秒的時間關閉方舟門！**"
    }
  },
  "[Ark door is closing!]": {
    "translation": "[方舟门正在关闭！]",
    "MultiLang": {
      "US": "",
      "JP": "[方舟の扉が閉まろうとしている！]",
      "CN": "[方舟门正在关闭！]",
      "KR": "[아크 문이 닫히고 있습니다!]",
      "TW": "[方舟門即將關閉！]"
    }
  },
  "[Clear whatever is jamming the gears first!]": {
    "translation": "[先清理任何卡住齿轮的东西！]",
    "MultiLang": {
      "US": "",
      "JP": "[まず歯車の詰まりを解消しろ！]",
      "CN": "[先清除卡住齿轮的东西！]",
      "KR": "[먼저 기계를 틀어막는 장애물을 제거하세요!]",
      "TW": "[先清除卡住齒輪的東西！]"
    }
  },
  "[The ark door won't close! Something must be jamming the gears!]": {
    "translation": "[方舟门无法关闭！一定有什么东西卡住了齿轮！]",
    "MultiLang": {
      "US": "",
      "JP": "[方舟の扉が閉まらない！何か歯車が詰まっているようだ！]",
      "CN": "[方舟门无法关闭！一定有什么东西卡住了齿轮！]",
      "KR": "[아크문이 닫히지 않습니다! 무언가 기계를 틀어막고 있습니다!]",
      "TW": "[方舟門無法關閉！一定有東西卡住了齒輪！]"
    }
  }
}
