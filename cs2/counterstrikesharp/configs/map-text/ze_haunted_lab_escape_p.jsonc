{
  "* * * LAST DOOR CLOSING IN 40 SECONDS! * * *": {
    "translation": "最后一扇门将在 40 秒后关闭！",
    "MultiLang": {
      "US": "",
      "JP": "* * * 最後の扉、40秒後に閉鎖！ * * *",
      "CN": "* * * 最后一扇门将在40秒后关闭！* * *",
      "KR": "* * 마지막 문 닫힘까지 40초! * *",
      "TW": "* * * 最後一扇門將在40秒後關閉！* * *"
    }
  },
  "* * Pull the Lever to charge the Teleport! * * *": {
    "translation": "拉动拉杆为传送装置充电！",
    "MultiLang": {
      "US": "",
      "JP": "* * レバーを引いてテレポートの準備を！ * * *",
      "CN": "* * 拉动杠杆以激活传送门！* * *",
      "KR": "* * 레버를 당겨 텔레포트를 충전하세요! * *",
      "TW": "* * 拉動操縱桿啟動傳送裝置！* * *"
    }
  },
  "* * * Break the DOOR to Enter! * * *": {
    "translation": "打破大门进入！",
    "MultiLang": {
      "US": "",
      "JP": "* * * 扉を壊して入ろう！ * * *",
      "CN": "* * * 打破房门即可进入！* * *",
      "KR": "* * 문을 부수고 진입하세요! * *",
      "TW": "* * * 破壞門即可進入！* * *"
    }
  },
  "* * Break the iron planks to enter the doors! * *": {
    "translation": "打破铁板进入大门！",
    "MultiLang": {
      "US": "",
      "JP": "* * 鉄の板を壊して扉に入ろう！ * *",
      "CN": "* * 破坏木板以进入下一扇门！* *",
      "KR": "* * 철제 판자를 파괴하여 문으로 진입하세요! * *",
      "TW": "* * 破壞木板即可進門！* *"
    }
  },
  "* * * Get up on the rescue spot! * * *": {
    "translation": "爬上救援点！",
    "MultiLang": {
      "US": "",
      "JP": "* * * 救助ポイントに登れ！ * * *",
      "CN": "* * * 登上救援点！* * *",
      "KR": "* * 구조 구역 위로 올라가세요! * *",
      "TW": "* * * 登上救援點！* * *"
    }
  },
  "* * * Train is leaving in 15 seconds! * * *": {
    "translation": "火车将在 15 秒后离开！",
    "MultiLang": {
      "US": "",
      "JP": "* * * 電車が15秒後に発車！ * * *",
      "CN": "* * * 列车将在15秒后驶离！* * *",
      "KR": "* * 기차가 15초 후에 출발합니다! * *",
      "TW": "* * * 列車將在15秒後發車！* * *"
    }
  },
  "* * The Electric Water will be disabled in 15 seconds! * *": {
    "translation": "水里的电将在 15 秒后失效！",
    "MultiLang": {
      "US": "",
      "JP": "* * 送水装置、15秒後に停止！ * *",
      "CN": "* * 电网将在15秒内关闭！* *",
      "KR": "* * 전기 워터가 15초 후 비활성화됩니다! * *",
      "TW": "* * 電水設施將在15秒後關閉！* *"
    }
  },
  "* * * Electric Water is Disabled * * *": {
    "translation": "水里的电失效了",
    "MultiLang": {
      "US": "",
      "JP": "* * * 送水装置が停止しました * * *",
      "CN": "* * * 电网已关闭 * * *",
      "KR": "* * 전기 워터가 비활성화되었습니다 * *",
      "TW": "* * * 電水設施已關閉* * *"
    }
  },
  "* * * Teleport is Charged in 30 Seconds! * * *": {
    "translation": "传送装置将在 30 秒后充电！",
    "MultiLang": {
      "US": "",
      "JP": "* * * テレポートのチャージが30秒後に完了します！* * *",
      "CN": "* * * 传送技能30秒后就绪！* * *",
      "KR": "* * * 텔레포트 30초 후 발동! * * *",
      "TW": "* * * 傳送已在 30 秒後就緒！* * *"
    }
  },
  "* * * Run to the Safe Room! * * *": {
    "translation": "跑向安全室！",
    "MultiLang": {
      "US": "",
      "JP": "* * * 安全な部屋へ避難してください！* * *",
      "CN": "* * * 快跑进安全屋！* * *",
      "KR": "* * * 안전실로 이동하세요! * * *",
      "TW": "* * * 跑向安全室！* * *"
    }
  },
  "* * * The Water is Electric so dont swim! * * *": {
    "translation": "水里有电，不要游泳！",
    "MultiLang": {
      "US": "",
      "JP": "* * * 水が帯電しているため泳がないでください！* * *",
      "CN": "* * * 水通电，禁止游泳！* * *",
      "KR": "* * * 전기가 흐르는 물이므로 수영하지 마세요! * * *",
      "TW": "* * * 水有電，不要游泳！* * *"
    }
  },
  "* * * Get on the Train! * * *": {
    "translation": "快上火车",
    "MultiLang": {
      "US": "",
      "JP": "* * * 電車に乗ってください！* * *",
      "CN": "* * * 快上火车！* * *",
      "KR": "* * * 기차로 이동하세요! * * *",
      "TW": "* * * 上列車！* * *"
    }
  },
  "* * * Zombie Nervegas Activated in 5 Seconds! * * *": {
    "translation": "僵尸神经毒气在 5 秒内激活！",
    "MultiLang": {
      "US": "",
      "JP": "* * * ゾンビー神経ガスの充塡が5秒後に開始されます！* * *",
      "CN": "* * * 丧尸毒气5秒后激活！* * *",
      "KR": "* * * 좀비 신경가스 5초 후 발동! * * *",
      "TW": "* * * 殭屍神經毒氣將在 5 秒後啟動！* * *"
    }
  },
  "* * * Zombie Shield Disabled! * * *": {
    "translation": "僵尸防护罩失效",
    "MultiLang": {
      "US": "",
      "JP": "* * * ゾンビーシールド無効化！* * *",
      "CN": "* * * 丧尸护盾已禁用！* * *",
      "KR": "* * * 좀비 방패 비활성화! * * *",
      "TW": "* * * 殭屍護盾已停用！* * *"
    }
  },
  "* * Zombie Shield Activated! * *": {
    "translation": "僵尸防护罩启动！",
    "MultiLang": {
      "US": "",
      "JP": "* * ゾンビーシールド有効化！* *",
      "CN": "* * 丧尸护盾已激活！* *",
      "KR": "* * 좀비 방패 활성화! * *",
      "TW": "* * 殭屍護盾已啟動！* *"
    }
  },
  "* * * Zombie Shield Disable in 20 Seconds! * * *": {
    "translation": "僵尸防护罩 20 秒后失效！",
    "MultiLang": {
      "US": "",
      "JP": "* * * ゾンビーシールド無効化が20秒後に開始されます！* * *",
      "CN": "* * * 丧尸护盾20秒后禁用！* * *",
      "KR": "* * * 좀비 방패 20초 후 비활성화! * * *",
      "TW": "* * * 殭屍護盾將在 20 秒後停用！* * *"
    }
  },
  "* * * The Gate Door Will Open in 5 Seconds! * * *": {
    "translation": "大门将在5秒内打开",
    "MultiLang": {
      "US": "",
      "JP": "*** 5秒後に門が開きます！ ***",
      "CN": "* * * 城门将在5秒后开启！* * *",
      "KR": "* * * 5초 후에 문이 열립니다! * * *",
      "TW": "* * * 城門将在5秒後開啟！* * *"
    }
  },
  "* * * Zombie Shield Activated in 20 Seconds!": {
    "translation": "僵尸防护罩 20 秒后激活",
    "MultiLang": {
      "US": "",
      "JP": "* * * 20秒後にゾンビシールド発動!",
      "CN": "* * * 僵尸护盾将在20秒后激活！",
      "KR": "* * * 20초 후 저장막 발동!",
      "TW": "* * * 殭屍護盾在20秒後啟動！"
    }
  },
  "* * * The Gate Door Will Open in 10 Seconds! * * *": {
    "translation": "大门将在 10 秒后打开！",
    "MultiLang": {
      "US": "",
      "JP": "*** 10秒後に門が開きます！ ***",
      "CN": "* * * 城门将在10秒后开启！* * *",
      "KR": "* * * 10초 후에 문이 열립니다! * * *",
      "TW": "* * * 城門将在10秒後開啟！* * *"
    }
  }
}
