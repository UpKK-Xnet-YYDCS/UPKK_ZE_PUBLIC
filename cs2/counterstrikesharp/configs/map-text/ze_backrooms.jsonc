  "Door opening in 10 s.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "10秒後に扉が開きます。",
      "CN": "大门将在 10 秒后开启。",
      "KR": "10초 후 문 개봉.",
      "TW": "大門即將在 10 秒後開啟。"
    }
  },
  "Door opening in 5 s.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "5秒後に扉が開きます。",
      "CN": "大门将在 5 秒后开启。",
      "KR": "5초 후 문 개봉.",
      "TW": "大門即將在 5 秒後開啟。"
    }
  },
  "Mass teleport in 15 s.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "15秒後に大量テレポ",
      "CN": "大规模传送将在 15 秒后启动。",
      "KR": "15초 후 일괄 텔레포트.",
      "TW": "15 秒後進行大型傳送。"
    }
  },
  "A door has been broken down.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "扉が壊されています。",
      "CN": "一扇门已被撞开。",
      "KR": "문이 부서졌습니다.",
      "TW": "一扇門已被撞開。"
    }
  },
  "Explosive Pillow found.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "爆発性の枕を発見。",
      "CN": "发现爆炸枕头。",
