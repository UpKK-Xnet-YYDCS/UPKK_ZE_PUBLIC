    }
  },
  "**Defend 80 seconds**": {
    "translation": "**防守80秒**",
    "MultiLang": {
      "US": "",
      "JP": "80秒間守れ",
      "CN": "**坚守80秒**",
      "KR": "**80초 동안 방어**",
      "TW": "**防禦80秒**"
    }
  },
  "**Everyone is immune during this time**": {
    "translation": "**现在所有人类都是免抓的，时间到没过的将跟僵尸一起传送**",
    "MultiLang": {
      "US": "",
      "JP": "この間、すべてのプレイヤーは無敵状態です",
      "CN": "**此期间所有人免疫**",
      "KR": "**이 시간 동안 모든 플레이어가 무적 상태입니다**",
      "TW": "**在此期間所有人免疫傷害**"
    }
  },
  "**Map by ApeXe & Bushido**": {
    "translation": "**地图作者：ApeXe & Bushido 汉化：秋刀鱼**",
    "MultiLang": {
      "US": "",
