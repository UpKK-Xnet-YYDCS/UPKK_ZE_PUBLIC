{
  "***Boat is leaving in 30s! Get on quick!!!***": {
    "translation": "***船将在30秒后离开！快上船！！！***",
    "MultiLang": {
      "US": "",
      "JP": "船が30秒後に離れます！quickに乗ってください！！！",
      "CN": "***船将在30秒后离开！快上来！！！***",
      "KR": "***배가 30초 후에 출항합니다! 빨리 탑승하세요!!!***",
      "TW": "***船隻即將離岸，倒數30秒！趕快上船！！！***"
    }
  },
  "***Defend the temple of Zeus for 45s!***": {
    "translation": "***防守宙斯神庙45秒！***",
    "MultiLang": {
      "US": "",
      "JP": "ゼウスの神殿を45秒間守れ！！！",
      "CN": "***保卫宙斯的神庙45秒！***",
      "KR": "***45초 동안 제우스 신전을 방어하세요!***",
      "TW": "***守護宙斯神廟45秒！***"
    }
  },
  "***Gate will close in 10s! Defend your position against the zombies!***": {
    "translation": "***大门将在10秒后关闭！保卫你的阵地，抵御僵尸！***",
    "MultiLang": {
      "US": "",
      "JP": "門が10秒後に閉じます！ザンビに対抗して陣地を守れ！！！",
      "CN": "大门将在10秒后关闭！守住你的阵地，抵御僵尸！***",
      "KR": "***문이 10초 후에 닫힙니다! 좀비로부터 입장을 방어하세요!***",
      "TW": "門將在10秒後關閉！請據守陣地，抵禦殭屍的攻擊！***"
    }
  },
  "***Gate will open in 15s! Defend yourself against the zombies!***": {
    "translation": "***大门将在15秒后打开！保护自己，抵御僵尸！***",
    "MultiLang": {
      "US": "",
      "JP": "門が15秒後に開きます！ザンビに対抗して身を守れ！！！",
      "CN": "大门将在15秒后打开！保护自己，抵御僵尸！***",
      "KR": "***문이 15초 후에 열립니다! 좀비로부터 자신을 방어하세요!***",
      "TW": "***門將在15秒後開啟！請奮力自衛，抵禦殭屍的攻擊！***"
    }
  },
