    }
  },
  "(>>Elevators will move in 40 seconds<<)": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "（エレベーターが40秒後に稼働します）",
      "CN": "（电梯将在40秒后启动）",
      "KR": "(>>엘리베이터가 40초 후에 움직입니다<<)",
      "TW": "（電梯將於 40 秒後運轉）"
    }
  },
  ">> Madara has casted ultima <<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "マダラがアルティマを唱えました",
