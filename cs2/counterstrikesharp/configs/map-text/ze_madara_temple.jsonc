    }
  },
  ">> Rock will explode in 10 seconds <<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">> 岩が10秒後に爆発します <<",
      "CN": ">> 岩石将在10秒后爆炸 <<",
