    }
  },
  "<<< Although the reason is not clear, the manipulators behind it will definitely stop us >>>": {
    "translation": "<<<虽然原因不明，但背后的操控者肯定会阻止我们>>>",
    "MultiLang": {
      "US": "",
      "JP": "理由は不明だが、背後の操り者が私達を止めるのは確実だ",
      "CN": "虽然原因不明，但幕后操纵者定会阻止我们",
      "KR": "원인은 명확하지 않지만, 배후의 조종자들이 우리를 막을 것이다",
      "TW": "<<< 雖然原因不明，但幕後的黑手絕對會阻止我們 >>>"
    }
  },
  "<<< Although we have left the town temporarily, there are evil spirits bound there >>>": {
    "translation": "<<<虽然我们暂时离开了城镇，但那里仍然有恶灵束缚>>>",
    "MultiLang": {
      "US": "",
      "JP": "一時的に街から離れているが、そこに縛られた悪霊がいる",
      "CN": "虽然我们暂时离开了城镇，但有恶灵被束缚于此",
      "KR": "마을을 일시적으로 떠났지만, 그곳에는 매달린 악령들이 있다",
      "TW": "<<< 雖然我們暫時離開了城鎮，但仍有多餘的邪靈被約束在那裡 >>>"
    }
  },
  "<<< However, we should pay attention to the houses in towns. We do not know when the enemy will launch an attack >>>": {
    "translation": "<<<然而，我们应该注意城镇里的房屋。我们不知道敌人何时会发动攻击>>>",
    "MultiLang": {
      "US": "",
      "JP": "しかし、街の家屋には注意する必要がある。敵が攻撃をしかけてくる時期はわからない",
      "CN": "然而，我们必须关注城镇中的房屋。我们不知道敌人何时会发动攻击",
      "KR": "그러나 마을의 가옥들에 주의해야 한다. 적들이 언제 공격할지 모른다",
      "TW": "<<< 但是，我們應該注意城鎮的房屋。我們不知道敵人何時會發動攻擊 >>>"
    }
  },
  "<<< May Lordaeron protect us >>>": {
    "translation": "<<<愿洛丹伦保护我们>>>",
    "MultiLang": {
      "US": "",
      "JP": "ロデロンのご加護あれ",
      "CN": "愿洛丹伦保佑我们",
      "KR": "로더론이 우리를 지켜주시기를",
      "TW": "<<< 願洛丹倫保佑我們 >>>"
    }
  },
  "<<< May Lordaeron shine on us! >>>": {
    "translation": "<<<愿洛丹伦照耀我们！>>>",
    "MultiLang": {
      "US": "",
      "JP": "ロデロンが我々に光を注がんことを！",
      "CN": "愿洛丹伦的光辉照耀我们！",
      "KR": "로더론이 우리에게 빛을 비추시기를!",
      "TW": "<<< 願洛丹倫之光照耀我們！ >>>"
    }
  },
  "<<< The Ministry has completely collapsed and needs to be reported to Lordaeron urgently >>>": {
    "translation": "<<<部门已经完全崩溃，需要紧急报告给洛丹伦>>>",
    "MultiLang": {
      "US": "",
      "JP": "省庁は完全に崩壊しており、ロデロンへ緊急に報告する必要がある",
      "CN": "该部门已完全崩溃，需紧急向洛丹伦汇报",
      "KR": "성부는 완전히 무너졌으며 로더론에 긴급히 보고해야 한다",
      "TW": "<<< 內政部已經完全崩潰，需要立即向洛丹倫報告 >>>"
    }
  },
  "<<< The roads in the town have been destroyed. There's nothing we can do but continue to the valley >>>": {
    "translation": "<<<镇上的道路已被摧毁。我们只能继续前往山谷>>>",
    "MultiLang": {
      "US": "",
      "JP": "街の道路は破壊されている。谷へと進み続ける以外に打つ手はない",
      "CN": "城镇的道路已被破坏。我们除了继续前往山谷外，别无他法",
      "KR": "마을의 도로는 파괴되었다. 우리는 계곡으로 계속 진행할 수밖에 없다",
      "TW": "<<< 城鎮的道路已被摧毀。我們無能為力，只能繼續前往山谷 >>>"
    }
  },
  "<<< This is the southwest outpost in Lordaeron,Stormwind Keep >>>": {
    "translation": "<<<这是洛丹伦的西南前哨，暴风城堡>>>",
    "MultiLang": {
      "US": "",
      "JP": "ここはロデロン南西の前哨基地、ストームウィンド砦だ",
      "CN": "这里是洛丹伦西南前哨站：暴风要塞",
      "KR": "여기는 로더론의 남서쪽 전초기지, 스톰윈드 성채입니다",
      "TW": "<<< 這是洛丹倫的西南前哨站，風暴城要塞 >>>"
    }
  },
  "<<< Time waits for no one. We need to get out of here as soon as possible >>>": {
    "translation": "<<<时间不等人。我们必须尽快离开这里>>>",
    "MultiLang": {
      "US": "",
      "JP": "刻は我々を待たない。できるだけ早くここから出る必要がある",
      "CN": "时不我待，我们必须尽快离开这里。",
      "KR": "시간은 누구를 기다려주지 않는다. 우리는 가능한 한 빨리 이곳을 떠날 필요가 있다.",
      "TW": "時間不等人，我們必須盡快離開這裡。"
    }
  },
  "<<< We stumbled into the storm fortress >>>": {
    "translation": "<<<我们跌入了暴风城堡的堡垒>>>",
    "MultiLang": {
      "US": "",
      "JP": "嵐の砦に紛れ込んだ",
      "CN": "我们误入了风暴堡垒。",
      "KR": "우리는 폭풍의 요새를 발견했다.",
      "TW": "我們誤入了風暴堡壘。"
    }
  },
  "<<< We'll cross the valley ahead to find our way to Lordaeron >>>": {
    "translation": "<<<我们将穿越前方的山谷，找到通往洛丹伦的路>>>",
    "MultiLang": {
      "US": "",
      "JP": "手前の谷を越えてロイドアローンへの道を見つけるだろう",
      "CN": "我们将穿越前方的山谷，寻找前往洛丹伦的路。",
      "KR": "앞의 계곡을 넘어 로더론으로 가는 길을 찾으려 한다.",
      "TW": "我們將穿越前方的山谷，尋找通往洛爾多隆的路徑。"
    }
  },
  ">> A player has picked up healing <<": {
    "translation": ">>一名玩家拾取了奶<<",
    "MultiLang": {
      "US": "",
      "JP": ">> 味方が回復アイテムを持ちました <<",
      "CN": ">>一名玩家拾取了治疗<<",
      "KR": ">> 플레이어가 회복 장비를 수집했습니다. <<",
      "TW": ">> 一名玩家拾取了治療藥劑 <<"
    }
  },
  ">> A player picked up lightning <<": {
    "translation": ">>一名玩家拾取了电<<",
    "MultiLang": {
      "US": "",
      "JP": ">> 味方が雷属性のアイテムを持ちました <<",
      "CN": ">>一名玩家拾取了闪电术<<",
      "KR": ">> 플레이자가 번개 장비를 수집했습니다. <<",
      "TW": ">> 一名玩家拾取了閃電 <<"
    }
  },
  ">> A player picked up soil <<": {
    "translation": ">>一名玩家拾取了土<<",
    "MultiLang": {
      "US": "",
      "JP": ">> 味方が土属性のアイテムを持ちました <<",
      "CN": ">>一名玩家拾取了土壤<<",
      "KR": ">> 플레이자가 흙 장비를 수집했습니다. <<",
      "TW": ">> 一名玩家拾取了泥土 <<"
    }
  },
  ">> A player picked up the circular wind <<": {
    "translation": ">>一名玩家拾取了环形风<<",
    "MultiLang": {
      "US": "",
      "JP": ">> 味方が円環風のアイテムを持ちました <<",
      "CN": ">>一名玩家拾取了回旋风灵<<",
      "KR": ">> 플레이자가 원형 바람 장비를 수집했습니다. <<",
      "TW": ">> 一名玩家拾取了旋風 <<"
    }
  },
  ">>One player picked up the wind<<": {
    "translation": ">>一名玩家拾取了风<<",
    "MultiLang": {
      "US": "",
      "JP": ">> 1人のプレイヤーが風属性のアイテムを持ちました <<",
      "CN": ">>一名玩家拾取了疾风之语<<",
      "KR": ">> 플레이어 한 명이 바람 장비를 수집했습니다. <<",
      "TW": ">> 一名玩家拾取了風 <<"
    }
  },
  ">>One player picker up the flame<<": {
    "translation": ">>一名玩家拾取了火<<",
    "MultiLang": {
      "US": "",
      "JP": ">>プレイヤーが火を受け取る<<",
      "CN": ">>一名玩家拾取了火焰<<",
      "KR": "플레이어가 화염을 집어들었습니다",
      "TW": ">>一名玩家撿起了火焰<<"
    }
  },
  "A player has picked up the book": {
    "translation": "***一名玩家拾取了书***",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが本を受け取った",
      "CN": "一名玩家已拾取书本",
      "KR": "플레이어가 책을 집어 들었습니다",
      "TW": "一名玩家已撿起書籍"
    }
  },
  "say ** good job! This book records how to unlock the switch and protect it **": {
    "translation": "**干得好！这本书记录了如何解锁开关并保护它**",
    "MultiLang": {
      "US": "",
      "JP": "言う** 良くやりました！この本はスイッチの解除方法と保護を記録しています **",
      "CN": "说 **做得好！这本书记录了如何解锁并保护开关**",
      "KR": "잘했어요! 이 책에는 스위치를 해제하고 보호하는 방법이 기록되어 있습니다",
      "TW": "說 ** 好棒！這本書記錄瞭如何解鎖開關並保護它 **"
    }
  },
  "** Hold for 15 seconds **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 15秒間押し続けてください **",
      "CN": "**保持15秒**",
      "KR": "**15초 동안 누르세요**",
      "TW": "** 持續按住 15 秒 **"
    }
  },
  "**10s**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**10秒**",
      "CN": "**10秒**",
      "KR": "**10초**",
      "TW": "** 10秒**"
    }
  },
  "** Break the small door, please wait **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 小さなドアを壊してください、お待ちください **",
      "CN": "**请砸开小门，请稍候**",
      "KR": "**작은 문을 부수세요. 잠시만 기다려 주세요**",
      "TW": "** 請稍候，正在打破小門 **"
    }
  },
  "** Resist zombies for 30 seconds **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**30秒間ゾンジに耐えてください **",
      "CN": "**抵抗僵尸30秒**",
      "KR": "** 좀비를 30초간 막아주세요 **",
      "TW": "** 抵抗殭屍 30 秒 **"
    }
  },
  "** Please wait 30 seconds **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 30秒お待ちください **",
      "CN": "**请等待30秒**",
      "KR": "** 30초간 기다려 주세요 **",
      "TW": "** 請稍候 30 秒 **"
    }
  },
  "** Well done, defend the window for 15 seconds **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "よくやった、15秒間窓を防衛せよ",
      "CN": "**干得好，防御窗口15秒**",
      "KR": "** 잘했어, 15초간 창문을 방어해 **",
      "TW": "** 做得好，守衛窗口 15 秒**"
    }
  },
  "** The transmitter has 15 seconds to trigger **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "送信機が作動するまで残り15秒",
      "CN": "**发射器有15秒的时间激活**",
      "KR": "** 송신기가 작동하는 데 15초 걸림 **",
      "TW": "** 發射器有 15 秒觸發時間**"
    }
  },
  "** Route change, drag the zombie for 30 seconds **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ルート変更、30秒間ゾンビを引きずれ",
      "CN": "**改变路线，牵引僵尸30秒**",
      "KR": "** 경로 변경, 좀비 30초간 끌고 가기 **",
      "TW": "** 路線變更，拖著殭屍 30 秒**"
    }
  },
  "** The gate is open. Retreat **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "門が開いた。退却せよ",
      "CN": "**大门已开。撤退。**",
      "KR": "** 문이 열림. 후퇴 **",
      "TW": "** 門已打開，撤退**"
    }
  },
  "**  20s door open **": {
    "translation": "",
    "MultiLang": {
      "US": "*** 20s Door Open ***",
      "JP": "20秒後に扉が開く",
      "CN": "**20秒后开门**",
      "KR": "** 20초 후 문 개방 **",
      "TW": "** 20秒後開門**"
    }
  },
  "** After 30 seconds, open the wooden door and activate the final transmission **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "30秒後、木製の扉を開き最終送信を起動せよ",
      "CN": "**30秒后打开木门并启动最终传输**",
      "KR": "** 30초 뒤 나무 문을 열고 최종 송신 시작 **",
      "TW": "** 30秒後打開木門並啟動最終傳輸**"
    }
  },
  "** Retreat, find the next route, watch out for zombies **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "退却、次のルートを探せ、ゾンビに注意",
      "CN": "**撤退，找到下一条路线，注意僵尸。**",
      "KR": "** 후퇴, 다음 경로 찾기, 좀비 주의 **",
      "TW": "** 撤退，尋找下一條路線，注意殭屍**"
    }
  },
  "** The door is closed, there is no way out! **": {
    "translation": "",
    "MultiLang": {
      "US": "**The door is closed, no way out!**",
      "JP": "扉が閉まった、脱出路なし！",
      "CN": "**门关了，无路可逃！**",
      "KR": "** 문이 닫혔다. 탈출구 없음! **",
      "TW": "** 門關閉了，沒有出路！**"
    }
  },
  "** The road is open. Let's go **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "道が開いた。行こう",
      "CN": "**道路已开辟，我们走吧。**",
      "KR": "길은 열려 있습니다. 갑시다.",
      "TW": "** 道路已開通，我們走吧 **"
    }
  }
}
