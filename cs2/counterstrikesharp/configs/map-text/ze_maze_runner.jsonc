  "找齐了全部的电池，你们做到了！": {
    "translation": "",
    "MultiLang": {
      "US": "You've collected all the batteries. You did it!",
      "JP": "全バッテリーを集めた！やったぜ！",
      "CN": "",
      "KR": "모든 배터리를 수집했습니다. 여러분이 해냈습니다!",
      "TW": "找齊了全部的電池，你們做到了！"
    }
  },
  "再坚持一会！等待电梯启动": {
    "translation": "",
    "MultiLang": {
      "US": "Hang in there! Wait for the elevator to start.",
      "JP": "もう少し待て！エレベータが動き出すまで待ってくれ",
      "CN": "",
      "KR": "조금만 더 참아 주세요! 엘리베이터 작동을 기다려 주세요",
      "TW": "再堅持一會兒！等待電梯啟動"
    }
  },
  "快上电梯！我们要逃出这鬼地方！": {
    "translation": "",
    "MultiLang": {
      "US": "Get on the elevator! We're escaping this dump!",
      "JP": "急いで乗れ！ここから逃げなければならない！",
      "CN": "",
      "KR": "빨리 엘리베이터로 이동하세요! 여기서脱출합시다!",
      "TW": "快上電梯！我們要逃出這鬼地方！"
    }
  },
  "run!run!run!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "走け！ 走け！",
      "CN": "跑！跑！快跑！",
      "KR": "달려라! 달려라! 달려라!",
      "TW": "run!run!run!"
    }
  },
  "你们做到了！卖人的狗！": {
    "translation": "",
    "MultiLang": {
      "US": "You did it! You selling dogs!",
      "JP": "やったな！ 裏切りの犬どもが！",
      "CN": "",
      "KR": "네티즌들이 해냈습니다! 개 같은 인간들을 파는 자들!",
      "TW": "你們做到了！賣人的狗！"
    }
  }
