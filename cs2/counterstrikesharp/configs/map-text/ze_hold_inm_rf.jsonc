  ">> なんでこんなところにゆうさくが！？ <<": {
    "translation": "",
    "MultiLang": {
      "US": ">> Why is Yusak here?! <<",
      "JP": "",
      "CN": ">> 为什么柚坂会在这里！？ <<",
