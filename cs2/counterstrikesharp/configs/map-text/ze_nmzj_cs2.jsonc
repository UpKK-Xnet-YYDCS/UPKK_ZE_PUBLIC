{
  "我的头好痛啊 这里是哪？": {
    "translation": "",
    "MultiLang": {
      "US": "My head hurts a lot, where am I?",
      "JP": "我的头好痛啊 这里是哪？",
      "CN": "",
      "KR": "My head hurts, where am I",
      "TW": "我的頭好痛啊，這裡是哪？"
    }
  },
  "我刚才不是在玩月影传说吗": {
    "translation": "",
    "MultiLang": {
      "US": "I wasn't playing Moon Shadow Legend earlier",
      "JP": "我刚才不是在玩月影传说吗",
      "CN": "",
      "KR": "I wasn't playing Moonlight Legend just now",
      "TW": "我剛才不是在玩月影傳說嗎"
    }
  },
  "先不管了出去看看外面什么情况": {
    "translation": "",
    "MultiLang": {
      "US": "Let's worry about it later and go see what's outside",
      "JP": "先不管了出去看看外面什么情况",
      "CN": "",
      "KR": "Never mind, let's go check what's outside first",
      "TW": "先不管了，出去看看外面的情況吧"
    }
  },
  "这个门好像出了点问题": {
    "translation": "",
    "MultiLang": {
      "US": "This door seems to have a problem",
      "JP": "这个门好像出了点问题",
      "CN": "",
      "KR": "This door seems to have a problem",
      "TW": "這個門好像有點問題"
    }
  },
  "搜索一下其他地方看看": {
    "translation": "",
    "MultiLang": {
      "US": "Search other places and see what's there",
      "JP": "搜索一下其他地方看看",
      "CN": "",
      "KR": "Search other places to see what's there",
      "TW": "搜索一下其他地方看看"
    }
  },
  "我醒来的房间好像有东西 做好战斗准备": {
    "translation": "",
    "MultiLang": {
      "US": "When I woke up, something was in my room. Get ready for battle.",
      "JP": "我醒来的房间好像有东西 做好战斗准备",
      "CN": "",
      "KR": "The room I woke up in seems to have something, get ready for battle!",
      "TW": "我醒來的房間好像有東西，做好戰鬥準備吧"
    }
  },
  "防守10秒": {
    "translation": "",
    "MultiLang": {
      "US": "Defend for 10 seconds",
      "JP": "防守10秒",
      "CN": "",
      "KR": "Defend for 10 seconds",
      "TW": "防守10秒內退出！"
    }
  },
  "我找到钥匙了": {
    "translation": "",
    "MultiLang": {
      "US": "I found the key",
      "JP": "我找到钥匙了",
      "CN": "",
      "KR": "I found the key",
      "TW": "我找到了鑰匙"
    }
  },
  "那个管道传来了怪物的声音": {
    "translation": "",
    "MultiLang": {
      "US": "The monster sound is coming from the pipe",
      "JP": "怪物の声をパイプから聞こえてきた",
      "CN": "",
      "KR": "그 파이프에서 괴물의 소리가 들리는 것 같아",
      "TW": "管道傳來怪物的聲音"
    }
  },
  "回去防守20秒": {
    "translation": "",
    "MultiLang": {
      "US": "Fall back for 20 seconds",
      "JP": "防御してください 秒 20",
      "CN": "",
      "KR": "방어하자 20초 남음",
      "TW": "回去防守二十秒"
    }
  },
  "这声音...我的大脑怎么传来这种声音": {
    "translation": "",
    "MultiLang": {
      "US": "...how does this sound come into my brain?",
      "JP": "この音...私の脳からそんな音がして",
      "CN": "",
      "KR": "\"이 소리가... 내 뇌에서 전해져 오는 거야?\"",
      "TW": "這聲音...我的大腦怎麼傳來这种声音"
    }
  },
  "外面好像有个怪物在说话": {
    "translation": "",
    "MultiLang": {
      "US": "There seems to be a monster talking outside",
      "JP": "外で何か話す怪物みたいだ",
      "CN": "",
      "KR": "밖에 괴물이 말하는 것 같아",
      "TW": "外面好像有個怪物在說話"
    }
  },
  "准备出门了小心一点": {
    "translation": "",
    "MultiLang": {
      "US": "Get ready to go out, watch your step",
      "JP": "出かけるよ ちょっと気をつけて",
      "CN": "",
      "KR": "나가려 할 땐 조심해",
      "TW": "準備出門了，小心點"
    }
  },
  "右边的门锁了 怪物那个方向好像有个锯子": {
    "translation": "",
    "MultiLang": {
      "US": "The right door is locked; the monster side probably has a saw",
      "JP": "右側のドアはロックされている 鬼族の方向にチェーンソーみたいなのがいる",
      "CN": "",
      "KR": "오른쪽 문은 잠겨 있어. 괴물 쪽으로는 체인 saw가 있는 것 같아",
      "TW": "右邊的門鎖了 怪物那個方向好像有個鋸子"
    }
  },
  "前面没路了 稍等我来打开右边的门": {
    "translation": "",
    "MultiLang": {
      "US": "No way forward, wait for me to open the right door",
      "JP": "先は通れない ちょっと待って で右側のドアを開けるよ",
      "CN": "",
      "KR": "길이 막혔어. 잠시만 기다려, 내가 오른쪽 문 좀 열게",
      "TW": "前面沒路了，稍等我來開右邊的門"
    }
  },
  "防守25秒": {
    "translation": "",
    "MultiLang": {
      "US": "Hold the line for 25 seconds",
      "JP": "防御してください 秒 25",
      "CN": "",
      "KR": "방어하자 25초 남음",
      "TW": "防守二十五秒"
    }
  },
  "侧面有僵尸攻入 箱子挡住了我们的去路 破坏他": {
    "translation": "",
    "MultiLang": {
      "US": "Side is blocked by a zombie, breaking the path ahead",
      "JP": "侧面有僵尸攻入 箱子挡住了我们的去路 破坏他",
      "CN": "",
      "KR": "侧面有僵尸攻入 箱子挡住了我们的去路 破坏他",
      "TW": "側面有僵屍攻入 箱子擋住我們的去路 破壞他"
    }
  },
  "漂亮 箱子被打碎了": {
    "translation": "",
    "MultiLang": {
      "US": "Nice! The box shattered.",
      "JP": "漂亮 箱子被打碎了",
      "CN": "",
      "KR": "漂亮 箱子被打碎了",
      "TW": "漂亮 箱子被打碎了"
    }
  },
  "防守一下 我来打开白门": {
    "translation": "",
    "MultiLang": {
      "US": "Hold the line while I open the white gate.",
      "JP": "防守一下 我来打开白门",
      "CN": "",
      "KR": "防守一下 我来打开白门",
      "TW": "防守一下，我來開白門"
    }
  },
  "防守15秒": {
    "translation": "",
    "MultiLang": {
      "US": "Stand guard for 15 seconds.",
      "JP": "防守15秒",
      "CN": "",
      "KR": "防守15秒",
      "TW": "防守15秒"
    }
  },
  "这里怎么没路了": {
    "translation": "",
    "MultiLang": {
      "US": "How did we lose the way here?",
      "JP": "这里怎么没路了",
      "CN": "",
      "KR": "这里怎么没路了",
      "TW": "這裡怎麼沒路了"
    }
  },
  "坏了 那家伙好像追上来了": {
    "translation": "",
    "MultiLang": {
      "US": "Crap! That guy’s on my tail.",
      "JP": "坏了 那家伙好像追上来了",
      "CN": "",
      "KR": "坏了 那家伙好像追上来了",
      "TW": "壞了，那個夥伴好像追上來了"
    }
  },
  "右边的门锁死了 我要进行破坏了": {
    "translation": "",
    "MultiLang": {
      "US": "The right door is locked—time to sabotage it!",
      "JP": "右边的门锁死了 我要进行破坏了",
      "CN": "",
      "KR": "右边的门锁死了 我要进行破坏了",
      "TW": "右邊的門鎖死了，我要進行破壞了"
    }
  },
  "我破坏成功 快躲进去": {
    "translation": "",
    "MultiLang": {
      "US": "Breach successful, get inside quickly.",
      "JP": "我破坏成功 快躲进去",
      "CN": "",
      "KR": "我破坏成功 快躲进去",
      "TW": "我成功破壞了，快躲進去"
    }
  },
  "僵尸5秒后传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombie 5 seconds later teleports",
      "JP": "5秒後にテレポート",
      "CN": "",
      "KR": "5초 후에 전송",
      "TW": "僵尸5秒后传送"
    }
  },
  "这种地方居然还有亮光": {
    "translation": "",
    "MultiLang": {
      "US": "This place surprisingly has a light!",
      "JP": "この場所に光が残っているとは信じられない",
      "CN": "",
      "KR": "이곳에 밝은 빛이 있다니 überrashnlich한데요?",
      "TW": "这种地方居然还有亮光"
    }
  },
  "坏了 惊扰到了四面八方的僵尸": {
    "translation": "",
    "MultiLang": {
      "US": "Oops, disturbed the zombies all around",
      "JP": "壊れた、四方八方のゾンビを起こしてしまった",
      "CN": "",
      "KR": "고장났어요. 사방에 있는 고립된 좀비들을 깨우게 되었네",
      "TW": "坏了 惊扰到了四面八方的僵尸"
    }
  },
  "僵尸从其他方向进攻了 准备防守": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies are attacking from other directions. Prepare to defend.",
      "JP": "ゾンビが別の方向から攻めてきた、防御準備します",
      "CN": "",
      "KR": "좀비가 다른 방향에서 공격하고 있어요. 방어 준비하세요",
      "TW": "僵尸从其他方向进攻了 准备防守"
    }
  },
  "这个门我来开锁 继续保持防守": {
    "translation": "",
    "MultiLang": {
      "US": "I'll unlock this door and keep defending",
      "JP": "このドアは俺が開ける。引き続き防御だ",
      "CN": "",
      "KR": "이 문은 제가 열어버릴게요. 계속해서 방어 유지해요",
      "TW": "这个门我来开锁 继续保持防守"
    }
  },
  "防守40秒": {
    "translation": "",
    "MultiLang": {
      "US": "Defend for 40 seconds",
      "JP": "防御40秒間継続します",
      "CN": "",
      "KR": "방어 40초",
      "TW": "防御40秒"
    }
  },
  "那怪物好像要来了 我们得赶紧离开这里": {
    "translation": "",
    "MultiLang": {
      "US": "That monster looks like it's coming. We need to leave quickly.",
      "JP": "その怪物、近いうちに来るみたい。早くここで離れよう",
      "CN": "",
      "KR": "그 괴물 같은 존재가 곧 나타날 것 같아요. 지금 바로 이 자리에서 빨리 나가야겠어요",
      "TW": "那怪物好像要来了 我们得赶紧离开这里"
    }
  },
  "这个门里面一定有东西": {
    "translation": "",
    "MultiLang": {
      "US": "There must be something inside this door",
      "JP": "ドアの中には何かあるはずだ",
      "CN": "",
      "KR": "이 문 안쪽에 뭔가가 있을 거예요",
      "TW": "这个门里面一定有东西"
    }
  },
  "你们挡住僵尸 我来破门": {
    "translation": "",
    "MultiLang": {
      "US": "You block the zombies, I'll break the door",
      "JP": "They block zombies, I'll break the door",
      "CN": "",
      "KR": "You're blocking the zombies, I'm going to break through",
      "TW": "你們擋住僵尸，我來破門。"
    }
  },
  "坚持一下我去开那个门": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on a second while I open that door",
      "JP": "Hold on a moment while I go open that door.",
      "CN": "",
      "KR": "Hold on a sec while I go open that door",
      "TW": "堅持一下，我去開那個門。"
    }
  },
  "又没路了？": {
    "translation": "",
    "MultiLang": {
      "US": "No more way?",
      "JP": "No more path?",
      "CN": "",
      "KR": "길이 없나요?",
      "TW": "又沒路了？"
    }
  },
  "等等 右边墙壁有声音": {
    "translation": "",
    "MultiLang": {
      "US": "Wait, there's a sound on the right wall",
      "JP": "Wait, there's a noise on the right side of the wall.",
      "CN": "",
      "KR": "Wait, there's a sound on the right wall",
      "TW": "等一下，右邊牆壁有聲音。"
    }
  },
  "攻击墙壁 看看能不能出去": {
    "translation": "",
    "MultiLang": {
      "US": "Shoot at the walls and see if we can get out",
      "JP": "Shoot at the walls and see if we can get out.",
      "CN": "",
      "KR": "Shoot at the walls and see if we can get out",
      "TW": "攻擊牆壁，看看能不能出去。"
    }
  },
  "打开了 兄弟们冲下去": {
    "translation": "",
    "MultiLang": {
      "US": "It's open, brothers! Move down there",
      "JP": "It opened, brothers, charge forward!",
      "CN": "",
      "KR": "The door's open, brothers charge down!",
      "TW": "開了 兄弟們衝下去。"
    }
  },
  "这给我干哪来了": {
    "translation": "",
    "MultiLang": {
      "US": "What the hell is this? Why are you doing it to me?",
      "JP": "What the hell is this? I'll do my best.",
      "CN": "",
      "KR": "이게 무슨 말이죠?",
      "TW": "這給我干哪來的？"
    }
  },
  "前方两条路 必须都要去人": {
    "translation": "",
    "MultiLang": {
      "US": "There are two paths ahead, and both must be taken by people",
      "JP": "Two paths ahead, must go both ways.",
      "CN": "",
      "KR": "앞에 두 갈래 길 모두 가야 합니다",
      "TW": "前方兩條路，必須都去人。"
    }
  },
  "僵尸14秒后传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombie 14 seconds later teleport",
      "JP": "zombie in 14 seconds",
      "CN": "",
      "KR": "좀비 14초 후 이동",
      "TW": "僵尸14秒後傳送"
    }
  },
  "左边路线成功触发 右边大门将于25秒后开门": {
    "translation": "",
    "MultiLang": {
      "US": "Left route success triggers, right gate will open in 25 seconds.",
      "JP": "succeeded left route; right gate will open in 25 seconds",
      "CN": "",
      "KR": "오른쪽 경로 성공 시 왼쪽 대문이 25초 후 열림",
      "TW": "左側路線成功觸發，右側大門於25秒後開"
    }
  },
  "右边路线成功触发 左边大门25秒打开": {
    "translation": "",
    "MultiLang": {
      "US": "Right route success triggers, left gate opens after 25 seconds.",
      "JP": "succeeded right route; left gate opens in 25 seconds",
      "CN": "",
      "KR": "왼쪽 경로 성공 시 오른쪽 대문이 25초 후 열림",
      "TW": "右側路線成功觸發，左側大門於25秒開"
    }
  },
  "前面就是终点了 坚持住": {
    "translation": "",
    "MultiLang": {
      "US": "The end ahead, hold on!",
      "JP": "The end is ahead. Hold on!",
      "CN": "",
      "KR": "앞은 최종 지점입니다.坚持一下",
      "TW": "前面就是終點了，堅持住！"
    }
  },
  "防守30秒": {
    "translation": "",
    "MultiLang": {
      "US": "Defend for 30 seconds.",
      "JP": "Defend for 30 seconds",
      "CN": "",
      "KR": "방어 30초",
      "TW": "防守30秒。"
    }
  },
  "我们暂时安全了": {
    "translation": "",
    "MultiLang": {
      "US": "We're temporarily safe now.",
      "JP": "We're safe—for now.",
      "CN": "",
      "KR": "우리는暂时安全了",
      "TW": "我們暫時安全了！"
    }
  },
  "我找到一把锯子": {
    "translation": "",
    "MultiLang": {
      "US": "I found a saw!",
      "JP": "Found a saw!",
      "CN": "",
      "KR": "나는 나무를 찾았어요.",
      "TW": "我找到了一把鋸子。"
    }
  },
  "旁边传来了怪物的叫声": {
    "translation": "",
    "MultiLang": {
      "US": "Monster growls nearby.",
      "JP": "Monster growls nearby.",
      "CN": "",
      "KR": "주변에서 괴물의 울음소리가 들려요.",
      "TW": "旁邊傳來怪物的叫聲"
    }
  },
  "准备防守其他路线进攻的怪物": {
    "translation": "",
    "MultiLang": {
      "US": "Prepare for monsters that will attack other routes",
      "JP": "準備防衛其他路线攻擊的怪物",
      "CN": "",
      "KR": "다른 경로에 도전하는 몬스터를 방어하기 위해 준비하세요",
      "TW": "準備防守其他路線攻擊的怪物"
    }
  }
}
