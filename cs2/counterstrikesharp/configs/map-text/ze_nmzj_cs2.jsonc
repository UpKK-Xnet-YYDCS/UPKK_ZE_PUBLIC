{
  "我的头好痛啊 这里是哪？": {
    "translation": "",
    "MultiLang": {
      "US": "My head hurts so much. Where am I?",
      "JP": "頭がズキズキする……ここはどこだ？",
      "CN": "",
      "KR": "머리가 너무 아파. 여기는 어디지?",
      "TW": "我的頭好痛，這裡是哪裡？"
    }
  },
  "我刚才不是在玩月影传说吗": {
    "translation": "",
    "MultiLang": {
      "US": "Weren't I just playing Moon Shadow Legend?",
      "JP": "さっきまで『月影の伝説』をプレイしてたはずなのに",
      "CN": "",
      "KR": "아직도 월영전설을 하고 있던 게 아닌가?",
      "TW": "我剛剛不是在玩《月影傳說》嗎？"
    }
  },
  "先不管了出去看看外面什么情况": {
    "translation": "",
    "MultiLang": {
      "US": "Never mind that for now. Let's check what's outside.",
      "JP": "まず外に出て、状況を確認するしかないな",
      "CN": "",
      "KR": "일단 밖으로 나가서 상황을 파악해 보자.",
      "TW": "先不管了，出去看看外面的情況。"
    }
  },
  "这个门好像出了点问题": {
    "translation": "",
    "MultiLang": {
      "US": "This door seems to have a problem.",
      "JP": "このドア、どうやら何か不具合があるようだ",
      "CN": "",
      "KR": "이 문에 뭔가 이상이 있는 것 같군.",
      "TW": "這扇門好像出了點問題。"
    }
  },
  "搜索一下其他地方看看": {
    "translation": "",
    "MultiLang": {
      "US": "Search elsewhere to see if there's anything.",
      "JP": "他の場所も調べてみるか",
      "CN": "",
      "KR": "다른 곳도 검색해 보자.",
      "TW": "搜尋其他地方看看。"
    }
  },
  "我醒来的房间好像有东西 做好战斗准备": {
    "translation": "",
    "MultiLang": {
      "US": "There seems to be something in the room where I woke up. Prepare for combat.",
      "JP": "目が覚めた部屋に何かがいる。戦闘態勢に入れ！",
      "CN": "",
      "KR": "내가 깨어난 방에 뭔가 있다. 전투 준비를 해라.",
      "TW": "我醒來的房間裡好像有東西，做好戰鬥準備。"
    }
  },
  "防守10秒": {
    "translation": "",
    "MultiLang": {
      "US": "Defend for 10 seconds.",
      "JP": "10秒間防衛せよ",
      "CN": "",
      "KR": "10초간 방어하라.",
      "TW": "防守10秒"
    }
  },
  "我找到钥匙了": {
    "translation": "",
    "MultiLang": {
      "US": "I found the key.",
      "JP": "キーが見つかったぞ",
      "CN": "",
      "KR": "열쇠를 찾았군.",
      "TW": "我找到鑰匙了。"
    }
  },
  "那个管道传来了怪物的声音": {
    "translation": "",
    "MultiLang": {
      "US": "That pipe传来的怪物发出的声音",
      "JP": "あの配管からモンスターの声が聞こえた",
      "CN": "",
      "KR": "배관에서 괴물 소리가 들려",
      "TW": "那個管道傳來了怪物的聲音"
    }
  },
  "回去防守20秒": {
    "translation": "",
    "MultiLang": {
      "US": "返回去防守20秒",
      "JP": "20秒間、後ろを防御しろ",
      "CN": "",
      "KR": "20초 후 방어로 돌아감",
      "TW": "回去防守20秒"
    }
  },
  "这声音...我的大脑怎么传来这种声音": {
    "translation": "",
    "MultiLang": {
      "US": "这声音...我的大脑怎么会有这种声音？",
      "JP": "この音…私の頭に何という音が響くのか",
      "CN": "",
      "KR": "이 소리... 내 뇌가 이런 소리를 보내고 있어",
      "TW": "這聲音...我的大腦怎麼傳來這種聲音"
    }
  },
  "外面好像有个怪物在说话": {
    "translation": "",
    "MultiLang": {
      "US": "外面好像有个怪物在说话。",
      "JP": "外で何か怪物が話しているようだ",
      "CN": "",
      "KR": "밖에서 무언가 괴물이 말을 거는 것 같아",
      "TW": "外面好像有個怪物在說話"
    }
  },
  "准备出门了小心一点": {
    "translation": "",
    "MultiLang": {
      "US": "准备出门了，小心一点。",
      "JP": "移動の準備ができたら、気をつけろ",
      "CN": "",
      "KR": "외출 준비 완료, 조심해",
      "TW": "準備出門了，小心一點"
    }
  },
  "右边的门锁了 怪物那个方向好像有个锯子": {
    "translation": "",
    "MultiLang": {
      "US": "右边的门锁住了，怪物那边似乎有个锯子。",
      "JP": "右のドアは施錠されている。怪物がいた方角にノコギリが見える",
      "CN": "",
      "KR": "오른쪽 문이 잠겼어. 괴물 쪽에 톱날이 보이는 것 같아",
      "TW": "右邊的門鎖了，怪物那個方向好像有個鋸子"
    }
  },
  "前面没路了 稍等我来打开右边的门": {
    "translation": "",
    "MultiLang": {
      "US": "前面没路了，稍等一下，我来打开右边的门。",
      "JP": "先は不通だ。少し待て、右のドアを開ける",
      "CN": "",
      "KR": "전방 통로가 막혔다. 잠시 뒤 오른쪽 문을 열게 도와줄게",
      "TW": "前面沒路了，稍等，我來打開右邊的門"
    }
  },
  "防守25秒": {
    "translation": "",
    "MultiLang": {
      "US": "防守25秒。",
      "JP": "25秒間、防御しろ",
      "CN": "",
      "KR": "25초 동안 방어 임무 수행",
      "TW": "防守25秒"
    }
  },
  "侧面有僵尸攻入 箱子挡住了我们的去路 破坏他": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies are breaking in from the side. A crate is blocking our path. Destroy it.",
      "JP": "側面からゾンビが侵入してきた！箱が通行を阻んでいる、壊せ",
      "CN": "",
      "KR": "측면에서 좀비들이 침입하고 있어. 상자가 우리의 길을 막고 있으니 부셔!",
      "TW": "側面有殭屍攻入，箱子擋住了我們的去路，破壞它。"
    }
  },
  "漂亮 箱子被打碎了": {
    "translation": "",
    "MultiLang": {
      "US": "Nice, the crate is broken.",
      "JP": "やったね！箱が砕けた",
      "CN": "",
      "KR": "좋아! 상자를 깼어.",
      "TW": "漂亮！箱子被打碎了。"
    }
  },
  "防守一下 我来打开白门": {
    "translation": "",
    "MultiLang": {
      "US": "Hold them off. I'll open the white door.",
      "JP": "防衛してて。白門を開けるから",
      "CN": "",
      "KR": "잠시 막아줘. 내가 백문을 열게!",
      "TW": "防守一下，我來打開白門。"
    }
  },
  "防守15秒": {
    "translation": "",
    "MultiLang": {
      "US": "Hold them for 15 seconds.",
      "JP": "15秒間守れ",
      "CN": "",
      "KR": "15초간 방어해!",
      "TW": "防守15秒。"
    }
  },
  "这里怎么没路了": {
    "translation": "",
    "MultiLang": {
      "US": "Why is there no path here?",
      "JP": "ここどうして道がないの？",
      "CN": "",
      "KR": "여기서 길이 끊겼네?",
      "TW": "這裡怎麼沒路了？"
    }
  },
  "坏了 那家伙好像追上来了": {
    "translation": "",
    "MultiLang": {
      "US": "Oh no, that guy seems to be catching up.",
      "JP": "まずい、あの奴が追ってきたかも",
      "CN": "",
      "KR": "야, 그 놈이 따라오는 것 같은데!",
      "TW": "壞了，那傢伙好像追上了。"
    }
  },
  "右边的门锁死了 我要进行破坏了": {
    "translation": "",
    "MultiLang": {
      "US": "The door lock on the right is jammed. I'll break it.",
      "JP": "右側の扉はロックされているので、破壊作業に入るよ",
      "CN": "",
      "KR": "오른쪽 문이 잠겨 있어. 파괴해야겠다.",
      "TW": "右邊的家門鎖死了，我要進行破壞。"
    }
  },
  "我破坏成功 快躲进去": {
    "translation": "",
    "MultiLang": {
      "US": "I've broken it successfully. Quick, get inside!",
      "JP": "破壊完了！さっさと中へ逃げなさい",
      "CN": "",
      "KR": "파괴 완료! 빨리 들어가!",
      "TW": "我破壞成功，快躲進去！"
    }
  },
  "僵尸5秒后传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies teleport in 5 seconds",
      "JP": "ゾンビは5秒後にテレポート",
      "CN": "",
      "KR": "좀비 5초 후 텔레포트",
      "TW": "殭屍五秒後傳送"
    }
  },
  "这种地方居然还有亮光": {
    "translation": "",
    "MultiLang": {
      "US": "It's amazing there's still light here.",
      "JP": "こんな場所にも光が",
      "CN": "",
      "KR": "이런 곳에 빛이 있다니 놀랍군",
      "TW": "這種地方居然還有亮光"
    }
  },
  "坏了 惊扰到了四面八方的僵尸": {
    "translation": "",
    "MultiLang": {
      "US": "Oh no, we've disturbed the zombies from all directions!",
      "JP": "まずい、四方八方のゾンビを驚かせた！",
      "CN": "",
      "KR": "말았네! 사방의 좀비들이 소음을 듣곤 달려왔다!",
      "TW": "糟糕！驚擾到四面八方的殭屍了"
    }
  },
  "僵尸从其他方向进攻了 准备防守": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies are attacking from other directions. Prepare for defense!",
      "JP": "他の方向からゾンビが攻撃してきた。防御準備だ。",
      "CN": "",
      "KR": "좀비가 다른 쪽에서 공격한다! 방비 태세 취해라!",
      "TW": "殭屍從其他方向進攻，準備防守"
    }
  },
  "这个门我来开锁 继续保持防守": {
    "translation": "",
    "MultiLang": {
      "US": "I'll pick this lock. Keep defending.",
      "JP": "このロックは私が開けるから、防御を続けろ。",
      "CN": "",
      "KR": "저 자물쇠는 내가 풀겠으니, 방비는 계속해주길!",
      "TW": "這個門由我來開鎖，繼續保持防守"
    }
  },
  "防守40秒": {
    "translation": "",
    "MultiLang": {
      "US": "Defend for 40 seconds",
      "JP": "40秒間の防御",
      "CN": "",
      "KR": "40초간 방비하십시오.",
      "TW": "防守40秒"
    }
  },
  "那怪物好像要来了 我们得赶紧离开这里": {
    "translation": "",
    "MultiLang": {
      "US": "That monster seems to be coming. We need to leave here quickly!",
      "JP": "あのモンスターがやってきそうだ。ここから早く逃げるべきだ。",
      "CN": "",
      "KR": "저 괴물이 approaching하는 것 같다! 이 자리를 ASAP 떠나라!",
      "TW": "那怪物好像要來了，我們得趕緊離開這裡"
    }
  },
  "这个门里面一定有东西": {
    "translation": "",
    "MultiLang": {
      "US": "There must be something inside this door.",
      "JP": "このドアの中には何かがあるに違いない",
      "CN": "",
      "KR": "문 저편에 뭔가 있군.",
      "TW": "這扇門裡面一定有東西"
    }
  },
  "你们挡住僵尸 我来破门": {
    "translation": "",
    "MultiLang": {
      "US": "You hold off the zombies; I'll breach the door.",
      "JP": "お前らがゾンビの足止めをしてくれ、俺が壁を壊す",
      "CN": "",
      "KR": "총기 장전을 기다리는 동안, 나는 문을 부수겠다.",
      "TW": "你們擋住殭屍，我來破門"
    }
  },
  "坚持一下我去开那个门": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on, I'm going to open that door.",
      "JP": "頑張っててくれ、あそこを開けに行く",
      "CN": "",
      "KR": "잠시만! 바로 문이 열릴 거야!",
      "TW": "再堅持一下，我去開那扇門"
    }
  },
  "又没路了？": {
    "translation": "",
    "MultiLang": {
      "US": "No way through again?",
      "JP": "また道が塞がった？",
      "CN": "",
      "KR": "길도 없는데?",
      "TW": "又沒路了？"
    }
  },
  "等等 右边墙壁有声音": {
    "translation": "",
    "MultiLang": {
      "US": "Wait, I hear something from the right wall.",
      "JP": "待て、右の壁から音がする",
      "CN": "",
      "KR": "잠깐, 저 오른쪽 벽에서 소리가 들려.",
      "TW": "等等，右邊牆壁有聲音"
    }
  },
  "攻击墙壁 看看能不能出去": {
    "translation": "",
    "MultiLang": {
      "US": "Attack the wall and see if we can break through.",
      "JP": "壁を攻撃して、抜けられるか試してみよう",
      "CN": "",
      "KR": "벽을 파괴해 봐. 탈출할 수 있을지도 몰라.",
      "TW": "攻擊牆壁，看看能不能出去"
    }
  },
  "打开了 兄弟们冲下去": {
    "translation": "",
    "MultiLang": {
      "US": "It's open! Brothers, charge!",
      "JP": "開いたぞ、皆で駆け下りろ",
      "CN": "",
      "KR": "열렸어! 자, 같이 가자!",
      "TW": "打開了，兄弟們衝下去"
    }
  },
  "这给我干哪来了": {
    "translation": "",
    "MultiLang": {
      "US": "Where the hell am I?",
      "JP": "ここはどこだよ",
      "CN": "",
      "KR": "여기가 어디지?",
      "TW": "這到底是哪兒啊？"
    }
  },
  "前方两条路 必须都要去人": {
    "translation": "",
    "MultiLang": {
      "US": "Two paths ahead. We must send someone down each.",
      "JP": "先に分岐する2つの道、どちらにも行く必要がある",
      "CN": "",
      "KR": "앞으로 두 갈래 길이 있어. 하나씩 가야 해.",
      "TW": "前方有兩條路，每條都要派人"
    }
  },
  "僵尸14秒后传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombie teleports in 14 seconds",
      "JP": "ゾンビが14秒後に転送される",
      "CN": "",
      "KR": "좀비 14초 후 텔레포트",
      "TW": "殭屍將在14秒後傳送"
    }
  },
  "左边路线成功触发 右边大门将于25秒后开门": {
    "translation": "",
    "MultiLang": {
      "US": "Left route triggered. Right gate opens in 25 seconds.",
      "JP": "左側ルート成功。右の大門は25秒後に開く",
      "CN": "",
      "KR": "왼쪽 경로 성공, 오른쪽 문이 25초 후에 개방됩니다.",
      "TW": "左側路線已成功觸發，右側大門將在25秒後開啟"
    }
  },
  "右边路线成功触发 左边大门25秒打开": {
    "translation": "",
    "MultiLang": {
      "US": "Right route triggered. Left gate opens in 25 seconds.",
      "JP": "右側ルート成功。左の大門は25秒後に開く",
      "CN": "",
      "KR": "오른쪽 경로 성공, 왼쪽 문이 25초 후에 개방됩니다.",
      "TW": "右側路線已成功觸發，左側大門將在25秒後開啟"
    }
  },
  "前面就是终点了 坚持住": {
    "translation": "",
    "MultiLang": {
      "US": "The finish line is ahead. Hold on!",
      "JP": "ここが終点だ。頑張って！",
      "CN": "",
      "KR": "지금부터 최종 지점입니다. 버텨주세요!",
      "TW": "前面就是終點了，請堅持住"
    }
  },
  "防守30秒": {
    "translation": "",
    "MultiLang": {
      "US": "Defend for 30 seconds.",
      "JP": "30秒間防衛せよ",
      "CN": "",
      "KR": "30초 간 방어",
      "TW": "防守30秒"
    }
  },
  "我们暂时安全了": {
    "translation": "",
    "MultiLang": {
      "US": "We're safe for now.",
      "JP": "一時的に安全だ",
      "CN": "",
      "KR": "일시적으로 안전해졌습니다.",
      "TW": "我們暫時安全了"
    }
  },
  "我找到一把锯子": {
    "translation": "",
    "MultiLang": {
      "US": "I found a saw.",
      "JP": "ノコギリを見つけた！",
      "CN": "",
      "KR": "톱을 하나 찾았어요.",
      "TW": "我找到一把鋸子"
    }
  },
  "旁边传来了怪物的叫声": {
    "translation": "",
    "MultiLang": {
      "US": "Monsters are screaming nearby.",
      "JP": "横からモンスターの叫声が聞こえる",
      "CN": "",
      "KR": "근처에서 괴물의 울음소리가 들립니다.",
      "TW": "旁邊傳來了怪物的叫聲"
    }
  },
  "准备防守其他路线进攻的怪物": {
    "translation": "",
    "MultiLang": {
      "US": "Prepare to defend against monsters attacking other routes",
      "JP": "他のルートからの怪物の攻撃に備えて守りを固める",
      "CN": "",
      "KR": "다른 경로의 공격을 방어할 준비를 하다",
      "TW": "準備防守其他路線的怪物進攻"
    }
  }
}
