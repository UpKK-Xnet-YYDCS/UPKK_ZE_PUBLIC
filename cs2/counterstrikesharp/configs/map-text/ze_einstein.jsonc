{
  "Map by Kurt von Kolmar": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "マップ制作: Kurt von Kolmar",
      "CN": "地图制作：Kurt von Kolmar",
      "KR": "맵 제작: Kurt von Kolmar",
      "TW": "地圖製作：Kurt von Kolmar"
    }
  },
  "Port by Charlie": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "移植: Charlie",
      "CN": "移植：Charlie",
      "KR": "이식: Charlie",
      "TW": "移植：Charlie"
    }
  },
  "<> WARNING: Zombies Teleport in 10 Seconds! <>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<> 警告: 10秒後にゾンビがテレポートします! <>",
      "CN": "<> 警告：僵尸将在10秒后传送！ <>",
      "KR": "<> 경고: 10초 후 좀비 순간이동! <>",
      "TW": "<> 警告：殭屍將在 10 秒後傳送！ <>"
    }
  },
  "<> DANGER: Lava is Rising! <>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<> 危険: 溶岩が上昇中! <>",
      "CN": "<> 危险：岩浆正在上升！ <>",
      "KR": "<> 위험: 용암이 상승 중! <>",
      "TW": "<> 危險：熔岩正在上升！ <>"
    }
  },
  "<> NOTICE: Button 1/2 Pressed! <>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<> 通知: ボタン 1/2 が押されました! <>",
      "CN": "<> 提示：按钮 1/2 已按下！ <>",
      "KR": "<> 알림: 버튼 1/2이 눌림! <>",
      "TW": "<> 通知：按鈕 1/2 已按下！ <>"
    }
  },
  "<> NOTICE: Defend the Bridge! <>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<> 通知: 橋を防衛せよ! <>",
      "CN": "<> 提示：防守桥梁！ <>",
      "KR": "<> 알림: 다리를 방어하라! <>",
      "TW": "<> 通知：防守橋樑！ <>"
    }
  },
  "<> NOTICE: Button 2/2 Pressed! <>": {
    "translation": "",
    "MultiLang": {
