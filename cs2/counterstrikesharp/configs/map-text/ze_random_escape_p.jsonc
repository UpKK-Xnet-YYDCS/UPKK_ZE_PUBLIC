  "***1***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "***Good Luck!!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***幸運を祈ります！！***",
      "CN": "***祝好运！！***",
      "KR": "***행운을 빕니다!!***",
      "TW": "***祝好運！！***"
    }
  },
  "***LEVEL -- ZOMBIE DEATHRUN***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***LEVEL -- ゾンビデスラン***",
      "CN": "***关卡 -- 僵尸逃亡赛***",
      "KR": "***LEVEL -- 좀비 데스런***",
      "TW": "***關卡名稱 -- 殭屍逃生挑戰***"
    }
  },
  "***Escape the Rusty Temple Ruins before the curse spreads to the exit!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***出口まで呪いが広がる前に、錆びた寺院の遺跡から脱出してください！***",
      "CN": "***在诅咒蔓延到出口之前逃离锈色神殿遗迹！***",
      "KR": "***저주가 출구까지 퍼지기 전에 녹슨 사원 유적을 탈출하세요!***",
      "TW": "***在詛咒蔓延到出口之前，逃離鏽蝕神廟遺址！***"
    }
  },
  "***Be careful as the zombies will use traps to send you to the zombie cage!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***殭屍が罠を使ってあなたを殭屍檻に送り込むので注意してください！***",
      "CN": "***小心，僵尸会使用陷阱将你送入尸笼！***",
      "KR": "*** 좀비들이 덫을 사용해 당신을 좀비 감옥으로 보낼 수 있으니 주의하세요!***",
      "TW": "***小心，殭屍會利用陷阱將你送進殭屍籠！***"
    }
  },
  "***Curse has reached the entrance!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***呪いが入口に到達しました！***",
      "CN": "***诅咒已蔓延至入口！***",
      "KR": "*** 저주가 입구에 도달했습니다!***",
      "TW": "***詛咒已蔓延至入口處！***"
    }
  },
  "***Curse has reached the dual arches!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***呪いが二つのアーチに到達しました！***",
      "CN": "***诅咒已蔓延至双拱门！***",
      "KR": "*** 저주가 쌍층 아치에 도달했습니다!***",
      "TW": "***詛咒已蔓延至雙拱門！***"
    }
  },
  "***LEVEL -- CITY NIGHT ESCAPE***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***レベル -- 都市の夜脱出***",
      "CN": "***关卡 -- 城市夜逃***",
      "KR": "*** 레벨 --시티 나이트 탈출***",
      "TW": "***關卡 -- 城市之夜逃生***"
    }
  },
  "***Escape to the helicopter on the roof!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***屋上のヘリコプターに脱出せよ！***",
      "CN": "***逃往屋顶的直升机！***",
      "KR": "*** 옥상의 헬리콥터로 탈출하세요!***",
      "TW": "***逃往頂樓的直升機！***"
    }
  },
  "***LEVEL -- INTERSTELLAR ESCAPE 9***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***レベル -- 星間脱出9***",
      "CN": "***关卡 -- 星际逃生9***",
      "KR": "*** 레벨 --인터스텔라 탈출 9***",
      "TW": "***關卡 -- 星际逃生 9***"
    }
  },
  "***Escape the black hole by making it to the Interstellar 999!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***インターステラー999に到達して、ブラックホールから脱出せよ！***",
      "CN": "***前往星际999以逃离黑洞！***",
      "KR": "*** 인터스텔라 999에 도달해 블랙홀에서 탈출하세요!***",
      "TW": "***逃離黑洞，前往星际 999！***"
    }
  },
  "***Cargo doors open in 10secs and will remain open for 10secs after opening! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***貨物ゲートは10秒後に開き、開いた後10秒間開放状態になります！***",
      "CN": "***货舱门将在10秒后开启，并保持开启状态10秒！***",
      "KR": "*** 화물 문이 10초 후에 열리며, 열린 후 10초 동안OPEN 상태로 유지됩니다! ***",
      "TW": "***貨艙門將在 10 秒後打開，並將保持開啟狀態 10 秒！ ***"
    }
  },
  "***LEVEL -- ZOMEAL ESCAPE***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***レベル -- ゾーメル脱出***",
      "CN": "***关卡 -- 佐梅尔逃脱***",
      "KR": "***레벨 -- 조멜 탈출***",
      "TW": "***關卡 -- 卓梅爾逃脫***"
    }
  },
  "***The Combealz Empire has invaded! Escape the falling kingdom!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***コンベルツ帝国が侵攻！崩れゆく王国から脱出せよ！***",
      "CN": "***康贝尔斯帝国入侵！逃离即将倾覆的王国！***",
      "KR": "***콤벨 제국이 침공했습니다! 무너지는 왕국을 탈출하세요!***",
      "TW": "***康伯齊帝國已入侵！逃離傾倒的國度吧！***"
    }
  },
  "***Use the two-man manual override to open the gate! LEFT then RIGHT!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***二人掛けの手動オーバーライドでゲートを開け！左、そして右！***",
      "CN": "***使用双人工位手动控制开启大门！先左后右！***",
      "KR": "***수동 두 명 조작장으로 게이트를 여세요! 왼쪽 다음 오른쪽!***",
      "TW": "***使用雙機手動重啟裝置開啟大門！先左後右！***"
    }
  },
  "***Enemy air troops have dropped off ground forces! Hatch will open in 25secs!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***敵の航空部隊が地上部隊を投下！ハッチは25秒後に開放！***",
      "CN": "***敌方空投部队已投放地面部队！舱口将在25秒后开启！***",
      "KR": "***적 항공 부대가 지상 병력을 투하했습니다! 해치가 25초 후 열립니다!***",
      "TW": "***敵方空中部隊已空投地面部隊！艙門將在25秒後開啟！***"
    }
  },
  "***Don't Delay!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***引き延ばすな！***",
      "CN": "***切勿拖延！***",
      "KR": "***미루지 마세요!***",
      "TW": "***別遲疑！***"
    }
  },
  "***LEVEL -- FAIL NADE***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***レベル -- ナデ失敗***",
      "CN": "***关卡 -- 失败nade***",
      "KR": "***레벨 -- 패일 네이드***",
      "TW": "***關卡 -- 失敗炸彈***"
    }
  },
  "***Survive 35secs until the upper pipe barriers break!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***上部のパイプバリアが壊れるまで35秒間生存せよ！***",
      "CN": "***坚持35秒，直到上层管道屏障破碎！***",
      "KR": "***상부 파이프 장벽이 파괴될 때까지 35초 동안 생존하세요!***",
      "TW": "***存活35秒直到上方管道屏障崩解！***"
    }
  },
  "***Land a nade in each one to activate the zombie drain!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***それぞれの箇所にナデを叩き込み、ゾンビの排水を起動せよ！***",
      "CN": "***在每个目标投放一枚nade以激活僵尸排水口！***",
      "KR": "***각 지점에 네이드를 맞춰 좀비 배수구를 활성화하세요!***",
      "TW": "***在各處丟入炸彈以啟動殭屍排水機制！***"
    }
  },
  "***Zombies will arrive in 5secs!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ゾンビが5秒後に到着します！***",
      "CN": "***丧尸将在5秒后到达！***",
      "KR": "***저스들이 5초 후에 도착합니다!***",
      "TW": "***殭屍將在5秒內抵達！***"
    }
  },
  "***Upper pipes now open! Land a nade inside both within 25secs!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***上側のパイプが開きました！25秒以内に両方のパイプ内に手榴弾を投げて下さい！***",
      "CN": "***上部管道现已开启！请在25秒内将手雷投入两个管道中！***",
      "KR": "***상부 파이프가 이제 개방되었습니다! 25초 이내에 두 개의 파이프 안에 손수레를 착지시키세요!***",
      "TW": "***上方管道已開啟！請於25秒內將兩顆手榴彈投入其中！***"
    }
  },
  "***Pipe B block destroyed!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***パイプBのブロックが破壊されました！***",
      "CN": "***B管道区块已摧毁！***",
      "KR": "***파이프 B 블록이 파괴되었습니다!***",
      "TW": "***B管區塊已摧毀！***"
    }
  },
  "***Pipe A block destroyed!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***パイプAのブロックが破壊されました！***",
      "CN": "***A管道区块已摧毁！***",
      "KR": "***파이프 A 블록이 파괴되었습니다!***",
      "TW": "***A管區塊已摧毀！***"
    }
  },
  "***Zombie drain is now open!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ゾンビの排水管が開きました！***",
      "CN": "***丧尸排水道现已开启！***",
      "KR": "***저스 하수가 이제 개방됩니다!***",
      "TW": "***殭屍排放口已開啟！***"
    }
  },
  "***Elevator will arrive in 10secs!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***エレベーターが10秒後に到着します！***",
      "CN": "***电梯将在10秒后到达！***",
      "KR": "***엘리베이터가 10초 후에 도착합니다!***",
      "TW": "***電梯將在10秒內抵達！***"
    }
  },
  "***Elevator will leave in 10secs!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***エレベーターが10秒後に出発します！***",
      "CN": "***电梯将在10秒后离开！***",
      "KR": "***엘리베이터가 10초 후에 떠납니다!***",
      "TW": "***電梯將於10秒後離開！***"
    }
  },
  "***In case of emergency DO NOT break glass!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***非常時にはガラスを割らないで下さい！***",
      "CN": "***紧急情况下请勿击碎玻璃！***",
      "KR": "***비상 시 유리를 깨지 마십시오!***",
      "TW": "***緊急狀況下，請不要打破玻璃！***"
    }
  },
  "***Power lost! Shoot the doors open!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "動力停止！扉を撃ち破れ！",
      "CN": "***电量耗尽！射击打开大门！***",
      "KR": "***전력 끊김! 문을 총으로 열어라!***",
      "TW": "***電力喪失！射擊大門打開它！***"
    }
  },
  "***Hold the office for 10secs!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "オフィスを守って10秒間維持せよ！",
      "CN": "***守住办公室10秒！***",
      "KR": "***사무실을 10초간 방어해라!***",
      "TW": "***守衛辦公室10秒！***"
    }
  },
  "***Balcony open! Fall back!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バルコニー開放！退却する！",
      "CN": "阳台已开！撤退！***",
      "KR": "***발코니 개방! 후퇴!***",
      "TW": "***陽台開放！撤退！***"
    }
  },
  "***Helicopter is on its way to pick you up!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ヘリコプターが救援に来ております！",
      "CN": "***直升机正在赶来接应你们！***",
      "KR": "***헬리콥터가 당신을 수거하러 온다!***",
      "TW": "***直升機即將到達接您！***"
    }
  },
  "***Helicopter will arrive in 5secs!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ヘリコプターは5秒後に到着します！",
      "CN": "***直升机将在5秒后到达！***",
      "KR": "***헬리콥터 도착까지 5초!***",
      "TW": "***直升機將在5秒後到達！***"
    }
  },
  "***4***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "***OH SH--!!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "くそっ！！",
      "CN": "***该死！！***",
      "KR": "***으악!!***",
      "TW": "***啊～該死！！***"
    }
  },
  "***Hold W to go faster and S to slow down!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Wキーで加速、Sキーで減速ができます！",
      "CN": "***按住W键加速，按住S键减速！***",
      "KR": "***W를 누르면 속도가 빨라지고 S를 누르면 느려집니다!***",
      "TW": "***按住W鍵加速，按住S鍵減速！***"
    }
  },
  "***Jump and be careful not to hit to many blockers!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ジャンプして、ブロックに多く当たらないよう注意せよ！",
      "CN": "***跳跃并注意不要碰到太多障碍物！***",
      "KR": "***점프하고 많은 장애물에 부딪히지 않도록 주의하세요!***",
      "TW": "***跳躍時小心不要撞到太多障礙物！***"
    }
  },
  "***Teleporting to next map!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***次のマップへテレポート中！***",
      "CN": "***即将传送至下一张地图！***",
      "KR": "***다음 맵으로 워프 중!***",
      "TW": "***傳送至下一個地圖！***"
    }
  },
  "***LEVEL -- OPEN FIELD***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***レベル -- 野外***",
      "CN": "***LEVEL -- 开阔地带***",
      "KR": "***LEVEL -- 오픈 필드***",
      "TW": "***LEVEL -- 開放區域***"
    }
  },
  "***Beware K.'s SlenderMan!*** ": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***K.のスレンダーマンに注意！***",
      "CN": "***小心K.'的瘦长鬼影！***",
      "KR": "***K.'s SlenderMan 주의!***",
      "TW": "***小心 K.'s SlenderMan！***"
    }
  },
  "***Survive for 75secs***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***75秒間生き残れ***",
      "CN": "***坚持75秒***",
      "KR": "***75초간 생존***",
      "TW": "***存活75秒***"
    }
  },
  "***Survive for 15secs***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***15秒間生き残れ***",
      "CN": "***坚持15秒***",
      "KR": "***15초간 생존***",
      "TW": "***存活15秒***"
    }
  },
  "***Gate open!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ゲート開放！***",
      "CN": "***闸门已打开！***",
      "KR": "***게이트 개방!***",
      "TW": "開啟通道！***"
