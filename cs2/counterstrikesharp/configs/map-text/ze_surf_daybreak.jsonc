  "~ The portal is open ~": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "～ ポータルが開きました ～",
      "CN": "~ 传送门已开启 ~",
      "KR": "~ 포털이 열렸습니다 ~",
      "TW": "~ 傳送門已開啟 ~"
    }
  },
  "~ Zombies come in 20sec ~": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "～ ゾンビが20秒後に出現します ～",
      "CN": "~ 20秒后刷尸潮 ~",
      "KR": "~ 좀비가 20초 후에 나타납니다 ~",
      "TW": "~ 殭屍將出現於 20 秒後 ~"
    }
  },
  "~ Touch the light to open the portal ~": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "～ 光にタッチしてポータルを開いてください ～",
      "CN": "~ 触碰光源以开启传送门 ~",
      "KR": "~ 빛에 닿아 포털을 여세요 ~",
      "TW": "~ 觸碰光亮以開啟傳送門 ~"
    }
  },
  "~ Afk tele in 20sec ~": {
