    }
  },
  "*** DOOR OPENS IN 20 SECONDS ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ドアは20秒後に開きます ***",
      "CN": "*** 门将在 20 秒后打开 ***",
      "KR": "*** 문이 20초 후에 열립니다 ***",
      "TW": "*** 20 秒後門將打開 ***"
    }
  },
  "*** DOOR OPENS IN 10 SECONDS ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ドアは10秒後に開きます ***",
