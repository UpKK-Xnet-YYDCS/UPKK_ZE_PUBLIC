    }
  },
  ">>NICE JOB! Helicopter leaving in 5 seconds<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>お疲れ様！ヘリコプターは5秒後に離脱<<",
      "CN": ">>干得漂亮！直升机5秒后离开<<",
