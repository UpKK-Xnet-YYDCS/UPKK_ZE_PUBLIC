      "US": "",
      "JP": ">>任務1：迎撃（イージー）<<",
      "CN": ">>任务一：拦截（简单）<<",
      "KR": ">>미션 1: 요격 (쉬움)<<",
      "TW": ">>任務一：攔截（普通）<<"
    }
  },
  ">>HOLD THE COMPOUND FOR 50 SECONDS<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>複合施設を50秒間保持<<",
      "CN": ">>坚守据点50秒<<",
      "KR": ">>기지에서 50초간 버티세요<<",
      "TW": ">>守住基地50秒<<"
    }
  },
  ">>10 SECONDS LEFT<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>残り10秒<<",
      "CN": ">>剩余10秒<<",
      "KR": ">>남은 시간 10초<<",
      "TW": ">>剩餘10秒<<"
    }
  },
  ">>FALL BACK<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>後退せよ<<",
      "CN": ">>撤退<<",
      "KR": ">>후퇴<<",
      "TW": ">>後退<<"
    }
  },
  ">>SPLIT UP! GO TOP AND BOTTOM<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>分散！上下へ移動<<",
      "CN": ">>分散行动！上下分流！<<",
      "KR": ">>분산! 위로와 아래로 이동<<",
      "TW": ">>分頭行動！一個在上，一個在下<<"
    }
  },
  ">>HOLD UP HERE WHILE DOORS ARE HACKED OPEN<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>ドアがハッキングされ開くまでここで待機<<",
      "CN": ">>黑客破解门禁，在此坚守<<",
      "KR": ">>문 해킹 중 여기에서 대기<<",
      "TW": ">>破解門扉時在此待命<<"
    }
  },
  ">>HOLD FOR 40 SECONDS<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>40秒間保持<<",
      "CN": ">>坚守40秒<<",
      "KR": ">>40초간 버티세요<<",
      "TW": ">>堅持40秒<<"
    }
  },
  ">>DOORS ARE OPEN! FALL BACK<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>ドア開放！後退せよ<<",
      "CN": ">>门已打开！立即撤退！<<",
      "KR": ">>문 개방! 후퇴<<",
      "TW": ">>門已開！後退！<<"
    }
  },
  ">>ELEVATOR LEAVING IN 15 SECONDS<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>エレベーター、15秒後に発車<<",
      "CN": "电梯将在15秒后离开",
      "KR": "엘리베이터 15초 후 출발합니다",
      "TW": ">>電梯將於15秒後關閉<<"
    }
  },
  ">>Laboratory door seals in 30 seconds!! Hold the lab!!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>研究所のドア閉鎖まで30秒！实验室を堅持せよ！<<",
      "CN": "实验室门将于30秒后密封！守住实验室！",
      "KR": "연구실 출입구 밀폐 30초! 연구실을 지키시오!",
      "TW": ">>實驗室門即將封閉，倒數30秒！守住實驗室！！<<"
    }
  },
  ">>Hit the green button on the computer!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>コンピュータの緑色ボタンを押せ！<<",
      "CN": "按下电脑上的绿色按钮！",
      "KR": "컴퓨터의 초록색 버튼을 누르세요!",
      "TW": ">>按下電腦上的綠色按鈕！<<"
    }
  },
  ">>Door re-opens in 25 seconds! Escape!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>ドア、25秒後に再開放！脱出だ！<<",
      "CN": "门将在25秒后重新打开！快逃！",
      "KR": "출입구 25초 후 다시 열립니다! 탈출하세요!",
      "TW": ">>門將於25秒後重新開啟！逃脫！<<"
    }
  },
  ">>You've awoken some sort of prototype...<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>お前の目覚めが、何らかのプロトタイプを起動させた…<<",
      "CN": "你似乎唤醒了某种原型体……",
      "KR": "어떤 프로토타입을 깨워버렸습니다...",
      "TW": ">>你喚醒了某種原型物體...<<"
    }
  },
  ">>Guards are on their way!!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>警備員が急行中！<<",
      "CN": "士兵正在赶来的路上！",
      "KR": "경비팀이 출동 중입니다!!",
      "TW": ">>護衛正在趕來！！<<"
    }
  },
  ">>ESCAPE THROUGH THE OPEN DOOR!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>開いたドアから脱出しろ！<<",
      "CN": "从敞开的门逃离！",
      "KR": "열린 문을 통해 탈출하세요!",
      "TW": ">>從開啟的門口逃脫！<<"
    }
  },
  ">>DEFENSE FIELD STILL ACTIVE!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>防御フィールド、依然として稼働中！<<",
      "CN": "防御场仍生效中！",
      "KR": "방어 필드 여전히 활성화됨!",
      "TW": ">>防禦場仍活躍中！<<"
    }
  },
  ">>THROW A GRENADE INTO THE WATCH TOWER BEHIND YOU!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>背後の監視塔に手榴弾を投げろ！<<",
      "CN": ">>往你身后的瞭望塔扔手雷！<<",
      "KR": ">> 뒤에 있는 감시탑에 수류탄을 던져! <<",
      "TW": ">>往後方的監視塔丟手榴彈！<<"
    }
  },
  ">>NICE JOB! Shields powering down...<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>お疲れ様！シールドがダウン中…<<",
      "CN": ">>干得漂亮！护盾正在关闭……<<",
      "KR": ">> 훌륭해! 실드 충전 중... <<",
      "TW": ">>做得好！護盾正在關閉……<<"
    }
  },
  ">>Hold for 20 seconds...<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>20秒間持ちこたえろ…<<",
      "CN": ">>坚持住，还有20秒……<<",
      "KR": ">> 20초간 버티기... <<",
      "TW": ">>保持防禦20秒……<<"
    }
  },
  ">>SHIELDS ARE DOWN! RUN TO THE CHOPPER!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>シールドがダウン！ヘリコプターへ走れ！<<",
      "CN": ">>护盾已关闭！快冲向直升机！<<",
      "KR": ">> 실드 꺼짐! 헬리콥터로 쫓아 ! <<",
      "TW": ">>護盾已關閉！快往直升機跑！<<"
    }
  },
  ">>ENEMY HELICOPTER INCOMING!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>敵ヘリコプター接近中！<<",
      "CN": ">>敌机来袭！<<",
      "KR": ">> 적 헬리콥트 접근 중! <<",
      "TW": ">>敵方直升機接近中！<<"
    }
  },
  ">>WE CANNOT LEAVE UNTIL THAT IS GONE!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>あれがなくなるまで撤退できない！<<",
      "CN": ">>只要那东西还在，我们就不能离开！<<",
      "KR": ">> 저것을 제거하기 전에는 떠날 수 없습니다! <<",
      "TW": ">>在它離開前，我們不能撤退！<<"
    }
  },
  ">>HELICOPTER WILL ATTACK IN 1 MINUTE!!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>ヘリコプターの攻撃開始まで1分！！<<",
