  ">>Doors opening...<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>ドアが開く…<<",
      "CN": ">>门正在开启...<<",
      "KR": ">>문 열림...<<",
      "TW": ">>大門即將開啟...<<"
    }
  },
  ">>Activate the elevator to prepare your escape!!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>脱出のためにエレベーターを起動せよ！！<<",
      "CN": ">>启动电梯以准备逃脱！！<<",
      "KR": ">>탈출 준비를 위해 엘리베이터 작동을 시작하라!!<<",
      "TW": ">>啟動電梯以準備逃脫！！<<"
    }
  },
  ">>Don't let any zombies into the facility!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>施設内にゾンジを入れないでくれ！<<",
      "CN": ">>别让任何僵尸进入设施！<<",
      "KR": ">>좀무리 관내 침입을 막아라!<<",
      "TW": ">>絕對不要讓殭屍進入設施內！<<"
    }
  },
  ">>Doors opening in 30 seconds...<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>30秒後にドア開く…<<",
      "CN": ">>门将在30秒后开启...<<",
      "KR": ">>문 30초 내 열림...<<",
      "TW": ">>大門30秒後開啟...<<"
    }
  },
  ">>Elevator departing in 10 seconds...<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>10秒後に出発…<<",
      "CN": ">>电梯将在10秒后出发...<<",
      "KR": ">>엘리베이터 10초 내 출발...<<",
      "TW": ">>電梯10秒後出發...<<"
    }
  },
  ">>....it looks like someone was waiting for us...<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>…どうやら、誰かが私たちを待っていたらしい…<<",
      "CN": ">>……看起来有人一直在等我们……<<",
      "KR": ">>....아무르가 우리들을 기다리고 있었던 모양이다...<<",
      "TW": ">>....看來有人在等我們...<<"
    }
  },
  ">>THE PROTOTYPE HAS BEEN DEFEATED!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>プロトタイプを撃破した！<<",
      "CN": ">>原型已被击败！<<",
      "KR": ">>프로토타입을 처치했습니다!<<",
      "TW": "原型已被擊潰！"
    }
  },
  ">>ESCAPE WHILE YOU STILL CAN<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<今こそ、逃げよ>>",
      "CN": ">>在还有机会时逃离<<",
      "KR": "<<지금 도망가세요>>",
      "TW": "趁早逃命去吧！"
    }
  },
  ">>IT IS NOT DEAD!! SHOOT IT!!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "死んでいない！！撃て！！<<",
      "CN": ">>它还没死！！射击它！！<<",
      "KR": ">>죽지 않았습니다!! 쏴!!!<<",
      "TW": "它還沒死！射擊它！"
    }
  },
  ">>The prototype is dead...<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プロトタイプは死んだ…<<",
      "CN": ">>原型已死亡……<<",
      "KR": ">>프로토타입이 죽었다...<<",
      "TW": "原型已喪命……"
    }
  },
  ">>HOLD FOR 15 SECONDS WHILE THE PORTAL OPENS!!!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<ポータルが開くまで15秒待機！！>>",
      "CN": ">>传送门开启时请坚守15秒！！！<<",
      "KR": ">>포털이 열릴 때까지 15초간 기다리세요!!!<<",
      "TW": "保持固定 15 秒，直到傳送門開啟！"
    }
  },
  ">>JUMP INTO THE PORTAL! THERE IS NO GOING BACK!!!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<ポータルに飛び込め！取り返しがつかないぞ！！>>",
      "CN": ">>跳进传送门！没有回头路了！！！<<",
      "KR": ">>포털로 점프하세요! 돌아갈 수 없습니다!!!<<",
      "TW": "跳入傳送門！別無退路！"
    }
  },
  ">>YOU WIN! MOVING ON TO ZM<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "勝利！ZMへ進んだ<<",
      "CN": ">>你赢了！继续推进至ZM区域<<",
      "KR": ">>승리! ZM으로 진행합니다<<",
      "TW": "勝利！進入 ZM 章節"
    }
  },
  ">>MISSION 4: ZM<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ミッション4：ZM<<",
      "CN": ">>任务4：ZM区域<<",
      "KR": ">>미션 4: ZM<<",
      "TW": "任務四：ZM"
    }
  },
  ">>Survive until the zombie nuke!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>ゾンビの核攻撃まで生き残れ！<<",
      "CN": ">>存活到僵尸核弹降临！<<",
      "KR": ">>좀비 원자력 탄도 미사일이 떨어지기 전까지 생존하세요!<<",
      "TW": ">>存活至殭屍核彈爆炸！<<"
    }
  },
  ">>TYPE MAT_COLORCORRECTION 0 TO DISABLE CC<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>タイプ MAT_COLORCORRECTION 0 でカラーコレクションを無効化<<",
      "CN": ">>输入MAT_COLORCORRECTION 0以禁用色彩校正<<",
      "KR": ">>TYPE MAT_COLORCORRECTION 0 TO DISABLE CC<<",
      "TW": ">>輸入 MAT_COLORCORRECTION 0 以停用色彩校正<<"
    }
  },
  ">>Missions restart after this round<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>このラウンド終了後、ミッションがリスタートします<<",
      "CN": ">>本轮结束后任务将重新开始<<",
      "KR": ">>미션은 라운드 종료 후 재시작됩니다<<",
      "TW": ">>此輪結束時任務將重新開始<<"
    }
  },
  ">>Turn music to zero in options to mute the song<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>オプションで音楽をゼロにして曲をミュートできます<<",
      "CN": ">>请在选项中将音乐音量调至零以静音<<",
      "KR": ">>음악을 끄려면 옵션에서音量을 0으로 설정하세요<<",
      "TW": ">>請在選項中將音樂音量調至最低以關閉音樂<<"
    }
  },
  ">>10 seconds remain!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>残り10秒！<<",
      "CN": ">>剩余10秒！<<",
      "KR": ">>10초 남았습니다!<<",
      "TW": ">>剩餘 10 秒！<<"
    }
  },
  ">>Nuke launched!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>核ミサイル発射！<<",
      "CN": ">>核弹已发射！<<",
      "KR": ">>원자력 탄도 미사일 발사!<<",
      "TW": ">>已發射核彈！<<"
    }
  }
}
