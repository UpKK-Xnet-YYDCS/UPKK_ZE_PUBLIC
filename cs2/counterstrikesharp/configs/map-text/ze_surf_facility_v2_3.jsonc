{
  "***Prepare defences! 35 seconds!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "防備を準備せよ！ 35秒後！",
      "CN": "***准备防御！还剩35秒！***",
      "KR": "***방어 준비! 35초 남음!***",
      "TW": "***準備防禦！35秒內！***"
    }
  },
  "***Intro song is Spanish Flea***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "イントロソングは『Spanish Flea』",
      "CN": "***开场曲《西班牙跳蚤舞曲》***",
      "KR": "***인트로 음악은 스페인 벼룩***",
      "TW": "***開場歌曲為《西班牙跳蚤》***"
    }
  },
  "***Middle song is Red Canyon by F-Zero***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "中盤ソングは『F-Zero』の『Red Canyon』",
      "CN": "***中段曲F-Zero《红峡谷》***",
      "KR": "***중간 음악은 F-Zero의 레드 캐니언***",
      "TW": "***中段歌曲為F-Zero的《紅峽谷》***"
    }
  },
  "***Finale song is Tristan by Two Steps From Hell***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "フィナーレソングは『Two Steps From Hell』の『Tristan』",
      "CN": "***终场曲Two Steps From Hell《特里斯坦》***",
      "KR": "***피날레 노래는 Two Steps From Hell의 트리스탄입니다***",
      "TW": "***最終曲為Two Steps From Hell的《崔斯坦》***"
    }
  },
  "****Map by Eugenio Motanum Roman****": {
    "translation": "",
