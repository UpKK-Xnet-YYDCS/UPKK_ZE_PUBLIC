{
  "\">>>赞达拉万古长存！<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>>Long live the Zandalari!<<<",
      "JP": ">>>ザンダラ万歳！<<<",
      "CN": ">>>扎达拉万古长存！<<<",
      "KR": ">>>贊달라가 오래 가도다!<<<",
      "TW": ">>>贊達拉永垂不朽！<<<"
    }
  },
  "\">>>mapper: ze探险家<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>>mapper: ze Explorer<<<",
      "JP": ">>>mapper: ze探検家<<<",
      "CN": ">>>地图制作者:ze探险家<<<",
      "KR": ">>>mapper: ze탐험가<<<",
      "TW": ">>>mapper: ze探险家<<<"
    }
  },
  "\">>>我们需要找到并击碎12个面具，才能通向祖达萨<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>>We need to find and destroy 12 masks to reach Zul'Dare<<<",
      "JP": ">>>祖ダサへの道を開くため、12個の仮面を見つけ、壊さなければなりません<<<",
      "CN": "",
      "KR": ">>>祖达萨로 가는 길에 12개의 가면을 찾아 부숴야 합니다<<<",
      "TW": ">>>我们需要找到并击碎12个面具，才能通向祖达萨<<<"
    }
  },
  "\">>>20 seconds left<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>残り20秒<<<",
      "CN": ">>>剩余20秒<<<",
      "KR": ">>>20초 남음<<<",
      "TW": ">>>还剩20秒<<<"
    }
  },
  "\"1/12\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "\">>>有一个开关藏在希尔瓦娜斯雕像的后边<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>>There is a switch hidden behind the Sylvanas statue<<<",
      "JP": ">>>シルヴァナス像の裏にスイッチがあります<<<",
      "CN": "",
      "KR": ">>>希尔瓦娜스 상 뒤쪽에 숨겨진 스위치가 있습니다<<<",
      "TW": ">>>希尔瓦娜斯雕像后面藏着一个开关<<<"
    }
  },
  "\">>>40 seconds left<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>残り40秒<<<",
      "CN": ">>>剩余40秒<<<",
      "KR": ">>>40초 남음<<<",
      "TW": ">>>还剩40秒<<<"
    }
  },
  "\">>>我们需要找到左右两边的3个按钮才能继续前进<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>>We need to find 3 buttons on the left and right to proceed<<<",
      "JP": ">>>先に進むために左右の3つのボタンを見つけなければなりません<<<",
      "CN": "",
      "KR": ">>>좌우에 있는 3개의 버튼을 찾아야 앞으로 나아갈 수 있습니다<<<",
      "TW": ">>>我们需要找到左右两边的3个按钮才能继续前进<<<"
    }
  },
  "\">>>30 seconds<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>残り30秒<<<",
      "CN": ">>>30秒<<<",
      "KR": ">>>30초 남음<<<",
      "TW": ">>>还剩30秒<<<"
    }
  },
  "\">>>击碎面具我们才能通行<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>>We must destroy the masks to pass<<<",
      "JP": ">>>マスクを壊さないと通行できない<<<",
      "CN": "",
      "KR": ">>>면구를 깨부수야 통과할 수 있다<<<",
      "TW": ">>>擊碎面具我們才能通行<<<"
    }
  },
  "\">>>10 seconds left<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>残り10秒<<<",
      "CN": ">>>剩余10秒<<<",
      "KR": ">>>10초 남음<<<",
      "TW": ">>>剩餘 10 秒<<<"
    }
  },
  "\">>>70 seconds left<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>残り70秒<<<",
      "CN": ">>>剩余70秒<<<",
      "KR": ">>>70초 남음<<<",
      "TW": ">>>剩餘 70 秒<<<"
    }
  },
  "\">>>门后边的按钮能帮我们提前打开<<<\"": {
    "translation": "",
    "MultiLang": {
      "US": ">>>The button behind the door can help us open it in advance<<<",
      "JP": ">>>扉の向こう側のボタンで、提前に開けることができる<<<",
      "CN": "",
      "KR": ">>>문 뒤의 버튼으로 사전 개방이 가능하다<<<",
      "TW": ">>>門後的按鈕能幫我們提前開啟<<<"
    }
  },
  "\"需要找到3个按钮才能打开巨擘封印的大门\"": {
    "translation": "",
    "MultiLang": {
      "US": "Need to find 3 buttons to open the door sealed by the Colossus",
      "JP": "巨大な封印の扉を開くには、3つのボタンを見つける必要がある",
      "CN": "",
      "KR": "거대한 봉인의 문을 열기 위해 3개의 버튼을 찾아야 한다.",
      "TW": "需要找到 3 個按鈕才能打開巨擘封印的大門"
    }
  },
