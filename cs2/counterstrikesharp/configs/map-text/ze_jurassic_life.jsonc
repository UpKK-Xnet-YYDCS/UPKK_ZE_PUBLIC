{
  "***HOLD 20 SECONDS***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***20秒間待機***",
      "CN": "***按住20秒***",
      "KR": "***20초 동안 유지***",
      "TW": "***堅持20秒***"
    }
  },
  "***GATE OPENS IN 10 SECONDS***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ドア10秒後オープン***",
      "CN": "***大门将在10秒后打开***",
      "KR": "***게이트 10초 후 개방***",
      "TW": "***門將在10秒後開啟***"
    }
  },
  "***GATE OPENS IN 5 SECONDS***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ドア5秒後オープン***",
      "CN": "***大门将在5秒后打开***",
      "KR": "***게이트 5초 후 개방***",
      "TW": "***門將在5秒後開啟***"
    }
  },
  "***FALL BACK TO THE KITCHEN!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***キッチンへ後退せよ！***",
      "CN": "***退回厨房！***",
      "KR": "***주방으로 퇴각해!***",
      "TW": "撤回廚房！***"
    }
  },
  "***HOLD HERE, KITCHEN DOORS OPEN SOON***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ここで待機、ドア間もなくオープン***",
      "CN": "***坚守此处，厨房门即将打开***",
      "KR": "***여기서 대기, 주방 문 곧 개방***",
      "TW": "***在此坚守，厨房门即将开启***"
    }
  },
  "***10 SECONDS LEFT***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***残り10秒***",
      "CN": "***剩余10秒***",
      "KR": "***남은 시간 10초***",
      "TW": "***剩余10秒***"
    }
  },
  "***5 SECONDS LEFT***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***残り5秒***",
      "CN": "***剩余5秒***",
      "KR": "***남은 시간 5초***",
      "TW": "***剩余5秒***"
    }
  },
  "***GO GO GO FALL BACK***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***後退せよ、後退せよ***",
      "CN": "***快！快！撤退！***",
      "KR": "***서둘러 퇴각!***",
      "TW": "***快跑，撤退***"
    }
  },
  "***Find your way through the visitors center to the roof top!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ビジターセンターから屋上へのルートを見つけよう！***",
      "CN": "***穿过访客中心，前往屋顶！***",
      "KR": "***안내센터 경로를 따라 옥상으로 가세요!***",
      "TW": "***找到前往遊客中心的天際線！***"
    }
  },
  "***HOLD HERE, DOOR OPEN 10 SEONDS***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ここから操作開始、10秒後にドアが開きます***",
      "CN": "***此处停留，门将在10秒后开启***",
      "KR": "***여기에 대기하세요, 문 10초 후 열림***",
      "TW": "***繼續等待，門將在10秒內打開。***"
    }
  },
  "***HOLD HERE, DOOR OPENS SOON***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ここから操作開始、まもなくドアが開きます***",
      "CN": "***此处停留，门将很快开启***",
      "KR": "***여기에 대기하세요, 곧 문이 열립니다***",
      "TW": "***繼續等待，門即將打開。***"
    }
  },
  "***HOLD HERE, GATE OPENS SOON***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ここから操作開始、まもなくゲートが開きます***",
      "CN": "***此处停留，闸门将很快开启***",
      "KR": "***여기에 대기하세요, 곧 게이트가 열립니다***",
      "TW": "***繼續等待，大門即將打開。***"
    }
  },
  "***PHONE USED, HOLD AND GET READY FOR THE ROOF TOP***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***電話を使用した。屋上に向けて準備してください***",
      "CN": "***电话已使用，请保持在此并准备前往屋顶***",
      "KR": "***전화 사용 완료, 옥상으로 바로 가세요***",
      "TW": "***電話已用，持續按住並準備前往頂層。***"
    }
  },
  "***GATE OPEN***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ゲートが開きました***",
      "CN": "***闸门已开启***",
      "KR": "***게이트 개방***",
      "TW": "***大門已打開。***"
    }
  },
  "***HELICOPTER ON THE WAY***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ヘリコプターが近づいています***",
      "CN": "***直升机正在赶来***",
      "KR": "***헬리콥터 접근 중***",
      "TW": "直升機正在趕來。***"
    }
  },
  "***CLIMB ON TO THE ROOF TOPS!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***屋上に登ってください！***",
      "CN": "***爬上屋顶！***",
      "KR": "***옥상으로 오르세요!***",
      "TW": "***前往頂層！***"
    }
  },
  "***LADDER TO ROOFTOP UNLOCKED OUTSIDE!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***屋外用ロフトへの階段が解放されました！***",
      "CN": "***通往天台的梯子已在外部解锁！***",
      "KR": "***옥상으로 올라가는 사다리 외부에서 사용 가능!***",
      "TW": "***屋頂梯子已在外面解鎖！***"
    }
  }
}
