{
  "***HOLD 20 SECONDS***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***20秒間キープ***",
      "CN": "***保持不动，持续20秒***",
      "KR": "***20초 동안 버티기***",
      "TW": "***保持 20 秒***"
    }
  },
  "***GATE OPENS IN 10 SECONDS***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***10秒後にゲートが開く***",
      "CN": "***10秒后开门***",
      "KR": "***10초 후 문이 열립니다***",
      "TW": "***閘門将在 10 秒后打开***"
    }
  },
  "***GATE OPENS IN 5 SECONDS***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***5秒後にゲートが開く***",
      "CN": "***5秒后开门***",
      "KR": "***5초 후 문이 열립니다***",
      "TW": "***閘門将在 5 秒后打开***"
    }
  },
  "***FALL BACK TO THE KITCHEN!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***キッチンに退避！***",
      "CN": "***撤退到厨房！***",
      "KR": "***부엌으로 후퇴하세요!***",
      "TW": "***撤退到厨房！***"
    }
  },
  "***HOLD HERE, KITCHEN DOORS OPEN SOON***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ここにキープ、まもなくキッチンのドアが開きます***",
      "CN": "***在此位置等待，厨房门即将打开***",
      "KR": "***여기서 버티세요. 곧 주방 문이 열립니다***",
      "TW": "***在此处等待，厨房门很快会打开***"
    }
  },
  "***10 SECONDS LEFT***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***残り10秒***",
      "CN": "***剩余10秒***",
      "KR": "***10초 남았습니다***",
      "TW": "***剩余 10 秒***"
    }
  },
  "***5 SECONDS LEFT***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***残り5秒***",
      "CN": "***剩余5秒***",
      "KR": "***5초 남았습니다***",
      "TW": "***剩余 5 秒***"
    }
  },
  "***GO GO GO FALL BACK***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***行くぞ、退避！***",
      "CN": "***前进！撤退！***",
      "KR": "***돌격! 후퇴!***",
      "TW": "***前进！撤退！***"
    }
  },
  "***Find your way through the visitors center to the roof top!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ビジターセンター内を通り抜け、屋上を目指しましょう！***",
      "CN": "***穿过游客中心，找到通往屋顶的道路！***",
      "KR": "***방문자 센터를 통과하여 옥상으로 가는 길을 찾으세요!***",
      "TW": "***穿過參觀者中心，前往頂樓！***"
    }
  },
  "***HOLD HERE, DOOR OPEN 10 SEONDS***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ここに止まり、10秒間ドアが開きます***",
      "CN": "***请在此处等待，门将在10秒后打开***",
      "KR": "***여기에서 잠시 기다리세요, 문이 10초 후에 열립니다.***",
      "TW": "***請在此處等待，門將開啟 10 秒***"
    }
  },
  "***HOLD HERE, DOOR OPENS SOON***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ここに止まり、まもなくドアが開きます***",
      "CN": "***请在此处等待，门即将打开***",
      "KR": "***여기에서 잠시 기다리세요, 문이 곧 열립니다.***",
      "TW": "***請在此處等待，門將很快開啟***"
    }
  },
  "***HOLD HERE, GATE OPENS SOON***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ここに止まり、まもなくゲートが開きます***",
      "CN": "***请在此处等待，闸门即将打开***",
      "KR": "***여기에서 잠시 기다리세요, 게이트가 곧 열립니다.***",
      "TW": "***請在此處等待，閘門將很快開啟***"
    }
  },
  "***PHONE USED, HOLD AND GET READY FOR THE ROOF TOP***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***電話を使用しました。ここに留まり、屋上への準備をしてください***",
      "CN": "***已使用电话，请保持不动，准备登上屋顶***",
      "KR": "***전화기를 사용했습니다. 잠시 기다리면서 옥상으로 이동할 준비를 하세요.***",
      "TW": "***已使用電話，請保持靜止，準備前往頂樓***"
    }
  },
  "***GATE OPEN***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ゲートが開きました***",
      "CN": "***闸门已打开***",
      "KR": "***게이트가 열렸습니다.***",
      "TW": "***閘門已開啟***"
    }
  },
  "***HELICOPTER ON THE WAY***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***ヘリコプターが向かっています***",
      "CN": "***直升机正在前往***",
      "KR": "***헬리콥터가 곧 도착합니다.***",
      "TW": "***直升機正在前往***"
    }
  },
  "***CLIMB ON TO THE ROOF TOPS!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***屋上に登ってください！***",
      "CN": "***爬上屋顶！***",
      "KR": "***옥상으로 올라가세요!***",
      "TW": "***爬上屋頂！***"
    }
  },
  "***LADDER TO ROOFTOP UNLOCKED OUTSIDE!***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***屋上への梯子が外から利用できるようになりました！***",
      "CN": "***已解锁：可在户外使用梯子到达屋顶！***",
      "KR": "***옥상으로 연결되는 사다리가 잠금 해제되었습니다!***",
      "TW": "***已在外側解鎖通往屋頂的階梯！***"
    }
  }
}
