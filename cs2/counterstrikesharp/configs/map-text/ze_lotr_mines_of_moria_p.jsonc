  },
  "**Go to the Khazad-Dum bridge!**": {
    "translation": "** 去卡扎督姆桥！**",
    "MultiLang": {
      "US": "",
      "JP": "カーザド＝ドゥームの橋へ向かえ！",
      "CN": "前往卡扎督姆大桥！",
      "KR": "**카자드두마 다리로 이동하세요!**",
      "TW": "**前往卡扎督姆橋！**"
    }
  },
  "**Go!**": {
    "translation": "** 走！**",
    "MultiLang": {
