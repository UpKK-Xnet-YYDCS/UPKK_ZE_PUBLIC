  },
  "The first chapter: climb the mountain": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "第一章：山を登れ",
      "CN": "第一章：攀登高山",
      "KR": "첫 번째 장: 산을 오르다",
      "TW": "第一章：攀山"
    }
  },
  "We need to go to the fairyland to cultivate": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "妖精の国で修行する必要がある",
