    }
  },
  "<快跑!他们要爬上来了！>": {
    "translation": "",
    "MultiLang": {
      "US": "Run fast! They're climbing up!",
      "JP": "<急げ！彼らが上ってくるぞ！>",
      "CN": "",
      "KR": "",
      "TW": "快跑!他們要爬上來了！"
    }
  },
  "<你先别急,这要花点时间...>": {
    "translation": "",
    "MultiLang": {
      "US": "<Don't rush this will take some time...>",
      "JP": "<あなたは急いでもらいません。これには時間が必要です...>",
