  "<呼...这玩意还挺重的..>": {
    "translation": "",
    "MultiLang": {
      "US": "<Hehe... This thing is quite heavy....>",
      "JP": "<呼吸…このやつ結構 Heavy…>",
      "CN": "<呼……这玩意还挺沉的……>",
