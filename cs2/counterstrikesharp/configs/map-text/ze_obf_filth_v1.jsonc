  },
  "<应该差不多了,做好准备!>": {
    "translation": "",
    "MultiLang": {
      "US": ">> Should be about ready, get prepared!<<",
      "JP": "べき差不多了, 準備做好!",
      "CN": "差不多了，做好准备！",
      "KR": "<약간의 시간이 더 필요하지만, 준비를 마)__完成翻译，请继续。>",
      "TW": "應該差不多了,做好準備!"
    }
  },
  "<正在试着打开这扇门..>": {
    "translation": "",
    "MultiLang": {
      "US": "<Trying to open this door..>",
      "JP": "<この扉を開こうとしている..\" >",
      "CN": "",
      "KR": "<이 문을 열려고 시도중...>",
      "TW": "<正在試著打開這扇門..>"
    }
  },
  "<快进来,门在关闭!>": {
    "translation": "",
    "MultiLang": {
      "US": "<Come in fast, the door is closing!>",
      "JP": "<早く入って来い、扉が閉まってる！>",
      "CN": "快进来，门在关闭！",
      "KR": "<빨리 들어와, 문이 닫히고 있다!]",
      "TW": "<快進來，門在關閉！>"
    }
  },
  "<尝试重启这门的动力..>": {
    "translation": "",
    "MultiLang": {
      "US": "<Trying to restart this one...>",
      "JP": "<試験的に再起動する気力...>",
