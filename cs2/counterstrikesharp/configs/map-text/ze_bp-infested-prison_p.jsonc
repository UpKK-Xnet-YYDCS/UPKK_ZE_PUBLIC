{
  "[There's fumes going through the vents! Get out of there!]": {
    "translation": "通风口有烟雾，快离开",
    "MultiLang": {
      "US": "",
      "JP": "換気口からガスが発生してる！そこを離れろ！",
      "CN": "通风管道里有毒气！快离开！",
      "KR": "배기관에서 유독 가스가 흘러나옵니다! 거기서 나가세요!",
      "TW": "廢氣正從通風口灌入！快逃！"
    }
  },
