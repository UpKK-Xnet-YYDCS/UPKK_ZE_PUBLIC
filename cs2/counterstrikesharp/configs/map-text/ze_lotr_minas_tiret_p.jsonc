  },
  "**Gate in throne-room opens in 90 seconds!**": {
    "translation": "王座房间的门将在90秒后打开！",
    "MultiLang": {
      "US": "",
      "JP": "**王間の扉が90秒後に開きます！**",
      "CN": "王座室的大门将在90秒后开启！",
      "KR": "왕좌실의 문이 90초 후 열립니다!",
      "TW": "**王座室前的門將在 90 秒後開啟！**"
    }
  },
  "**Gate is now open!**": {
    "translation": "门现在打开了！",
    "MultiLang": {
