    "MultiLang": {
      "US": "",
      "JP": "本当に？",
      "CN": "真的？",
      "KR": "정말요?",
      "TW": "真的嗎？"
    }
  },
  "触发也太慢了吧哥们": {
    "translation": "",
    "MultiLang": {
      "US": "Man, your triggers are way too slow.",
      "JP": "トラップの速度が遅すぎるよ、哥们",
      "CN": "触发也太慢了吧兄弟",
      "KR": "트리거가 너무 느려요, 형",
      "TW": "觸發也太慢了吧，老兄。"
