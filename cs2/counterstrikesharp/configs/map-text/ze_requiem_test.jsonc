  },
  "< ACT 1 : 罪厅 >": {
    "translation": "",
    "MultiLang": {
      "US": "ACT 1: Hall of Sin",
      "JP": "ACT 1 : 罪廳",
      "CN": "",
      "KR": "< ACT 1 : 죄청 >",
      "TW": "< ACT 1 : 罪廳 >"
    }
  },
  "< Map by @Seth >": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "< 地図由@Seth 制作 >",
      "CN": "< 地图由@Seth 制作 >",
      "KR": "< 맵由 @Seth >",
      "TW": "< 圖譜由 @Seth 制作 >"
    }
  },
  "< 地图作者 @Seth. >": {
    "translation": "",
    "MultiLang": {
      "US": "Map Author @Seth.",
      "JP": "地図作者 @Seth.",
      "CN": "",
      "KR": "지도 저작자 @Seth.",
      "TW": "地圖作者 @Seth."
    }
  },
  "...": {
    "translation": "",
    "MultiLang": {
      "US": "【BeginTranslation】",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": "【開始翻譯】"
    }
  },
  "此非汝等血肉之躯接近的地方.": {
    "translation": "",
    "MultiLang": {
      "US": "This is no place for mortal flesh to tread.",
      "JP": "ここは貴様の血肉の体が続けられる場所ではない",
      "CN": "此非汝等血肉之躯可近之地.",
      "KR": "여기는 귀하의 육체가 가까이할 곳이 아닙니다.",
      "TW": "此地非你等血肉之軀可輕易涉足之處。"
    }
  },
  "回头吧.": {
    "translation": "",
    "MultiLang": {
      "US": "Turn back.",
      "JP": "引き返せ",
      "CN": "",
      "KR": "돌아가시오.",
      "TW": "回去吧。"
    }
  },
  "..还是说，你和其他人一样.": {
    "translation": "",
    "MultiLang": {
      "US": "..Or do you, like the others,",
      "JP": "……それとも、他の者と同じだ？",
      "CN": "",
      "KR": "..아니면, 당신도 다른 이들과 같습니까?",
      "TW": "..還是說，你也和那些人一樣。"
    }
  },
  "饱受罪孽,悔恨,痛苦的折磨.": {
    "translation": "",
    "MultiLang": {
      "US": "Crushed by sin, regret, and anguish.",
      "JP": "罪孽、悔恨、苦悩に苛まれた",
      "CN": "",
      "KR": "죄업, 회한, 고통에 시달리다.",
      "TW": "深受罪孽、悔恨與痛苦的煎熬。"
    }
  },
  "踏入炼狱,渴望获得救赎？..": {
    "translation": "",
    "MultiLang": {
      "US": "Step into Purgatory, seeking redemption?..",
      "JP": "煉獄に足を踏み入れ、救済を渇望したか？……",
      "CN": "",
      "KR": "연옥으로 뛰어들어 구원을 갈구하십니까?..",
      "TW": "踏入煉獄，渴望獲得救贖？.."
    }
  },
  "> 逝者的太刀: 正面按E斩出剑气定身僵尸5秒,60秒CD. <": {
    "translation": "> 逝者的太刀: 正面按E斩出剑气定身僵尸5秒,60秒CD. <",
    "MultiLang": {
      "US": "> Deceased's Katana: Press E to unleash a sword energy slash, immobilizing the zombie for 5 seconds. 60-second cooldown. <",
      "JP": "> 亡者の太刀: Aキー（正面）で気剣を斬り出し、僵尸を5秒間硬直させる。クールタイムは60秒。",
      "CN": "> 逝者的太刀: 正面按E斩出剑气定身僵尸5秒,60秒CD. <",
      "KR": ">逝去자의 다도: 정면 E 누르면 기예를 발사해 좀비를 5초간 정지, 60초 쿨다운.<",
      "TW": "> 逝者的太刀：正面按E斬出劍氣定身殭屍5秒，60秒冷卻時間。<"
    }
  },
  "< 15 >": {
    "translation": "< 15s >",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "< 5 >": {
    "translation": "< 5s >",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "你真的相信救赎吗.": {
    "translation": "",
    "MultiLang": {
      "US": "Do you truly believe in redemption?",
      "JP": "本当に救済を信じるのか",
      "CN": "",
      "KR": "정말 구원을 믿습니까?",
      "TW": "你真的相信救贖嗎。"
    }
  },
  "或许,前方等待你的,会是更大的痛楚？..": {
    "translation": "",
    "MultiLang": {
      "US": "Perhaps, awaiting you ahead is a greater torment?..",
      "JP": "おそらく、その先に待つのは……より大きな苦痛だ？……",
      "CN": "",
      "KR": "아마도, 앞서 기다리고 있는 것은 더 큰 고통일지도 모릅니다?..",
      "TW": "或許，前方等待你的，會是更深的痛楚？.."
    }
  },
  "< 20 >": {
    "translation": "< 20s >",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "那么,但愿你做好了觉悟.": {
    "translation": "",
    "MultiLang": {
      "US": "Then, I hope you are prepared.",
      "JP": "では、覚悟していろ。",
      "CN": "",
      "KR": "좋아, 각오 단단히 해라.",
      "TW": "那麼，但願你做好了覺悟。"
    }
  },
  "去面对由你的意识形成的阻碍.": {
    "translation": "",
    "MultiLang": {
      "US": "Face the obstacles formed by your consciousness.",
      "JP": "お前の意識が作り出した障害に向き合え。",
      "CN": "面对由你意识形成的空间阻碍。",
      "KR": "네 의식이 만들어낸 장벽에 맞서라.",
      "TW": "去面對由你的意識形成的障礙。"
    }
  },
  "给我记好了,人类...": {
    "translation": "",
    "MultiLang": {
      "US": "Remember this, humans...",
      "JP": "覚えていろ、人類……",
      "CN": "",
      "KR": "기억해두어라, 인간들이여...",
      "TW": "給我記好了，人類……"
    }
  },
  "所有的奇迹,都需要牺牲.": {
    "translation": "",
    "MultiLang": {
      "US": "All miracles require sacrifice.",
      "JP": "すべての奇跡には、犠牲が必要だ。",
      "CN": "所有奇迹，都需要 sacrifice.",
      "KR": "모든 기적은 대가를 치른다.",
      "TW": "所有的奇蹟，都需要犧牲。"
    }
  },
  "去意已决呢,": {
    "translation": "",
    "MultiLang": {
      "US": "If you are determined,",
      "JP": "覚悟は決まったのか？",
      "CN": "",
      "KR": "결심했군.",
      "TW": "去意已決呢，"
    }
  },
  "那么,让我们继续吧.": {
    "translation": "",
    "MultiLang": {
      "US": "Then, let us continue.",
      "JP": "では、続けよう。",
      "CN": "",
      "KR": "좋아, 계속하자.",
      "TW": "那麼，讓我們繼續吧。"
    }
  },
  "< ACT 2 : 霓渊 >": {
    "translation": "",
    "MultiLang": {
      "US": "[ACT 2: Niyuan]",
      "JP": "ACT 2 : 霓淵",
