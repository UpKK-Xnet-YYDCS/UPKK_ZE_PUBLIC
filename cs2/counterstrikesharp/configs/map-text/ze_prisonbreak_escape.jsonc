      "KR": "헬리콥터 탑승 5초 전...",
      "TW": "直升機離場倒數5秒..."
    }
  },
  "直升机撤离前4秒...": {
    "translation": "",
    "MultiLang": {
      "US": "Helicopter extraction in 4 seconds...",
