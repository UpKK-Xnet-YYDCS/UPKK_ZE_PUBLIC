  },
  "直升机撤离前2秒...": {
    "translation": "",
    "MultiLang": {
      "US": "2 seconds until helicopter evacuation...",
      "JP": "ヘリコプター離陸まで残り2秒…",
      "CN": "",
      "KR": "헬기 출항 2초 전...",
