    }
  },
  "直升机撤离前1秒...": {
    "translation": "",
    "MultiLang": {
      "US": "1 second until helicopter evacuation...",
      "JP": "ヘリコプター離陸まで残り1秒…",
      "CN": "",
      "KR": "헬기 출항 1초 전...",
      "TW": "直升機撤離倒數1秒"
    }
  },
  "逃脱成功！！": {
    "translation": "",
    "MultiLang": {
      "US": "Escape successful!!",
      "JP": "脱出成功！！",
      "CN": "",
      "KR": "탈출 성공!!",
      "TW": "脫逃成功！！"
    }
  },
  "All zombies have been eliminated.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "すべてのゾンキーを倒しました。",
      "CN": "所有僵尸已被消灭。",
      "KR": "모든 좀비가 제거되었습니다.",
      "TW": "所有喪屍已被清除。"
    }
  },
  "The door to the underground bunker has opened!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "地下シェルターへの扉が開きました！",
      "CN": "地下掩体的门已打开！",
      "KR": "지하 벙커의 문이 열렸습니다!",
      "TW": "地下堡壘的門已開啟！"
    }
  },
  "This round will end in 10 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "このラウンドは10秒後に終了します。",
      "CN": "本轮将在10秒后结束。",
      "KR": "이번 라운드는 10초 후 종료됩니다.",
      "TW": "本局将在 10 秒後結束。"
    }
  },
  "Open the door to start the next round!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "扉を開いて次のラウンドを開始してください！",
      "CN": "打开门以开始下一轮！",
      "KR": "다음 라운드를 시작하려면 문을 여세요!",
      "TW": "開啟門以開始下一回合！"
    }
  },
  "The round has started!!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ラウンド開始！",
      "CN": "本轮已开始！！",
      "KR": "라운드 시작!!",
      "TW": "回合已開始！！"
    }
  },
  "Secure an escape route by activating the controller in each room!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "各部屋のコントローラーを起動し、脱出路を確保せよ！",
      "CN": "激活每个房间内的控制器，建立逃生路线！",
      "KR": "각 방의 컨트롤러를 활성화해 탈출로를 확보하세요!",
      "TW": "激活每個房間中的控制器，確保安逃路線！"
    }
  },
  "Invade the room and operate the controller!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "部屋に侵入し、コントローラーを操作しろ！",
      "CN": "入侵房间并操作控制器！",
      "KR": "방에 침투하여 컨트롤러를 작동시키세요!",
      "TW": "入侵房間並操作控制器！"
    }
  },
  "Warning!Zombie reinforcements have arrived!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "警告！ゾンビの援軍が到着！",
      "CN": "警告！僵尸增援已到达！",
      "KR": "경고! 좀비 증원대가 도착했습니다!",
      "TW": "警告！殭屍援軍已抵達！"
    }
  },
  "Controller activation at 10%.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "コントローラー起動率：10%",
      "CN": "控制器激活至10%。",
