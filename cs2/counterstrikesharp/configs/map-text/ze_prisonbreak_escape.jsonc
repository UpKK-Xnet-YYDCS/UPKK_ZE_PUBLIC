{
  "僵尸猖狂起来了！请坚持1分钟！！": {
    "translation": "",
    "MultiLang": {
      "US": "The zombies have risen! Hold on for 1 minute!!",
      "JP": "ゾンビが暴れ回っている！1分間持ちこたえて！！",
      "CN": "丧尸嚣张起来啦！请坚持1分钟！！",
      "KR": "좀비들이 맹렬하게 기어올라오고 있습니다! 1분 버텨주세요!!",
      "TW": "殭屍猖獗！請堅持1分鐘！"
    }
  },
  "地下沙坑的入口被打开了！": {
    "translation": "",
    "MultiLang": {
      "US": "The entrance to the underground sand pit has been opened!",
      "JP": "地下の砂坑の入口が開いた！",
      "CN": "",
      "KR": "지하 모래주머니의 입구가 열렸습니다!",
      "TW": "地下沙坑的入口已打開！"
    }
  },
  "关上门才能终止本回合。": {
    "translation": "",
    "MultiLang": {
      "US": "Close the door to end this round.",
      "JP": "ドアを閉じてこのターンを終了する。",
      "CN": "关门后才能结束本轮。",
      "KR": "문을 닫아야만 이 라운드를 종료할 수 있습니다.",
      "TW": "關閉門才能結束本回合。"
    }
  },
  "打开门，开始下一回合！": {
    "translation": "",
    "MultiLang": {
      "US": "Open the door and start the next round!",
      "JP": "ドアを開けて次のターンへ！",
      "CN": "开门，开始下1轮！",
      "KR": "문을 열고 다음라운드로 진행합니다!",
      "TW": "打開門，開始下一回合！"
    }
  },
  "回合开始！！": {
    "translation": "",
    "MultiLang": {
      "US": "Round begins!!",
      "JP": "ターン開始！！",
      "CN": "",
      "KR": "라운드 시작!!",
      "TW": "回合開始！"
    }
  },
  "分别打开四个房间的门，并进入开启里面的控制器！": {
    "translation": "",
    "MultiLang": {
      "US": "Open the doors to all four rooms and activate the controllers inside!",
      "JP": "4つの部屋のドアをそれぞれ開け、中のコンソールを操作する！",
      "CN": "",
      "KR": "네 방의 문을 각각 열고, 안쪽에 있는 제어기를 작동하세요!",
      "TW": "分別打開四個房間的門，並進入開啟其中的控制器！"
    }
  },
  "请冲进房间并开启控制器！": {
    "translation": "",
    "MultiLang": {
      "US": "Please rush into the room and activate the controller!",
      "JP": "部屋へ急行し、コンソールを起動せよ！",
      "CN": "",
      "KR": "방으로 진입하여 제어기를 가동해주세요!",
      "TW": "請衝進房間並開啟控制器！"
    }
  },
  "控制器在30秒后启动！！": {
    "translation": "",
    "MultiLang": {
      "US": "The controller will activate in 30 seconds!!",
      "JP": "コンソールが30秒後に起動する！！",
      "CN": "",
      "KR": "제어기가 30초 후 가동됩니다!!",
      "TW": "控制器將在30秒後啟動！"
    }
  },
  "已启动2号控制器！！": {
    "translation": "",
    "MultiLang": {
      "US": "Controller #2 Activated!!",
      "JP": "コントローラー2号起動！",
      "CN": "",
      "KR": "2번 컨트롤러가 활성화되었습니다!!",
      "TW": "2號控制器已啟動！！"
    }
  },
  "区域即将关闭，请逃脱。": {
    "translation": "",
    "MultiLang": {
      "US": "Area closing. Please escape.",
      "JP": "エリアが閉鎖されます。脱出してください。",
      "CN": "",
      "KR": "구역이 곧 폐쇄됩니다. 탈출하세요.",
      "TW": "區域即將關閉，請立即逃離。"
    }
  },
  "已启动3号控制器！！": {
    "translation": "",
    "MultiLang": {
      "US": "Controller #3 Activated!!",
      "JP": "コントローラー3号起動！",
      "CN": "",
      "KR": "3번 컨트롤러가 활성화되었습니다!!",
      "TW": "3號控制器已啟動！！"
    }
  },
  "已启动1号控制器！！": {
    "translation": "",
    "MultiLang": {
      "US": "Controller #1 Activated!!",
      "JP": "コントローラー1号起動！",
      "CN": "",
      "KR": "1번 컨트롤러가 활성화되었습니다!!",
      "TW": "1號控制器已啟動！！"
    }
  },
  "已启动4号控制器！！": {
    "translation": "",
    "MultiLang": {
      "US": "Controller #4 Activated!!",
      "JP": "コントローラー4号起動！",
      "CN": "",
      "KR": "4번 컨트롤러가 활성화되었습니다!!",
      "TW": "4號控制器已啟動！！"
    }
  },
  "通往下一个场所的门被打开了！": {
    "translation": "",
    "MultiLang": {
      "US": "The door to the next area has opened!",
      "JP": "次の施設への扉が開きました！",
      "CN": "",
      "KR": "다음 장소로 이어지는 문이 열렸습니다!",
      "TW": "通往下一區域的大門已開啟！"
    }
  },
  "迅速移动到直升机乘机场！！": {
    "translation": "",
    "MultiLang": {
      "US": "Quickly move to the helicopter landing zone!!",
      "JP": "ヘリコプター搭乗場へ迅速に移動！",
      "CN": "迅速移动到直升机乘坐点！！",
      "KR": "헬리콥터 이착륙장으로 즉시 이동하세요!!",
      "TW": "請迅速前往直升機登機點！！"
    }
  },
  "在2分钟内清除障碍物，确保道路畅通！": {
    "translation": "",
    "MultiLang": {
      "US": "Clear obstacles within 2 minutes to keep the path clear!",
      "JP": "2分以内に障害物を除去し、道路を確保！",
      "CN": "",
      "KR": "2분 이내에 장애물을 제거하여 도로를 통행 가능하게 하세요!",
      "TW": "請在2分鐘內清除障礙物，確保道路暢通！"
    }
  },
  "3分钟内制服全部武装守军！": {
    "translation": "",
    "MultiLang": {
      "US": "Subdue all armed guards within 3 minutes!",
      "JP": "3分以内に全武装守備隊を制圧せよ！",
      "CN": "",
      "KR": "무장한 수비군 전원 3분 이내에 제압!",
      "TW": "3分鐘內制服全部武裝守軍！"
    }
  },
  "破坏控制器！": {
    "translation": "",
    "MultiLang": {
      "US": "Sabotage the controller!",
      "JP": "コントローラーを破壊せよ！",
      "CN": "",
      "KR": "컨트롤러 파괴!",
      "TW": "破壞控制器！"
    }
  },
  "第二控制器已安放炸弹，1分钟后引爆！": {
    "translation": "",
    "MultiLang": {
      "US": "Bombs planted on Controller #2, detonating in 1 minute!",
      "JP": "第二コントローラーに爆弾を設置、1分後に起爆！",
      "CN": "第二个控制器已经安置了炸弹，1分钟后爆炸！",
      "KR": "두 번째 컨트롤러에 폭탄 설치, 1분 후 폭발!",
      "TW": "第二控制器已安放炸彈，1分鐘後引爆！"
    }
  },
  "第四控制器已安放炸弹，1分钟后引爆！": {
    "translation": "",
    "MultiLang": {
      "US": "Bombs planted on Controller #4, detonating in 1 minute!",
      "JP": "第四コントローラーに爆弾を設置、1分後に起爆！",
      "CN": "",
      "KR": "네 번째 컨트롤러에 폭탄 설치, 1분 후 폭발!",
      "TW": "第四控制器已安放炸彈，1分鐘後引爆！"
    }
  },
  "第三控制器已安放炸弹，1分钟后引爆！": {
    "translation": "",
    "MultiLang": {
      "US": "Bombs planted on Controller #3, detonating in 1 minute!",
      "JP": "第三コントローラーに爆弾を設置、1分後に起爆！",
      "CN": "",
      "KR": "세 번째 컨트롤러에 폭탄 설치, 1분 후 폭발!",
      "TW": "第三控制器已安放炸彈，1分鐘後引爆！"
    }
  },
  "30秒后引爆！！": {
    "translation": "",
    "MultiLang": {
      "US": "Detonation in 30 seconds!!",
      "JP": "30秒後に起爆！！",
      "CN": "30秒后引爆!!",
      "KR": "30초 후 폭발!!",
      "TW": "30秒後引爆！！"
    }
  },
  "第一控制器已安放炸弹，1分钟后引爆！": {
