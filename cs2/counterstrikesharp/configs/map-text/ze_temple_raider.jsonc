{
  "** ZE TEMPLE RAIDER **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 寺院盗掘者 **",
      "CN": "** 神庙掠夺者 **",
      "KR": "** ZE 사원 약탈자 **",
      "TW": "** ZE 神廟強盜團 **"
    }
  },
  "** MAP BY SLAYERDRAGON **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 地図作成：SLAYERDRAGON **",
      "CN": "** 地图作者：SLAYERDRAGON **",
      "KR": "** SLAYERDRAGON 작성 맵 **",
      "TW": "** 地圖製作者：SLAYERDRAGON **"
    }
  },
  "Warmup - 40 sec.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ウォームアップ - 40秒。",
      "CN": "热身 - 40秒。",
      "KR": "예비 - 40초 후 시작",
      "TW": "熱身 - 40 秒。"
    }
  },
  "** HOLD THIS AREA UNTIL THE DOOR UNLOCKS **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** このエリアを確保し、ドアが開くまで待機せよ **",
      "CN": "** 守住该区域，直到大门解锁 **",
      "KR": "** 문이 열릴 때까지 이 지역을 유지하십시오 **",
      "TW": "** 守住此區域，直到門解鎖 **"
    }
  },
  "** HEALTH KIT ACQUIRED - 50s cooldown **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ハーネスキット取得 - クールダウン50秒 **",
      "CN": "** 已获取急救包 - 冷却时间50秒 **",
      "KR": "** 체력 회복제 획득 - 50초 재사용 대기 시간 **",
      "TW": "** 取得醫療包 - 冷卻時間 50 秒 **"
    }
  },
  "** SHOOT THE CRATES TO OPEN A WAY **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 箱を破壊して通行経路を開けろ **",
      "CN": "** 击毁箱子以开辟道路 **",
      "KR": "**crate을 쏴서 길을 여십시오 **",
      "TW": "** 射擊木箱以開出一条路 **"
    }
  },
  "** HOLD THE TEMPLE ENTRANCE **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 寺院の入口を死守せよ **",
      "CN": "** 守卫神庙入口 **",
      "KR": "** 사원 정문을 방어하십시오 **",
      "TW": "** 守住神廟入口 **"
    }
  },
  "** DOOR OPENS IN 5 SECONDS **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ドアが5秒後に開く **",
      "CN": "** 大门将在5秒后开启**",
      "KR": "** 문이 5초 후에 열립니다 **",
      "TW": "** 門將在 5 秒後開啟 **"
    }
  },
  "** FALL BACK **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** フォールバック **",
      "CN": "** 备用方案 **",
      "KR": "** 폴백 **",
      "TW": "** 備用方案 **"
    }
  },
  "** THE DRAGON IS CHARGING FOR A SUPERATTACK **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ドラゴンが超必殺技を準備中だ **",
      "CN": "** 恶龙正在蓄力发动超级攻击 **",
      "KR": "** 드래곤이 슈퍼공격을 준비 중입니다 **",
      "TW": "** 龍獸正在蓄力準備超擊殺攻擊 **"
    }
  },
  "** USE THE CATAPULTS ON BOTH SIDES TO STAGGER HIM **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 両側の大砲を使って彼を気絶させろ **",
      "CN": "** 利用两侧的投石机将其击退 **",
      "KR": "** 양쪽의 투석기를 사용하여 그를 얼려주세요 **",
      "TW": "** 使用兩側的投石機使其失衡 **"
    }
  },
  "** THE DRAGON IS CHARGING FOR HIS FINAL ATTACK **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ドラゴンが決死の攻撃を仕掛けてくる **",
      "CN": "** 恶龙正在蓄力发动终结攻击 **",
      "KR": "** 드래곤이 마지막 공격을 준비 중입니다 **",
      "TW": "** 龍獸準備發動終極攻擊 **"
    }
  },
  "** WE FOUND THE TREASURE ROOM! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 宝物室を発見した！ **",
      "CN": "** 我们发现藏宝箱了！ **",
      "KR": "** 보물방을 발견했습니다! **",
      "TW": "** 我們找到寶藏室了！ **"
    }
  },
  "** HOLD HERE TILL THE DOOR OPENS **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 扉が開くまでここで耐えろ **",
      "CN": "** 死守此处，直到大门打开 **",
      "KR": "** 문이 열릴 때까지 여기에서 버티세요 **",
      "TW": "** 守在這裡直到門打開 **"
    }
  },
  "** END OF THE LINE - HOLD THE TOP **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 最後の砦 - 頂上を保持せよ **",
      "CN": "** 已无路可退 - 固守高处 **",
      "KR": "** 끝자리 - 상단을 방어하세요 **",
      "TW": "** 窮途末路 - 守住頂部 **"
    }
  },
  "** ESCAPE VIA THE ROPES! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 綱で脱出だ！ **",
      "CN": "** 从绳索撤离！ **",
      "KR": "** 로프로 도피하세요! **",
      "TW": "** 沿著繩索逃生！ **"
    }
  },
  "** KEEP DEFENDING TILL WE FIND A WAY OUT **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "撤退経路を見つけたら、そこまですべて守り続けろ！",
      "CN": "坚守阵地，直到找到出路！",
      "KR": "** 출구를 찾을 때까지 계속 방어하라 **",
      "TW": "繼續防守，直到我們找到出口！"
    }
  },
  "** RUN !! THE TUNNEL IS COLLAPSING !! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "逃げる！！通路が崩壊する！！",
      "CN": "快跑！隧道要塌了！",
      "KR": "** 도망쳐 !! 터널이 붕괴되고 있다 !! **",
      "TW": "快跑！隧道正在崩塌！"
    }
  },
  "** DEFEND WHILE WE ARE OPENING THE FINAL GATES **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "最終ゲートの開放中は、守り続けろ。",
      "CN": "在最终闸门开启期间坚守阵地",
      "KR": "** 최종 문문을 열 동안 방어하라 **",
      "TW": "在我們開啟最終大門的同時繼續防守！"
    }
  },
  "** KEEP DEFENDING TILL THE LAST GATE OPENS **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "最後のゲートが開くまで、すべてを守り続けろ！",
      "CN": "坚守直至最后一扇大门打开",
      "KR": "** 마지막 문이 열릴 때까지 계속 방어하라 **",
      "TW": "持續防守，直到最後一道門打開！"
    }
  },
  "** THIS IS THE END - DEFEND TILL WE SECURED THIS POSITION! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ここで最後の戦いだ！陣地確保まで守り抜け！",
      "CN": "战局已定——确保阵地安全！",
      "KR": "** 이것은 최후다 - 이 위치를 확보할 때까지 방어하라! **",
      "TW": "這就是終點——堅守陣地，直至我們secured這個位置！"
    }
  },
  "** DESTROY THE INVADERS - unlimited ammo enabled **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "侵入者を殲滅せよ - 弾薬無限",
      "CN": "歼灭入侵者 - 无限弹药模式",
      "KR": "** 침입자를 파괴하라 - 무제한 탄약 활성화 **",
      "TW": "消滅入侵者——子彈無限"
    }
  },
  "** SHIP ESCAPED **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "船は脱出完了",
      "CN": "飞船成功逃脱",
      "KR": "** 탈출 성공 **",
      "TW": "飛船已逃脫"
    }
  }
}
