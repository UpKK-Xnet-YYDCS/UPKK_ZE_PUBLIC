  "**[CLOUD] I can see 1 crystal downstairs!** ": {
    "translation": "**[克劳德] 我看到楼下有一个水晶！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] 階下にクリスタルが1つあるのが見える！",
      "CN": "【云】我看到楼下有1个水晶！",
      "KR": "[구름] 아래층에 결정체 1개가 보입니다!",
      "TW": "[雲層]我樓下看到1個水晶！"
    }
  },
  "**[CLOUD] I need time to open this doors! Hold here for 12 seconds!**": {
    "translation": "**[克劳德] 我需要时间来打开这些门！在这里防守12秒！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] この扉を開けるまでに時間がかかる！ここを12秒間防衛しろ！",
      "CN": "【云】我需要时间打开这扇门！守住这里12秒！",
      "KR": "[구름] 이 문을 여는 데 시간이 필요합니다! 여기서 12초간 유지하세요!",
      "TW": "[雲層]我需要時間開門！守住這裡12秒！"
    }
  },
  "**[CLOUD] I need time to open this gate!**": {
    "translation": "**[克劳德] 我需要时间来打开这扇门！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] この門を開けるまでに時間がかかる！",
      "CN": "【云】我需要时间打开这扇门！",
      "KR": "[구름] 이 문을 여는 데 시간이 필요합니다!",
      "TW": "[雲層]我需要時間開門！"
    }
  },
  "**[CLOUD] I will try to open gate but it will take some time**": {
    "translation": "**[克劳德] 我会尝试打开门，但需要一些时间**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] 扉を開けるが、少し時間がかかる",
      "CN": "[CLOUD] 我会试着打开大门，但需要一些时间。",
      "KR": "[CLOUD]게이트를 열려고 하지만 시간이 좀 걸릴거다",
      "TW": "[CLOUD] 我會嘗試開啟門，但需要一些時間"
    }
  },
  "**[CLOUD] If we want enter the ancient temple first activate teleport crystal!**": {
    "translation": "**[克劳德] 如果我们想进入古老的神殿，首先激活传送水晶！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] 古代神殿に入る前に、テレポートクリスタルを起動しろ！",
      "CN": "[CLOUD] 如果想先进入古庙，就先激活传送水晶！",
      "KR": "[CLOUD]고대 사원에 들어가고 싶으면 우선 텔레포트 결정체를 활성화해!",
      "TW": "[CLOUD] 如果我們要進入古廟，先啟動傳送水晶！"
    }
  },
  "**[CLOUD] It will be easier here but you have to wait a moment**": {
    "translation": "**[克劳德] 在这里会更容易，但你得等一会儿**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] ここなら簡単だが、少し待て",
      "CN": "[CLOUD] 这里会更容易一些，但你需要稍作等待。",
      "KR": "[CLOUD]여기서는 수월하겠지만 잠시 기다려야 해",
      "TW": "[CLOUD] 這裡會比較簡單，但你必須稍等一會兒"
    }
  },
  "**[CLOUD] It's last hold! Defend this bridge for 20 seconds!**": {
    "translation": "**[克劳德] 这是最后的防守！在这座桥上防守20秒！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] 最後の保持！この橋を20秒間防衛しろ！",
      "CN": "[CLOUD] 这是最后的坚守！守住这座桥20秒！",
      "KR": "[CLOUD]마지막 방어야! 20초간 이 다리를 지켜!",
      "TW": "[CLOUD] 這是最後一次抵禦！守住這座橋20秒！"
    }
  },
  "**[CLOUD] It's last hold! Sephiroth must be here! I can feel it!**": {
    "translation": "**[克劳德] 这是最后的防守！萨菲罗斯一定在这里！我能感觉到！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] 最後の保持だ！セフィロスがここにいるはずだ！そう感じる！",
      "CN": "[CLOUD] 这是最后的坚守！萨菲罗斯一定在这里！我能感觉到！",
      "KR": "[CLOUD]마지막 방어! 세피로트는 여기 있을 거야! 직감적으로 느껴져!",
      "TW": "[CLOUD] 這是最後一次抵禦！薩菲羅斯一定在這附近！我能感覺到！"
    }
  },
  "**[CLOUD] Nades do bigger damage**": {
    "translation": "**[克劳德] 手雷造成更大的伤害**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] ナデスはより大きなダメージを与える",
      "CN": "[CLOUD] 手榴弹造成更大的伤害。",
      "KR": "[CLOUD]나데는 더 큰 피해를 입힌다",
      "TW": "[CLOUD] 手榴彈造成更大的傷害"
    }
  },
  "**[CLOUD] Ruby dragon blocking the way!**": {
    "translation": "**[克劳德] 红宝石龙挡住了路！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] ルビードラゴンが道を塞いでいる！",
      "CN": "[CLOUD] 红宝石龙挡住了去路！",
      "KR": "[CLOUD]루비 드래곤이 길을 막고 있다!",
      "TW": "[CLOUD] 紅龍擋住了去路！"
    }
  },
  "**[CLOUD] Something is wrong here better prepare to fight**": {
    "translation": "**[克劳德] 这里有些不对，最好准备战斗**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] ここはおかしい。戦いの準備をせい",
      "CN": "[CLOUD] 这里情况不对，最好做好战斗准备。",
      "KR": "[CLOUD]여기가 이상하다. 싸울 준비를 잘 해",
      "TW": "[CLOUD] 這裡有些不對勁，最好準備戰鬥"
    }
  },
  "**[CLOUD] Stay here it should be safe I'll check what happens in next room!**": {
    "translation": "**[克劳德] 留在这里，应该安全，我去检查下一间房间发生了什么！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] ここにいて。安全だと思う。次の部屋を調べてくる！",
      "CN": "[云]待在这里应该安全，我去看看下一间屋里的情况！",
      "KR": "[클라우드] 여기는 안전해. 다음 방에서 무슨 일이 일어나는지 확인하겠어!",
      "TW": "[CLOUD] 留在這裡，應該很安全。我去看看下一個房間！"
    }
  },
  "**[CLOUD] The doors are locked! We need crystal to open them**": {
    "translation": "**[克劳德] 门被锁住了！我们需要水晶来打开它们**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] 扉が施錠されている！開けるにはクリスタルがいるんだ",
      "CN": "[云]门被锁上了！我们需要水晶才能打开它",
      "KR": "[클라우드] 문이 잠겨 있어! 열려면 결정이 필요해.",
      "TW": "[CLOUD] 門被鎖住了！我们需要水晶來開啟它們。"
    }
  },
  "**[CLOUD] The gate will open in 15 seconds! Defend!**": {
    "translation": "**[克劳德] 大门将在15秒后打开！防守！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] 15秒後に扉が開く！守れ！",
      "CN": "[云]城门将在15秒后开启！守住了！",
      "KR": "[클라우드] 게이트가 15초 후에 열려! 방어해!",
      "TW": "[CLOUD] 城門將在15秒後打開！守住！"
    }
  },
  "**[CLOUD] The only way is through this gate**": {
    "translation": "**[克劳德] 唯一的路是通过这扇门**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] この先は扉を抜けるしかない",
      "CN": "[云]只有通过这道门",
      "KR": "[클라우드] 유일한 경로는 이 게이트를 통과하는 거야.",
      "TW": "[CLOUD] 唯一的路就是穿過這道城門。"
    }
  },
  "**[CLOUD] This place looks familiar this is where Sephiroth is hiding**": {
    "translation": "**[克劳德] 这个地方看起来很熟悉，这就是萨菲罗斯藏身的地方**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] ここはどこだか思い出すが……ここはセフィロスが潜んでいる場所だ",
      "CN": "[云]这地方看起来很熟悉，萨菲罗斯就藏在这里",
      "KR": "[클라우드] 이곳은 낯설게 느껴져. 여기가 바로 세피로스가 숨어 있는 곳이야.",
      "TW": "[CLOUD] 這裡看起來很眼熟……這裡就是薩菲羅斯躲藏的地方。"
    }
  },
  "**[CLOUD] Tri- Face has casted Gravity Attack!**": {
    "translation": "**5秒，[克劳德] Tri-Face施放了黑洞攻击！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] トライ・フェイスが重力攻撃を使用した！",
      "CN": "[云]三面相施放了重力攻击！",
      "KR": "[클라우드] 트라이페이스가 중력 공격을 발동했어!",
      "TW": "[CLOUD] Tri-Face 發動了重力攻擊！"
    }
  },
  "**[CLOUD] Tri-Face has been killed! Keep running!**": {
    "translation": "**[克劳德] Tri-Face被击杀！继续奔跑！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] トライ・フェイスを倒した！走り抜けろ！",
      "CN": "[云]三面相已阵亡！快跑！",
      "KR": "[클라우드] 트라이페이스를 처치했다! 계속 달아나!",
      "TW": "[CLOUD] Tri-Face 已被擊殺！繼續前進！"
    }
  },
  "**[CLOUD] Tri-Face is going to jump! Don't stay on the middle**": {
    "translation": "**5秒，[克劳德] Tri-Face准备跳跃！不要待在中间**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] トライ・フェイスが飛び掛かってくる！真ん中にいるな",
      "CN": "[云]三面相要跳起来了！别站在中间",
      "KR": "[클라우드] 트라이페이스가 점프할 거야! 가운데에 서 있으면 안 돼!",
      "TW": "[CLOUD] Tri-Face 準備跳躍！不要待在中央位置。"
    }
  },
  "**[CLOUD] Tri-Face is healing himself**": {
    "translation": "**5秒，[克劳德] Tri-Face正在自我治疗**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] トライフェイスが自己回復中",
      "CN": "[CLOUD] 三重脸正在自我恢复",
      "KR": "[클라우드] 트라이페이스가 자신을 치료하고 있어.",
      "TW": "[雲] 三角臉正在恢復自己的生命力"
    }
  },
  "**[CLOUD] Try to find way to lowest floor and take crystal to open the gates!** ": {
    "translation": "**[克劳德] 尝试找到通往最底层的道路，并拿到水晶以打开大门！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] 最下層への道を探し、クリスタルを持って門を開けろ！",
      "CN": "[CLOUD] 试着找到通往最底层的路，带着水晶打开城门！",
      "KR": "[클라우드] 가장 낮은 층으로 가는 방법을 찾고, 결석을 가져와 문을 열어라!",
      "TW": "[雲] 嘗試找到前往最底層的路徑，並取得水晶以打開門！"
    }
  },
  "**[CLOUD] Wait here! We don't know what waiting downstairs**": {
    "translation": "**[克劳德] 在这里等着！我们不知道楼下在等着什么**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] ここで待て！下階に何が控えているかわからんだろ",
      "CN": "[CLOUD] 在这里等！我们不知道楼下会发生什么",
      "KR": "[클라우드] 여기서 기다려! 아래층에 무슨 일이 있는지 알 수 없어.",
      "TW": "[雲] 在這裡等一下！我們不知道在樓下等會發生什麼事"
    }
  },
  "**[CLOUD] We don't have time on it! Back to the temple we need to find sephiroth!**": {
    "translation": "**[克劳德] 我们没有时间了！回到神殿，我们需要找到萨菲罗斯！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] 余裕はない！テンプルに戻ってセフィロスを探せ！",
      "CN": "[CLOUD] 我们没有时间了！回到神殿，我们需要找到萨菲罗斯！",
      "KR": "[클라우드] 시간이 없어! 템플로 돌아가서 세피로드를 찾아야 해!",
      "TW": "[雲] 我們沒有時間浪費！必須回到寺院，我們要找到薩菲羅斯！"
    }
  },
  "**[CLOUD] We must defeat that beast to get Materia**": {
    "translation": "**[克劳德] 我们必须击败那只野兽才能获得魔晶石**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] マテリアを手にするには、その獣を討つしかない",
      "CN": "[CLOUD] 我们必须击败那只野兽以获取魔晶石",
      "KR": "[클라우드] 마테리아를 얻으려면 그 야수를 물리쳐야 해.",
      "TW": "[雲] 我們必須擊敗那隻怪獸以獲取魔晶石"
    }
  },
  "**[CLOUD] Well done! Doors will open in 10 seconds!**": {
    "translation": "**[克劳德] 干得好！门将在10秒后打开！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] よくやった！10秒後に門が開く！",
      "CN": "[CLOUD] 干得好！门将在10秒后打开！",
      "KR": "[클라우드] 잘했어! 10초 후에 문이 열려!",
      "TW": "[雲] 做得好！門將在10秒後開啟！"
    }
  },
  "**[CLOUD] Zombies esaped": {
    "translation": "**[克劳德] 僵尸逃脱了**",
    "MultiLang": {
      "US": "",
      "JP": "[CLOUD] ゾンビーが脱出",
      "CN": "[CLOUD] 丧尸逃跑了",
      "KR": "[클라우드] 좀비가 도주했습니다",
      "TW": "[雲] 殭屍逃脫了"
    }
  },
  "**[CLOUD] Zombies esaped!**": {
    "translation": "**[克劳德] 僵尸逃脱了！**",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド] ゾンビが脱出！",
      "CN": "[CLOUD] 丧尸逃跑了！",
      "KR": "[클라우드] 좀비가 도주했습니다!",
      "TW": "[雲] 殭屍逃脫了！"
    }
  },
  "**[Cloud] Sephiroth what you want!?**": {
    "translation": "**[克劳德] 萨菲罗斯你想要什么！？**",
    "MultiLang": {
      "US": "",
      "JP": "【クラウド】セフィロス、何を望む！",
      "CN": "[克劳德] 萨菲罗斯，你想干什么？！",
      "KR": "[클라우드] 세피로스가 뭐야, 자네?!",
      "TW": "【克勞德】薩菲羅斯！你到底想要做什麼？"
    }
  },
  "**[Cloud] it's safe downstairs! Jump!**": {
    "translation": "**[克劳德] 楼下是安全的！跳下去！**",
    "MultiLang": {
      "US": "",
      "JP": "【クラウド】下は安全だ！飛び降りろ！",
      "CN": "[克劳德] 下面安全！跳！",
      "KR": "[클라우드] 아래층은 안전해! 뛰어내려!",
      "TW": "【克勞德】樓下已經安全了！跳！"
    }
  },
  "**[HIGHWIND] Come on guys! We don't have much time!**": {
    "translation": "**[海温德] 快点，伙计们！我们没有多少时间了！**",
    "MultiLang": {
      "US": "",
      "JP": "【ハイウインド】みんな、急げ！時間がない！",
      "CN": "[空中花园] 快啊大家！我们没时间了！",
      "KR": "[하이위드] 자들아, 얼른 와! 시간이 얼마 안 남았어!",
      "TW": "【飛空艇HIGHWIND】快點！我們時間不多了！"
    }
  },
  "**[HIGHWIND] Hold this area! We leaving in 12 seconds!**": {
    "translation": "**[海温德] 在这里防守！我们将在12秒后离开！**",
    "MultiLang": {
      "US": "",
      "JP": "【ハイウインド】この地点を維持しろ！12秒で離脱する！",
      "CN": "[空中花园] 守住这里！我们要在第12秒离开！",
      "KR": "[하이위드] 이 지역을 방어해! 우리 12초 후에 떠날 거야!",
      "TW": "【飛空艇HIGHWIND】守住這個區域！我們12秒後出發！"
    }
  },
  "**[HIGHWIND] Hold this area! We leaving in 18 seconds!**": {
    "translation": "**[海温德] 在这里防守！我们将在18秒后离开！**",
    "MultiLang": {
      "US": "",
      "JP": "【ハイウインド】この地点を維持しろ！18秒で離脱する！",
      "CN": "[空中花园] 守住这里！我们要在第18秒离开！",
      "KR": "[하이위드] 이 지역을 방어해! 우리 18초 후에 떠날 거야!",
      "TW": "【飛空艇HIGHWIND】守住這個區域！我們18秒後出發！"
    }
  },
  "**[HIGHWIND] Temple going to explode! Keep running!**": {
    "translation": "**[海温德] 神殿要爆炸了！继续奔跑！**",
    "MultiLang": {
      "US": "",
      "JP": "【ハイウインド】寺院が爆発する！走り続けろ！",
      "CN": "[空中花园] 神殿要爆炸了！继续跑！",
      "KR": "[하이위드] 사원이 폭발할 거야! 계속 달릴게!",
      "TW": "【飛空艇HIGHWIND】神殿即將爆炸！繼續前進！"
    }
  },
  "**[SEPHIROTH] Despair will lead to your end!**": {
    "translation": "**[萨菲罗斯] 绝望将导致你的终结！**",
    "MultiLang": {
      "US": "",
      "JP": "【セフィロス】絶望が、お前の終末を招く！",
      "CN": "[萨菲罗斯] 绝望会引领你走向终结！",
      "KR": "[세피로스] 절망이 당신의 종말을 이끌 것이네!",
      "TW": "【薩菲羅斯】絕望將引你走向終結！"
    }
  },
  "**[SEPHIROTH] Do you still yearn for the light?**": {
    "translation": "**[萨菲罗斯] 你还渴望光明吗？**",
    "MultiLang": {
      "US": "",
