  },
  "Find the way out!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "出口を見つけろ！",
      "CN": "找到出路！",
      "KR": "출구를 찾으세요!",
      "TW": "找出出口！"
    }
  },
  "Split here! We have to defend two sides!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ここで分かれ！両面を防守せねば！",
      "CN": "在此分兵！我们必须防守两个方向！",
      "KR": "여기서 분할하세요! 양쪽을 방어해야 합니다!",
      "TW": "在此分兵！我們必須防衛兩側！"
    }
  },
  "Someone have to go down!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "誰かが下に行かねばならぬ！",
      "CN": "有人必须下去！",
      "KR": "누군가는 내려가야 합니다!",
      "TW": "總得有人下去！"
    }
  },
  "Defend 30 seconds!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "30秒間防衛せよ！",
      "CN": "防守30秒！",
      "KR": "30초 방어하세요!",
      "TW": "防衛 30 秒！"
    }
  },
  "Defend and wait for sponge!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "守ってスポンジを待ちましょう！",
      "CN": "防守并等待海绵！",
      "KR": "방어하고 스펀지가 올 때까지 기다려라!",
      "TW": "防守並等待海綿！"
    }
  },
  "Sponge is moving!": {
    "translation": "",
    "MultiLang": {
