  "Defend here 30 seconds!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ここで30秒間防衛せよ！",
      "CN": "在此处防守30秒！",
      "KR": "여기서 30초 버티세요!",
