{
  "该死！大家还好么？": {
    "translation": "",
    "MultiLang": {
      "US": "Damn! Is everyone alright?",
      "JP": "くそ！みんな無事か？",
      "CN": "",
      "KR": "젠장! 다들 괜찮은가?",
      "TW": "該死！大家還好嗎？"
    }
  },
  "我们没事头儿": {
    "translation": "",
    "MultiLang": {
      "US": "We're okay, boss.",
      "JP": "大丈夫、隊長。",
      "CN": "",
      "KR": "괜찮습니다, 대장님.",
      "TW": "我們沒事，隊長。"
    }
  },
  "看来只能找到另外的路出去了": {
    "translation": "",
    "MultiLang": {
      "US": "Looks like we'll have to find another way out.",
      "JP": "どうやら別の道を探すしかないようだ。",
      "CN": "",
      "KR": "안타깝지만 다른 길을 찾아야겠군.",
      "TW": "看來只能找到另一條路出去。"
    }
  },
  "无线电能联系上么？": {
    "translation": "",
    "MultiLang": {
      "US": "Can we contact anyone over the radio?",
      "JP": "無線は繋がるか？",
      "CN": "",
      "KR": "무전으로 연락이 될까요?",
      "TW": "無線電能聯繫上嗎？"
    }
  },
  "不行 没信号头儿": {
    "translation": "",
    "MultiLang": {
      "US": "No, no signal, boss.",
      "JP": "繋がらない、隊長。電波なし。",
      "CN": "",
      "KR": "안 됩니다, 대장님. 신호가 없습니다.",
      "TW": "不行，沒信號，隊長。"
    }
  },
  "打起精神来！我一定会带你们出去": {
    "translation": "",
    "MultiLang": {
      "US": "Stay strong! I'm going to get you all out of here.",
      "JP": "気力を振り絞れ！必ずみんなを救い出す",
      "CN": "",
      "KR": "힘내세요! 저는 반드시 여러분을 이 곳에서 탈출시킬 겁니다.",
      "TW": "打起精神來！我一定會帶你們出去。"
    }
  },
  "守住15秒！刷！！！！": {
    "translation": "",
    "MultiLang": {
      "US": "Hold the line for 15 seconds! Attack!",
      "JP": "15秒間持ちこたえろ！攻撃開始！！！！",
      "CN": "",
      "KR": "15초 동안 방어! 공격!!!!",
      "TW": "堅持15秒！刷！！！！"
    }
  },
  "怎么这里也有丧尸！开火！一个不留！": {
    "translation": "",
    "MultiLang": {
      "US": "What? Zombies here too! Open fire! Leave no one behind!",
      "JP": "なぜここにもゾンビがいる！発砲！一人残さずやれ！",
      "CN": "",
      "KR": "어떻게 여기에 좀비가! 공격! 하나도 남기지 마!",
      "TW": "怎麼這裡也有殭屍！開火！一個不留！"
    }
  },
  "该死难道我们还没走出去这个鬼基地么！": {
    "translation": "",
    "MultiLang": {
      "US": "Damn, haven't we gotten out of this cursed base yet!",
      "JP": "くそ、まだこの忌々しい基地から出られないのか！",
      "CN": "",
      "KR": "젠장, 우리가 아직 이 끔찍한 기지에서 나가지 못했나!",
      "TW": "該死，難道我們還沒從這個鬼基地裡出來嗎！"
    }
  },
  "看起来给上电了": {
    "translation": "",
    "MultiLang": {
      "US": "It seems to be powered on.",
      "JP": "どうやら起動したようだ",
      "CN": "",
      "KR": "작동하는 것 같아.",
      "TW": "看起來已經供電了。"
    }
  },
  "该死这破门跟本不动！给我15秒我来敲开他！": {
    "translation": "",
    "MultiLang": {
      "US": "Damn, this broken door won't budge! Give me 15 seconds, I'll break it open!",
      "JP": "ちくしょう、このクソみたいなドアが全然開かない！15秒だけ待ってくれ、こじ開けるから！",
      "CN": "",
      "KR": "젠장, 이 엿같은 문이 아예 안 열려! 15초만 줘, 내가 부술 수 있어!",
      "TW": "該死，這該死的門根本不動！給我15秒，我來敲開它！"
    }
  },
  "僵尸3秒传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies teleport in 3 seconds.",
      "JP": "ゾンビは3秒後にテレポート",
      "CN": "",
      "KR": "좀비는 3초 후 이동.",
      "TW": "殭屍3秒後傳送。"
    }
  },
  "可恶这地方烧的有点大给我30秒弄开他": {
    "translation": "",
    "MultiLang": {
      "US": "Damn, this place is on fire! Give me 30 seconds to clear it.",
      "JP": "ちくしょう、この場所がちょっと燃えすぎだ。30秒だけ時間をくれ、なんとかして消火する",
      "CN": "",
      "KR": "빌어먹을, 이 놈의 곳이 너무 많이 불타고 있어. 30초만 줘서 치워볼게.",
      "TW": "可惡，這個地方燒得有點大了，給我30秒弄開它。"
    }
  },
  "这门好像是某个办公室打不开了给我点时间敲开他": {
    "translation": "",
    "MultiLang": {
      "US": "This door seems to be locked from an office; give me some time to break it open.",
      "JP": "このドアは、どうやら何かのオフィスに繋がっていて、開かない。少しだけ時間をくれ、こじ開ける",
      "CN": "",
      "KR": "이 문은 아마도 어떤 사무실 문인 것 같은데, 열리지 않아. 잠시만 시간을 줘서 부수볼게.",
      "TW": "這扇門好像是某個辦公室的，無法打開，給我一點時間，我來敲開它。"
    }
  },
  "也许能发现点什么": {
    "translation": "",
    "MultiLang": {
      "US": "Maybe we can find something.",
      "JP": "何かが見つかるかもしれない",
      "CN": "",
      "KR": "아마 뭔가 발견할 수 있을 거야.",
      "TW": "也許能發現些什麼。"
    }
  },
  "僵尸3秒后传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies teleport in 3 seconds.",
      "JP": "ゾンビは3秒後にテレポート",
      "CN": "",
      "KR": "좀비는 3초 후에 이동.",
      "TW": "殭屍3秒後傳送。"
    }
  },
  "这个人身边好像是个终端，看着权限很高": {
    "translation": "",
    "MultiLang": {
      "US": "It seems like this person has a terminal nearby, and it looks like it has high-level permissions.",
      "JP": "この人物の周りには端末があるようだ。アクセス権限が非常に高いようだな。",
      "CN": "",
      "KR": "저 사람 옆에는 터미널 같은 게 있는데, 권한이 엄청 높은 것 같습니다.",
      "TW": "这个人身边好像是一个终端，看起来权限很高。"
    }
  },
  "旁边还有个门，好像要这个终端才能打开": {
    "translation": "",
    "MultiLang": {
      "US": "There's another door next to it, and it looks like you need that terminal to open it.",
      "JP": "隣にドアがある。おそらく、この端末で開けるのだろう。",
      "CN": "",
      "KR": "옆에 문이 하나 더 있는데, 아마 이 터미널이 있어야 열리는 것 같습니다.",
      "TW": "旁边还有一扇门，似乎需要这个终端才能打开。"
    }
  },
  "给我15秒我去破解": {
    "translation": "",
    "MultiLang": {
      "US": "Give me 15 seconds, I'll try to crack it.",
      "JP": "15秒だけ時間をもらって、解析する。",
      "CN": "",
      "KR": "15초만 주세요, 해킹해 보겠습니다.",
      "TW": "给我15秒，我去破解。"
    }
  },
  "无线电还是联系不上么？": {
    "translation": "",
    "MultiLang": {
      "US": "Still no connection via radio?",
      "JP": "無線通信はまだ繋がらないのか？",
      "CN": "",
      "KR": "무전은 여전히 연결이 안 되나요?",
      "TW": "无线电还是无法联系吗？"
    }
  },
  "僵尸在3秒后传送": {
    "translation": "",
    "MultiLang": {
      "US": "The zombie will teleport in 3 seconds.",
      "JP": "ゾンビは3秒後にテレポートする。",
      "CN": "",
      "KR": "좀비는 3초 후에 순간이동합니다.",
      "TW": "僵尸将在3秒后传送。"
    }
  },
  "一直联系!我去看看我们从哪里能出去": {
    "translation": "",
    "MultiLang": {
      "US": "Keep trying to contact me! I'll go see if I can find a way out.",
      "JP": "常に連絡を取り合おう！出口がどこにあるか調べてみる。",
      "CN": "",
      "KR": "계속 연락해요! 제가 나가갈 수 있는 곳이 있는지 확인해 보겠습니다.",
      "TW": "一直保持联系！我去看看我们从哪里能出去。"
    }
  },
  "全是干扰头儿！": {
    "translation": "",
    "MultiLang": {
      "US": "Just static!",
      "JP": "全てが妨害電波だ！",
      "CN": "",
      "KR": "전부 방해 신호예요!",
      "TW": "全是干扰源！"
    }
  },
  "该死！他们追上来了": {
    "translation": "",
    "MultiLang": {
      "US": "Damn! They're catching up!",
      "JP": "くそ！やつらが追ってきたぞ！",
      "CN": "",
      "KR": "젠장! 그들이 따라왔어!",
      "TW": "该死！他们追上来了。"
    }
  },
  "我草！那是什么东西，好像被卡住了，这里不能久留": {
    "translation": "",
    "MultiLang": {
      "US": "Damn! What is that thing? It looks like it's stuck. We can't stay here long.",
      "JP": "うわっ！あれは何だ？何か引っかかってるみたいだ。ここは危険だ、長くは留まれない。",
      "CN": "",
      "KR": "젠장! 저게 뭐지, 뭔가 걸린 것 같아. 여기는 오래 머물 수 없어.",
      "TW": "我靠！那是什么东西，好像被卡住了，这里不能久留"
    }
  },
  "守住50秒": {
    "translation": "",
    "MultiLang": {
      "US": "Hold out for 50 seconds.",
      "JP": "50秒間、持ちこたえる。",
      "CN": "",
      "KR": "50초 동안 버텨내세요.",
      "TW": "坚持50秒"
    }
  },
  "队长这有个电台！": {
    "translation": "",
    "MultiLang": {
      "US": "Captain, there's a radio here!",
      "JP": "隊長、通信機があるぞ！",
      "CN": "",
      "KR": "대장님, 여기 라디오가 있네요!",
      "TW": "队长，这里有一个无线电！"
    }
  },
  "好！看看能不能联系上外面还能用么？": {
    "translation": "",
    "MultiLang": {
      "US": "Good! Let's see if we can contact the outside and see if anything is still working.",
      "JP": "よし！外と連絡が取れるかどうか試してみよう。",
      "CN": "",
      "KR": "좋아요! 밖과 연결이 되는지 확인해 봅시다.",
      "TW": "好！看看能不能联系上外面，还能用吗？"
    }
  },
  "有信号了队长！": {
    "translation": "",
    "MultiLang": {
      "US": "We have a signal, Captain!",
      "JP": "隊長、通信できました！",
      "CN": "",
      "KR": "신호가 잡혔습니다, 대장님!",
      "TW": "有信号了，队长！"
    }
  },
  "猛禽2-2呼叫日暮小队听到请回复！": {
    "translation": "",
    "MultiLang": {
      "US": "Raptor 2-2 calling Dusk Squad, do you read?",
      "JP": "猛禽2-2、日暮小隊に聞こえますか？応答願います！",
      "CN": "",
      "KR": "맹금류 2-2, 일몰 분대에게 연락합니다. 응답해주세요!",
      "TW": "猛禽2-2呼叫日暮小队，听到请回复！"
    }
  },
  "猛禽2-2这里是日暮小队！我们在基地被截断了！请求立刻撤离": {
    "translation": "",
    "MultiLang": {
      "US": "Raptor 2-2, this is Dusk Squad! We've been cut off at the base! Requesting immediate evacuation.",
      "JP": "猛禽2-2、こちら日暮小隊！我々は基地で通信が遮断されました！直ちに避難を要請します。",
      "CN": "",
      "KR": "맹금류 2-2, 여기는 일몰 분대입니다! 저희는 기지에서 통신이 끊겼습니다! 즉시 철수 요청합니다.",
      "TW": "猛禽2-2，这里是日暮小队！我们被困在基地！请求立刻撤离！"
    }
  },
  "快反已经出发！一定要活着出来！外面的情况也不容乐观！": {
    "translation": "",
    "MultiLang": {
      "US": "Reinforcements have launched! We must survive! The situation outside is not optimistic either!",
      "JP": "増援部隊が出発しました！必ず生きて帰ってきてください！外の状況も芳しくありません！",
      "CN": "",
      "KR": "정면 공격 부대가 출발했습니다! 반드시 살아 돌아오세요! 외부 상황도 좋지 않습니다!",
      "TW": "增援部队已经出发！一定要活着出来！外面的情况也不容乐观！"
    }
  },
  "收到!基地北面有个直升机停机坪我们会在那接你！": {
    "translation": "",
    "MultiLang": {
      "US": "Received! There's a helicopter landing pad north of the base. We'll meet you there!",
      "JP": "了解！基地北側にヘリポートがあります。そちらであなたをお迎えします！",
      "CN": "",
      "KR": "수신! 기지 북쪽에 헬리콥터 착륙장이 있습니다. 거기서 뵙겠습니다!",
      "TW": "收到！基地北面有一个直升机停机坪，我们会在那里接您！"
    }
  },
  "你们身上带的是未来人类的走向猛禽2-2完毕！": {
    "translation": "",
    "MultiLang": {
      "US": "You are carrying the future of humanity. This is Raptor 2-2, over!",
      "JP": "これは、未来の人類の行く末を象徴する猛禽2-2だ！",
      "CN": "",
      "KR": "여러분은 미래 인류의 방향을 제시하는 맹금류 2-2입니다. 완료!",
      "TW": "你们身上携带的是未来人类的走向，猛禽2-2，完毕！"
    }
  },
  "兄弟们 坚持住 我们一定会活着出去！": {
    "translation": "",
    "MultiLang": {
      "US": "Guys, hold on! We will definitely make it out alive!",
      "JP": "みんな、頑張れ！必ず生きて脱出するぞ！",
      "CN": "",
      "KR": "형제들, 버텨! 우리는 반드시 살아남아 나갈 것이다!",
      "TW": "兄弟们，坚持住，我们一定会活着出去！"
    }
  },
  "该死这个基地设施已经波及到这个程度了么！": {
    "translation": "",
    "MultiLang": {
      "US": "Damn, the damage to this base is already this severe!",
      "JP": "くそ、この基地の施設がこんなに被害を受けているとは！",
      "CN": "",
      "KR": "젠장, 이 기지의 시설이 이 정도까지 파괴되었단 말인가!",
      "TW": "该死，这个基地的设施已经损坏到这种程度了吗！"
    }
  },
  "给我40秒！": {
    "translation": "",
    "MultiLang": {
      "US": "Give me 40 seconds!",
      "JP": "40秒だ！",
      "CN": "",
      "KR": "40초만 주세요!",
      "TW": "给我40秒！"
    }
  },
  "该死他们要来了！": {
    "translation": "",
    "MultiLang": {
      "US": "Damn, they're coming!",
      "JP": "くそ、やつらが来るぞ！",
      "CN": "",
      "KR": "젠장, 녀석들이 온다!",
      "TW": "该死，他们要来了！"
    }
  },
  "小心！！！！": {
    "translation": "",
    "MultiLang": {
      "US": "Watch out!",
      "JP": "注意！！",
      "CN": "",
      "KR": "조심하십시오!!!!",
      "TW": "小心！！！！"
    }
  },
  "别卖我！！！": {
    "translation": "",
    "MultiLang": {
      "US": "Don't betray me!",
      "JP": "僕を置いて行かないで！！",
      "CN": "",
      "KR": "저를 버리지 마세요!!!",
      "TW": "别卖我！！！"
    }
  },
  "快！我们快走！": {
    "translation": "",
    "MultiLang": {
      "US": "Hurry! We need to move fast!",
      "JP": "快！さあ、早く行こう！",
      "CN": "",
      "KR": "빨리! 우리 빨리 가자!",
      "TW": "快！我們快走！"
    }
  },
  "草！这该死的破门！没电了哪个地方肯定没接上去找！": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it! This blasted door! The power must be disconnected somewhere; I need to find the connection!",
      "JP": "クソ！このクソったれなドア！電気が切れている場所には必ず接続されていない原因があるんだ！",
      "CN": "",
      "KR": "젠장! 이 빌어먹을 낡은 문! 전기가 끊긴 곳이 분명히 연결되지 않은 곳이 있을 거야!",
      "TW": "該死！這該死的破門！沒電了哪個地方肯定沒接上去找！"
    }
  },
  "冯的可算找到了！给我15秒我给它接上去！！": {
    "translation": "",
    "MultiLang": {
      "US": "I've found where the power goes! Give me 15 seconds to reconnect it!",
      "JP": "ついにフェイ・フォンを見つけた！15秒だけ時間をくれ、接続するから！！",
      "CN": "",
      "KR": "드디어 폰을 찾았어! 15초만! 연결해 줄게!!",
      "TW": "馮的終於找到了！給我15秒我給它接上去！！"
    }
  },
  "门要开了 快走！": {
    "translation": "",
    "MultiLang": {
      "US": "The door is opening! Let's go!",
      "JP": "ドアが開くぞ！早く行け！",
      "CN": "",
      "KR": "문이 열리고 있어! 빨리 가!",
      "TW": "門要開了，快走！"
    }
  },
  "头儿..我们还能出去么": {
    "translation": "",
    "MultiLang": {
      "US": "Boss... is there any way out?",
      "JP": "隊長…私たちはまだ脱出できるでしょうか？",
      "CN": "",
      "KR": "대장님... 저희는 아직 나갈 수 있나요?",
      "TW": "老大...我們還能出去嗎？"
    }
  },
  "少在这跟我发牢骚有那闲心不如多开火个干掉几个": {
    "translation": "",
    "MultiLang": {
      "US": "Stop complaining to me. If you have the time, focus on firing and taking out some enemies.",
      "JP": "そんなに文句ばかり言うな。時間があるなら、もっと攻撃して敵を倒すべきだ。",
      "CN": "",
      "KR": "여기서 불평할 시간 없어. 차라리 총을 쏴서 몇 명이나 더 없애.",
      "TW": "少在這跟我發牢騷，有那閒心不如多開火幹掉幾個。"
    }
  },
  "该死这破基地是尤里建的嘛到处没电！": {
    "translation": "",
    "MultiLang": {
      "US": "Damn this broken base! Yuri must have built it; there's no power anywhere!",
      "JP": "くそ、このボロい基地はユーリが作ったのか？ あちこちで電気が止まっている！",
      "CN": "",
      "KR": "젠장, 이 낡은 기지는 유리(Yuri)가 만든 건가? 여기는 전기가 완전히 끊겼어!",
      "TW": "該死，這破基地是尤里建的嗎，到处没电！"
    }
  },
  "这好像是一个发电机房！给我15秒弄开他": {
    "translation": "",
    "MultiLang": {
      "US": "This looks like a generator room! Give me 15 seconds to get it running.",
      "JP": "これは発電機室のようだ！15秒だけ時間をくれ、起動させるから。",
      "CN": "",
      "KR": "이곳은 발전기실 같아! 15초만 시간을 줘! 열어줄게.",
      "TW": "這好像是一個發電機房！給我15秒弄開他"
    }
  },
  "看来已经恢复了一部分电力": {
    "translation": "",
    "MultiLang": {
      "US": "It seems some power has been restored.",
      "JP": "どうやら一部の電力は復旧したようです。",
      "CN": "",
      "KR": "전력 공급이 일부 복구된 것 같습니다.",
      "TW": "看来已经恢复了一部分电力"
    }
  },
  "僵尸将在3秒后传送": {
    "translation": "",
    "MultiLang": {
      "US": "The zombie will teleport in 3 seconds.",
      "JP": "ゾンビは3秒後にテレポートします。",
      "CN": "",
      "KR": "좀비는 3초 후에 이동합니다.",
      "TW": "殭屍將在3秒後傳送"
    }
  },
  "另一台机器需要预热15秒": {
    "translation": "",
    "MultiLang": {
      "US": "Another machine needs 15 seconds to warm up.",
      "JP": "別の機械は15秒間の予熱が必要です。",
      "CN": "",
      "KR": "다른 기기는 15초 동안 예열이 필요합니다.",
      "TW": "另一台機器需要預熱15秒"
    }
  },
  "第二个机器也给上电了！": {
    "translation": "",
    "MultiLang": {
      "US": "The second machine is now powered on!",
      "JP": "2つ目の機械も起動しました！",
      "CN": "",
      "KR": "두 번째 기기도 전원이 연결되었습니다!",
      "TW": "第二台機器也已經啟動了！"
    }
  },
  "电梯将在15秒后抵达": {
    "translation": "",
    "MultiLang": {
      "US": "The elevator will arrive in 15 seconds.",
      "JP": "エレベーターは15秒後に到着します。",
      "CN": "",
      "KR": "엘리베이터는 15초 후에 도착합니다.",
      "TW": "電梯將在15秒後到達"
    }
  },
  "好了快给上电我们坐电梯离开这里": {
    "translation": "",
    "MultiLang": {
      "US": "Okay, quickly power it on, we're taking the elevator to leave here.",
      "JP": "準備OK、エレベーターに乗ってここから脱出しましょう。",
      "CN": "",
      "KR": "좋아요, 빨리 전원을 연결해서 엘리베이터를 타고 여기서 나가요.",
      "TW": "好了，快啟動，我們坐電梯離開這裡"
    }
  },
  "电梯马上就到了坚持！！": {
    "translation": "",
    "MultiLang": {
      "US": "The elevator is arriving soon, hold on!",
      "JP": "エレベーターはもうすぐ到着です！頑張ってください！！",
      "CN": "",
      "KR": "엘리베이터가 곧 도착합니다! 버티세요!!",
      "TW": "電梯馬上就要到，堅持一下！！"
    }
  },
  "快进来我们要走了！": {
    "translation": "",
    "MultiLang": {
      "US": "Hurry up and come in, we're leaving!",
      "JP": "急いで！私たちが出発します！",
      "CN": "",
      "KR": "어서 들어오세요! 우리 가야 합니다!",
      "TW": "快進來，我們要走了！"
    }
  },
  "该死无线电又被干扰了": {
    "translation": "",
    "MultiLang": {
      "US": "Damn, the radio is being jammed again.",
      "JP": "くそ、また無線が妨害されている。",
      "CN": "",
      "KR": "젠장, 무전기가 또 방해받고 있어.",
      "TW": "該死，無線電又被干擾了。"
    }
  },
  "前面那个门好像需要什么开启": {
    "translation": "",
    "MultiLang": {
      "US": "That door up ahead seems to require something to open it.",
      "JP": "前のドアは、何かで開ける必要があるようだ。",
      "CN": "",
      "KR": "저기 앞쪽 문은 뭔가 있어야 열리는 것 같아.",
      "TW": "前面那個門好像需要什麼才能開啟。"
    }
  },
  "草！这电路老坏了好在通上了10秒后就能按开门了": {
    "translation": "",
    "MultiLang": {
      "US": "Crap! This circuit is so unreliable, but it's working now. It should open the door after 10 seconds.",
      "JP": "チッ、この回路は相変わらず壊れやすいが、10秒ほど持てばドアを開けられる。",
      "CN": "",
      "KR": "젠장! 이 회로가 또 고장 났나? 다행히 연결됐어. 10초 후에 문을 열 수 있을 거야.",
      "TW": "糟糕！這個電路老是出問題，但現在通了，按下按鈕後10秒鐘就能打開門了。"
    }
  },
  "门开了快肘！！！": {
    "translation": "",
    "MultiLang": {
      "US": "The door is opening fast!!!",
      "JP": "ドアが開いたぞ！早く！",
      "CN": "",
      "KR": "문이 거의 열렸어!!!",
      "TW": "門開得真快！！！"
    }
  },
  "守住50秒兄弟们,这里走出去就到撤离点了": {
    "translation": "",
    "MultiLang": {
      "US": "Hold out for 50 seconds, guys. Once you go through here, you'll reach the evacuation point.",
      "JP": "50秒間、ここは守り抜くぞ、仲間たち。ここから出れば避難地点だ。",
      "CN": "",
      "KR": "50초 동안 버텨줘, 형제들. 여기서 나가면 바로 대피 지점이야.",
      "TW": "守住50秒，各位兄弟們，從這裡出去就能到達撤離點。"
    }
  },
  "可恶还是呼叫不到,这该死的垃圾玩意": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it, still can't get a signal. This stupid piece of junk.",
      "JP": "ちくしょう、まだ通信できない。このクソッタレなガラクタ。",
      "CN": "",
      "KR": "젠장, 여전히 연결이 안 돼. 이 망할 놈의 기계.",
      "TW": "可惡，還是無法呼叫，這該死的垃圾東西。"
    }
  },
  "这里到底发生了什么干扰这么严重？还是有人故意....": {
    "translation": "",
    "MultiLang": {
      "US": "What the hell is going on here to cause such a severe interference? Or is someone deliberately...",
      "JP": "一体、ここで何が起きて、こんなに深刻な妨害が発生しているんだ？それとも、誰かがわざと...",
      "CN": "",
      "KR": "여기에 대체 무슨 일이 일어난 거야? 방해 전파가 너무 심한데? 아니면 누군가가 일부러...",
      "TW": "到底發生了什麼事，導致干擾這麼嚴重？還是有人故意..."
    }
  },
  "门开了快走！": {
    "translation": "",
    "MultiLang": {
      "US": "The door is open, hurry!",
      "JP": "ドアが開いた！急げ！",
      "CN": "",
      "KR": "문이 열렸으니 빨리 가!",
      "TW": "門開了，快跑！"
    }
  },
  "该死！接应我们的人呢！？": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it! Where are our reinforcements?!",
      "JP": "くそっ！援護に来る部隊はどこだ！？",
      "CN": "",
      "KR": "젠장! 지원팀은 어디 있는 거지!?",
      "TW": "該死！支援我們的隊伍在哪！？"
    }
  },
  "等等！无线电有讯号了！！": {
    "translation": "",
    "MultiLang": {
      "US": "Wait! We're getting a radio signal!",
      "JP": "待て！無線に信号がある！！",
      "CN": "",
      "KR": "잠깐! 무전에서 신호가 잡혔어!!",
      "TW": "等等！無線電有訊號了！！"
    }
  },
  "日暮小队收到回复！收到请回复！": {
    "translation": "",
    "MultiLang": {
      "US": "Team Dusk, do you copy? Please respond!",
      "JP": "日暮小隊、応答してください！応答を確認しました。",
      "CN": "",
      "KR": "일몰 분대, 응답해주세요! 응답 부탁드립니다!",
      "TW": "日暮小隊收到回復！收到請回復！"
    }
  },
  "这里是日暮小队！我们到撤离点了！": {
    "translation": "",
    "MultiLang": {
      "US": "This is Team Dusk! We've arrived at the extraction point!",
      "JP": "こちら日暮小隊！避難地点に到着しました。",
      "CN": "",
      "KR": "여기는 일몰 분대입니다! 저희는 탈출 지점으로 이동 중입니다!",
      "TW": "這裡是日暮小隊！我們已抵達撤離點！"
    }
  },
  "收到！我们路上遇到了点麻烦，现在前往你们的坐标地点": {
    "translation": "",
    "MultiLang": {
      "US": "Roger that. We encountered some trouble on the way, but we're heading to your coordinates now.",
      "JP": "了解！道中、少しトラブルがありましたが、現在、あなたの座標地点へ向かっています。",
      "CN": "",
      "KR": "알겠습니다! 저희는 이동 중에 약간의 문제가 발생했고, 지금은 귀하의 좌표로 향하고 있습니다.",
      "TW": "收到！我們路上遇到了一些麻煩，現在正在前往你們的座標地點。"
    }
  },
  "快点！我可不想成为僵尸的": {
    "translation": "",
    "MultiLang": {
      "US": "Hurry up! I don't want to become a zombie.",
      "JP": "急げ！私はゾンビになりたくない。",
      "CN": "",
      "KR": "빨리! 저는 좀비가 되는 건 싫어요.",
      "TW": "快點！我可不想成為殭屍的。"
    }
  },
  "坚持住兄弟们 门马上开了 25s之后": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on, guys! The door is almost open! In 25 seconds...",
      "JP": "持ちこたえろ、兄弟たち。ドアはもうすぐだ。25秒後。",
      "CN": "",
      "KR": "버티세요, 동료들! 문이 곧 열릴 겁니다. 25초 후에.",
      "TW": "堅持住，兄弟們，大門馬上打開，25秒後。"
    }
  },
  "头儿！那是我们的直升机！": {
    "translation": "",
    "MultiLang": {
      "US": "Boss! That's our helicopter!",
      "JP": "隊長！あれは私たちのヘリだ！",
      "CN": "",
      "KR": "대장님! 저것은 저희 헬리콥터입니다!",
      "TW": "隊長！那是我們的直升機！"
    }
  },
  "该死！前面有个检查站我们先进去！": {
    "translation": "",
    "MultiLang": {
      "US": "Damn! There's a checkpoint ahead, let's go in!",
      "JP": "くそっ！前方にチェックポイントだ、突入するぞ！",
      "CN": "",
      "KR": "젠장! 앞에 검문소가 있네, 들어가야 해!",
      "TW": "該死！前面有個檢查站，我們進去！"
    }
  },
  "猛禽2-2呼叫友军单位！撤离点有不明单位袭击我们正在坠落重复我们正在坠落！": {
    "translation": "",
    "MultiLang": {
      "US": "Raptor 2-2 calling for friendly units! Our evacuation point is under attack, we are going down, repeat, we are going down!",
      "JP": "猛禽2-2、友軍部隊に連絡！脱出地点に不明な敵が攻撃を仕掛けている、墜落中、繰り返す、墜落中！",
      "CN": "",
      "KR": "맹금류 2-2, 아군에게 연락! 탈출 지점에 원치 않는 세력이 공격 중, 추락 중 반복, 추락 중!",
      "TW": "猛禽2-2呼叫友軍單位！撤離點遭到不明單位襲擊，我們正在墜落，重複，我們正在墜落！"
    }
  },
  "快关啊！草！！！": {
    "translation": "",
    "MultiLang": {
      "US": "Close it quickly! Damn it!",
      "JP": "早く閉めてくれ！くそっ！！！",
      "CN": "",
      "KR": "빨리 닫아! 빌어먹을!",
      "TW": "快關門啊！草！！！"
    }
  },
  "这地方能启用大门..我看看..": {
    "translation": "",
    "MultiLang": {
      "US": "This place can activate the gate... let me see...",
      "JP": "この場所からゲートを作動させられるか…ちょっと見てみる…",
      "CN": "",
      "KR": "이 장소에서 문을 열 수 있을까... 한번 보자...",
      "TW": "這個地方能啟動大門...我看看..."
    }
  },
  "什么？身份认证？？？": {
    "translation": "",
    "MultiLang": {
      "US": "What? Identity verification???",
      "JP": "何？身分認証！？",
      "CN": "",
      "KR": "뭐라고? 신원 확인???",
      "TW": "什麼？身份認證？？？"
    }
  },
  "刚才在办公室找到的ID卡也许有用": {
    "translation": "",
    "MultiLang": {
      "US": "The ID card I found in the office might be useful.",
      "JP": "さっきオフィスで見つけたIDカード、役に立つかもしれない。",
      "CN": "",
      "KR": "방금 사무실에서 찾은 신분증, 어쩌면 도움이 될 거야.",
      "TW": "剛在辦公室找到的身份證，或許有用。"
    }
  },
  "守住50s": {
    "translation": "",
    "MultiLang": {
      "US": "Hold the 50-second mark.",
      "JP": "50秒地点を死守しろ",
      "CN": "",
      "KR": "50초 지점 방어!",
      "TW": "守住50秒。"
    }
  },
  "！有用！兄弟们坚持住": {
    "translation": "",
    "MultiLang": {
      "US": "!Useful! Hold on, guys!",
      "JP": "！使える！みんな、持ちこたえろ！",
      "CN": "",
      "KR": "! 쓸모 있어! 동료들, 버텨!",
      "TW": "！有用！兄弟們堅持住。"
    }
  },
  "他们要破墙出来了": {
    "translation": "",
    "MultiLang": {
      "US": "They're breaking through the wall!",
      "JP": "彼らは壁を壊して出てくるだろう。",
      "CN": "",
      "KR": "그들은 벽을 부수고 나왔습니다.",
      "TW": "他們要破牆而出。"
    }
  },
  "准备好兄弟们要撤了": {
    "translation": "",
    "MultiLang": {
      "US": "Get ready, everyone, we're pulling back.",
      "JP": "準備はいいか、仲間たち、撤退するぞ。",
      "CN": "",
      "KR": "준비하세요, 동료들, 철수합니다.",
      "TW": "準備好了，兄弟們，我們要撤退了。"
    }
  },
  "猛禽2-3呼叫日暮小队我们遭到攻击不能等你们太久 穿过地下隧道外有个停机坪": {
    "translation": "",
    "MultiLang": {
      "US": "Raptor 2-3 calling Dusk Squad, we are under attack, we can't wait for you. There's a landing pad outside the underground tunnel.",
      "JP": "猛禽部隊2-3より、日暮小隊へ。我々に攻撃を受けている、長く待てない。地下トンネルを抜けると、外にヘリポートがある。",
      "CN": "",
      "KR": "맹금류 2-3, 일몰 분대에게 연락합니다. 공격을 받고 있으며, 오래 기다릴 수 없습니다. 지하 터널을 지나면 외부 부흥장(헬리패드)이 있습니다.",
      "TW": "猛禽2-3呼叫日暮小隊，我們遭到攻擊，不能等你們太久，穿過地下隧道外有個停機坪。"
    }
  },
  "我们会在那里等你们,总部下令要彻底摧毁这里！祝好运！！": {
    "translation": "",
    "MultiLang": {
      "US": "We'll be waiting for you there. HQ has ordered a complete destruction of this place! Good luck!!",
      "JP": "我々はそこで待っている。本部は、ここを完全に破壊するように命令している！頑張れ！！",
      "CN": "",
      "KR": "우리는 그곳에서 여러분을 기다리고 있습니다. 본부는 이곳을 완전히 파괴하라는 명령을 내렸습니다! 행운을 빕니다!!",
      "TW": "我們會在那裡等你們，總部下令要徹底摧毀這裡！祝你好運！！"
    }
  },
  "当心！！！！": {
    "translation": "",
    "MultiLang": {
      "US": "Watch out!!!",
      "JP": "注意！！！！",
      "CN": "",
      "KR": "조심하십시오!!!!",
      "TW": "小心！！！！"
    }
  },
  "甩掉他们了么？": {
    "translation": "",
    "MultiLang": {
      "US": "Did we lose them?",
      "JP": "奴らを振り切ったのか？",
      "CN": "",
      "KR": "그들을 따돌렸습니까?",
      "TW": "甩掉了他們嗎？"
    }
  },
  "什么动静？": {
    "translation": "",
    "MultiLang": {
      "US": "What's that noise?",
      "JP": "何か物音がする。",
      "CN": "",
      "KR": "무슨 소리가 들려요?",
      "TW": "什麼動靜？"
    }
  },
  "可恶他们在我们头上！": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it, they're above us!",
      "JP": "ちくしょう、奴らは我々の頭上だ！",
      "CN": "",
      "KR": "빌어먹을, 그들이 우리 머리 위에 있어요!",
      "TW": "可惡，他們在我們頭上！"
    }
  },
  "这群阴魂不散的混蛋！": {
    "translation": "",
    "MultiLang": {
      "US": "These persistent, annoying ghosts!",
      "JP": "この厄介な幽霊のような連中め！",
      "CN": "",
      "KR": "저 놈의 악령 떼를 버려야지!",
      "TW": "这群挥之不去的混蛋！"
    }
  },
  "守住25秒，准备逃亡": {
    "translation": "",
    "MultiLang": {
      "US": "Hold out for 25 seconds, prepare to escape.",
      "JP": "25秒間持ちこたえて、脱出の準備を。",
      "CN": "",
      "KR": "25초 동안 버티고, 탈출 준비.",
      "TW": "坚持25秒，准备撤退"
    }
  },
  "门开了！跑！！": {
    "translation": "",
    "MultiLang": {
      "US": "The door is open! Run!!",
      "JP": "扉が開いた！逃げろ！！",
      "CN": "",
      "KR": "문이 열렸어! 도망쳐!!",
      "TW": "门开了！跑！！"
    }
  },
  "日暮小队,我们已经抵达目标地点！": {
    "translation": "",
    "MultiLang": {
      "US": "Team Dusk, we have arrived at the target location!",
      "JP": "日暮小隊、目標地点に到着しました！",
      "CN": "",
      "KR": "일몰 분대, 목표 지점에 도착했습니다!",
      "TW": "日暮小队，我们已经抵达目标地点！"
    }
  },
  "收到,我们马上就到,请求火力支援丧尸数量太多了": {
    "translation": "",
    "MultiLang": {
      "US": "Received, we are arriving immediately, requesting fire support. The number of zombies is too high.",
      "JP": "了解、直ちに到着します。火力支援を要請します。ゾンビの数が多すぎます。",
      "CN": "",
      "KR": "수신, 곧 도착합니다. 화력 지원 요청합니다. 좀비 수가 너무 많습니다.",
      "TW": "收到，我们马上就到，请求火力支援，丧尸数量太多了。"
    }
  },
  "该死这破门 给我15秒弄开他！": {
    "translation": "",
    "MultiLang": {
      "US": "Damn this broken door! Give me 15 seconds to open it!",
      "JP": "くそ、このクソみたいなドアを、15秒で開けろ！",
      "CN": "",
      "KR": "빌어먹을 놈의 문! 15초 안에 열어!",
      "TW": "该死的这破门，给我15秒打开它！"
    }
  },
  "猛禽2-3收到，以红色信号弹为标记": {
    "translation": "",
    "MultiLang": {
      "US": "Hawk Team 2-3, received. Mark the location with a red signal flare.",
      "JP": "猛禽2-3に受信、赤色の信号弾を目標地点として。",
      "CN": "",
      "KR": "맹금 2-3, 수신 완료. 빨간 신호탄으로 위치를 표시합니다.",
      "TW": "猛禽2-3收到，以红色信号弹为标记"
    }
  },
  "僵尸10秒后传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies will teleport in 10 seconds.",
      "JP": "10秒後にゾンビがテレポートします。",
      "CN": "",
      "KR": "좀비는 10초 후에 순간이동합니다.",
      "TW": "僵尸将在10秒后传送"
    }
  },
  "我们出来了猛禽2-3 马上撤离！": {
    "translation": "",
    "MultiLang": {
      "US": "We're out, Raptors 2-3, prepare to evacuate!",
      "JP": "我方脱出！猛禽2-3号，立刻撤离！",
      "CN": "",
      "KR": "우리가 나왔습니다! 맹금류 2-3, 즉시 철수합니다!",
      "TW": "我們出動了，猛禽2-3，立即撤離！"
    }
  },
  "收到,停机坪外有个大门需要外部手动开启！": {
    "translation": "",
    "MultiLang": {
      "US": "Roger, there's a large door outside the landing pad that needs to be manually opened from the outside!",
      "JP": "了解。ヘリポート外に大きな扉があり、手動で開ける必要があります。",
      "CN": "",
      "KR": "알겠습니다. 활주로 외부에 외부 수동으로 열어야 하는 문이 있습니다!",
      "TW": "收到，停機坪外有一個大門需要外部手動開啟！"
    }
  },
  "该死！这破门怎么不动！！！": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it! Why isn't this stupid door moving?!",
      "JP": "くそ！このくそったれな扉が動かない！！",
      "CN": "",
      "KR": "젠장! 이 망할 문이 왜 안 열리지?!",
      "TW": "該死！這該死的門怎麼動不了！！！"
    }
  },
  "坚持住兄弟们35s": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on, guys, 35 seconds!",
      "JP": "持ちこたえろ、兄弟たち！35秒。",
      "CN": "",
      "KR": "버티세요, 동료들! 35초!",
      "TW": "堅持住，兄弟們，35秒"
    }
  },
  "目标确认！准备轰炸！": {
    "translation": "",
    "MultiLang": {
      "US": "Target confirmed! Prepare to strike!",
      "JP": "目標を確認！爆撃の準備！",
      "CN": "",
      "KR": "목표 확인! 폭격 준비!",
      "TW": "目標已確認！準備轟炸！"
    }
  },
  "抓紧了！！我们要走了": {
    "translation": "",
    "MultiLang": {
      "US": "Hang on tight! We're leaving!",
      "JP": "しっかりつかまれ！我々は出発するぞ。",
      "CN": "",
      "KR": "꽉 잡으세요! 우리가 가야 합니다!",
      "TW": "抓緊了！！我們要走了"
    }
  },
  "可恶超载了给我10秒": {
    "translation": "",
    "MultiLang": {
      "US": "Damn, overloaded! Give me 10 seconds!",
      "JP": "ちくしょう、過負荷だ！10秒待ってくれ。",
      "CN": "",
      "KR": "빌어먹을, 과부하가 걸렸습니다. 10초만 더!",
      "TW": "可惡，超載了，給我10秒"
    }
  },
  "我们马上就能离开这个鬼地方！": {
    "translation": "",
    "MultiLang": {
      "US": "We'll be able to leave this hellhole soon!",
      "JP": "我々はすぐにこの地獄から脱出できるぞ！",
      "CN": "",
      "KR": "우리는 곧 이 지옥 같은 곳에서 벗어날 수 있습니다!",
      "TW": "我們馬上就能離開這個鬼地方了！"
    }
  },
  "引擎正常液压正常，总部我们即将返航": {
    "translation": "",
    "MultiLang": {
      "US": "Engine normal, hydraulics normal. Headquarters, we are about to return.",
      "JP": "エンジン正常、油圧も正常です。本部へ、帰還します。",
      "CN": "",
      "KR": "엔진은 정상이고, 유압 시스템도 정상입니다. 본사로 곧 귀환합니다.",
      "TW": "引擎正常，液压系统正常，总部，我们即将返航。"
    }
  },
  "一切？都结束了么？！": {
    "translation": "",
    "MultiLang": {
      "US": "Is everything... is it all over?!",
      "JP": "全て…終わったのか？！",
      "CN": "",
      "KR": "모든 것이... 끝난 건가?!",
      "TW": "一切都结束了吗？！"
    }
  }
}
