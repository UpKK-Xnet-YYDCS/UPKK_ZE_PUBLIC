  "<<< 电梯将在20秒后上升 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "Elevator rising in 20 seconds.",
      "JP": "エレベーターが20秒後に上昇します",
      "CN": "",
      "KR": "엘리베이터가 20초 후 상승합니다",
      "TW": "電梯將在20秒後上升"
    }
  },
  "<<< 等待30秒破坏箱子 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "Wait 30 seconds to break the chest.",
      "JP": "30秒後に箱を破壊してください",
      "CN": "",
      "KR": "30초 후 상자 파괴 예정",
      "TW": "等待30秒破壞箱子"
    }
  },
  "<<< 所有城门都关上了!这是个陷阱! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "All gates are shut! It's a trap!",
      "JP": "すべての城門が閉まりました！これは罠です！",
      "CN": "",
      "KR": "모든 성문이 닫혔습니다! 함정입니다!",
      "TW": "所有城門都關上了!這是個陷阱!"
    }
  },
  "<<< 终于摆脱了巨人!我们快回去吧! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "We finally escaped the giant! Let's head back quickly!",
      "JP": "ようやく巨人から逃れた！帰ろう！",
      "CN": "",
      "KR": "드디어 거인으로부터 벗어나다니! 빨리 돌아갑시다!",
      "TW": "終於擺脫了巨人!我們快回去吧!"
    }
  },
  "<<< 巨人正在朝着城墙来!快把炮台都准备好! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "Giant heading to the wall! Prepare all turrets!",
      "JP": "巨人が城壁に近づいている！大砲の準備を急げ！",
      "CN": "",
      "KR": "거인성이 성벽을 향해 다가오고 있습니다! 대포들을 모두 준비하십시오!",
      "TW": "巨人正朝城牆逼近！快準備好所有砲台！"
    }
  },
  "<<< 所有炮台都已设置完毕!拉动并保护城门总开关! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "All turrets deployed! Pull and hold the main gate lever!",
      "JP": "すべての大砲が設置完了！城門のメインレバーを引いて守れ！",
      "CN": "",
      "KR": "모든 포대가 배치되었습니다! 성문의 메인 스위치를 당기고 방어하십시오!",
      "TW": "所有砲台已設定完畢！拉下城門總開關並守護它！"
    }
  },
  "<<< 开关已经拉下!坚守45秒!!! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "Lever pulled! Hold for 45 seconds!",
      "JP": "レバーを下げた！45秒持ちこたえろ！！！",
      "CN": "",
      "KR": "스위치가 작동되었습니다! 45초 동안 버티십시오!!!",
      "TW": "開關已啟動！堅守45秒！！！"
    }
  }
}
