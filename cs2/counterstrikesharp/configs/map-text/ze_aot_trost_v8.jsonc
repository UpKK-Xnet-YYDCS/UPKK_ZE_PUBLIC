  "<<< 电梯将在20秒后上升 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "The elevator will ascend in 20 seconds.",
      "JP": "エレベーターが20秒後に上昇します",
      "CN": "",
      "KR": "에levator 20초 후 상승",
      "TW": "電梯將在20秒後上升"
    }
  },
  "<<< 等待30秒破坏箱子 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "Wait 30 seconds to break the crate.",
      "JP": "30秒後に箱を破壊してください",
      "CN": "",
      "KR": "상자 파쇄까지 30초 대기",
      "TW": "等待30秒破壞箱子"
    }
  },
  "<<< 所有城门都关上了!这是个陷阱! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "All city gates are closed! It's a trap!",
      "JP": "すべての城門が閉じました！これは罠です！",
      "CN": "",
      "KR": "모든 성문이 닫혔습니다! 이는 함정입니다!",
      "TW": "所有城門都關上了！這是個陷阱！"
    }
  },
  "<<< 终于摆脱了巨人!我们快回去吧! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "Finally free from the Giant! Let's head back!",
      "JP": "ついに巨人から逃れられた！帰るぞ！",
      "CN": "",
      "KR": "드디어 거인에서 벗어났다! 빨리 돌아가자!",
      "TW": "終於擺脫了巨人！我們快回去吧！"
    }
  },
  "<<< 巨人正在朝着城墙来!快把炮台都准备好! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "Giants are approaching the walls! Prepare all turrets!",
      "JP": "巨人が城壁に近づいている！速やかに砲台の準備をしろ！",
      "CN": "",
      "KR": "거인이 성벽을 향해 다가오고 있습니다! 즉시 포탑을 준비하세요!",
      "TW": "巨人正朝城牆逼近！快將所有砲台準備就緒！"
    }
  },
  "<<< 所有炮台都已设置完毕!拉动并保护城门总开关! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "All turrets are in position! Draw and secure the main gate lever!",
      "JP": "すべての砲台が設置完了！城門の制御レバーを引き、守れ！",
      "CN": "",
      "KR": "모든 포탑이 배치되었습니다! 성문 주전원을 가동하고 보호하세요!",
      "TW": "所有砲台已部署完畢！啟動並守護城門主開關！"
    }
  },
  "<<< 开关已经拉下!坚守45秒!!! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "The lever is pulled! Hold on for 45 seconds!!!",
      "JP": "レバーを引いた！45秒間坚守するんだ！！!",
      "CN": "",
      "KR": "주전원이 조작되었습니다! 45초간 버티세요!!!",
      "TW": "開關已拉起！死守45秒！！！"
    }
  }
}
