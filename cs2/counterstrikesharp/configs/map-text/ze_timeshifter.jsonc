{
  "**Warm-up**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ウォームアップ**",
      "CN": "热身",
      "KR": "워밍업",
      "TW": "熱身"
    }
  },
  "**Press E to Shift through time**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**Eキーを押して時間をシフトする**",
      "CN": "按 E 穿越时空",
      "KR": "E키를 눌러 시간을 이동하세요",
      "TW": "按 E 穿梭時空"
    }
  },
  "**This door does not seem to open**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**このドアは開かないようだ**",
      "CN": "这扇门似乎打不开",
      "KR": "이 문은 열리지 않는 것 같습니다",
      "TW": "這扇門似乎打不開"
    }
  },
  "**Press E**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**Eキーを押す**",
      "CN": "按 E",
      "KR": "E키를 누르세요",
      "TW": "按 E"
    }
  },
  "**Try shifting to the Past**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**過去へシフトしてみよう**",
      "CN": "尝试穿越到过去",
      "KR": "과거로 이동해 보세요",
      "TW": "嘗試穿梭至過去"
    }
  },
  "**A door will open in the Past in 15 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**15秒後に過去でドアが開きます**",
      "CN": "15秒后过去将有一扇门打开",
      "KR": "15초 후 과거에서 문이 열립니다",
      "TW": "15 秒後將會有門在過去開啟"
    }
  },
  "**A door will open in the Present in 30 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**30秒後に現在でドアが開きます**",
      "CN": "30秒后现在将有一扇门打开",
      "KR": "30초 후 현재에서 문이 열립니다",
      "TW": "30 秒後將會有門在現在開啟"
    }
  },
  "**A Door will open in the Past in 30 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**30秒後に過去でドアが開きます**",
      "CN": "30秒后过去将有一扇门打开",
      "KR": "30초 후 과거에서 문이 열립니다",
      "TW": "30 秒後將會有門在過去開啟"
    }
  },
  "**An Elevator will arrive in the Past in 30 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**エレベーターが30秒後に過去に到着します**",
      "CN": "**电梯将在30秒后抵达过去**",
      "KR": "**과거에 30초 후 엘리베이터가 도착합니다**",
      "TW": "電梯將在 30 秒後抵達過去"
    }
  },
  "**A Door will open in the Past in 25 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ドアが25秒後に過去で開きます**",
      "CN": "**一扇门将在25秒后在过去打开**",
      "KR": "**과거에 25초 후 문이 열립니다**",
      "TW": "門將在 25 秒後於過去打開"
    }
  },
  "**A Door will open in the Past in 20 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ドアが20秒後に過去で開きます**",
      "CN": "**一扇门将在20秒后在过去打开**",
      "KR": "**과거에 20초 후 문이 열립니다**",
      "TW": "門將在 20 秒後於過去打開"
    }
  },
  "**Facility Self Destruct in 120 Seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**施設自爆まで120秒**",
      "CN": "**设施将在120秒后自毁**",
      "KR": "**시설 자폭 120초 전**",
      "TW": "設施將在 120 秒後自毀"
    }
  },
  "**The Final Door will open in the Present in 30 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**最終ドアが30秒後に現在で開きます**",
      "CN": "**最终之门将在30秒后在现在打开**",
      "KR": "**현재에서 30초 후 마지막 문이 열립니다**",
      "TW": "最後的門將在 30 秒後於現在打開"
    }
  },
  "**Facility Self Destruct in 10 Seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**施設自爆まで10秒**",
      "CN": "**设施将在10秒后自毁**",
      "KR": "**시설 자폭 10초 전**",
      "TW": "設施將在 10 秒後自毀"
    }
