    "MultiLang": {
      "US": "A zombie picked up [Group Healing]",
      "JP": "ゾンビが[群体治疗]を持っていた",
      "CN": "",
      "KR": "좀비 하나가 [군대 치료]를 주워 들었다.",
      "TW": "一名殭屍撿起了[群體治療]"
    }
  },
  "人类引力装置已启用": {
    "translation": "",
    "MultiLang": {
      "US": "Gravity device for humanity has been enabled",
      "JP": "ヒューマングラビティデバイスが有効化されました",
      "CN": "",
      "KR": "인간 중력 장치가 활성화되었습니다",
