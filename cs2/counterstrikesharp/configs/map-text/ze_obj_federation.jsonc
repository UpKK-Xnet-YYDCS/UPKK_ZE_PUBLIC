  "<车组成员>炮手就位": {
    "translation": "",
    "MultiLang": {
      "US": "<Crew Member> Gunner, take your position!",
      "JP": "<車載部隊員>砲手、準備！",
      "CN": "",
      "KR": "<차승무원> 포수, 사격 준비!",
      "TW": "<車組成員>砲手就位"
    }
  },
  "<车组成员>我们修好了引擎，感谢你们的帮助！": {
    "translation": "",
    "MultiLang": {
      "US": "<Crew Member> We fixed the engine. Thanks for your help!",
      "JP": "<車載部隊員>エンジンが修理完了しました、皆さんのお力添え感謝します！",
      "CN": "",
      "KR": "<차승무원> 엔진 수리를 완료했습니다. 도움 감사합니다!",
      "TW": "<車組成員>我們修好了引擎，感謝你們的幫助！"
    }
