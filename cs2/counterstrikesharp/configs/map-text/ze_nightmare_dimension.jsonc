  "|| Go ! Reload your weapons ! ||": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "|| 行け！武器をリロードしろ！",
      "CN": "前进！重新装填武器！",
      "KR": "|| 가자 ! 무기를 재장전해라 ! ||",
      "TW": "快！重新裝填武器！"
    }
  },
  "|| Zombies prepare to take control of the Giant Eye ||": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "|| ゾンビは巨大な目玉の支配を試みている",
      "CN": "僵尸们准备夺取巨眼控制权",
      "KR": "|| 좀비들이 거대 눈을 장악할 준비를 하라 ||",
      "TW": "殭屍準備控制巨眼"
    }
  },
  "|| Shoot the red shining Orb ! ||": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "|| 赤い光るオーブを撃て！",
      "CN": "射击那个发光的红色能量球！",
      "KR": "|| 붉게 빛나는 오브를 사격해라 ! ||",
      "TW": "射擊紅色發光寶珠！"
    }
  },
  "|| Hold 'Use' to push the lever down ||": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "|| '操作'ボタンを押してレバーを下に押す",
      "CN": "按住‘交互’键以压下操纵杆",
      "KR": "|| '사용'을 길게 눌러 레버를 아래로 내리세요 ||",
      "TW": "按住「使用」以按下把手"
    }
  },
  "|| You defeated the boss ! Escape now ! ||": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "|| ボス撃破！今すぐ脱出しろ！",
      "CN": "你击败了Boss！立刻逃离！",
      "KR": "|| 보스를 격파했습니다 ! 지금 탈출하세요 ! ||",
      "TW": "你擊敗了老闆！現在逃！"
    }
  },
  "|| Portal closing in 30 seconds ||": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "|| ポータル30秒で閉鎖",
