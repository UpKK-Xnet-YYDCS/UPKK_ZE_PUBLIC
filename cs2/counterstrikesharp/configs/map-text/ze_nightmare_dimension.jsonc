  },
  "|| Portal closing ||": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ポータルが閉じます",
      "CN": "传送门即将关闭",
      "KR": "포털 닫힘",
      "TW": "|| 傳送門關閉 ||"
    }
  },
  "|| Kill Remaining zombies ||": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残りゾンキーを倒す",
      "CN": "消灭剩余的僵尸",
      "KR": "잔여 좀비 처치",
      "TW": "|| 消滅剩餘殭屍 ||"
    }
  },
  "|| Thanks for playing ! ||": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイありがとうございます！",
      "CN": "感谢游玩！",
      "KR": "플레이해 주셔서 감사합니다!",
      "TW": "|| 感謝遊玩！ ||"
