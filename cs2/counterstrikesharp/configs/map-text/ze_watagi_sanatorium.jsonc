  "\"Ghost girl :\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "幽霊少女 :",
      "CN": "\"幽灵少女：\"",
      "KR": "\"유령 소녀:\"",
      "TW": "\"幽靈女孩：\""
    }
  },
  "\"「I don't know how long I've been here...」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「どれくらいの期間ここにいるのか…わからない…」",
      "CN": "\"我不知道在这里待了多久…\"",
      "KR": "\"얼마나 여기에 있었는지 모르겠어...\"",
      "TW": "\"「我不知道我已經在這裡待了多久……」\""
    }
  },
  "\"「I don't even know why I'm dead...」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「自分がなぜ死んだのかも…わからない…）」",
      "CN": "\"我甚至不知道自己为什么死了…\"",
      "KR": "\"내가 왜 죽었는지도 잘 모르겠어...\"",
      "TW": "\"「我甚至不知道自己為什麼死了……」\""
    }
  },
  "\"「If there's one thing I know...」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「私が知ってることの一つがある……」",
      "CN": "\"如果有一件事是清楚的……\"",
      "KR": "\"하나만 알 수 있는 게 있다면…\"",
      "TW": "「如果有一件事我可以確定……」"
    }
  },
  "\"「I mean I have to go to the Watagi Tunnel...」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「つまり、私は和氣トンネルに行かなきゃならない……」",
      "CN": "「我的意思是我必须去渡部隧道……」",
      "KR": "\"내가 와타기 터널에 가야 한다는 거지…\"",
      "TW": "「我的意思是，我非得去和我那隧道不可……」"
    }
  },
  "\"「Because there might be something there to get to know me...」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「なぜなら、私を知るための何かがそこにあるかもしれないから……」",
      "CN": "「因为那里可能有了解我的东西……」",
      "KR": "\"왜냐하면, 나를 알아줄 무언가가 있을지도 모르니까…\"",
      "TW": "「因為那裡可能有什麼讓我更了解自己……」"
    }
  },
  "\"「This place was a sanatorium...」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「ここは療養所だった……」",
      "CN": "「这个地方以前是疗养院……」",
      "KR": "\"이 곳은 요양원이었어…\"",
      "TW": "「這地方曾經是一家療養院……」"
    }
  },
  "\"「For some reason, I feel at home here...」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「なぜか、ここで落ち着く気がする……」",
      "CN": "「不知道为什么，我觉得这里很有家的感觉……」",
      "KR": "유독 이 곳에서 친근함을 느껴…\"",
      "TW": "「不知為何，我覺得這裡很有家的感覺……」"
    }
  },
  "\"「This is an old air-raid shelter...」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「これは古い防空壕だ……」",
      "CN": "「这是一个旧的防空洞……」",
      "KR": "\"이것은 오래된 공습 대피소야…\"",
      "TW": "「這是一個舊的防空洞……」"
    }
  },
  "\"「To me it feels like the whole area is on fire...」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「私には、ここ全体が火事の中にいるように感じる……」",
      "CN": "「对我来说，感觉整个区域都在燃烧……」",
      "KR": "나한테는 전체가 불타고 있는 것 같아…\"",
      "TW": "「對我來說，感覺整個地區都在燃燒……」"
    }
  },
  "\"「Was this some kind of ceremonial place...?」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「これは何らかの儀式用の場所だったのか……？」",
      "CN": "「这里曾经是某种仪式场所吗……？」",
      "KR": "\"어떤 의식이 있던 곳이었나?\"",
      "TW": "「這裡曾經是某種儀式場所嗎……？」"
    }
  },
  "\"「There might be a way to get to the tunnel from here...」\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「ここから洞窟に至る方法があるはずだ…」",
      "CN": "「也许从这里可以找到通往隧道的路……」",
      "KR": "\"여기서 터널로 들어갈 수 있는 길이 있을지도 모릅니다...\"",
      "TW": "「這裡也許有通往隧道的方法……」"
    }
  }
}
