{
  "\"「いつからここにいるのか分からない...」\"": {
    "translation": "\"「我不知道从什么时候开始在这里...」\"",
    "MultiLang": {
      "US": "\"I can't remember when I got here...\"",
      "JP": "",
      "CN": "「いつからここにいるのか分からない...」",
      "KR": "\"어디서부터 여기에 있었던 걸까...\"",
      "TW": "「不知道自己從什麼時候就在這裡了……」"
    }
  },
  "\"「ここからトンネルへ行けるかもしれない...」\"": {
    "translation": "\"「也许可以从这里通往隧道...」\"",
    "MultiLang": {
      "US": "\"There might be a tunnel from here...\"",
      "JP": "",
      "CN": "「ここからトンネルへ行けるかもしれない...」",
      "KR": "\"여기서 터널로 갈 수 있을지도 몰라...\"",
      "TW": "「或許可以從這裡去隧道……」"
    }
  },
  "\"「ここは何かの儀式場...？」\"": {
    "translation": "\"「这里是某种仪式场所...？」\"",
    "MultiLang": {
      "US": "\"Is this some kind of ritual site?\"",
      "JP": "",
      "CN": "「ここは何かの儀式場...？」",
      "KR": "\"어딘가 의식장 같은 곳이야...?\"",
      "TW": "「這裡像是某種儀式場所……？」"
    }
  },
  "\"「この場所は療養所...」\"": {
    "translation": "\"「这个地方是疗养所...」\"",
    "MultiLang": {
      "US": "\"This place is a sanatorium...\"",
      "JP": "",
      "CN": "「この場所は療養所...」",
      "KR": "\"이곳은 요양 시설이야...\"",
      "TW": "「這裡是療養院……」"
    }
  },
  "\"「そこに私を知るための何かがあるかもしれないから...」\"": {
    "translation": "\"「因为那里可能有了解我的东西...」\"",
    "MultiLang": {
      "US": "\"There might be something here to help me learn more about myself...\"",
      "JP": "",
      "CN": "「そこに私を知るための何かがあるかもしれないから...」",
      "KR": "\"나를 알아가는 무언가가 있을지도 모르니까...\"",
      "TW": "「那裡或許藏著讓我了解自身的事情……」"
    }
  },
  "\"「なぜだかここにいると落ち着くような...」\"": {
    "translation": "\"「不知道为什么在这里会感到平静...」\"",
    "MultiLang": {
      "US": "\"For some reason, I feel calm being here...\"",
      "JP": "",
      "CN": "「なぜだかここにいると落ち着くような...」",
      "KR": "왠지 여기 있으면 마음이 차분해지는 기분이 들었어...\",\"7\":\"하나 분명해진 건...\",\"8\":\"낡은 대공 폭격 피난처...\")",
      "TW": "「不知為何，待在這裡總讓我感到安心……」"
    }
  },
  "\"「一つ分かることと言えば...」\"": {
    "translation": "\"「唯一能确定的是...」\"",
    "MultiLang": {
      "US": "\"One thing I've come to realize is...\"",
      "JP": "",
      "CN": "「一つ分かることと言えば...」",
      "KR": "\"하나 분명한 점은...\"",
      "TW": "「我可以確定的一件事是……」"
    }
  },
  "\"「古い防空壕...」\"": {
    "translation": "\"「这是一个旧的防空洞...」\"",
    "MultiLang": {
      "US": "\"An old air-raid shelter...\"",
      "JP": "",
      "CN": "「古い防空壕...」",
      "KR": "\"낡은 방공호...\"",
      "TW": "「舊防空壕道……」"
    }
  },
  "\"「渡木トンネルへ行かなければならないということ...」\"": {
    "translation": "\"「我必须去渡木隧道...」\"",
    "MultiLang": {
      "US": "\"I must go to Watanuki Tunnel...\"",
      "JP": "「渡木トンネルへ行かなければならないというthing...」",
      "CN": "「必须去渡木隧道……」",
      "KR": "\"무목 터널로 가야 한다는 건가...\"",
      "TW": "\"「非得去渡木隧道不可了……」\""
    }
  },
  "\"「私がなぜ死んでいるのかも分からない...」\"": {
    "translation": "\"「我也不知道我为什么会死...」\"",
    "MultiLang": {
      "US": "\"I don't even know why I'm dead...\"",
      "JP": "「私はなぜ死んでいるのでもわからない...」",
      "CN": "「我甚至不明白为什么自己已经死了……」",
      "KR": "\"내가 왜 죽었는지조차 모른다...\"",
      "TW": "\"「我也搞不清楚自己為什麼已經死了……」\""
    }
  },
  "\"「私には辺りが燃えているように感じる...」\"": {
    "translation": "\"「我感觉周围像是在燃烧...」\"",
    "MultiLang": {
      "US": "\"It feels like everything is burning around me...\"",
      "JP": "",
      "CN": "「我感觉四周仿佛在燃烧……」",
      "KR": "\"주변이 불타는 것처럼 느껴진다...\"",
      "TW": "\"「我覺得周圍彷佛正在燃燒……」\""
    }
  },
  "\"幽霊少女 :\"": {
    "translation": "\"幽灵少女：\"",
    "MultiLang": {
      "US": "Ghost Girl :",
      "JP": "幽霊少女 :",
      "CN": "\"幽灵少女：\"",
      "KR": "유령 소녀 :",
      "TW": "幽靈少女："
    }
  },
