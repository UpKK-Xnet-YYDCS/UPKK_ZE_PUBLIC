{
  "** Access to the nuke room will open in 20 seconds! **": {
    "translation": "** 核弹房的入口将在20秒内打开！ **",
    "MultiLang": {
      "US": "",
      "JP": "※原子炉部屋へのアクセスは20秒後に開放されます！",
      "CN": "** 进入核弹室通道将在20秒后开启！ **",
      "KR": "** 20초 후 워커룸 출입이 열립니다! **",
      "TW": "進入核子機房通道將在20秒後開啟！"
    }
  },
  "** Final teleport will be enabled in 15 seconds... **": {
    "translation": "** 最后的传送点将在15秒内启用... **",
    "MultiLang": {
      "US": "",
      "JP": "※最後のテレポートは15秒後に有効になります...",
      "CN": "** 最终传送门将在15秒后激活... **",
      "KR": "** 최종 텔레포트가 15초 후 활성화됩니다... **",
      "TW": "最終傳送門將在15秒後啟用……"
    }
  },
  "** Please do NOT get MAD! This map is JUST A TRIM!!! **": {
    "translation": "** 请不要生气！这只是一张陷阱多的地图而已！ **",
    "MultiLang": {
      "US": "",
      "JP": "※怒らないでください！このマップは単なる寸法調整です。",
      "CN": "** 请千万不要生气！本地图仅是一个试玩版！！！**",
      "KR": "** 절대 화내지 마세요! 이 맵은 오직 한 줄의 가짓에 불과합니다!!! **",
      "TW": "請不要發脾氣！這個地圖只是簡易版而已！"
    }
  },
  "** Slowfart teleport will be enabled in 30 seconds... **": {
    "translation": "** 慢速传送将在30秒内启用... **",
    "MultiLang": {
      "US": "",
      "JP": "※のろのろテレポートは30秒後に有効になります...",
      "CN": "** 慢速飞踹传送将在30秒后激活... **",
      "KR": "** 느린 발걸음 텔레포트가 30초 후 활성화됩니다... **",
      "TW": "慢速衝刺傳送門將在30秒後啟用……"
    }
  },
  "** Someone reached the end of the maze... **": {
    "translation": "** 有人到达了迷宫的尽头... **",
    "MultiLang": {
      "US": "",
      "JP": "※誰かが迷路のゴールに到達しました...",
      "CN": "** 有人成功到达迷宫终点... **",
      "KR": "** 누군가가 미로의 끝에 도달했습니다... **",
      "TW": "有人已抵達迷宮盡頭……"
    }
  },
  "** Teleport will be enabled in 30 seconds! Temple gates will open soon... **": {
    "translation": "** 传送将在30秒内启用！寺庙的大门即将打开... **",
    "MultiLang": {
      "US": "",
      "JP": "※テレポートは30秒後に有効になります！神殿の門まもなく開放...",
      "CN": "** 传送门将在30秒后激活！神殿大门即将开启... **",
      "KR": "** 30초 후 텔레포트가 활성화됩니다! 신전 문이 곧 열릴 것입니다... **",
      "TW": "傳送門將在30秒後啟用！神殿大門即將開啟……"
    }
  },
  "** The TRAP ESCAPE doors will open soon! **": {
    "translation": "** 陷阱逃亡的大门即将打开！**",
    "MultiLang": {
      "US": "*** THE TRAP ESCAPE DOORS WILL OPEN SOON! ***",
      "JP": "※トラップエグジットはまもなく開放されます！",
      "CN": "** “陷阱逃脱”门即将开启！ **",
      "KR": "** 함정 탈출문이 곧 열립니다! **",
      "TW": "陷阱逃生門即將開啟！"
    }
  },
  "** The final area has been reached! Keep the zombies behind the suspiciously convenient caution line! **": {
    "translation": "** 已到达最后区域！将僵尸控制在那条显眼的警戒线后面！ **",
    "MultiLang": {
      "US": "",
      "JP": "※最終エリアに到達しました！不気味な便利さを併せ持つ警戒線 behind にゾンキーを集めてください！",
      "CN": "** 最终区域已到达！请将僵尸留在那条可疑的便利警戒线之后！ **",
      "KR": "** 최종 구역에 도달했습니다! 수상하게도 편리한 주의선 너머로 좀비를 붙잡아 두세요! **",
      "TW": "已到達最終區域！請將殭屍留在那道可疑方便的警戒線後面！"
    }
  },
  "** The temple has been reached... **": {
    "translation": "** 已到达寺庙... **",
    "MultiLang": {
      "US": "",
      "JP": "** テンプレートに到達しました... **",
      "CN": "** 寺庙已到达... **",
      "KR": "** 신전이 도달되었습니다... **",
      "TW": "**已抵達寺廟…**"
    }
  },
  "** Welcome to TRAP ESCAPE **": {
    "translation": "** 欢迎来到陷阱逃亡 翻译：Asteri3m **",
    "MultiLang": {
