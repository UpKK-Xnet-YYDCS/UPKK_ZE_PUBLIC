  "<Unkown Radio> ... ...": {
    "translation": "<无线电> ... ...",
    "MultiLang": {
      "US": "",
      "JP": "<Unkown Radio> ... ...",
      "CN": "<未知电台> …… ……",
      "KR": "<알 수 없는 라디오> ... ...",
      "TW": "<未知無線電> ... ..."
    }
  },
  "<Unkown Radio> The world is in chaos": {
    "translation": "<无线电> 世界陷入一片混乱",
    "MultiLang": {
      "US": "",
      "JP": "<不明な電波> 世界は混沌としている",
      "CN": "<未知电台> 世界已陷入混乱",
      "KR": "<알 수 없는 라디오> 세상이 혼란에 빠졌다",
      "TW": "<未知無線電> 世界陷入混亂"
    }
  },
  "<Unkown Radio> It's time to wake up, soldiers with a burning heart": {
    "translation": "<无线电> 是时候苏醒来了，怀揣炽热之心的战士们",
    "MultiLang": {
      "US": "",
      "JP": "<未確認の無線> 燃える思いを持つ者よ、目覚めの時だ",
      "CN": "<未知电台> 是醒来的时候了，满怀热血的士兵们",
      "KR": "<알 수 없는 라디오\"> 일어나세요, 용기를 잃지 않는 병사들\"",
      "TW": "<未知無線電> 喚醒熱血士兵的時刻已至"
    }
  },
  "<Unkown Radio> Leave this place, Find me on the edge of the world": {
    "translation": "<无线电> 离开这里，到终点处汇合",
    "MultiLang": {
      "US": "",
      "JP": "<不詳の無線> この場所を離れ、世界の果で私を見つけて",
      "CN": "<未知电台>离开这里，在世界尽头找我",
      "KR": "<알 수 없는 라디오> 이 장소를 떠나라, 이 세계의 끝에서 나를 찾아오게",
      "TW": "<未知電台> 離開這裡，在世界盡頭與我會合"
    }
  },
