    }
  },
  "El Son Goku: Bomba nuclear en 60 segundos": {
    "translation": "孙悟空: 核弹将在60秒内引爆",
    "MultiLang": {
      "US": "",
      "JP": "エル・ソン・ゴクウ：核爆弾、60秒後",
      "CN": "埃尔多森·悟空：核弹将在60秒后引爆",
      "KR": "엘 선구우:핵폭발 60초 후",
      "TW": "孫悟空：60秒後核彈發射"
    }
  },
  "El Son Goku: DESPEGUE aprieta la radio para la bomba nuclear": {
    "translation": "孙悟空: 起飞，按下无线电启动核弹",
    "MultiLang": {
      "US": "",
      "JP": "エル・ソン・ゴクウ：離陸。爆弾の発射はラジオを押す",
      "CN": "埃尔多森·悟空：起飞时按无线电启动核弹",
      "KR": "엘 선구우: 이륙 시, 내무관 버튼으로 핵폭발 호출",
      "TW": "孫悟空：起飛！按住按鈕引爆核彈"
    }
  },
  "El Son Goku: Despegue en 10 segundos": {
    "translation": "孙悟空: 10秒内起飞",
    "MultiLang": {
      "US": "",
      "JP": "エル・ソン・ゴクウ：10秒後に離陸",
      "CN": "埃尔多森·悟空：10秒后起飞",
      "KR": "엘 선구우: 10초 뒤 이륙",
      "TW": "孫悟空：10秒內起飛"
    }
  },
  "El Son Goku: El camion sale en 5 segundos": {
    "translation": "孙悟空: 卡车将在5秒内出发",
    "MultiLang": {
      "US": "",
      "JP": "エル・ソン・ゴクウ：トラックは5秒後に発進",
