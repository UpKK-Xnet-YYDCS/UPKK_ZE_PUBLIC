  "El Son Goku: 5 segundos preparate a correr": {
    "translation": "孙悟空: 5秒，准备跑",
    "MultiLang": {
      "US": "",
      "JP": "エル・ソン・ゴクウ：5秒後に逃げろ！",
      "CN": "埃尔多森·悟空：5秒后准备起跑",
      "KR": "엘 선구우: 5초 뒤 도주 준비",
      "TW": "孫悟空：準備好，5秒後開始跑步"
    }
  },
  "El Son Goku: Barco 1 se va en 10 segs": {
    "translation": "孙悟空: 船1将在10秒内离开",
    "MultiLang": {
      "US": "",
      "JP": "エル・ソン・ゴクウ：船1は10秒後に発進",
      "CN": "埃尔多森·悟空：1号船将在10秒后出发",
      "KR": "엘 선구우: 배 1호 10초 뒤 출항",
      "TW": "孫悟空：1號船在10秒內離開"
    }
  },
  "El Son Goku: Barco 2 se va en 10 segs": {
    "translation": "孙悟空: 船2将在10秒内离开",
    "MultiLang": {
