  "Get in and keep holding until the door is closed!": {
    "translation": "进入并保持直到门关闭！",
    "MultiLang": {
      "US": "",
      "JP": "中には入って、ドアが閉まるまで持ち続けるんだ！",
      "CN": "快进去，保持按压直到门关闭！",
      "KR": "안에 타고 문이 닫힐 때까지 계속 잡고 계세요!",
      "TW": "快進去，一直緊握直到門關上！"
    }
  },
  "Get inside !": {
    "translation": "快进来！",
    "MultiLang": {
      "US": "",
      "JP": "中へ入りなさい！",
      "CN": "快进去！",
