{
  "<<<Good luck.>>>": {
    "translation": "<<<祝你好运。>>>",
    "MultiLang": {
      "US": "",
      "JP": "幸運を祈る。",
      "CN": "祝你好运。",
      "KR": "행운을 빕니다.",
      "TW": "祝好運。"
    }
  },
  "<<<No one is more deserving of a rest, all the effort in the world would have gone to waste.>>>": {
    "translation": "<<<没有人比你们更值得休息，否则整个世界的努力都将白费。>>>",
    "MultiLang": {
      "US": "No one deserves a break more, all the effort in the world would have gone to waste.",
      "JP": "休息を必要とする者は誰よりも多く、この世のすべての努力が無駄になることになる。",
      "CN": "没有人比你更值得休息，所有的努力都不会白费。",
      "KR": "그 누구보다 휴식이 필요한 분이에요. 그토록 많은 노력이 헛되지 않도록 말이죠.",
      "TW": "沒人比你更該休息，世上所有的努力都不會白費。"
    }
  },
  "<<<Rise and shine, Soldiers with burning heart.>>>": {
    "translation": "<<<剑该出鞘了，怀揣着赤子之心的战士们。>>>",
    "MultiLang": {
      "US": "",
      "JP": "燃えるような心を抱く兵士たち、目覚めよ。",
      "CN": "起床吧，内心炽热的士兵们。",
      "KR": "일어나라, 뜨거운 마음을 가진 병사들이여.",
      "TW": "醒來吧，戰士們，心中燃起熱望。"
    }
  },
  "<<<The right man in the wrong place can make all the difference in the world.>>>": {
    "translation": "<<<正确的人在错误的地方引起了世界线的变动。>>>",
    "MultiLang": {
      "US": "",
      "JP": "間違った場所にいる適切な人物が、この世に大きな違いをもたらすことができる。",
      "CN": "对的人在错的位置也能改变整个世界。",
      "KR": "잘못된 위치에 있는 올바른 사람이世间의 모든 것을 바꿀 수 있습니다.",
      "TW": "錯位」的好人，往往能扭轉乾坤。"
    }
  },
  "<<<Wake up and smell the Ashes.>>>": {
    "translation": "<<<醒来吧，嗅到灰烬的气息。>>>",
    "MultiLang": {
      "US": "",
      "JP": "目を覚まし、灰の香りをかぐのだ。",
      "CN": "醒来，闻闻灰烬的味道吧。",
      "KR": "일어나서 재의 향기를 맡아보라.",
      "TW": "醒來面對現實吧。"
    }
  },
  "<<<your hour is come again.>>>": {
    "translation": "<<<变革的时机来临了。>>>",
    "MultiLang": {
      "US": "",
      "JP": "あなたの時間が再び訪れた。",
      "CN": "你的时刻再次到来。",
      "KR": "그대의 시간이 다시 왔습니다.",
      "TW": "你的時刻再次到來。"
    }
  },
  "Bad feelings...": {
    "translation": "不祥的预感...",
    "MultiLang": {
      "US": "",
      "JP": "悪い感情...",
      "CN": "负面情绪……",
      "KR": "나쁜 기분...",
      "TW": "負面情緒……"
    }
  },
  "Bomb will blow up to in 110 sec.": {
    "translation": "炸弹将在110秒后爆炸。",
    "MultiLang": {
      "US": "",
      "JP": "爆弾は110秒後に破裂します。",
      "CN": "炸弹将在110秒后爆炸。",
      "KR": "폭탄이 110초 후에 폭발합니다.",
      "TW": "炸彈將在110秒後爆炸。"
    }
  },
  "Break the laser power switch!": {
    "translation": "打破激光电源开关！",
    "MultiLang": {
      "US": "",
      "JP": "レーザー・パワー・スイッチを破壊しろ!",
      "CN": "切断激光电源开关！",
      "KR": "레이저 전원 스위치를 파괴하세요!",
      "TW": "破壞雷射電源開關！"
    }
  },
  "DEFEND 70 SECONDS": {
    "translation": "防守70秒",
    "MultiLang": {
      "US": "",
      "JP": "70秒間防衛せよ",
      "CN": "防守70秒",
      "KR": "70초간 방어",
      "TW": "防守 70 秒"
    }
  },
  "Defend until virus get uploaded": {
    "translation": "防守直到病毒上传完成",
    "MultiLang": {
      "US": "",
      "JP": "ウイルスのアップロード完了まで防衛しろ",
      "CN": "防守直至病毒上传完成",
      "KR": "바이러스가 업로드될 때까지 방어",
