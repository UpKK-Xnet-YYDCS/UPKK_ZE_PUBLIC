    "MultiLang": {
      "US": "",
      "JP": "指定エリアを45秒間キープ！",
      "CN": "在指定区域坚守45秒！",
      "KR": "45초 동안 지구를 유지하세요!",
      "TW": "保持該區域 45 秒！"
    }
  },
  "**Hold here for 10 seconds!**": {
