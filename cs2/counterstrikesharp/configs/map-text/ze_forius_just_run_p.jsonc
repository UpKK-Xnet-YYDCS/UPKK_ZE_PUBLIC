{
  "***Elevator doors open***": {
    "translation": "***电梯门打开***",
    "MultiLang": {
      "US": "",
      "JP": "***エレベーターの扉が開く***",
      "CN": "***电梯门打开***",
      "KR": "***엘리베이터 문이 열립니다***",
      "TW": "***電梯門開啟***"
    }
  },
  "***HOLD UNTIL DOOR CLOSES!!!***": {
    "translation": "***防守到门关！！！***",
    "MultiLang": {
      "US": "",
      "JP": "***扉が閉じるまで押し続ける！！！**",
      "CN": "***按住直到门关闭！***",
      "KR": "***문闭合까지 유지!!!***",
      "TW": "***直到門關閉前請保持按住!!!***"
    }
  },
  "***Humans reached the vent thingies***": {
    "translation": "***人类到达了通风口***",
    "MultiLang": {
      "US": "",
      "JP": "***人間が換気口の方へ到達***",
      "CN": "***人类到达通风口装置***",
      "KR": "인간이 환기구 구멍에 도달했습니다***",
      "TW": "***人類已到達通風口裝置***"
    }
  },
  "***LAST DOOR!!! HOLD 1 MINUTE!***": {
    "translation": "***这是最后一扇门！！！防守60秒！***",
    "MultiLang": {
      "US": "",
      "JP": "***最後の扉！！！ 1分間押し続ける！***",
      "CN": "***最后一扇门！坚持1分钟！***",
      "KR": "***마지막 문!!! 1분간 유지!***",
      "TW": "最後一扇門！請保持按住 1 分鐘！***"
    }
  },
  "***NUKE LAUNCHED!!!***": {
    "translation": "***核弹发射！！！***",
    "MultiLang": {
      "US": "",
      "JP": "***核ミサイル発射！！！**",
      "CN": "***核弹发射！***",
      "KR": "핵미사일 발사!!!***",
      "TW": "***核彈已發射!!!***"
    }
  },
  "***Once someone makes the climb the elevator will be accessible!***": {
    "translation": "***一旦有人爬到顶部，电梯就可以使用！***",
    "MultiLang": {
      "US": "",
      "JP": "***誰かが登頂すると、エレベーターが利用可能になる！***",
      "CN": "***有人成功攀爬后电梯将恢复使用！***",
      "KR": "누군가 등반을 완료하면 엘리베이터가 작동합니다!***",
      "TW": "***一旦有人完成攀爬，電梯即可使用！***"
    }
  },
  "***Someone must make a climb!***": {
    "translation": "***必须有人爬上去！***",
    "MultiLang": {
      "US": "",
      "JP": "***誰かが登らなければならない！***",
      "CN": "***必须有人进行攀爬！***",
      "KR": "누군가가 등반해야 합니다!***",
      "TW": "***必須有人進行攀爬！***"
    }
  },
  "***Someone reached the top of the climb***": {
    "translation": "***有人到达了顶部***",
    "MultiLang": {
      "US": "",
      "JP": "***誰かが登頂点に到達***",
      "CN": "***有人成功到达攀爬点顶部***",
      "KR": "***누군가 등반의 정상을 도달했습니다***",
      "TW": "***有人已抵達攀爬頂端***"
    }
  },
  "***Wait 40 seconds***": {
    "translation": "***等待40秒***",
    "MultiLang": {
      "US": "",
      "JP": "***40秒待機してください***",
