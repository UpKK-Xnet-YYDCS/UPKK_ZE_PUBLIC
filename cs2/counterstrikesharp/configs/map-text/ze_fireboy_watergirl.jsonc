{
  ">>> MAPPING CONTEST <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>> マップコンテスト <<<",
      "CN": ">>> 地图制作大赛 <<<",
      "KR": ">>> 맵 제작 콘테스트 <<<",
      "TW": ">>> 地圖競賽 <<<"
    }
  },
  "Map Creator : Platin": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "マップ作成者: Platin",
      "CN": "地图制作者：Platin",
      "KR": "맵 제작자: Platin",
      "TW": "地圖製作人：Platin"
    }
  },
  "### LEVEL 1/2 ###": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "### レベル 1/2 ###",
      "CN": "### 关卡 1/2 ###",
      "KR": "### 레벨 1/2 ###",
      "TW": "### 關卡 1/2 ###"
    }
  },
  "NOSTALGIA": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ノスタルジア",
      "CN": "怀旧",
      "KR": "향수",
      "TW": "懷舊"
    }
  },
  "Red door: Can pass through red waters. Cannot pass through blue and green waters.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "赤いドア: 赤い水は通過できる。青と緑の水は通過できない。",
      "CN": "红色门：可以穿过红色水域。不能穿过蓝色和绿色水域。",
      "KR": "빨간 문: 빨간 물은 통과할 수 있습니다. 파란색과 녹색 물은 통과할 수 없습니다.",
      "TW": "紅色門：可以穿過紅色水域。不能穿過藍色和綠色水域。"
    }
  },
  "Blue door : Can pass through blue water. Cannot pass through red and green water.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "青いドア: 青い水は通過できる。赤と緑の水は通過できない。",
      "CN": "蓝色门：可以穿过蓝色水域。不能穿过红色和绿色水域。",
      "KR": "파란 문: 파란 물은 통과할 수 있습니다. 빨간색과 녹색 물은 통과할 수 없습니다.",
      "TW": "藍色門：可以穿過藍色水域。不能穿過紅色和綠色水域。"
    }
  },
  "Zombies can pass through green water. Blue and red water slows down zombies.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビは緑の水を通過できる。青と赤の水はゾンビの動きを遅らせる。",
      "CN": "僵尸可以穿过绿色水域。蓝色和红色水域会减缓僵尸的速度。",
      "KR": "좀비는 녹색 물을 통과할 수 있습니다. 파란색과 빨간색 물은 좀비의 속도를 늦춥니다.",
      "TW": "殭屍可以穿過綠色水域。藍色和紅色水域會減慢殭屍的速度。"
    }
  },
  "In 25 seconds the elevator will move.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "25秒後にエレベーターが動き出す。",
      "CN": "25秒后，电梯将会移动。",
      "KR": "25초 후, 엘리베이터가 움직입니다.",
      "TW": "25秒後，電梯將會移動。"
    }
  },
  "Last 10 sec ! GO BACK !": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り10秒！後退！",
      "CN": "最后 10 秒！返回！",
      "KR": "마지막 10초! 되돌아가세요!",
      "TW": "最後 10 秒！返回！"
    }
  },
  "Elevator leaving.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーターが出発します。",
      "CN": "电梯即将离开。",
      "KR": "엘리베이터 출발.",
      "TW": "電梯即將離開。"
    }
  },
  "ZM TP 5 sec!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビ、テレポート 5秒！",
      "CN": "僵尸传送，5 秒！",
