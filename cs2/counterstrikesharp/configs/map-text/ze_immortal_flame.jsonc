{
  "And all that we are": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "我々なるものは",
      "CN": "而我们的一切",
      "KR": "우리가 모든 것이다",
      "TW": "我們所是的一切"
    }
  },
  "And could ever be": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "そして常にそうあり得たもの",
      "CN": "以及我们曾拥有的一切",
      "KR": "그리고 우리가 될 수 있었던 모든 것",
      "TW": "以及永遠可能成為的一切"
    }
  },
  "Begin again": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "再び始めよう",
      "CN": "重新开始",
      "KR": "다시 시작하다",
      "TW": "重新開始"
    }
  },
  "Blaze an immortal": {
    "translation": "",
    "MultiLang": {
      "US": "Ignite the immortal",
      "JP": "不滅の焔を焚べよ",
      "CN": "化为不朽",
      "KR": "불멸을 Blaze하라",
      "TW": "化作永恆"
    }
  },
  "Blaze an immortal flame": {
    "translation": "",
    "MultiLang": {
      "US": "Ignite an eternal flame",
      "JP": "不滅の炎を灯せ",
      "CN": "点燃不灭火焰",
      "KR": "불멸의 불꽃을 Blaze하라",
      "TW": "化為永恆之火"
    }
  },
  "Blaze like an immortal flame": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "不滅の炎のごとく燃え上がれ",
      "CN": "如不朽之火般燃烧",
      "KR": "불멸의 불꽃처럼 Blaze하라",
      "TW": "如永生之火般燃燒"
    }
  },
  "Chasing your dreams": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "夢を追いかけて",
      "CN": "追逐你的梦想",
      "KR": "네 꿈을 쫓다",
      "TW": "追尋你的夢想"
    }
  },
  "Die": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "死",
      "CN": "死亡",
      "KR": "죽다",
      "TW": "死亡"
    }
  },
  "F L A M E": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "火",
      "CN": "火焰",
      "KR": "불꽃",
      "TW": "F L A M E"
    }
  },
  "Flame": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "炎",
      "CN": "火焰",
      "KR": "플레임",
      "TW": "火焰"
    }
  },
  "From the ash we rise": {
    "translation": "",
    "MultiLang": {
      "US": "Rise from the ashes",
      "JP": "灰燼から私たちは立ち上がる",
      "CN": "我们从灰烬中崛起",
      "KR": "재 속부터 일어나리라",
      "TW": "從灰烬中崛起"
    }
  },
  "Ignite the fire": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "炎を灯せ",
      "CN": "点燃怒火",
      "KR": "불을 붙여라",
      "TW": "點燃火焰"
    }
  },
  "Is within our reach": {
    "translation": "",
    "MultiLang": {
      "US": "Within our reach",
      "JP": "我々の手の中に",
      "CN": "在我们的触手可及之处",
      "KR": "우리의 손에 잡힌다",
      "TW": "在我們觸手可及之處"
    }
  },
  "It's a lonely road": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "孤独な道だ",
      "CN": "这是一条孤独的路",
      "KR": "그 길은 외롭다",
      "TW": "那是一條孤獨的路"
    }
  },
  "Just to burn this bright": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "これほどまでに輝くために",
      "CN": "只为如此炽烈地燃烧",
      "KR": "오직 이만큼 타오르기 위해",
      "TW": "只為燃燒得如此明亮"
    }
  },
  "Light the way": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "道を照らせ",
      "CN": "照亮前路",
      "KR": "길을 밝히라",
      "TW": "照亮前路"
    }
  },
  "Like phoenix taking flights": {
    "translation": "",
    "MultiLang": {
      "US": "Like a phoenix rising",
      "JP": "鳳凰のごとく翔ける",
      "CN": "如火凤展翅翱翔",
      "KR": "불사조처럼 날아오르듯",
      "TW": "如鳳凰展翅高飛"
    }
  },
  "May the bridges that we burn": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "我々が焼き尽くした橋々や",
      "CN": "愿我们燃尽的羁绊",
      "KR": "우리가 태운 다리들이여",
      "TW": "願我們斬斷的橋樑"
    }
  },
  "Piercing the sky": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "天を衝く",
      "CN": "刺破苍穹",
      "KR": "하늘을 찌르듯",
      "TW": "穿透天際"
    }
  },
  "Pure hearts can never expire": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "純粋な心は決して朽ちない",
      "CN": "纯净之心永不褪色",
      "KR": "순수한 마음은Expiration(만료)될 수 없다",
      "TW": "純潔之心永不褪色"
    }
  },
  "Rise from the fire": {
    "translation": "",
    "MultiLang": {
      "US": "Rise from the flames",
      "JP": "火から立ち上がれ",
      "CN": "浴火重生",
      "KR": "불길 속에서 일어나라",
      "TW": "浴火重生"
    }
  },
  "Shine like the sun": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "太陽のように輝け",
      "CN": "如烈日般闪耀",
      "KR": "태양처럼 빛나라",
      "TW": "如太陽般閃耀"
    }
  },
  "Truth be told": {
    "translation": "",
    "MultiLang": {
      "US": "To be honest",
      "JP": "言いわけをするなら",
      "CN": "坦白说",
      "KR": "솔직히 말해서",
      "TW": "坦白說"
    }
  },
  "Waited all our lives": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "一生待ち続けてきた",
      "CN": "守望一生",
      "KR": "우리 생애 전체를 기다렸다",
      "TW": "守候了我們一生"
    }
  },
