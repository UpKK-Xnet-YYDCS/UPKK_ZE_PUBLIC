{
  "WELCOME TO ZE CIRCLE": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "サークルへようこそ",
      "CN": "欢迎来到 ZE CIRCLE",
      "KR": "서클에 오신 것을 환영합니다",
      "TW": "歡迎來到 ZE CIRCLE"
    }
  },
  "MAPPER: AC SEAWEED": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "マッパー: AC SEAWEED",
      "CN": "地图作者：AC SEAWEED",
      "KR": "맵퍼: AC SEAWEED",
      "TW": "製圖者：AC SEAWEED"
    }
  },
  "Get through in 5 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "5秒で抜け出せ。",
      "CN": "5 秒内通过。",
      "KR": "5초 안에 통과하세요.",
      "TW": "在 5 秒內通過。"
    }
  },
  "1st door will open in 20 seconds": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "1番目のドアは20秒後に開く",
      "CN": "第一扇门将在 20 秒后打开",
      "KR": "첫 번째 문이 20초 후 열립니다",
      "TW": "第一道門將在 20 秒後打開"
    }
  },
  "Just jump over the door its not too hard": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ただジャンプしてドアを越えればよい。それほど難しくないぞ",
      "CN": "只需跳过错门即可，这并不难",
      "KR": "문 위를 그냥 뛰어넘으세요 어렵지 않아요",
      "TW": "只需跳過這道門，並不難"
    }
  },
  "door will open in 20 seconds": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアは20秒後に開く",
      "CN": "门将在 20 秒后打开",
      "KR": "문이 20초 후 열립니다",
      "TW": "門將在 20 秒後打開"
    }
  },
  "The next door will open in 30 seconds": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "次のドアは30秒後に開く",
      "CN": "下一扇门将在 30 秒后打开",
      "KR": "다음 문이 30초 후 열립니다",
      "TW": "下一道門將在 30 秒後打開"
    }
  },
  "Next door will open in 60 seconds. Hold for a while!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "次のドアは60秒後に開く。しばし待て!",
      "CN": "下一扇门将在 60 秒后打开。请稍候片刻！",
      "KR": "다음 문이 60초 후 열립니다. 잠시 기다려 주세요!",
      "TW": "下一道門將在 60 秒後打開。稍微等待片刻！"
    }
  },
  "The last door will open in 25s": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "最後のドアは25秒で開きます",
      "CN": "最后一扇门将在 25 秒后打开",
      "KR": "마지막 문이 25초 후 열립니다",
      "TW": "最後一扇門將在25秒後打開"
    }
  },
  "RUN!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "走れ！",
      "CN": "跑！",
      "KR": "달려!",
      "TW": "快跑！"
    }
  },
  "YOU MADE IT!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "無事到着！",
      "CN": "你成功了！",
      "KR": "성공!",
      "TW": "你做到了！"
    }
  },
  "THE CENTER ROTATOR HAS STOPPED!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "中央のローテーターが停止しました！",
      "CN": "中央转盘已停止！",
      "KR": "중심 회전기가 멈췄습니다!",
      "TW": "中央旋轉器已停止！"
    }
  },
  "The forklift will leave in 27 seconds!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "フォークリフトは27秒後に発車します！",
      "CN": "叉车将在 27 秒后离开！",
      "KR": "포크레프트가 27초 후 출발합니다!",
      "TW": "叉車將在27秒後離開！"
    }
  },
  "MAP BY AC SEAWEED": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "マップ：AC SEAWEEED",
      "CN": "地图由 AC SEAWEED 制作",
