      "JP": "最後の島に到達したな",
      "CN": "*** 你们来到了最后一座岛屿 ***",
      "KR": "*** 너는 마지막 섬에 도착했다 ***",
      "TW": "*** 你來到了最後一座島嶼 ***"
    }
  },
  "*** You win ! ***": {
    "translation": "***你赢了！***",
    "MultiLang": {
      "US": "",
      "JP": "お前の勝ちだ！",
      "CN": "*** 胜利！ ***",
