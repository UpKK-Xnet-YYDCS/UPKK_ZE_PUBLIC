    }
  },
  "是Federation小队...我们得救了吗？": {
    "translation": "是Federation小队...我们得救了吗？",
    "MultiLang": {
      "US": "It's the Federation squad... Are we rescued?",
      "JP": "フェデレーション隊だ…助かったのでしょうか？",
      "CN": "是Federation小队...我们得救了吗？",
