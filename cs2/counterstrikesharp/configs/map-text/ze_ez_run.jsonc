  },
  ">>>大门即将关闭 10 seconds<<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>>The gate will close in 10 seconds.<<<",
      "JP": ">>>大門がまもなく閉まります。残り10秒<<<",
