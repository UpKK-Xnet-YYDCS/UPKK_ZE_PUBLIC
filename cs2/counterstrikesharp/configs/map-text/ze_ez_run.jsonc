  },
  ">>>大门即将打开 30 seconds<<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>>The gate will open in 30 seconds.<<<",
      "JP": ">>>大門がまもなく開きます。残り30秒<<<",
      "CN": "",
      "KR": ">>>문이 곧 열립니다. 30초 남았습니다.<<<",
      "TW": ">>>大門即將打開，倒數 30 秒<<<"
    }
  },
  ">>>僵尸即将传送 10 seconds<<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>>Zombies will appear in 10 seconds.<<<",
      "JP": ">>>ゾンビがまもなくテレポートします。残り10秒<<<",
      "CN": "",
      "KR": ">>>좀비가 곧 소환됩니다. 10초 남았습니다.<<<",
      "TW": ">>>殭屍即將傳送，倒數 10 秒<<<"
    }
  },
  ">>>大门即将打开 20 seconds<<<": {
    "translation": "",
