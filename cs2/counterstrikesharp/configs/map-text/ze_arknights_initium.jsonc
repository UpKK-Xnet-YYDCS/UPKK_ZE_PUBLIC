{
  "阿米娅：博士，整合运动已经发现了这里，我们需要尽快撤离": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya:博士，整合运动已经发现了这里，我们需要尽快撤离",
      "JP": "阿米娅：ドクター、大衆解放軍がここに到達しました。速やかに撤退します",
      "CN": "",
      "KR": "아미야: 박사님, 통합운동 측이 이곳을 탐지했습니다. 빠르게 철수해야 합니다.",
      "TW": "阿米婭：博士，整合運動已經發現這裡了，我們得盡快撤離。"
    }
  },
  "阿米娅：大门还有30s打开，请再坚持一下": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya:大门还有30s打开，请再坚持一下",
      "JP": "阿米娅：扉はまだ30秒で開きます。もう少しだけ耐えてください",
      "CN": "",
      "KR": "아미야: 메인 게이트가 30초 후에 열립니다. 조금 더 참고 기다려 주세요.",
      "TW": "阿米婭：大門還有30秒才會開啟，請再堅持一下。"
    }
  },
  "阿米娅：博士，地面出口就在那里": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya:博士，地面出口就在那里",
      "JP": "阿米娅：ドクター、地上の出口はあちらです",
      "CN": "",
      "KR": "아미야: 박사님, 지상 출구는 바로 저기입니다.",
      "TW": "阿米婭：博士，地面出口就在那裡。"
    }
  },
  "阿米娅：糟糕，这里已经被整合运动包围了": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya:糟糕，这里已经被整合运动包围了",
      "JP": "阿米娅：まずい、ここは大衆解放軍に包囲されてしまいました",
      "CN": "",
      "KR": "아미야: 망쳤네요. 여기가 통합운동 측에 완전히 포위되었습니다.",
      "TW": "阿米婭：糟了，這裡已經被整合運動包圍了。"
    }
  },
  "ACE：博士，听得到吗，15s后我将进行墙壁爆破，请注意躲避": {
    "translation": "",
    "MultiLang": {
      "US": "ACE:博士，听得到吗，15s后我将进行墙壁爆破，请注意躲避",
      "JP": "ACE：ドクター、聞こえますか。15秒後に壁を爆破します。避けてください",
      "CN": "",
      "KR": "에이스: 박사님, 들리십니까? 15초 후 벽을 폭파합니다. 조심하십시오.",
      "TW": "ACE：博士，聽得到嗎？15秒後我將進行牆壁爆破，請注意躲避。"
    }
  },
  "ACE：博士，快走，整合运动还有15s空降": {
    "translation": "",
    "MultiLang": {
      "US": "ACE:博士，快走，整合运动还有15s空降",
      "JP": "ACE：ドクター、早く！大衆解放軍が15秒後に降下します",
      "CN": "",
      "KR": "에이스: 박사님, 빨리 가세요. 통합운동 측 공수 요원이 15초 후에 도착합니다.",
      "TW": "ACE：博士，快走！整合運動還有15秒就會空降。"
    }
  },
  "阿米娅：博士，前方的道路还有20s开放": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya:博士，前方的道路还有20s开放",
      "JP": "阿米娅：ドクター、前方のルートはあと20秒で開放されます",
      "CN": "",
      "KR": "아미야: 박사님, 앞쪽 도로가 20초 후에 개방됩니다.",
      "TW": "阿米婭：博士，前方的道路還有20秒開放。"
    }
  },
  "阿米娅：博士，前面是巨大的源石丛，我们已经无路可走了": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya:博士，前面是巨大的源石丛，我们已经无路可走了",
      "JP": "阿米娅：ドクター、前方に巨大なオリジウム結晶があります。行く手が阻まれました",
      "CN": "",
      "KR": "아미야: 박사님, 앞쪽에 거대한 오벌륨 군락이 있습니다. 더 이상 갈 곳이 없습니다.",
      "TW": "阿米婭：博士，前面是巨大的源石叢，我們已經沒有退路了。"
    }
  },
  "ACE：井盖下方似乎通往切尔诺伯格的排水管道": {
    "translation": "",
    "MultiLang": {
      "US": "ACE: There appears to be a drain pipe leading to Chernobog beneath the manhole cover.",
      "JP": "ACE：マンホールの下はチェルノボルの排水路に繋がっているようです",
      "CN": "",
      "KR": "ACE: 맨홀 아래로 체르노빌의 배수관으로 이어지는 것 같습니다.",
      "TW": "ACE：井蓋下方似乎通往車諾貝格的排水管道"
    }
  },
  "ACE:博士，我需要一点时间打开这个井盖": {
    "translation": "",
    "MultiLang": {
      "US": "ACE: Doctor, I need some time to open this manhole cover.",
      "JP": "ACE：ドクター、このマンホールを開けるまで少し時間をください",
      "CN": "",
      "KR": "ACE: 박사님, 이 맨홀을 열时间이 좀 필요합니다.",
      "TW": "ACE：博士，我需要一點時間打開這個井蓋"
    }
  },
  "ACE:好，打开了": {
    "translation": "",
    "MultiLang": {
      "US": "ACE: Alright, it's open.",
      "JP": "ACE：よし、開けました",
      "CN": "",
      "KR": "ACE: 됐습니다, 열렸습니다.",
      "TW": "ACE：好，打開了"
    }
  },
  "ACE：博士，请尽快破坏通风口，整合运动将在40s后空降": {
    "translation": "",
    "MultiLang": {
      "US": "ACE: Doctor, please destroy the ventilation shaft as soon as possible. Reunion will airdrop in 40 seconds.",
      "JP": "ACE：ドクター、換気口を速やかに破壊してください。レボリューショナリーズは40秒後に空中投下されます",
      "CN": "",
      "KR": "ACE: 박사님, 환풍구를 최대한 빨리 파괴하십시오. 통합운동이 40초 후 공중 투하됩니다.",
      "TW": "ACE：博士，請盡快破壞通風口，整合運動將在40秒後空降"
    }
  },
  "ACE:即将空降，博士，抓稳了": {
    "translation": "",
    "MultiLang": {
      "US": "ACE: Airdrop incoming, Doctor, hold on tight.",
      "JP": "ACE：空挺投下が近いです、ドクター、しっかり掴まってください",
      "CN": "",
      "KR": "ACE: 곧 공중 투하됩니다, 박사님,牢牢하게 잡으세요.",
      "TW": "ACE：即將空降，博士，抓穩了"
    }
  },
  "阿米娅：博士，请给我30s的时间部署水上平台，不要掉下去了哦": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Doctor, please give me 30 seconds to deploy the water platform. Don't fall in.",
      "JP": "アルミナ：ドクター、水上プラットフォームを展開するまでに30秒させてください。落ちてしまわないように哦",
      "CN": "",
      "KR": "아미야: 박사님, 수상 플랫폼을 배치하는데 30초가 필요합니다. 떨어지지 않도록 주의하세요.",
      "TW": "阿米婭：博士，請給我30秒的時間部署水上平台，不要掉下去了哦"
    }
  },
  "阿米娅：整合运动还有10s空降，前方的道路还有30s开放": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Reunion will airdrop in 10 seconds, and the path ahead will open in 30 seconds.",
      "JP": "アルミナ：レボリューショナリーズはあと10秒で空挺投下されます。前方の通路は30秒後に開放されます",
      "CN": "",
      "KR": "아미야: 통합운동이 10초 후 공중 투하됩니다.前方的로가 30초 후 개방됩니다.",
      "TW": "阿米婭：整合運動還有10秒空降，前方的道路還有30秒開放"
    }
  },
  "阿米娅：整合运动还有10s进行空降，前方的震撼装置还需要30s进行爆破": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Reunion will airdrop in 10 seconds, and the shock device ahead still needs 30 seconds to detonate.",
      "JP": "アルミナ：レボリューショナリーズはあと10秒で空挺投下されます。前方の衝撃装置の爆破にはさらに30秒かかります",
      "CN": "阿米娅：整合运动还有10秒进行空降，前方的小型爆破装置还需要30秒进行爆破。",
      "KR": "아미야: 통합운동이 10초 후 공중 투하됩니다.前方的의 충격 장치를 폭파하는데 30초가 더 필요합니다.",
      "TW": "阿米婭：整合運動還有10秒進行空降，前方的震撼裝置還需要30秒進行爆破"
    }
  },
  "阿米娅：请大家再防守30s，前方就是1-7关卡了": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Please hold the defense for another 30 seconds. Stage 1-7 is ahead.",
      "JP": "アーミア：皆さん、あと30秒間だけ防衛を維持してください。前方は1-7ステージです。",
      "CN": "",
      "KR": "아미야: 모두 30초 더 방어해 주세요. 바로 앞에 1-7 클리어가 있습니다.",
      "TW": "阿米婭：請大家再防禦30秒，前方即將到達第1-7關卡"
    }
  },
  "阿米娅：距离任务完成还剩下30s": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Mission completion in 30 seconds.",
      "JP": "アーミア：ミッション完了まで残り30秒です",
      "CN": "",
      "KR": "아미야: 미션 완료까지 30초 남았습니다.",
      "TW": "阿米婭：距離任務完成還剩30秒"
    }
  },
  "阿米娅：罗德岛大门还有30s打开": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Rhodes Island Gate will open in 30 seconds.",
      "JP": "アーミア：ロドスの門が開くまであと30秒です",
      "CN": "",
      "KR": "아미야: 로데오 정문까지 30초면 개방됩니다.",
      "TW": "阿米婭：羅德島大門將在30秒後開啟"
    }
  },
  "阿米娅：正在紧急联系维什戴尔小姐，马上就能获得支援了": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: I'm urgently contacting Ms. Wis'adel. Support will be here momentarily.",
      "JP": "アーミア：ウィスカード様に緊急連絡中です。すぐに支援が到着します",
      "CN": "",
      "KR": "아미야: 위슈데일 님과 긴급 연락 중입니다. 곧 지원이 도착할 예정입니다.",
      "TW": "阿米婭：正在緊急聯繫維什戴爾小姐，馬上就能獲得支援了"
    }
  },
  "祖宗发射器将在10s内充能完毕，请远离轰炸区域": {
    "translation": "",
    "MultiLang": {
      "US": "The Ancestor Launcher will finish charging in 10 seconds. Please stay clear of the bombardment zone.",
      "JP": "祖先ランチャーは10秒以内でチャージを完了します。爆撃区域から離れてください",
      "CN": "",
      "KR": "조상 발사기가 10초 내에 조준을 완료합니다. 폭격 지역 근처에 머무르지 마십시오.",
      "TW": "祖宗發射器將在10秒內充能完畢，請遠離轟炸區域"
    }
  },
  "阿米娅：博士，我们已经到达龙门了": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Doctor, we have arrived in Lungmen.",
      "JP": "アーミア：ドクター、ロンドンに着きました",
      "CN": "",
      "KR": "아미야: 박사님, 저희가 문룡에 도착했습니다.",
      "TW": "阿米婭：博士，我們已經到達龍門了"
    }
  },
  "阿米娅：当务之急是与龙门领袖魏彦吾谈判并取得与龙门的合作，我们才有机会抵御整合运动的进攻": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Our top priority is to negotiate with Lungmen's leader, Wei Yanwu, and secure a cooperation agreement with Lungmen. Only then do we have a chance to resist the Reunion offensive.",
      "JP": "アーミア：今すぐやるべきはロンドンのリーダー、魏彥吾氏との交渉を行い、ロンドンとの提携を締結することです。それこそが統合運動の攻撃に耐える唯一の機会です",
      "CN": "",
      "KR": "아미야: 당务之急是与龙门领袖魏彦吾谈判并取得与龙门的合作，我们才有机会抵御整合运动的进攻",
      "TW": "阿米婭：當務之急是與龍門領袖魏彥吾談判並取得與龍門的合作，我們才有機會抵禦整合運動的進攻"
    }
  },
  "前方红灯40s，请遵守龙门交规": {
    "translation": "",
    "MultiLang": {
      "US": "The red light ahead is 40 seconds. Please obey Lungmen traffic regulations.",
      "JP": "前方信号機は赤色40秒。ロンドンの交通規則に従ってください",
      "CN": "",
      "KR": "전방 신호등 40초, 문룡 교통규정을 준수하십시오.",
      "TW": "前方紅燈40秒，請遵守龍門交通規則"
    }
  },
  "魏彦吾：罗德岛，我在选择盟友时只看重一点": {
    "translation": "",
    "MultiLang": {
      "US": "Wei Yenwu: When choosing allies, I value only one thing",
      "JP": "魏彦吾：ロードアイランド、私が同盟者を選ぶ場合、只看一点に過ぎない",
      "CN": "",
      "KR": "위연오: 로드아일랜드는 동맹을 선택할 때 한 가지만 중시합니다.",
      "TW": "魏彥吾：羅德島，我在選擇盟友時只看重一點"
    }
  },
  "魏彦吾：那就是要拥有与我并肩的实力": {
    "translation": "",
    "MultiLang": {
      "US": "That is the strength to stand alongside me",
      "JP": "魏彦吾：それは、私と肩を並べるだけの実力を持つことだ",
      "CN": "",
      "KR": "그것은 저와 어깨를 나란히 할 실력을 갖춘 것이죠.",
      "TW": "魏彥吾：那就是要擁有與我並肩的實力"
    }
  },
  "距离龙门近卫局大门打开还有20s": {
    "translation": "",
    "MultiLang": {
      "US": "There are still 20 seconds until the龙门 City Guard Headquarters gates open",
      "JP": "洛嘉の警備局の門が開くまで、あと20秒",
      "CN": "",
      "KR": "룽먼 근위국 정문 개설까지 20초 남았습니다.",
      "TW": "距離龍門近衛局大門打開還有20s"
    }
  },
  "魏彦吾：想要得到我的认可，就先和近卫局的警卫们过几招吧": {
    "translation": "",
    "MultiLang": {
      "US": "Wei Yenwu: If you want my approval, then first prove yourselves against the City Guard",
      "JP": "魏彦吾：私の承認を得たいなら、まず警備局の護衛たちと几らか試合をしてみろ",
      "CN": "",
      "KR": "위연오: 제 인정을 받으려면, 먼저 근위국 경비병들과 승부를 겨뤄보세요.",
      "TW": "魏彥吾：想要得到我的認可，就先和近衛局的警衛們過幾招吧"
    }
  },
  "阿米娅：前方的区域还有40s开放": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: The area ahead will be open in 40 seconds",
      "JP": "阿米娅：前方の区域は、あと40秒で開放されます",
      "CN": "",
      "KR": "아미야: 앞 구역 개방까지 40초 남았습니다.",
      "TW": "阿米婭：前方的區域還有40s開放"
    }
  },
  "阿米娅：办公室大门还有30s打开": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: The office doors will open in 30 seconds",
      "JP": "阿米娅：事務所の玄関は、あと30秒で開きます",
      "CN": "",
      "KR": "아미야: 사무실 정문 개방까지 30초 남았습니다.",
      "TW": "阿米婭：辦公室大門還有30s打開"
    }
  },
  "已获得整合运动领袖情报1": {
    "translation": "",
    "MultiLang": {
      "US": "Obtained 1 intelligence report on the leader of Reunion",
      "JP": "統合運動のリーダーに関する情報1を入手しました",
      "CN": "",
      "KR": "통합운동 지도부 관련 정보 1 획득",
      "TW": "已獲得整合運動領袖情報1"
    }
  },
  "阿米娅：博士，如果能搜集一些整合运动领袖的情报，或许有助于我们接下来的行动": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Doctor, if we could gather some intelligence on the leader of Reunion, it might help our upcoming operations",
      "JP": "阿米娅：ドクター、もし統合運動のリーダーに関する情報をいくつか集められれば、今後の作戦に役立つかもしれません",
      "CN": "",
      "KR": "아미야: 박사는 통합운동 지도부 관련 정보를 조금이라도 수집하시면, 이후 작전에 도움이 될지도 모릅니다.",
      "TW": "阿米婭：博士，如果能蒐集一些整合運動領袖的情報，或許有幫助於我們接下來的行動"
    }
  },
  "阿米娅：办公室小门还有30s打开": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: The office side door will open in 30s.",
      "JP": "アミヤ：オフィス内の小門まであと30秒で解放されます",
      "CN": "",
      "KR": "아미야: 사무실 작은 문이 30초 후에 열려요.",
      "TW": "阿米婭：辦公室小門還有30秒開啟"
    }
  },
  "阿米娅：似乎找到了魏警官房门的钥匙": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: I seem to have found the key to Officer Wei's office door.",
      "JP": "アミヤ：どうやらチン警官の部屋の鍵を見つけました",
      "CN": "阿米娅：看来找到了魏警官的房门钥匙",
      "KR": "아미야: 위 경감님의 현관문을 열 수 있는 키를 찾은 것 같아요.",
      "TW": "阿米婭：似乎找到了魏警官房門的鑰匙"
    }
  },
  "阿米娅：好像没有别的道路了": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: It seems there are no other ways out.",
      "JP": "アミヤ：これ以上ほかの道はないようです",
      "CN": "",
      "KR": "아미야: 다른 길은看不到 보여지지 않는군요.",
      "TW": "阿米婭：好像沒有別的路可走了"
    }
  },
  "陈：没记错的话，这面墙的后面直通魏长官的办公室": {
    "translation": "",
    "MultiLang": {
      "US": "Ch'en: If I remember correctly, the wall behind us leads directly to Chief Wei's office.",
      "JP": "陳：間違いなければ、この壁の向こうはストリート長官のオフィスに直接繋がっています",
      "CN": "",
      "KR": "진: 착각이 아니라면, 이 벽 뒤로 위 국장님의 사무실로 바로 이어져 있을 거야.",
      "TW": "陳：沒記錯的話，這面牆的後面直通魏局長的辦公室"
    }
  },
  "陈：不对，外面已经被近卫局包围了": {
    "translation": "",
    "MultiLang": {
      "US": "Ch'en: No, the area outside is already surrounded by the Administrative Committee.",
      "JP": "陳：違う、もう外は近衛局に包囲されてます",
      "CN": "",
      "KR": "진: 아니다, 외부가 이미 근위대에 의해 포위되었어.",
      "TW": "陳：不對，外面已經被近衛局包圍了"
    }
  },
  "已获得整合运动领袖情报2": {
    "translation": "",
    "MultiLang": {
      "US": "Acquired Intelligence: Reunion Leader",
      "JP": "統合運動のリーダーに関する情報を2件入手しました",
      "CN": "",
      "KR": "통합운동 지도부 정보를 획득했습니다 2",
      "TW": "已獲得整合運動領袖情報2"
    }
  },
  "陈：试试找一找周围有没有能用的东西": {
    "translation": "",
    "MultiLang": {
      "US": "Ch'en: Try looking around for anything useful.",
      "JP": "陳：周囲で使えそうなものをかぎ上げてみよう",
      "CN": "",
      "KR": "진: 주변에 쓸 만한 물건이 없는지 확인해 봐.",
      "TW": "陳：試試看周圍有沒有能用得上的東西"
    }
  },
  "陈：博士，我需要20s的时间来引爆": {
    "translation": "",
    "MultiLang": {
      "US": "Ch'en: Doctor, I need 20s to detonate.",
      "JP": "陳：ドクター、爆発させるまでにあと20秒给您ください",
      "CN": "",
      "KR": "진: 박사님,폭파를 위해 20초가 필요해요.",
      "TW": "陳：博士，我需要20秒的時間來引爆"
    }
  },
  "阿米娅：绿色箱子里有一些炸药": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: There are some explosives in the green box.",
      "JP": "アミヤ：緑色の箱には爆弾が入っています",
      "CN": "",
      "KR": "아미야: 녹색 상자 속에 폭발물이 들어 있어요.",
      "TW": "阿米婭：綠色箱子裡有一些炸藥"
    }
  },
  "阿米娅：魏警官的办公室门还有40s打开": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Officer Wei's office door will open in 40s.",
      "JP": "アミヤ：ウィー警察官のオフィスは40秒後に開きます",
      "CN": "",
      "KR": "아미야: 웨이옌우 경감의 사무실 문이 열리기까지 40초 남았어요.",
      "TW": "阿米婭：魏警官的辦公室門還有40秒開啟"
    }
  },
  "魏彦吾：博士，我已经认可了罗德岛的实力，希望接下来合作愉快": {
    "translation": "",
    "MultiLang": {
      "US": "Wei Yanwu: Doctor, I have recognized Rhodes Island's capabilities. I hope our cooperation going forward will be fruitful.",
      "JP": "魏延吾：ドクター、私はロードアイランドの実力を認めます。これからの協力を楽しみにしています",
      "CN": "",
      "KR": "웨이옌우: 박사와 로도스는 이미 상호 간의 실력을 인정했습니다. 앞으로의 협력이 순조롭게 이루어지길 바랍니다.",
      "TW": "魏彥吾：博士，我已經認可了羅德島的實力，希望接下來合作愉快"
    }
  },
  "阿米娅：博士，我们接下来的目的地是切尔诺伯格下城区，请做好准备": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: Doctor, our next destination is the Lower City of Chernobog. Please prepare accordingly.",
      "JP": "アミヤ：ドクター、次に訪れるのはチェルノコブラの下部です。準備を完了させてください",
      "CN": "",
      "KR": "아미야: 박사님, 다음 목적지는 체르노베크 하층 도시입니다. 준비를 해 주세요.",
      "TW": "阿米婭：博士，我們接下來的目的地是切爾諾伯格下城區，請做好準備"
    }
  },
  "阿米娅：前方道路还有40s开放": {
    "translation": "",
    "MultiLang": {
      "US": "Amiya: The road ahead will open in 40s.",
      "JP": "アミヤ：前方の道はあと40秒で解放されます",
      "CN": "",
      "KR": "아미야: 앞의 도로가 열리기까지 40초 남았어요.",
      "TW": "阿米婭：前方道路還有40秒開放"
    }
  },
  "已获得整合运动领袖情报3": {
    "translation": "",
