  "** MAP BY SLAYERDRAGON **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** MAP BY SLAYERDRAGON **",
      "CN": "** 地图作者：SLAYERDRAGON **",
      "KR": "** MAP BY SLAYERDRAGON **",
      "TW": "** 地圖製作：SLAYERDRAGON **"
    }
  },
  "** HOLD THIS AREA UNTIL THE DOOR UNLOCKS **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** このエリアを、扉が開くまで防衛してください **",
      "CN": "** 守住该区域，直到门打开 **",
      "KR": "** 문이 열릴 때까지 이 지역을 방어하세요 **",
      "TW": "** 守住這個區域，直到門開啟 **"
    }
  },
  "** SHOOT THE CRATES TO OPEN A WAY **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 箱を破壊して、道を開きましょう **",
      "CN": "** 射击箱子以开辟道路 **",
      "KR": "** 상자를 쏘서 길을 만드세요 **",
      "TW": "** 射擊箱子以打開通道 **"
    }
  },
  "** HOLD THE TEMPLE ENTRANCE **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 神殿の入り口を防衛してください **",
      "CN": "** 守住神庙入口 **",
      "KR": "** 사원 입구를 지키세요 **",
      "TW": "** 守住神廟入口 **"
    }
  },
  "** DOOR OPENS IN 5 SECONDS **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 扉は5秒後に開きます **",
      "CN": "** 门将在 5 秒后打开 **",
      "KR": "** 문이 5초 후에 열립니다 **",
      "TW": "** 門將在 5 秒後開啟 **"
    }
  },
  "** FALL BACK **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 退避 **",
      "CN": "** 撤退 **",
      "KR": "** 후퇴하세요 **",
      "TW": "** 撤退 **"
    }
  },
  "** THE DRAGON IS CHARGING FOR A SUPERATTACK **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ドラゴンが超強力な攻撃を準備しています **",
      "CN": "** 巨龙正在蓄力进行超级攻击 **",
      "KR": "** 용이 강력 공격을 준비하고 있습니다 **",
      "TW": "** 巨龍正在蓄力進行超級攻擊 **"
    }
  },
  "** USE THE CATAPULTS ON BOTH SIDES TO STAGGER HIM **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "両側のカタパルトを使って、彼を混乱させましょう！",
      "CN": "** 使用两侧的投石器，让他无法集中火力！**",
      "KR": "양쪽의 투석기를 사용하여 그를 혼란시키세요.",
      "TW": "** 利用兩側的投石機，擾亂他的行動 **"
    }
  },
  "** THE DRAGON IS CHARGING FOR HIS FINAL ATTACK **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドラゴンが最後の攻撃に備えています！",
      "CN": "** 巨龙正在蓄力，准备发动最终攻击！**",
      "KR": "용이 마지막 공격을 준비하고 있습니다.",
      "TW": "** 巨龍正在蓄力，準備發動最後的攻擊 **"
    }
  }
