  "HOW DARE YOU ENTER HERE! BE GONE!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "よくも ここに 入ってきたな! 出て行け!",
      "CN": "你竟敢闯入此地！给我滚出去！",
      "KR": "감히 여길 들어오다니! 사라져라!",
      "TW": "你竟敢闖入這裡！給我滾出去！"
