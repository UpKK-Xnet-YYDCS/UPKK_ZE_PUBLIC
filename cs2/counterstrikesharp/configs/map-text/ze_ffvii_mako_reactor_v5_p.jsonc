    }
  },
  "** A player has adquired WIND MATERIA **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** プレイヤーが「風」のマテリアを入手しました **",
      "CN": "** 玩家已获得 WIND MATERIA **",
      "KR": "** 플레이어가 WIND MATERIA를 획득했습니다. **",
      "TW": "** 一名玩家已获得「风」玛纳 **"
    }
  },
  "** TIP: GRENADES MAKE A LOT OF DAMAGE ** USE IT **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ヒント：手榴弾は大きなダメージを与えます。** 使用しましょう！",
      "CN": "** 提示：手榴弹造成大量伤害！** 请使用它！",
      "KR": "** 팁: 수류탄은 큰 피해를 줍니다. 사용하세요! **",
      "TW": "** 提示：手榴弹能造成大量伤害！** 请使用它！"
    }
  },
  "** Dont stop shooting ! Dont let him attack !": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 撃ち止めるな！ 攻撃させないで！",
      "CN": "** 不要停止射击！不要让他攻击！",
      "KR": "** 계속 쏘세요! 공격을 허용하지 마세요! **",
      "TW": "** 不要停止射击！不要让他攻击！"
    }
  },
  "** Bahamut is in attack position ** Keep firing !! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** バハムートが攻撃態勢に入っています。** 撃ち続けろ！！",
      "CN": "** 巴哈姆特进入攻击状态！** 继续射击！！",
      "KR": "** 바하무트가 공격 자세를 취했습니다. 계속 공격하세요!! **",
      "TW": "** 巴哈姆特已进入攻击状态！** 继续射击！！"
    }
  },
  "** Bahamut is going to cast Mega Flare !! Shoot !! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** バハムートが「メガフレア」を詠唱しようとしています！** 撃て！！",
      "CN": "** 巴哈姆特即将释放 Mega Flare！！射击！！",
      "KR": "** 바하무트가 메가 플레어를 사용하려고 합니다! 쏘세요!! **",
      "TW": "** 巴哈姆特即将释放「超强闪光」！！射击！！"
    }
  },
  "** BAHAMUT IS GOING TO EXTERMINATE ALL US ! DONT STOP SHOOTING **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** バハムートは我々全てを滅ぼそうとしている！ 撃ち止めるな！",
      "CN": "** 巴哈姆特将要消灭我们所有人！不要停止射击！",
      "KR": "** 바하무트가 우리 모두를 파괴하려고 합니다! 계속 쏘세요! **",
      "TW": "** 巴哈姆特将要消灭我们所有人！不要停止射击！"
    }
  },
  "**Bahamut has been defeated ! ** Go go! Run upstairs ! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** バハムートを倒した！** さあ、行け！ 階段へ！",
      "CN": "** 巴哈姆特已被击败！** 冲啊！跑上楼！",
      "KR": "** 바하무트가 쓰러졌습니다! 가세요! 계단으로 올라가세요! **",
      "TW": "** 巴哈姆特已被击败！** 冲啊！跑上楼梯！"
    }
  },
  "** A player has adquired GRAVITY MATERIA **": {
    "translation": "",
    "MultiLang": {
