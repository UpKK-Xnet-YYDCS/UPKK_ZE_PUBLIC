  "** A player has adquired ELECTRO MATERIA **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 一人のプレイヤーがエレキオマターを獲得しました **",
      "CN": "** 有玩家获得了雷元素素材 **",
      "KR": "** 한 명의 플레이어가 전해 재료를 획득했습니다 **",
      "TW": "** 玩家已取得電屬性質料 **"
    }
  },
  "** A player has adquired EARTH MATERIA **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 一人のプレイヤーがアースマテリアを取得しました **",
      "CN": "** 有玩家获得了土元素素材 **",
      "KR": "** 한 명의 플레이어가 토지 재료를 획득했습니다 **",
      "TW": "** 玩家已取得土屬性質料 **"
    }
  },
  "** A player has adquired ULTIMA MATERIA **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 一人のプレイヤーがウルトラマテリアを獲得しました **",
      "CN": "** 有玩家获得了终极素材 **",
      "KR": "** 한 명의 플레이자가终极材料를 획득했습니다 **",
      "TW": "** 玩家已取得極致屬性質料 **"
    }
  },
  "** A player has adquired WIND MATERIA **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーがウィンド魔晶石を獲得した",
      "CN": "** 某位玩家已夺取风属性魔晶 **",
      "KR": "** 한 플레이어가 바람 마테리아를 획득했습니다 **",
      "TW": "** 一名玩家取得了風屬性魔晶石 **"
    }
  },
  "** TIP: GRENADES MAKE A LOT OF DAMAGE ** USE IT **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ヒント：グレネードは大きなダメージを与える！ 使いこなせ！",
      "CN": "** 提示：手榴弹伤害极高，请善用！**",
      "KR": "** 팁: 수류탄은 큰 피해를 줍니다. 사용하세요! **",
      "TW": "** 提示：手榴彈能造成大量傷害 ** 請使用 **"
    }
  },
  "** Dont stop shooting ! Dont let him attack !": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "射撃を止めるな！彼が攻撃する隙を与えるな！",
      "CN": "** 不要停止射击！别让他发起攻击！**",
      "KR": "** 사격을 멈추지 마세요! 적의 공격을 막으세요!",
      "TW": "** 別停止射擊！別讓他攻擊！**"
    }
  },
  "** Bahamut is in attack position ** Keep firing !! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バハムトが攻撃態勢に入った！ 射撃を続けろ！！",
      "CN": "** 巴哈姆特已进入攻击姿态！继续开火！！**",
      "KR": "** 바ハ무트가 공격 태세에 들어갔습니다! 계속 쏴주세요!! **",
      "TW": "** 巴哈姆特進入攻擊模式 ** 繼續射擊！！ **"
    }
  },
  "** Bahamut is going to cast Mega Flare !! Shoot !! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バハムトがメガルエーションを詠唱する！！ 撃て！！",
      "CN": "** 巴哈姆特即将发动“大太阳神”！开火！！**",
      "KR": "** 바ハ무트가 메가 플레어를 시전하려고 합니다! 저격하세요!! **",
      "TW": "** 巴哈姆特即將施展巨型火焰！！開火！**"
    }
  },
  "** BAHAMUT IS GOING TO EXTERMINATE ALL US ! DONT STOP SHOOTING **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バハムトが一掃攻撃を仕掛ける！ 撃撃し続けるな！",
      "CN": "** 巴哈姆特要消灭我们所有人了！不要停！**",
      "KR": "** 바하무트가 우리 모두를 몰살시키려 합니다! 사격을 멈추지 마세요! **",
      "TW": "** 巴哈姆特要消滅我們所有人！別停止射擊 **"
    }
  },
  "**Bahamut has been defeated ! ** Go go! Run upstairs ! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バハムトを倒した！ 行け！上の階へ逃げろ！",
      "CN": "** 巴哈姆特已被击败！快跑！上楼去！**",
      "KR": "** 바하무트가 물리쳤습니다! 갑시다! 옥상으로 올라가세요! **",
      "TW": "** 巴哈姆特已被擊敗！** 快走！跑到樓上！**"
    }
  },
  "** A player has adquired GRAVITY MATERIA **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーがグラビティ魔晶石を獲得した",
      "CN": "** 某位玩家已夺取重力属性魔晶 **",
      "KR": "** 한 플레이어가 중력 마테리아를 획득했습니다 **",
      "TW": "** 一名玩家取得了重力屬性魔晶石 **"
    }
  },
