  "「あなたが...セラフィックメイデン...」": {
    "translation": "「你就是……天使少女……」",
    "MultiLang": {
      "US": "\"You are... a Seraphic Maiden...\"",
      "JP": "",
      "CN": "「你竟然是……塞拉菲克少女……」",
      "KR": "「당신이요... 세라핌 메이드...」",
      "TW": "「你……是聖性少女……」"
    }
  },
  "「ここがセレスティアルの深層...」": {
    "translation": "「这里是天体的深层……」",
    "MultiLang": {
      "US": "\"This is the deep layer of Celestia...\"",
      "JP": "",
      "CN": "「这里是天界深层……」",
      "KR": "여기가 셀레스티얼의 심층...!",
      "TW": "「這裡是崇高領域的深層……」"
    }
  },
  "「ここは更なる意識レイヤ、集合的無意識を超えた究極深層...」": {
    "translation": "「这里是更深的意识层，超越集体无意识的终极深层……」",
    "MultiLang": {
      "US": "\"This is an even deeper conscious layer, the ultimate deep beyond the collective unconscious...\"",
      "JP": "",
      "CN": "「这里是更深的意识层，超越了集体潜意识的最终深层……」",
      "KR": "여기는 더 깊은 의식의 층, 집단 무의식을 초월한 궁극 심층...",
      "TW": "「這裡是超越集無意識的更深刻意識層、究極深層……」"
    }
  },
  "「ここまで意識が保持できることが不思議...」": {
    "translation": "「能保持意识到这里真是不可思议……」",
    "MultiLang": {
      "US": "\"It's strange that consciousness can be maintained this far...\"",
      "JP": "「ここまで意識を保てることに驚き...」",
      "CN": "「能保持这份意识真是不可思议……」",
      "KR": "여기까지 의식이 유지된다는 것이 신기하네요...",
      "TW": "「意識能維持到這種程度，真是不可思議……」"
    }
  },
  "「この胸に突き刺さるような憎悪...」": {
    "translation": "「内心刺痛的仇恨……」",
    "MultiLang": {
      "US": "\"This hatred, stabbing straight into my chest...\"",
      "JP": "",
      "CN": "「这份如利刃刺入胸膛般的憎恶……」",
      "KR": "\"가슴에 박히는 듯한 증오...\"",
      "TW": "「這股彷彿刺入胸口的憎惡……」"
    }
  },
  "「それはやってみなければ分からない！」": {
    "translation": "「那是必须尝试才知道的！」",
    "MultiLang": {
      "US": "\"You'll never know until you try!\"",
      "JP": "「それがやってみなければ分からん！」",
      "CN": "不试试看怎么知道呢！",
      "KR": "\"그건 해봐야 알지!\"",
      "TW": "「不試試看是不知道！」"
    }
  },
  "「だけどこの先から...」": {
    "translation": "「不过，从这里开始……」",
    "MultiLang": {
      "US": "\"But from here on...\"",
      "JP": "",
      "CN": "但是从这里开始……",
      "KR": "\"하지만 이 뒤로...\"",
      "TW": "「但是接下來……」"
    }
  },
  "「だけどもう戻れないという可能性も...」": {
    "translation": "「不过也有可能再也无法回头……」",
    "MultiLang": {
      "US": "\"There's also the possibility that there's no turning back...\"",
      "JP": "",
      "CN": "但也有可能已经无法回头……",
      "KR": "\"하지만 이미 돌아갈 수 없는 가능성도...\"",
      "TW": "「不過也有可能再也回不去了……」"
    }
  },
  "「とてつもなく憎悪の力を感じる...」": {
    "translation": "「感受到异常强大的仇恨之力……」",
    "MultiLang": {
      "US": "\"I feel an unimaginable power of hatred...\"",
      "JP": "",
      "CN": "感受到无比强烈的憎恶之力……",
      "KR": "\"엄청난 증오의 힘을 느껴...\"",
      "TW": "「感受到了一股無可匹敵的憎惡力量……」"
    }
  },
  "「まさかこんな深くまで続いているとは...」": {
    "translation": "「没想到竟然延续到了如此深的地方……」",
    "MultiLang": {
      "US": "\"I never imagined it would go this deep...\"",
      "JP": "「まさかこれほど深くまで続いているとは...」",
      "CN": "真没想到竟然这么深……",
      "KR": "\"이렇게 깊게 이어질 줄은 생각하지도 못했어...\"",
      "TW": "「真沒想到會延伸得這麼深……」"
    }
  },
  "「もう少しで...」": {
    "translation": "「再稍微一点……」",
    "MultiLang": {
      "US": "Almost there...\", \"7\": \"Am I to be killed simply because of that foolish delusion? How amusing.\", \"8\": \"Then let's see how well you can handle your own mistakes!\"}",
      "JP": "「もう少しだけ...」",
      "CN": "再一点点……",
      "KR": "\"조금만 더...\"",
      "TW": "「再一點點……」"
    }
  },
  "「ソンナ カラノゲンソウノタメニ、ワタシハコロサレルノカ。ナカナカオモシロイ。」": {
    "translation": "「为了这样的外壳幻想，我是否会被杀？这真是有趣。」",
    "MultiLang": {
      "US": "\"Oh, so this is the reason for my death. How amusing.\"",
      "JP": "「sono na karanogeносоугенソウノ tame ni, watashi hako RS3コロサレル no ka. naka naka omoshiroi.」",
      "CN": "就这样，我会死于你的妄想，这不是很有趣吗。",
      "KR": "\"그런 각본 때문에 내가 죽는 거야? 꽤 재미있네.\"",
      "TW": "這樣一來不就代表我會被殺嗎？真是有趣。」"
    }
  },
  "「デハクルガイイ。オノレノ アヤマチヲ オモイシルトイイサ！」": {
    "translation": "「那么来吧。好好思念一下自己的过错吧！」",
    "MultiLang": {
      "US": "\"That is indeed a blessing! Reflect upon your own mistakes!\"",
      "JP": "「絶対遵守以下规则。自己担当的失误要反省才是！」",
      "CN": "那就继续吧！好好去反省你的错误！",
      "KR": "좋아! 자신을 돌이켜보면 알 수 있다.",
      "TW": "這是好事。請反省自己的錯誤！」"
    }
  },
  "「ホウ、ヨクココマデ タドリツイタモノダ。」": {
    "translation": "「哼，真不容易来到这里。」",
    "MultiLang": {
      "US": "Hmph. You have done well to come this far.",
      "JP": "「好、優ここまで伝 penetra」",
      "CN": "哦，你竟能走到这一步。",
      "KR": "호, 잘도 여기까지 왔군.",
      "TW": "嗯，能到這裡真不簡單。」"
    }
  },
  "「ワタシニ ナマエナドナイ。シカシ アリガタク チョウダイシテオコウ。」": {
    "translation": "「我并没有名字。不过，谢谢你给我这个机会。」",
    "MultiLang": {
      "US": "You need not tell me your name. However, I shall welcome you.",
      "JP": "「ワタしに ナマエンアノ。しかしご かたきゅうて おこがましΈ。」",
      "CN": "无需报上名来。即便如此，我也就收下了吧。",
      "KR": "나의 이름을 부르지 마라. 그러나 감사히 받아주마.",
      "TW": "不必告訴我名字。但請讓我接受這份好意。」"
    }
  },
  "「ワタシヲ破壊シタトコロデ、憎悪ガキエルコトハナイ。」": {
    "translation": "「即便毁掉我，仇恨也不会消失。」",
    "MultiLang": {
      "US": "Destroying me will not erase your hatred.",
      "JP": "",
      "CN": "即便将我毁灭，憎恶亦不会消去。",
      "KR": "나를 파괴한다고 해서憎惡이 사라지지는 않는다.",
      "TW": "即使消滅了我，憎惡也不會終結。」"
    }
  },
  "「今更私に引き返すという選択肢はなかったんだ...」": {
    "translation": "「现在已经没有选择能让我回头了……」",
    "MultiLang": {
      "US": "There was no turning back for me at this point...",
      "JP": "",
      "CN": "事到如今，我已没有回头的余地了……",
      "KR": "지금쯤 내가 뒤로 물러설 여유는 없었지...",
      "TW": "到這時候，我已經沒有退路了……」"
    }
  },
  "「君たちに挑戦してもらう試練はこれだ！」": {
    "translation": "「你们即将挑战的考验就是这个！」",
    "MultiLang": {
      "US": "Here is the trial by which you shall prove yourselves!",
      "JP": "",
      "CN": "这便是我赐予你们的试炼！",
      "KR": "네들에게 도전하게 할 시련은 바로 이것이다!",
      "TW": "這就是我要你們挑戰的考驗！」"
    }
  },
  "「憎悪トハ、無ノサキカラウマレシモノ。ヒトガノゾムモノデハナイ。世界ガノゾムノダ。」": {
    "translation": "「仇恨，是从虚无之中诞生的东西。不是人所希求的。是世界所渴望的。」",
    "MultiLang": {
      "US": "Hatred is born from the void, not by human will. The world desires it.",
      "JP": "",
      "CN": "憎恶，乃是从虚无中诞生的之物。并非人所祈愿，而是世界所渴求之物。",
      "KR": "憎惡이란, 무에서 태어난 것이다. 인간이 원하는 것이 아니다. 세계가 원하는 것이다.",
      "TW": "憎惡，源於虛無深處。它並非人類所願，而是世界所渴望之物。」"
    }
  },
  "「挑戦状を手に入れたようだな」": {
    "translation": "「看来你们得到了挑战状呢」",
    "MultiLang": {
      "US": "It seems you have acquired the challenge.",
      "JP": "",
      "CN": "看来你已经拿到挑战书了啊。",
      "KR": "도전장을 손에 넣었군.",
      "TW": "看來你已經拿到了挑戰書呢。」"
    }
  },
  "「準備ができた者からそのサークルへ飛び込みなさい」": {
    "translation": "「做好准备的人，请跳入那个圆圈」",
    "MultiLang": {
      "US": "Those who are ready, jump into that circle.",
      "JP": "",
      "CN": "准备好的人，即刻跳入那个圆圈吧",
      "KR": "준비가 된 자는 그サー클로 뛰어들라",
      "TW": "準備就緒者，請立即加入該團隊。"
    }
  },
  "「研究対象はおそらくこの先...」": {
    "translation": "「研究对象大概就在前方……」",
    "MultiLang": {
      "US": "\"The subject of the research is probably ahead...\"",
      "JP": "",
      "CN": "「研究对象可能在这之后……」",
      "KR": "연구 대상은 아마 앞으로...다",
      "TW": "研究對象可能在前線……"
    }
  },
  "「私はあなたを抹殺しにきた。人々を救うために。」": {
    "translation": "「我是来抹杀你们的。为了拯救大家。",
    "MultiLang": {
      "US": "\"I have come to eliminate you. To save the people.\"",
      "JP": "",
      "CN": "「我来此是为了消灭你。为了拯救世人。」",
      "KR": "나는 너를 삭제하러 왔다. 사람들을 구하기 위해.",
      "TW": "我是來抹殺你的，為了拯救世人。"
    }
  }
}
