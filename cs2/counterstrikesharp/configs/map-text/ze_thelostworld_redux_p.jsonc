{
  "** BRACE YOURSELVES **": {
    "translation": "**做好准备**",
    "MultiLang": {
      "US": "*** BRACE YOURSELF ***",
      "JP": "** 皆、支度をしろ **",
      "CN": "大家做好心理准备！",
      "KR": "** 몸을 단단히 매고 준비해라 **",
      "TW": "**各位，準備！**"
    }
  },
  "** BRIDGE CHARGE DETONATED -- JUMP YOU FOOLS! **": {
    "translation": "**桥梁炸药已引爆--快跳，你们这群傻瓜！**",
    "MultiLang": {
      "US": "",
      "JP": "** ブリッジ爆発 -- 跃べ、馬鹿野郎！ **",
      "CN": "桥体爆炸……跳啊，你们这群蠢货！",
      "KR": "** 다리가 폭발했다 -- 어리석은 자들이여, 도약하라! **",
      "TW": "**橋樑炸藥起爆——你們這些瘋子，快跳！**"
    }
  },
  "** C4 planted! **": {
    "translation": "**C4已安放！ 翻译：Asteri3m**",
    "MultiLang": {
      "US": "",
      "JP": "** C4設置完了！ **",
      "CN": "C4炸药已放置！",
      "KR": "** C4 설치 완료! **",
      "TW": "**C4已佈置！**"
    }
  },
  "** Follow the game trails through the island interior to reach Embryonic Research B. **": {
    "translation": "**沿着游戏路线穿过岛屿内部到达胚胎研究中心B**",
    "MultiLang": {
      "US": "",
      "JP": "** 島の内部をゲームの痕跡に沿って進み、胎生研究施設Bへ向かえ。 **",
      "CN": "沿着岛屿内部的赛道前行，前往胚胎研究所B区。",
      "KR": "** 섬 내부의 게임 트레일을 따라 진흙탕 연구소 B로 향하십시오. **",
      "TW": "**沿著遊戲中的步道穿越島嶼內部，前往胚胎研究B區。**"
    }
  },
  "** InGen has received your distress signal. A109 inbound for extraction in 60... **": {
    "translation": "**InGen已收到你的求救信号，A109直升机将在60秒内到达进行救援...**",
    "MultiLang": {
      "US": "",
      "JP": "** InGen、貴社のSOSを受信。A109救援機60秒後に離脱準備完了... **",
      "CN": "因特吉公司已接收到你们的求救信号。A109号直升机将在60秒后抵达执行撤离任务……",
      "KR": "** 이인젠에서 긴급 신호를 수신했습니다. 구출을 위해 A109가 60초 내로 도착합니다... **",
      "TW": "**InGen已收到你的求救訊號。A109即將進場，60秒內執行撤離……**"
    }
  },
  "** Laboratory Security online. Locking in 10 seconds... **": {
    "translation": "**实验室安全系统已启动，10秒后锁定...**",
    "MultiLang": {
      "US": "",
      "JP": "** 研究所セキュリティ稼働。ロック開始から10秒後... **",
      "CN": "实验室安保系统已启动。倒计时10秒，锁定中……",
      "KR": "** 연구소 보안 시스템 가동 중. 잠금 처리까지 10초... **",
      "TW": "**實驗室安全系統已啟動。鎖定程序倒數10秒……**"
    }
  },
  "** Power has been restored to Isla Sorna **": {
    "translation": "**索纳岛的电力已恢复**",
    "MultiLang": {
      "US": "",
      "JP": "** イスラソルナに電力供給復旧 **",
      "CN": "索纳岛电力已恢复。",
      "KR": "** 솔라 섬의 전원이 복원되었습니다. **",
      "TW": "**索納島電源已恢復。**"
    }
  },
  "** Push the C4 between the barrels **": {
    "translation": "**将C4放置在桶之间**",
    "MultiLang": {
      "US": "",
      "JP": "** C4を樽の間に設置 **",
      "CN": "将C4炸药推到油桶之间。",
      "KR": "** 통나무 사이에 C4를 밀어 넣으세요. **",
      "TW": "**將C4推進油桶之間。**"
    }
  },
  "** Raptor nest has been disturbed! **": {
    "translation": "**猛禽巢穴被打扰了！**",
    "MultiLang": {
      "US": "",
      "JP": "**ラプター巣が邪魔された！**",
      "CN": "** 迅猛龙巢穴已被惊动！ **",
      "KR": "** 랩터 둥지가 방해받았습니다! **",
      "TW": "**恐龍巢穴已受驚擾！**"
    }
  },
  "** Satellite link established. Phone access enabled. **": {
    "translation": "**卫星链接已建立，电话访问已启用**",
    "MultiLang": {
      "US": "",
      "JP": "**衛星リンク確立。電話アクセス可能。**",
      "CN": "** 卫星链路已建立。电话接入已启用。 **",
      "KR": "** 위성 연결 완료. 전화 접속 가능. **",
      "TW": "**已建立衛星連結，手機通訊已啟用。**"
    }
  },
  "** THE PLANE IS GOING TO CRASH **": {
    "translation": "**飞机要坠毁了**",
    "MultiLang": {
      "US": "",
      "JP": "**機体が墜落する！**",
      "CN": "** 飞机即将坠毁 **",
      "KR": "** 비행기가 추락합니다 **",
      "TW": "**飛機會墜毀**"
    }
  },
  "** There's no power. We're screwed! **": {
    "translation": "**这里没有电，我们完蛋了！**",
    "MultiLang": {
      "US": "",
      "JP": "**電力がない。終わりだ！**",
      "CN": "** 没有动力。我们完了！ **",
      "KR": "** 전원이 끊겼습니다. 우리가 망했어요! **",
      "TW": "**沒電了。我們完蛋了！**"
    }
  },
  "** Zodiac departing for island interior. **": {
    "translation": "**气垫船正前往岛屿内部**",
    "MultiLang": {
      "US": "** Zodiac heading to island interior. **",
      "JP": "**ゾディアック、島内へ向けて離陸。**",
      "CN": "** 黄道十二宫号飞往岛屿腹地。 **",
      "KR": "** 조디악, 섬 내부로 출발. **",
      "TW": "**寶瓶座號正飛往島嶼內部。**"
    }
  },
  "**AFK TELE 10 SECONDS**": {
    "translation": "**挂机玩家10秒后传送**",
    "MultiLang": {
      "US": "",
      "JP": "**AFKテレポート10秒**",
      "CN": "** AFK传送10秒后 **",
      "KR": "**AFK 텔레포트 10초 후**",
      "TW": "**離線傳送剩餘 10 秒**"
    }
  },
  "**AFK TELE 20 SECONDS**": {
    "translation": "**挂机玩家20秒后传送**",
    "MultiLang": {
      "US": "",
      "JP": "**AFKテレポート20秒**",
      "CN": "** AFK传送20秒后 **",
      "KR": "**AFK 텔레포트 20초 후**",
      "TW": "**離線傳送剩餘 20 秒**"
    }
  }
