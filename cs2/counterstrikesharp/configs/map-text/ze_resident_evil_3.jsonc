  "**Warmup Round -- The game will start in 40 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ウォームアップラウンド -- ゲーム開始まで40秒**",
      "CN": "准备阶段 -- 游戏将在 40 秒后开始",
      "KR": "준비 시간 라운드 -- 게임이 40초 후에 시작됩니다",
      "TW": "**熱身輪次 —— 遊戲將於 40 秒後開始**"
    }
  },
  "**Warmup Round -- The game will start in 20 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ウォームアップラウンド -- ゲーム開始まで20秒**",
      "CN": "准备阶段 -- 游戏将在 20 秒后开始",
      "KR": "준비 시간 라운드 -- 게임이 20초 후에 시작됩니다",
