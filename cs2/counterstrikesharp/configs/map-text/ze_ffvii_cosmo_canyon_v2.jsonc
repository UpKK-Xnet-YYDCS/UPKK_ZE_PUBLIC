  "**ZE_FFVII_COSMO_CANYON**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ZE_FFVII_COSMO_CANYON",
      "CN": "**ZE_FFVII_COSMO_CANYON**",
      "KR": "ZE_FFVII_COSMO_CANYON",
      "TW": "ZE_FFVII_COSMO_CANYON"
    }
  },
  "**Map by Headshooter.SC & HaRyDe**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Headshooter.SC & HaRyDeによるマップ",
      "CN": "**地图由Headshooter.SC & HaRyDe制作**",
      "KR": "Headshooter.SC 및 HaRyDe 제작",
      "TW": "地图由 Headshooter.SC & HaRyDe 制作"
    }
  },
  "**NORMAL MODE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "通常モード",
      "CN": "**普通模式**",
      "KR": "일반 모드",
      "TW": "普通模式"
    }
  },
  "**Thanks to Weed-Lancer for tons of grammar errors fix**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Weed-Lancer氏に文法修正を多数ご協力いただきありがとうございます。",
      "CN": "**感谢Weed-Lancer修复了大量的语法错误**",
      "KR": "Weed-Lancer님께, 많은 문법 오류 수정에 감사드립니다.",
      "TW": "感谢 Weed-Lancer 修复了大量的语法错误"
    }
  },
  "** Models & animations by Batnik_ref.smd **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "モデルとアニメーション：Batnik_ref.smd",
      "CN": "**模型和动画由Batnik_ref.smd制作**",
      "KR": "Batnik_ref.smd 제작 모델 및 애니메이션",
      "TW": "模型与动画由 Batnik_ref.smd 制作"
    }
  },
  "**Cover here for 5 seconds before we clear this obstacle**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "この障害物を突破する前に、5秒間ここに隠れてください。",
      "CN": "**请在此处等待5秒，然后我们将清除这个障碍**",
      "KR": "이 장애물을 지나기 전에 5초 동안 이곳에 대기하세요.",
      "TW": "请在此处待 5 秒，然后我们清除这个障碍"
    }
  },
  "**A player has picked up HEAL materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーが「HEAL」マテリアを獲得しました。",
      "CN": "**一名玩家拾取了治疗药**",
      "KR": "한 플레이어가 HEAL 마테리아를 획득했습니다.",
      "TW": "一位玩家拾取了 HEAL 魔法石"
    }
  },
  "**We are near Cosmo Canyon**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "我々はコスモキャニオンの近くにいます",
      "CN": "我们已经接近宇宙峡谷。",
      "KR": "우리는 코스모 캐년 근처에 있습니다.",
      "TW": "我們已經接近宇宙峽谷。"
    }
  },
  "**The gates will open in 20 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートは20秒後に開きます",
      "CN": "大门将在20秒后打开。",
      "KR": "게이트가 20초 후에 열립니다.",
      "TW": "大門會在 20 秒後打開。"
    }
  },
  "**Welcome to Cosmo Canyon**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "コスモキャニオンへようこそ",
      "CN": "欢迎来到宇宙峡谷。",
      "KR": "코스모 캐년에 오신 것을 환영합니다.",
      "TW": "歡迎來到宇宙峽谷。"
    }
  },
  "**The barman will open the door in 5 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バーテンダーが5秒後にドアを開けます",
      "CN": "酒保将在5秒后打开门。",
      "KR": "바텐더가 5초 후에 문을 열 것입니다.",
      "TW": "酒保會在 5 秒後打開門。"
    }
  },
  "**Zombies are coming. Defend Cosmo Bar for 25 seconds before we open the back door** ": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビが近づいてきます。バックドアを開ける前に、25秒間コスモバーを守りましょう",
      "CN": "僵尸正在来袭。在25秒内保卫宇宙酒吧，我们会在那时打开后门。",
      "KR": "좀비들이 몰려옵니다. 뒷문을 열기 전에 25초 동안 코스모 바를 방어하십시오.",
      "TW": "殭屍正在逼近。在我們打開後門之前，請守住宇宙酒吧 25 秒。"
    }
  },
  "**5 SECONDS LEFT**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り5秒",
      "CN": "剩余5秒。",
      "KR": "5초 남았습니다.",
      "TW": "剩餘 5 秒。"
    }
  },
  "**FALL BACK**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "退却",
      "CN": "撤退！",
      "KR": "후퇴!",
      "TW": "撤退！"
    }
  },
  "**The rock will explode in 25 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "岩が25秒後に爆発します",
      "CN": "这块岩石将在25秒后爆炸。",
      "KR": "바위가 25초 후에 폭발합니다.",
      "TW": "這塊岩石會在 25 秒後爆炸。"
    }
  },
  "**The gates will open in 25 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートは25秒後に開きます。",
      "CN": "大门将在25秒后打开。",
      "KR": "게이트가 25초 후에 열립니다.",
      "TW": "大門會在 25 秒後開啟。"
    }
  },
  "**A player has picked up BIO materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーがBIOマテリアを入手しました。",
      "CN": "一名玩家拾取了BIO魔元。",
      "KR": "한 플레이어가 BIO 마테리아를 획득했습니다.",
      "TW": "一位玩家拾取了 BIO 物質。"
    }
  },
  "**The Cave of the GI gates will open in 15 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "GIゲートの洞窟は15秒後に開きます。",
      "CN": "GI大门洞穴将在15秒后打开。",
      "KR": "GI 게이트 동굴이 15초 후에 열립니다.",
      "TW": "GI 大門入口的洞穴會在 15 秒後開啟。"
    }
  },
  "**Wait until something happens**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "何か起こるまで待ちます。",
      "CN": "请等待发生一些事情。",
      "KR": "무언가가 발생할 때까지 기다리세요.",
      "TW": "請等待發生一些事情。"
    }
  },
  "**GI Nattak arena will open in 35 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "GIナッタカアリーナは35秒後に開きます。",
      "CN": "GI纳塔克竞技场将在35秒后开放。",
      "KR": "GI Nattak 경기장이 35초 후에 열립니다.",
      "TW": "GI Natta 競技場會在 35 秒後開啟。"
    }
  },
  "**A player has picked up EARTH materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーがEARTHマテリアを入手しました。",
      "CN": "一名玩家拾取了EARTH魔元。",
      "KR": "한 플레이어가 EARTH 마테리아를 획득했습니다.",
      "TW": "一位玩家拾取了 EARTH 物質。"
    }
  },
  "**A player has picked up WIND materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーがWINDマテリアを入手しました。",
      "CN": "一名玩家拾取了WIND魔元。",
      "KR": "한 플레이어가 WIND 마테리아를 획득했습니다.",
      "TW": "一位玩家拾取了 WIND 物質。"
    }
  },
  "**A player has picked up BOMB summon**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーがBOMBの召喚を入手しました。",
      "CN": "一名玩家拾取了BOMB召唤物。",
      "KR": "한 플레이어가 BOMB 소환 마법을 획득했습니다.",
      "TW": "一位玩家拾取了 BOMB 召喚。"
    }
  },
  "**The Bomb was summoned**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "爆弾が召喚されました",
      "CN": "已召唤出炸弹",
      "KR": "폭탄이 소환되었습니다.",
      "TW": "已召唤出炸弹。"
    }
  },
  "**A player has picked up ELECTRO materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーが ELECTRO マテリア を入手しました",
      "CN": "一名玩家拾取了 ELECTRO 道具",
      "KR": "한 플레이어가 ELECTRO 마테리아를 획득했습니다.",
      "TW": "一位玩家拾取了 ELECTRO 道具。"
    }
  },
  "**Nades do more damage. Use them!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "手榴弾はより多くのダメージを与えます。使いましょう！",
      "CN": "手榴弹造成更多伤害。请使用它们！",
      "KR": "수류탄의 데미지가 증가했습니다. 사용하세요!",
      "TW": "手榴弹造成的伤害更高。请使用它们！"
    }
  },
  "**Some of the items can affect him. Use them!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "いくつかのアイテムは彼に影響を与えます。使いましょう！",
      "CN": "某些道具可能会影响他。请使用它们！",
      "KR": "일부 아이템이 그에게 영향을 줄 수 있습니다. 사용하세요!",
      "TW": "某些道具可能会影响他。请使用它们！"
    }
  },
  "**Gi Nattak has healed 150 hp**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ギ・ナットゥクが150 HPを回復しました",
      "CN": "Gi Nattak 回复了 150 点生命值",
      "KR": "Gi Nattak이 150의 체력을 회복했습니다.",
      "TW": "Gi Nattak 回复了 150 点生命值。"
    }
  },
  "**Gi Nattak is using gravity**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ギ・ナットゥクが重力を使用しています",
      "CN": "Gi Nattak 正在使用重力",
      "KR": "Gi Nattak이 중력을 사용하고 있습니다.",
      "TW": "Gi Nattak 正在使用重力。"
    }
  },
  "**Gi Nattak is using poison**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ギ・ナットゥクが毒を使用しています",
      "CN": "Gi Nattak 正在使用毒",
      "KR": "Gi Nattak이 독을 사용하고 있습니다.",
      "TW": "Gi Nattak 正在使用毒。"
    }
  },
  "**Gi Nattak is spawning minions. Watch out for them**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ギ・ナットゥクがミニオンを出現させています。注意してください。",
      "CN": "Gi Nattak 正在召唤小怪。小心它们",
      "KR": "Gi Nattak이 미니언을 소환하고 있습니다. 조심하세요.",
      "TW": "Gi Nattak 正在召唤小怪。请注意它们。"
    }
  },
  "**Gi Nattak is using aspil**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattak は aspil を使用しています",
      "CN": "Gi Nattak 正在使用 aspil。",
      "KR": "Gi Nattak은 aspil을 사용하고 있습니다.",
      "TW": "Gi Nattak 正在使用 aspil。"
    }
  },
  "**Gi Nattak is using fire**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattak は炎を使用しています",
      "CN": "Gi Nattak 正在使用火焰。",
      "KR": "Gi Nattak은 불을 사용하고 있습니다.",
      "TW": "Gi Nattak 正在使用火焰。"
    }
  },
  "**Gi Nattck is using shield**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattck はシールドを使用しています",
      "CN": "Gi Nattck 正在使用盾牌。",
      "KR": "Gi Nattck은 방패를 사용하고 있습니다.",
      "TW": "Gi Nattck 正在使用盾牌。"
    }
  },
  "**A player has picked up FIRE materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが FIRE マテリアを拾いました",
      "CN": "一位玩家拾取了 FIRE 魔法。",
      "KR": "한 플레이어가 FIRE 마테리아를 획득했습니다.",
      "TW": "一名玩家拾取了 FIRE 魔法。"
    }
  },
  "**A player has picked up Cactus summon**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが Cactus の召喚を拾いました",
      "CN": "一位玩家拾取了仙人掌召唤物。",
      "KR": "한 플레이어가 척박한 땅의 소환수를 획득했습니다.",
      "TW": "一名玩家拾取了仙人掌召唤物。"
    }
  },
  "**The Cactuar was summoned**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "カクタスが召喚されました",
      "CN": "仙人掌被召唤了出来。",
      "KR": "Cactuar가 소환되었습니다.",
      "TW": "仙人掌已被召唤。"
    }
  },
  "**Gi Nattak is using wind**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattak は風を使用しています",
      "CN": "Gi Nattak 正在使用风。",
      "KR": "Gi Nattak은 바람을 사용하고 있습니다.",
      "TW": "Gi Nattak 正在使用风。"
    }
  },
  "**Gi Nattack is dead**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattack は死亡しました",
      "CN": "Gi Nattack 已死亡",
      "KR": "Gi Nattack은 사망했습니다.",
      "TW": "Gi Nattack 已死亡。"
    }
  },
  "**Now you can get out of Cave of Gi**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "これで、ギの洞窟から脱出できます",
      "CN": "现在你可以离开吉的洞穴了。",
      "KR": "이제 기의 동굴에서 나갈 수 있습니다.",
      "TW": "現在您可以離開吉的洞穴。"
    }
  },
  "**DOOR OPENS IN 35 SECONDS**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "扉は35秒後に開きます",
      "CN": "门将在35秒后打开。",
      "KR": "문이 35초 후에 열립니다.",
      "TW": "門將在 35 秒後開啟。"
    }
  },
  "**10 SECONDS LEFT**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り10秒",
      "CN": "剩余10秒。",
      "KR": "남은 시간: 10초",
      "TW": "剩 10 秒。"
    }
  },
  "**This is your last hold point**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "これが最後の待機ポイントです",
      "CN": "这是你最后的安全点。",
      "KR": "이곳이 마지막 안전 지점입니다.",
      "TW": "這是您的最後一個防守點。"
    }
  },
  "**Get on the rocks and hold 25 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "岩の上に乗って、25秒間耐えましょう",
      "CN": "登上岩石并坚持25秒。",
      "KR": "바위 위로 올라가서 25초 동안 버티세요.",
      "TW": "登上岩石，堅持 25 秒。"
    }
  },
  "**NORMAL mode was beaten. Unlocking HARD mode **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "通常モードをクリアしました。ハードモードをアンロックします",
      "CN": "已通关普通模式。解锁困难模式。",
      "KR": "노멀 모드를 완료했습니다. 하드 모드를 잠금 해제합니다.",
      "TW": "已擊敗「普通」模式。正在解鎖「困難」模式。"
    }
  },
  "**HARD MODE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ハードモード",
      "CN": "困难模式",
      "KR": "하드 모드",
      "TW": "困難模式"
    }
  },
  "**A player has picked up GRAVITY materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーがGRAVITYマテリアを入手しました",
      "CN": "一名玩家拾取了重力魔石。",
      "KR": "한 플레이어가 GRAVITY 마테리아를 획득했습니다.",
      "TW": "一位玩家已拾取了「重力」魔導石。"
    }
  },
  "**A player has picked up ULTIMA materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが「ULTIMA」マテリアを入手しました",
      "CN": "一名玩家获得了 ULTIMA 魔法。",
      "KR": "플레이어가 ULTIMA 마테리아를 획득했습니다.",
      "TW": "一名玩家已拾取了 ULTIMA 魔導石。"
    }
  },
  "**The big cactus is blocking the way. Shopopt him!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "大きなサボテンが道を塞いでいます。ショップオプションで対処しましょう！",
      "CN": "巨大的仙人掌挡住了去路。去商店购买道具吧！",
      "KR": "거대한 선인장이 길을 막고 있습니다. Shopopt를 사용하세요!",
      "TW": "巨大的仙人掌擋住了去路。快去對付它！"
    }
  },
  "**He is dead. KEEP GOING**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "彼は倒れた。進み続けろ",
      "CN": "他已经死了。继续前进。",
      "KR": "그는 죽었습니다. 계속 진행하세요.",
      "TW": "他已經死了。繼續前進。"
    }
  },
  "**Hard mode is beaten. Challenge yourself in EXTREME mode ! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ハードモードをクリアしました。さらにチャレンジ精神を試すなら、EXREMEモードに挑戦しましょう！",
      "CN": "困难模式已通关。挑战自己，进入极度模式！",
      "KR": "하드 모드를 완료했습니다. EXTREME 모드에 도전해 보세요!",
      "TW": "困難模式已通關。挑戰極限模式吧！"
    }
  },
  "**EXTREME MODE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "EXREMEモード",
      "CN": "极度模式",
      "KR": "익스트림 모드",
      "TW": "極限模式"
    }
  },
  "**...Are you surprised?...**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "…驚きましたか？…",
      "CN": "...你感到惊讶了吗？...",
      "KR": "...놀라셨나요?...",
      "TW": "…你很驚訝嗎？…"
    }
  },
  "**...Didn't you expect me?...**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "…私を予想していなかった？…",
      "CN": "...你没有料到我的到来吗？...",
      "KR": "...저를 예상하지 못하셨나요?...",
      "TW": "…你沒有預料到我會出現嗎？…"
    }
  },
  "**...Oh okay i'm disappearing...**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "…ああ、わかった。消えるよ…",
      "CN": "...哦，好的，我要消失了...",
      "KR": "...알겠습니다, 사라지겠습니다...",
      "TW": "…好吧，我要消失了…"
    }
  },
  "**Ifrit is defeated! Get on the airship**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "イフリートを倒した！エアシップに乗れ",
      "CN": "伊弗利特已被击败！登上飞船",
      "KR": "이프리트가 쓰러졌다! 비행선에 타세요.",
      "TW": "伊芙利特已被击败！登上飞船。"
    }
  },
  "** EXTREME mode is beaten. Get ready for your last challenge ...**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エクストリームモードクリア！最後の試練に備えろ...",
      "CN": "极难模式已通关。准备好迎接你的最终挑战...",
      "KR": "익스트림 모드를 클리어했습니다. 마지막 도전 과제에 대비하세요...",
      "TW": "「極限」模式已通关。准备好迎接你最后的挑战..."
    }
  },
  "**RAGE MODE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "レイジモード",
      "CN": "狂暴模式",
      "KR": "분노 모드",
      "TW": "狂暴模式"
    }
  },
  "**Cover here for 10 seconds before we clear this obstacle**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "この障害物を突破する前に、10秒間ここに留まってください",
      "CN": "请在此处掩护 10 秒，以便我们清除这个障碍",
      "KR": "이 장애물을 제거하기 전에 10초 동안 여기에서 엄폐하세요.",
      "TW": "请在此处掩护10秒，我们清除障碍。"
    }
  },
  "**A player has picked up SLEEP materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あるプレイヤーが「スリープ」マテリアを入手しました",
      "CN": "一位玩家获得了睡眠魔石",
      "KR": "한 플레이어가 SLEEP 마테리아를 획득했습니다.",
      "TW": "一名玩家拾取了「睡眠」魔物。"
    }
  },
  "**The airship to Shinra will arrive in 25 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "シンラへのエアシップは、25秒後に到着します",
      "CN": "前往神罗的飞船将在 25 秒后到达",
      "KR": "신라로 향하는 비행선이 25초 후에 도착합니다.",
      "TW": "前往神罗的飞船将在25秒后到达。"
    }
  },
  "**The airship is right here...**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エアシップは、ここです...",
      "CN": "飞船就在这里...",
      "KR": "비행선이 바로 여기 있습니다...",
      "TW": "飞船就在这里..."
    }
  },
  "**The gates will open in 35 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートは、35秒後に開きます",
      "CN": "大门将在 35 秒后打开",
      "KR": "게이트가 35초 후에 열립니다.",
      "TW": "大门将在35秒后打开。"
    }
  },
  "**Wait 5 more seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "5秒間お待ちください",
      "CN": "等待 5 秒",
      "KR": "5초 더 기다리세요",
      "TW": "請再等待 5 秒。"
    }
  },
  "**Shinra gates will open in 20 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "シンラゲートは20秒後に開きます",
      "CN": "神罗大门将在 20 秒后打开",
      "KR": "신라 게이트가 20초 후에 열립니다",
      "TW": "神羅大門將在 20 秒後開啟。"
    }
  },
  "**The gates will open in 15 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートは15秒後に開きます",
      "CN": "大门将在 15 秒后打开",
      "KR": "게이트가 15초 후에 열립니다",
      "TW": "大門將在 15 秒後開啟。"
    }
  },
  "**The elevator will leave in 15 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーターは15秒後に発車します",
      "CN": "电梯将在 15 秒后离开",
      "KR": "엘리베이터가 15초 후에 출발합니다",
      "TW": "電梯將在 15 秒後啟動。"
    }
  },
  "**Ifrit is defeated. Get back in the elevator**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "イフリートを倒しました。エレベーターに戻ってください",
      "CN": "伊弗利特已被击败。请返回电梯",
      "KR": "이프리트가 쓰러졌습니다. 엘리베이터로 돌아가세요",
      "TW": "伊弗利特已被擊敗。請返回電梯。"
    }
  },
  "**The power is lost. Defend until the emergency generators are on**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "電源が喪失しました。非常用発電機が起動するまで防御してください",
      "CN": "电力中断。请坚守，直到紧急发电机启动",
      "KR": "전력이 공급되지 않았습니다. 비상 발전기가 작동할 때까지 방어하세요",
      "TW": "電力已喪失。請防守直到備用發電機啟動。"
    }
  },
  "**We got the power. The gates will open in 15 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "電源を回復しました。ゲートは15秒後に開きます",
      "CN": "我们恢复了电力。大门将在 15 秒后打开",
      "KR": "전력이 복구되었습니다. 게이트가 15초 후에 열립니다",
      "TW": "我們恢復了電力。大門將在 15 秒後開啟。"
    }
  },
  "** Nades do more damage. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ナデスはより多くのダメージを与えます。",
      "CN": "纳米炸弹造成更多伤害。",
      "KR": "나데스는 더 많은 피해를 입힙니다.",
      "TW": "炸彈造成更多傷害。"
    }
  },
  "**You have beaten Cosmo Canyon!! Congratulations !! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "あなたはコズモキャニオンをクリアしました！おめでとうございます！！",
      "CN": "你已经通关了宇宙峡谷！！恭喜！！",
      "KR": "코스모 캐니언을 정복했습니다!! 축하합니다!!",
      "TW": "你已經擊敗了 Cosmo Canyon！！恭喜！！"
    }
  },
  "**Hellz MODE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ヘルモード",
      "CN": "地狱模式",
      "KR": "헬즈 모드",
      "TW": "地獄模式"
    }
  },
  "**Cover here for 15 seconds before we clear this obstacle**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "この障害物を突破する前に、15秒間ここに隠れてください。",
      "CN": "请在此处遮蔽15秒，以便我们清除这个障碍。",
      "KR": "이 장애물을 제거하기 전에 15초 동안 여기에서 엄폐하십시오.",
      "TW": "在這裡掩護 15 秒，然後我們清除這個障礙。"
    }
  },
  "[Shinra Base] Zombie support has arrived. ": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[シンラ基地] ゾンビ部隊が到着しました。",
      "CN": "[神罗基地] 僵尸支援已到达。",
      "KR": "[신라 기지] 좀비 지원이 도착했습니다.",
      "TW": "[神羅基地] 殭屍增援已到。"
    }
  },
  "**The rock will explode in 35 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "岩が35秒後に爆発します。",
      "CN": "这块岩石将在35秒后爆炸。",
      "KR": "바위가 35초 후에 폭발합니다.",
      "TW": "這塊岩石會在 35 秒後爆炸。"
    }
  },
  "**The airship to Shinra will arrive in 35 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "シンラへの空母が35秒後に到着します。",
      "CN": "前往神罗的飞艇将在35秒后到达。",
      "KR": "신라로 향하는 비행선이 35초 후에 도착합니다.",
      "TW": "前往神羅的飛艇會在 35 秒後到達。"
    }
  },
  "**The gates will open in 40 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートが40秒後に開きます。",
      "CN": "城门将在40秒后打开。",
      "KR": "게이트가 40초 후에 열립니다.",
      "TW": "大門會在 40 秒後打開。"
    }
  },
  "**Shinra gates will open in 30 seconds**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "シンラのゲートが30秒後に開きます。",
      "CN": "神罗城门将在30秒后打开。",
      "KR": "신라 게이트가 30초 후에 열립니다.",
      "TW": "神羅大門會在 30 秒後打開。"
    }
  },
  "**ADMIN HAS CHANGED MAP LEVEL VIA ADMIN ROOM**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "管理者から、管理画面を通じてマップレベルが変更されました。",
      "CN": "**管理员已通过管理房间更改了地图等级**",
      "KR": "관리자가 관리자 방을 통해 맵 레벨을 변경했습니다.",
      "TW": "**管理員已透過管理員室更改地圖等級**"
    }
  },
  "**You are too slow**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "動きが遅すぎます。",
      "CN": "**你太慢了**",
      "KR": "너무 느립니다.",
      "TW": "**你太慢了**"
    }
  },
  "** Dont Bhop **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バウンドジャンプしないでください。",
      "CN": "**不要跳跃**",
      "KR": "점프를 하지 마세요.",
      "TW": "**不要使用空中跳躍**"
    }
  },
  "[Sephiroth]:You actually defeated Genesis... incredible.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[セフィロス]: 君がジェネシスを倒したとは…信じられない。",
      "CN": "[萨菲罗斯]:你竟然击败了创世...太不可思议了。",
      "KR": "[세피로스]: 당신이 실제로 제네시스를 물리다니... 믿을 수 없군요.",
      "TW": "[薩菲羅]:你竟然擊敗了蓋尼西斯...真是太不可思議了。"
    }
  },
  "[Sephiroth]: Now, are you prepared to face my attack？": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[セフィロス]: さて、私の攻撃に備えているか？",
      "CN": "[萨菲罗斯]:现在，你准备好面对我的攻击了吗？",
      "KR": "[세피로스]: 자, 제 공격에 맞설 준비가 되었습니까?",
      "TW": "[薩菲羅]: 現在，你準備好面對我的攻擊了嗎？"
    }
  },
  "[Sephiroth]: I will strike from the Right side.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[セフィロス]: 私は右から攻撃する。",
      "CN": "[萨菲罗斯]:我会从右侧发动攻击。",
      "KR": "[세피로스]: 저는 오른쪽에서 공격할 것입니다.",
      "TW": "[薩菲羅]:我將從右側發動攻擊。"
    }
  },
  "[Sephiroth]:I will never be a memory.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[セフィロス]: 私は決して忘れられる存在ではない。",
      "CN": "[萨菲罗斯]:我永远不会成为一个回忆。",
      "KR": "[세피로스]: 저는 결코 기억 속에 사라지지 않을 것입니다.",
      "TW": "[薩菲羅]:我永遠不會成為回憶。"
    }
  },
  "[Cloud] Nice job! I hope that we are done with them for once and for all. The next stop is Cosmo Canyon..": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[クラウド]: いい仕事だ！これで、もう二度と彼らと関わることはないことを願う。次の目的地はコスモキャニオンだ。",
      "CN": "[克劳德]:干得漂亮！我希望我们这次能彻底解决他们。下一个目的地是宇宙峡谷。",
      "KR": "[클라우드]: 잘 했어! 이번에는 완전히 끝냈기를 바라. 다음 목적지는 코스모 캐니언이야..",
      "TW": "[克勞德]: 很好！我希望我們這次能徹底解決他們。接下來的目標是宇宙峽谷。"
    }
  },
  "**ZM MODE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ZMモード",
      "CN": "**ZM模式**",
      "KR": "ZM 모드",
      "TW": "ZM 模式"
    }
  },
  "**The map is beaten. Find your place and defend it**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "マップを制覇したら、自分の陣地を見つけて防衛しましょう。",
      "CN": "**地图已被占领。找到你的位置并保卫它**",
      "KR": "맵을 정복하세요. 여러분의 자리를 찾고 방어하세요.",
      "TW": "地图已被征服。找到你的位置并保卫它。"
    }
  },
  "**2 MINUTES LEFT!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り2分！",
      "CN": "**剩余2分钟！**",
      "KR": "남은 시간: 2분!",
      "TW": "剩余 2 分钟！"
    }
  },
  "**1 MINUTES LEFT!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り1分！",
      "CN": "**剩余1分钟！**",
      "KR": "남은 시간: 1분!",
      "TW": "剩余 1 分钟！"
    }
  },
  "**30 SECONDS LEFT!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り30秒！",
      "CN": "**剩余30秒！**",
      "KR": "남은 시간: 30초!",
      "TW": "剩余 30 秒！"
    }
  },
  "**15 SECONDS LEFT!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り15秒！",
      "CN": "**剩余15秒！**",
      "KR": "남은 시간: 15초!",
      "TW": "剩余 15 秒！"
    }
  },
  "**Teleporting humans to the Observatory**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "人間を観測所にテレポート",
      "CN": "**将人类传送至观测站**",
      "KR": "인간들을 천문대로 순간이동 중...",
      "TW": "正在将人类传送至观测站。"
    }
  },
  "**Defend here for 15 seconds before the platform leaves**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プラットフォームが離れる前に、ここで15秒間防衛してください。",
      "CN": "**在平台离开前，在此处防御15秒",
      "KR": "플랫폼이 사라지기 전에 15초 동안 이곳을 방어하세요.",
      "TW": "在平台离开之前，在此地防御 15 秒。"
    }
  },
  "**The platform is leaving**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プラットフォームが離脱します",
      "CN": "平台正在离开",
      "KR": "플랫폼이 사라집니다",
      "TW": "平台即將離開"
    }
  },
  "**WINNERS GONNA CHANGE NEXT STAGE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "勝利者は次のステージへ",
      "CN": "获胜者将进入下一阶段",
      "KR": "승자는 다음 단계로 이동합니다",
      "TW": "獲勝者將進入下一階段"
    }
  },
  "**THE WINNERS HAD SELECTED THE MODE**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "勝利者がモードを選択しました",
      "CN": "获胜者已经选择了模式",
      "KR": "승자들이 모드를 선택했습니다",
      "TW": "獲勝者已經選擇了模式"
    }
  },
  "**Gi Nattck is using silence**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattckが沈黙を使用しています",
      "CN": "Gi Nattck 正在使用沉默",
      "KR": "Gi Nattck이 침묵 스킬을 사용합니다",
      "TW": "Gi Nattck 正在使用沉默"
    }
  },
  "**Gi Nattak is spawning minions. Look on them**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Gi Nattakがミニオンを召喚しています。注意してください",
      "CN": "Gi Nattak 正在召唤小怪。请注意观察它们",
      "KR": "Gi Nattak이 미니언을 소환합니다. 확인해 보세요",
      "TW": "Gi Nattak 正在生成小怪。請注意他們"
    }
  },
  "**GI NATTAK USES LAVA SUPERATTACK**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "GI NATTAKが溶岩スーパーアタックを使用します",
      "CN": "GI NATTAK 使用熔岩超强攻击",
      "KR": "GI NATTAK이 용암 초강력 공격을 사용합니다",
      "TW": "GI NATTAK 使用熔岩超技能"
    }
  },
  "**Get on the rocks to get saved!!!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "岩の上に乗って助けを求めてください!!!",
      "CN": "爬上岩石以获得救援!!!",
      "KR": "바위에 올라가 구조를 요청하세요!!!",
