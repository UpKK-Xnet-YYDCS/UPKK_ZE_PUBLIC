  "Diman: Shrek, help me": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ディマン：シュレック、助けて",
      "CN": "迪曼：史瑞克，救救我",
      "KR": "디만: 스크레, 도와줘",
      "TW": "迪曼：史瑞克，救救我"
    }
  },
  "Diman: I'm dying": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ディマン：死んじゃう…",
      "CN": "迪曼：我要死了",
      "KR": "디만: 죽어가고 있어",
      "TW": "迪曼：我要死了"
    }
  },
  "Diman: This fucking dictatorship killed me": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ディマン\": \"このファックな独裁政権が私を殺した",
      "CN": "迪曼：这该死的独裁政体害死了我",
      "KR": "디만: 이 개판 독재정이 나를 쏴죽였어",
      "TW": "迪曼：這該死的獨裁政權害死了我"
    }
  },
  "Shrek: What, who is it?": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "シュレック「いや、誰だ？」",
      "CN": "史瑞克：什么，是谁？",
      "KR": "스크레: 뭐, 누구야?",
      "TW": "史瑞克：怎麼了？是誰？"
    }
  },
  "Diman: I'm the best leader on Ze": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ディマン：私はゼで最高のリーダーです",
      "CN": "迪曼：我是泽星上最棒的领袖",
      "KR": "디만: 저는 제에서 가장 뛰어난 지도자입니다",
      "TW": "迪曼：我是澤上最棒的領袖"
    }
  },
  "Shrek: Diman???": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "シュレック：ディマン？？？",
      "CN": "史瑞克：迪曼？？？",
      "KR": "스크레: 디만??? 아니, 샤크??? 잠깐, 스크래그???",
