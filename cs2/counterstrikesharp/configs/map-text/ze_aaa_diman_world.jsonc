    }
  },
  "Diman: I'm dying": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ディマン：死にかけだ",
      "CN": "迪曼：我要死了",
      "KR": "디만: 죽어가고 있어",
      "TW": "迪曼：我要死了"
    }
  },
  "Diman: This fucking dictatorship killed me": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ディマン：このクソ独裁者が俺を殺した",
      "CN": "迪曼：这个该死的独裁政权杀了我",
