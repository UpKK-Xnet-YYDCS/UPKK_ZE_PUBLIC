    }
  },
  "Shark: Noooooooooooooooo": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "シャーク：ノオオオオオオオオオ！",
      "CN": "鲨鱼：不——————！",
      "KR": "샤크: 아니이이이이이이이이이!!!!!",
