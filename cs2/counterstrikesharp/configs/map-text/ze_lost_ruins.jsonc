    }
  },
  "\"door open in 60s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "60秒後に扉が開く。",
      "CN": "门将在60秒后打开。",
      "KR": "ドア開閉まであと60秒。",
      "TW": "門将在60秒後開啟。"
    }
  },
  "\"door opened.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "扉が開いた。",
      "CN": "门已打开。",
      "KR": "ドアが開いた。",
      "TW": "門已開啟。"
    }
  },
  "\"door opend.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアが開いている。",
      "CN": "门已打开。",
      "KR": "ドアが開いた。",
      "TW": "門已開啟。"
    }
  },
  "\"defend zombier 20s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビを20秒間守れ。",
      "CN": "抵御丧尸20秒。",
      "KR": "ゾンビーの攻撃から20秒間守れ。",
      "TW": "防禦殭屍20秒。"
    }
  },
  "\"yeah,you defender zombier.ready to final test\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "そう、君はdefend zombier。最終テストの準備はできたか。",
      "CN": "没错，你是防守者。准备好进行最终测试吧。",
      "KR": "そうだ、あなたはゾンビーの防衛者だ。最終テストの準備はできたか？",
      "TW": "是的，你是守衛者。準備好接受最終測試。"
    }
  },
  "\"door closed in 20s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "20秒後に扉が閉まる。",
      "CN": "门将在20秒后关闭。",
