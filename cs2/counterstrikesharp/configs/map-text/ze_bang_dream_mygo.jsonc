    }
  },
  "《迷途之子》": {
    "translation": "",
    "MultiLang": {
      "US": "Child of Labyrinth",
      "JP": "『見知らぬ子たち』",
      "CN": "",
      "KR": "〈길 잃은 아이〉",
      "TW": "《迷途之子》"
    }
  },
  "**地图作者：花泽爱吃香菜**": {
    "translation": "",
    "MultiLang": {
      "US": "**Map Creator: Hua Ze Ai Chi Ci Xin**",
      "JP": "**マップ制作者：花沢香菜がパクチー大好き**",
      "CN": "",
      "KR": "**지도 제작자: 화쩨아이찬샹**",
      "TW": "**地圖作者：花澤愛吃香菜**"
    }
  },
  "**皮皮猫233**": {
    "translation": "",
    "MultiLang": {
      "US": "**Pipimao233**",
      "JP": "**ピピー猫233**",
      "CN": "",
      "KR": "**피피머오233**",
      "TW": "**皮皮貓233**"
    }
  },
  "**SIRloin**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**SIRloin**",
      "CN": "**Sirloin**（西冷牛排）",
      "KR": "**SIRloin**",
      "TW": "**SIRloin**"
    }
  },
  "**热身关卡**": {
    "translation": "",
    "MultiLang": {
      "US": "**Warm-up Level**",
      "JP": "**ウォーミングアップステージ**",
      "CN": "",
      "KR": "**예선 맵**",
      "TW": "**熱身關卡**"
    }
  },
  "**人数超过20人后将进入正常流程**": {
    "translation": "",
    "MultiLang": {
      "US": "**If the number of players exceeds 20, it will proceed to the normal stage.**",
      "JP": "**参加人数が20人を超えると通常のフローに入ります**",
      "CN": "",
      "KR": "**인원이 20명을 초과하면 정상적인 흐름으로 진행됩니다**",
      "TW": "**人數超過20人後將進入正常流程**"
    }
  },
  "**若需要跳过热身关**": {
    "translation": "",
    "MultiLang": {
      "US": "**If you need to skip the warm-up stage**",
      "JP": "**ウォーミングアップステージをスキップする必要がある場合",
      "CN": "",
      "KR": "**예선 맵을 건너뛰려면**",
      "TW": "**若需要跳過熱身關**"
    }
  },
  "**请飞至镜子后按下调关按钮**": {
    "translation": "",
    "MultiLang": {
      "US": "**Please fly to behind the mirror and press the level adjustment button.**",
      "JP": "**鏡の後ろに行って調関ボタンを押してください**",
      "CN": "",
      "KR": "**거울 뒤로 날아감 버튼 누르기**",
      "TW": "請飛至鏡子後按下調關按鈕"
    }
  },
  "Perfect!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "完璧！",
      "CN": "完美！",
      "KR": "완벽해!",
      "TW": "完美！"
    }
  },
  "Great!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "素晴らしい！",
      "CN": "太棒了！",
      "KR": "훌륭해!",
      "TW": "太棒了！"
    }
  },
  "**核爆**": {
    "translation": "",
    "MultiLang": {
      "US": "**Nuclear Explosion**",
      "JP": "**核爆発**",
      "CN": "",
      "KR": "**핵폭발**",
      "TW": "核爆"
    }
  },
  "**关卡二**": {
    "translation": "",
    "MultiLang": {
      "US": "**Level 2**",
      "JP": "**レベル2**",
      "CN": "",
      "KR": "**레벨 2**",
      "TW": "關卡二"
    }
  },
  ">>高松灯:anon酱,你带我们来Ring干什么?<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>High Takamatsu Tomu: Anon, why did you bring us to Ring?<<",
      "JP": ">>高松灯：アノンちゃん、私たちをRingに連れてきて何の用？<<",
      "CN": "",
      "KR": ">>타카마즈 토모: 아논 씨, 왜 우리를 링으로 데려왔어요?<<",
      "TW": ">>高松燈：anon醬，你帶我們來Ring做什麼？<<"
    }
  },
  ">>这里有解除身体变小的方法吗?<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Is there a way to reverse the shrinking here?<<",
      "JP": ">>ここで体が小さくなる症状を解消する方法はありますか？<<",
      "CN": "",
      "KR": ">>여기서 몸이 작아지는 현상을 해결할 수 있는 방법이 있나요?<<",
      "TW": ">>這裡有解除身體變小的方法嗎？<<"
    }
  },
  ">>千早爱音:没有啊,我听说mujica在里面开演唱会我就来了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: No, I heard that Muji was holding a concert here, so I came.<|br|>>",
      "JP": ">>千早愛音：いいえ、Mujicaがここでライブを行うと聞いて来ました<<",
      "CN": "",
      "KR": ">>치하야 아이온: 없어요. 무지카가 여기서 콘서트를 연다고 해서 왔습니다<<",
      "TW": ">>千早愛音：沒有啊，我聽說mujica在這裡開演唱會就來了。<<"
    }
  },
  ">>众人:哈?????<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Everyone: Huh?????<<",
      "JP": ">>皆:はぁ?????<<",
      "CN": "",
      "KR": ">>모두: 하?????<<",
      "TW": ">>眾人：哈？？？？<<"
    }
  },
  "**防守10秒等待千早爱音开门**": {
    "translation": "",
    "MultiLang": {
      "US": "**Defend for 10 seconds waiting for Chihaya Anon to open the door**",
      "JP": "**10秒間防守して、千早愛音が扉を開けるのを待つ**",
      "CN": "",
      "KR": "**방어 10초 대기, 치하야 애인 문 열기**",
      "TW": "**防守10秒，等待千早愛音開門**"
    }
  },
  ">>长崎素世:哎呀你千早爱音给我干哪来了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Nagasaki Soyo: Oh my, what did you bring me to, Chihaya Anon?<|br|>>",
      "JP": ">>長崎そよ:あら、千早愛音、私どこへ連れてこちゃったの<<",
      "CN": "",
      "KR": ">>나가사키 소요: 어이, 치하야 애인, 넌 어디로 내가 데려왔니?>>",
      "TW": ">>長崎素世：哎呀，你千早愛音把我弄到哪來了<<"
    }
  },
  ">>这还是立本吗?<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Is this really Japan?<|br|>",
      "JP": ">>これって日本ですか?<<",
      "CN": "",
      "KR": ">>이게 일본의 모습이야?<<",
      "TW": ">>這還是立本嗎？<<"
    }
  },
  ">>我可不想被saki酱看到我变成这幅模样<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>I really don't want Saki-san to see me like this.<<",
      "JP": ">>さきちゃんにこの有様を見られたくないわ<<",
      "CN": "",
      "KR": ">>사키 양 내 모습 보는 거 원 안 해<<",
      "TW": ">>我可不想讓Saki醬看到我變成這副模樣<<"
    }
  },
  ">>千早爱音:我们从左边的货架一路绕过去<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: Let's go around from the shelf on the left.<<",
      "JP": ">>千早愛音:左の棚まで迂回して<<",
      "CN": "",
      "KR": ">>치하야 애인: 왼쪽 서랍대 거쳐 지나가자<<",
      "TW": ">>千早愛音：我們從左邊的貨架一路繞過去<<"
    }
  },
  ">>千早爱音:看到那个倒在地上的音响了吗<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: Do you see that speaker lying on the ground?<<",
      "JP": ">>千早愛音:あの倒れたスピーカー見える?<<",
      "CN": "",
      "KR": ">>치하야 애인: 바닥에 쓰러진 스피커 봤지?<<",
      "TW": ">>千早愛音：看到那個倒地的音響了嗎？<<"
    }
  },
  ">>我们可以把它推过来,利用它来爬上货架<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>We can push it over and use it to climb up to the shelf.<<",
      "JP": ">>それを押して寄せて、それを使って棚にのぼろう<<",
      "CN": "",
      "KR": ">>그걸 밀어서 이동, 쌓고 올라갈 거야<<\"",
      "TW": ">>我們可以把它推過來，利用它爬上貨架<<"
    }
  },
  "**音响推过来了**": {
    "translation": "",
    "MultiLang": {
      "US": "**The speaker has been pushed over.**",
      "JP": "**スピーカーが押されてきた**",
      "CN": "",
      "KR": "**스피커가 밀려왔다**",
      "TW": "**移動音響**"
    }
  },
  ">>千早爱音:来次够!<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: Here goes nothing!<<",
      "JP": ">>ちはや愛音:来たれ！<<",
      "CN": "",
      "KR": ">>치하야 아인: 딱 한 번만! <<",
      "TW": ">>千早愛音:準備好了嗎?!<<"
    }
  },
  ">>椎名立希:你这家伙真的去过英国吗<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Shiina Taki: Did you really go to the UK, you jerk?<<",
      "JP": ">>椎名立希:本当に英国に行ってきたの？<<",
      "CN": "",
      "KR": ">>이시나 타키: 너 진짜 영국에 가본 적 있어? <<",
      "TW": ">>椎名立希:你真的去過英國嗎?<<"
    }
  },
  "**僵尸将在10秒后传送**": {
    "translation": "",
    "MultiLang": {
      "US": "**Zombies will teleport in 10 seconds.**",
      "JP": "**ゾンビーが10秒後にテレポートする**",
      "CN": "",
      "KR": "**좀비가 10초 후에 텔레포트됩니다**",
      "TW": "**殭屍將在10秒後傳送**"
    }
  },
  ">>椎名立希:千早爱音,快来把这个专辑推下去<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Taki Shiina: Anon Chihaya, please push this album forward<<",
      "JP": ">>椎名立希:ちはや愛音、アルバムを押して下へ落として<<",
      "CN": "",
      "KR": ">>이시나 타키: 치하야 아인, 빨리 이 앨범을 밀어내! <<",
      "TW": ">>椎名立希:千早愛音，快點把這張專輯推下去<<"
    }
  },
  ">>千早爱音:这可是我们的专辑啊,那种事情不要啊<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Anon Chihaya: This is our album, don't do that<<",
      "JP": ">>千早愛音:これは私たちのアルバムだ、そんなことしてほしくない<<",
      "CN": "",
      "KR": ">>치하야 아인:这可是 우리의 앨범이잖아, 그런 짓 하지 마 <<",
      "TW": ">>千早愛音:可是這是我們的專輯啊，那種事不要啦<<"
    }
  },
  "**防守25秒**": {
    "translation": "",
    "MultiLang": {
      "US": "**Defense for 25 seconds**",
      "JP": "**25秒間守れ**",
      "CN": "",
      "KR": "**25초간 방어**",
      "TW": "**防守25秒**"
    }
  },
  ">>千早爱音:哼哼~哼哼哼哼~(糖哭中)<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Anon Chihaya: Hmm~ hum hum hum (sobbing in candy tears)<<",
      "JP": ">>千早愛音:フンフン~ヒンヒンヒン~(泣きながら)<<\": \">>千早愛音:フンフン〜ヒンヒンヒン〜(泣きながら)<<",
      "CN": "",
      "KR": ">>치하야 아인: 행잉~ 행잉행잉행~(설탕 울음 중) <<",
      "TW": ">>千早愛音:哼哼~哼哼哼哼~(邊哭邊唱)<<"
    }
  },
  ">>椎名立希:快点走吧千早爱音,不要在这里糖哭了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Taki Shiina: Hurry up and leave, Anon Chihaya, don't cry here<<",
      "JP": ">>椎名立希:快点走吧千早爱音,不要在这里糖哭了<<",
      "CN": "",
      "KR": ">>타이니 시리타: 빨리 가자요 치하야 애음, 여기에서 감정을 늘어놓지 마.\n<<",
      "TW": ">>椎名立希：趕快走吧，千早愛音，別在這裡磨蹭了<<"
    }
  },
  ">>千早爱音:soyorin你知道吗,其实...高松灯不是企鹅<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Anon Chihaya: Soyorn, do you know? Actually... Tomori Takamatsu isn't a penguin<<",
      "JP": ">>千早爱音:soyorin你知道吗,其实...高松灯不是企鹅<<",
      "CN": "",
      "KR": ">>치하야 애음: 소요린, 알아? 사실... 타카마스 램드는 펭귄이 아니야.\n<<",
      "TW": ">>千早愛音：素世，你知道嗎？其實……高松燈並不是企鵝<<"
    }
  },
  ">>长崎素世:是吗...为什么要对我说这个?<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Soyo Nagasaki: Is that so... Why are you telling me this?<<",
      "JP": ">>长崎素世:是吗...为什么要对我说这个?<<",
      "CN": "",
      "KR": ">>나गा사키 소요: 그렇구나... 왜 나한테 그런 걸 말하는 거야?\n<<",
      "TW": ">>長崎素世：是嗎……為什麼要跟我說這個？<<"
    }
  },
  ">>椎名立希:好多我们MyGO的专辑<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Taki Shiina: So many of our MyGO albums<<",
      "JP": ">>椎名立希:好多我们MyGO的专辑<<",
      "CN": "",
      "KR": ">>타이니 시리타: 우리가 만든 MyGO 앨범이랑 똑같다.\n<<",
      "TW": ">>椎名立希：好多我們MyGO的專輯<<"
    }
  },
  ">>高松灯:anon酱,这个就拜托你了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Tomori Takamatsu: Anon-chan, I'll leave this to you.<<",
      "JP": ">>高松灯:anon酱,这个就拜托你了<<",
      "CN": "",
      "KR": ">>타카마스 램드: 애음짱, 이것만은 부탁해.\n<<",
      "TW": ">>高松燈：愛音，這個就拜託你了<<"
    }
  },
  ">>千早爱音:既然是tomorrin提出的,那就没办法啦<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: Since it's tomorrin who suggested it, there's no choice.<<",
      "JP": ">>千早爱音:既然是tomorrin提出的,那就没办法啦<<",
      "CN": "",
      "KR": ">>치하야 애음: 토모린의 제안이라면 어쩔 수 없지.\n<<",
      "TW": ">>千早愛音：既然是tomorrin提出的，那就沒辦法了<<"
    }
  },
  "**防守25秒等待爱音将专辑推下**": {
    "translation": "",
    "MultiLang": {
      "US": "**Defend for 25 seconds while waiting for Anon to push the album down.**",
      "JP": "**防守25秒等待爱音将专辑推下**",
      "CN": "",
      "KR": "**25초 동안 방어하며 애음의 앨범 밀기 완료 대기**",
      "TW": "**防守25秒等待愛音將專輯推下**"
    }
  },
  ">>高松灯:辛苦你了anon酱<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Tomori Takamatsu: Thank you for your hard work, Anon-chan.<<",
      "JP": ">>高松灯:辛苦你了anon酱<<",
      "CN": "",
      "KR": ">>타카마스 램드: 애음짱, 정말 수고했어.\n<<",
      "TW": ">>高松燈：辛苦你了，愛音<<'"
    }
  },
  ">>千早爱音:还是有些不甘心啊<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: I still feel a bit unsatisfied.<<",
      "JP": ">>千早爱音:まだ悔しいな<<",
      "CN": "",
      "KR": ">>ちばあにん:まだ不服だな<<",
      "TW": ">>千早愛音：还是有些不甘心啊<<"
    }
  },
  ">>长崎素世:二楼就是演播厅了,我们快走吧<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Soyo Nagasaki: The second floor is the studio. Let's hurry up.<<",
      "JP": ">>長崎そよ:二階がスタジオだよ、早く行こう<<",
      "CN": "",
      "KR": ">>ながさきそよ:二階がスタジオだ。早く行こう<<",
      "TW": ">>長崎素世：二樓就是演播廳了，我們快走吧<<"
    }
  },
  "**僵尸将在10秒传送**": {
    "translation": "",
    "MultiLang": {
      "US": "**Zombies will teleport in 10 seconds.**",
      "JP": ">>ゾンビが10秒でテレポートします<<",
      "CN": "",
      "KR": "##僵尸将在10秒传送##",
      "TW": "**殭屍將在10秒傳送**"
    }
  },
  ">>长崎素世:前门好像被锁上了,我们去后门看看吧<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Soyo Nagasaki: The front door seems to be locked. Let's check the back door.<<",
      "JP": ">>長崎そよ:正面のドアが開かないみたいだ、裏口に行ってみよう<<",
      "CN": "",
      "KR": ">>ながさきそよ:表のドアが鍵がかかっているようだ。裏口を見ていこう<<",
      "TW": ">>長崎素世：前門好像被鎖上了，我們去後門看看吧<<"
    }
  },
  ">>高松灯:anon酱这个也拜托你了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Tomori Takamatsu: Anon, I'll leave this one to you too.<<",
      "JP": ">>高松燈:アノンちゃん、これもよろしく<<",
      "CN": "",
      "KR": ">>たкамまとおり:アノンちゃん、これも頼むね<<",
      "TW": ">>高松燈：anon醬這個也拜託你了<<"
    }
  },
  ">>千早爱音:既然是tomorrin拜托的事,那就没办法啦<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: Since it's something Tomorin asked, I have no choice but to do it.<<",
      "JP": ">>千早愛音:tomoちゃんからのお願いなら仕方ないわね<<",
      "CN": "",
      "KR": ">>ちばあにん:tomorrinから頼まれたことだし、仕方ないわね<<",
      "TW": ">>千早愛音：既然是tomorrin拜託的事，那就沒辦法啦<<"
    }
  },
  "**防守25秒等待爱音开门**": {
    "translation": "",
    "MultiLang": {
      "US": "**Defending for 25 seconds, waiting for Anon to open the door**",
      "JP": ">>25秒間防衛し、愛音のドア開放を待機<<",
      "CN": "",
      "KR": "##防守25秒等待爱音开门##",
      "TW": "**防守25秒等待愛音開門**"
    }
  },
  ">>千早爱音:门打开了,大家快进来<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: The door is open, everyone, come in quickly.<<",
      "JP": ">>千早愛音:開いたよ、みんな中にきて<<",
      "CN": "",
      "KR": ">>ちばあにん:ドアが開いたよ。みんな、中へ<<",
      "TW": ">>千早愛音：門打開了，大家快進來<<"
    }
  },
  ">>高松灯:anon酱,这个.....<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Tomori Takamatsu: Anon, this.....<<",
      "JP": ">>高松灯:アノンちゃん、これ……<<",
      "CN": "",
      "KR": ">>타카마스 란: 아논酱, 이거......<<",
      "TW": ">>高松燈:Amu醬,這個.....<<"
    }
  },
  ">>千早爱音:这个...这个也太...<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: This... this is too much...<<",
      "JP": ">>千早愛音：これ…これすぎる……<<",
      "CN": "",
      "KR": ">>치하야 아이노: 이... 이건 너무...<<",
      "TW": ">>千早愛音:這個...這個也太...<<"
    }
  },
  ">>还是我们一起推过去吧<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Let's just push it together, shall we?<<",
      "JP": ">>それでも一緒に押してみようか<<",
      "CN": "",
      "KR": ">>우리 함께 밀치는 게 좋겠어<<",
      "TW": ">>還是一起把它推過去吧<<"
    }
  },
  ">>千早爱音:舞台上怎么有五个跟我们长得一模一样的小人<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: How are there five tiny people on stage who look exactly like us?<<",
      "JP": ">>千早愛音：舞台上に私たちと瓜二つの小人が五人<<<",
      "CN": "",
      "KR": ">>치하야 아이노: 무대 위에 왜 우리와 똑같이 생긴 작은 사람들 5명이 있을까?",
      "TW": ">>千早愛音:舞台上怎麼有五個跟我們長得一模一樣的小人<<"
    }
  },
  ">>椎名立希:千早爱音,这个不会又是你搞得什么把戏吧<<": {
    "translation": "",
    "MultiLang": {
      "US": "\">>>Taki Shiina: Shinobu Chinatsu, you didn't pull some prank again, did you?<<<",
      "JP": ">>椎名立希:千早愛音、またあなたが仕掛けたトリックでしょうね<<<",
      "CN": "",
      "KR": ">>시라네 타키: 치하야 아이노, 또 너의 속임수인 건가?",
      "TW": ">>椎名立希:千早愛音,這個不會又是你搞的什麼把戲吧<<"
    }
  },
  ">>高松灯:我们现在这个样子,应该...不是anon酱干的吧...<<": {
    "translation": "",
    "MultiLang": {
      "US": "\">>>Tomori Takamatsu: We're in this state now, right... It's not Anon-chan's doing, is it...<<<",
      "JP": ">>高松灯:今の私たちは、アノンちゃんの仕業ではないはず……<<<",
      "CN": "",
      "KR": ">>타카마스 란: 지금 우리의 모습으로 봐서... 아논酱이 한 게 아닐 거야...<<",
      "TW": ">>高松燈:我們現在這個樣子,應該...不是Amu醬幹的吧...<<"
    }
  },
  ">>长崎素世:先上去看看再说吧<<": {
    "translation": "",
    "MultiLang": {
      "US": "\">>>Soyo Nagasaki: Let's go up and check first.<<<",
      "JP": ">>長崎そよ:とりあえず上って見てから<<",
      "CN": "",
      "KR": ">>나가사키 소요: 먼저上去해 보자 <<",
      "TW": ">>長崎素世:先上去看看再說吧<<"
    }
  },
  ">>要乐奈:有两个有趣的女人<<": {
    "translation": "",
    "MultiLang": {
      "US": "\">>>Rana Kanamari: There are two interesting women.<<<",
      "JP": ">>要楽奈:面白い女性がいるね<<<",
      "CN": "",
      "KR": ">>야라나 가: 흥미로운 여자들이 두 명 있어 <<",
      "TW": ">>要樂奈:有兩個有趣的女人<<"
    }
  },
  ">>众人(分身):没想到你们居然找到了这里<<": {
    "translation": "",
    "MultiLang": {
      "US": "\">>>>Everyone (Clones): We didn't expect you to actually find this place.<<<",
      "JP": ">>众人(分身):没想到皆さんここまで辿り着くなんて<<",
      "CN": "",
      "KR": ">>모든 사람(분신): 예상치 못게 너희가 여기까지 찾아왔네<<",
      "TW": ">>眾人(分身)：沒想到你們居然找到了這裡<<"
    }
  },
  ">>千早爱音(分身):来的正好,我正等着你们陪我玩几把呢<<": {
    "translation": "",
    "MultiLang": {
      "US": "\">>>>Chinatsu Shinobu (Clone): Perfect timing. I was just waiting for you to join me for a game.<<<",
      "JP": ">>千早愛音(分身):タイミングバッチリね。お待ちしてたわ、一緒に遊んであげる<<",
      "CN": "",
      "KR": ">>치하야 아니(분신): 딱 좋은 타이밍이군. 내가 너희와 몇 판 할 상대를 기다리고 있었으니까<<",
      "TW": ">>千早愛音(分身)：來得正好，我正等著你們陪我玩幾把呢<<"
    }
  },
  ">>高松灯:要...要玩什么<<": {
    "translation": "",
    "MultiLang": {
      "US": "\">>>>Tomori Takamatsu: Wh...What game are we going to play?<<<",
      "JP": ">>高松燈:な、何を…遊ぶの？<<",
      "CN": "",
      "KR": ">>타카마츠 아카리: 무... 뭘 할 거야<<",
      "TW": ">>高松燈：要...要玩什麼<<"
    }
  },
  ">>千早爱音(分身):我们干什么你们就要干什么<<": {
    "translation": "",
    "MultiLang": {
      "US": "\">>>>Chinatsu Shinobu (Clone): Whatever we do, you have to do it too.<<<",
      "JP": ">>千早愛音(分身):私たちの言うことを、そのまま実行していただくわ<<",
      "CN": "",
      "KR": ">>치하야 아니(분신): 우리가 뭔가를 하라면 너희도 똑같이 해야 해<<",
      "TW": ">>千早愛音(分身)：我們幹什麼你們就要幹什麼<<"
    }
  },
  ">>做对了有奖励,做错了有惩罚<<": {
    "translation": "",
    "MultiLang": {
      "US": "<<Do right and get a reward, do wrong and face punishment.>>",
      "JP": ">>正解したらご褒美、不正解なら罰ゲーム<<",
      "CN": "",
      "KR": ">>맞추면 상이 있고, 틀리면 벌칙이 있어<<",
      "TW": ">>做對了有獎勵，做錯了有懲罰<<"
    }
  },
  ">>高松灯:惩罚是...什么<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Tomori Takamatsu: Punishment... is what?<<",
      "JP": ">>高松燈:罰ゲームは…何でしょう？<<",
      "CN": "",
      "KR": ">>타카마츠 아카리: 벌칙은... 뭐야<<",
      "TW": ">>高松燈：懲罰是...什麼<<"
    }
  },
  ">>千早爱音(分身):惩罚就是saki酱将用鞋把你们踩在脚下<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Anon Chihaya (Clone): The punishment is that Saki will step on you with her shoes.<<",
      "JP": ">>千早愛音(分身):罰ゲームはね、さきちゃんが靴で皆さんを踏みつけることよ<<",
      "CN": "",
      "KR": ">>치하야 아니(분신): 벌칙은 사키양이 너희를 구두로 발뒤꿈치로 짓밟는 거야<<",
      "TW": ">>千早愛音(分身)：懲罰就是saki醬將用鞋把你們踩在腳下<<"
    }
  },
  ">>长崎素世:奖励说完了,惩罚呢?<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Soyo Nagasaki: I've heard about the reward. What about the punishment?<<",
      "JP": ">>長崎そよ:ご褒美の話は終わったわね。罰ゲームは？<<",
      "CN": "",
      "KR": ">>나가사키 소요: 상은 끝났는데, 벌칙은 뭐야?",
      "TW": ">>長崎素世：獎勵說完了，懲罰呢？<<"
    }
  },
  ">>众人:哈????<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Everyone: Huh????<<",
      "JP": ">>みんな:ハア????<<",
      "CN": "",
      "KR": ">>다 같이: 으???<<",
      "TW": ">>眾所期待:哈????<<"
    }
  },
  ">>千早爱音(分身):总之,游戏就要开始了,好好享受吧!<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Anon Chihaya (Clone): Anyway, the game starts now. Have fun!",
      "JP": ">>千早愛音(分身):まあそんなわけで、ゲーム開始！楽しんでね！<<",
      "CN": "",
      "KR": ">>치하야 아inou(분신): 아무튼, 게임이 시작되었어. 제대로 즐기세요!",
      "TW": ">>千早愛音(分身):總之，遊戲就要開始了，好好享受吧！<<"
    }
  },
  "**游戏开始**": {
    "translation": "",
    "MultiLang": {
      "US": "**Game Start**",
      "JP": "**ゲームスタート**",
      "CN": "",
      "KR": "**게임 시작**",
      "TW": "**遊戲開始**"
    }
  },
  "**请重复小纸片人刚才做出的动作**": {
    "translation": "",
    "MultiLang": {
      "US": "**Please repeat the action just shown by the origami figures.**",
      "JP": "**先ほどの紙ヒコーキ君の動きをもう一度行ってください**",
      "CN": "",
      "KR": "**작은 종이 인형이 방금 한 동작을 따라 해 주세요.**",
      "TW": "**請重複剛才小紙片人所做的動作**"
    }
  },
  "**超过限定时间将会扣除一定血量**": {
    "translation": "",
    "MultiLang": {
      "US": "Exceeding the time limit will deduct some of your health.",
      "JP": "**制限時間を過ぎるとHPが減少します**",
      "CN": "",
      "KR": "**제한 시간을 초과하면 체력이 일정량 감소합니다.**",
      "TW": "**超過限定時間將會扣除一定血量**"
    }
  },
  "**存活一段时间后方可获胜**": {
    "translation": "",
    "MultiLang": {
      "US": "You must survive for a certain amount of time to win.",
      "JP": "**一定時間生き残ればクリアです**",
      "CN": "",
      "KR": "**일정 시간이 경과해야 승리할 수 있습니다.**",
      "TW": "**存活一段時間後方可獲勝**"
    }
  },
  "**游戏结束**": {
    "translation": "",
    "MultiLang": {
      "US": "Game Over",
      "JP": "**ゲームオーバー**",
      "CN": "",
      "KR": "**게임 종료**",
      "TW": "**遊戲結束**"
    }
  },
  ">>千早爱音(分身):可恶,这副身体还是做不到吗<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chiha Anone (clone): Darn, this body still can't do it.<<",
      "JP": ">>千早愛音(分身):くっ、この体じゃ無理だったか<<",
      "CN": "",
      "KR": ">>치하야 아inou(분신): 까무러칠 듯이, 이 몸으로는 여전히 불가능한가<<",
      "TW": ">>千早愛音(分身):可惡，這副身體還是做不到嗎？<<"
    }
  },
  ">>也无妨,后面还有更大的挑战在等着你们呢<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>It doesn't matter. There are bigger challenges waiting for you ahead.<<",
      "JP": "それでも構わない、次にはさらに大きな試練が待っているからな。",
      "CN": "",
      "KR": ">>괜찮습니다, 뒤에는 더 큰 도전이 여러분을 기다리고 있습니다<<",
      "TW": ">>也沒關係，後面還有更大的挑戰等著你們呢<<"
    }
  },
  ">>你们就好好享受吧<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Just enjoy yourselves then.<<",
      "JP": "存分に楽しんでくれよ。",
      "CN": "",
      "KR": ">>잘 즐기세요<<",
      "TW": ">>你們就好好享受吧<<"
    }
  },
  ">>想知道变小的线索就去三楼餐去看看吧<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Want clues on how to shrink? Check out the third-floor restaurant.<<",
      "JP": "小さくなるヒントを知りたいなら、3階の食堂に行ってみてはどうか。",
      "CN": "",
      "KR": ">>작아지는 실마리를 알고 싶다면 3층 식당으로 가보세요<<",
      "TW": ">>想知道變小的線索就去三樓餐室看看吧<<"
    }
  },
  ">>嘿嘿嘿嘿~呀哈哈哈哈~(唐笑)<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Heheheh~ Yeah, hahahaha~ (Tang Xiao)<<",
      "JP": "フッフッフッフっ〜やっはははは〜（唐笑）",
      "CN": "",
      "KR": ">>헤히히히~야 하하하하~(탕소<<)",
      "TW": ">>嘿嘿嘿嘿~呀哈哈哈哈~(唐笑)<<"
    }
  },
  "**音箱即将被推下**": {
    "translation": "",
    "MultiLang": {
      "US": "**The speaker is about to be pushed over**",
      "JP": "**スピーカーが押し倒されようとしている**",
      "CN": "",
      "KR": "**스피커가 떨어지려고 함**",
      "TW": "**音箱即將被推下**"
    }
  },
  ">>高松灯:anon酱......<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Tokisawa Tohru: Anon-san...<<",
      "JP": ">>高松燈：アノンちゃん……<<",
      "CN": "",
      "KR": ">>타카마루 슨: 아논 양......<<",
      "TW": ">>高松燈：anon醬......<<"
    }
  },
  ">>千早爱音:我知道了啦<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: I know, I know<<",
      "JP": ">>千早愛音：わかったってば<<",
      "CN": "",
      "KR": ">>치하야 아이노: 알았어요<<",
      "TW": ">>千早愛音：我知道了啦<<"
    }
  },
  "**防守5秒等待爱音开门**": {
    "translation": "",
    "MultiLang": {
      "US": "**Defend for 5 seconds waiting for Anon to open the door**",
      "JP": "**愛音がドアを開けるまで5秒間の防御待機**",
      "CN": "",
      "KR": "**5초 동안 방어하며 아이노가 문을 여는 것을 기다림**",
      "TW": "**防守5秒等待愛音開門**"
    }
  },
  ">>长崎素世:穿过这条长廊,前面就是餐厅了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Nagasaki Soyo: After passing through this corridor, the dining room is ahead<<",
      "JP": ">>長崎そよ:この廊下を抜けると、目の前にレストランがあります<<",
      "CN": "",
      "KR": ">>나가사키 소요: 이 복도를 지나면 바로 식당입니다.<<",
      "TW": "長崎素世：穿過這條走廊，前面就是餐廳了。"
    }
  },
  ">>千早爱音:吧台上有纸飞机,我们也许可以利用那个快速抵达<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: There are paper planes on the bar counter, we might be able to use them to get there quickly<<",
      "JP": ">>千早愛音:カウンターに紙飛行機がありますね。それを使えば、あっという間に行けるかも<<",
      "CN": "",
      "KR": ">>ちはやあね: 바텐더 자리에는 종이비행기가 있네요. 그걸 이용하면 빠르게 도착할 수도 있어요.<<",
      "TW": "千早愛音：吧台上有一架紙飛機，我們可以利用它快速抵達。"
    }
  },
  ">>高松灯:我们...真的要乘坐纸飞机吗<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Tokisawa Tohru: Are we... really going to ride a paper plane<<",
      "JP": ">>高松燈:私たち……本当に、紙飛行機に乗っていいの？<<",
      "CN": "",
      "KR": ">>たかまつともしび: 우리... 진짜로 종이비행기를 탈 거야?<<",
      "TW": "高松燈：我們……真的要坐紙飛機嗎？"
    }
  },
  ">>这看起来也太危险了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>This looks way too dangerous<<'",
      "JP": ">>どう見ても危なそうですけど<<",
      "CN": "",
      "KR": ">>그게 너무 위험해 보이지 않아.<<",
      "TW": "這看起來也太危險了吧。"
    }
  },
  ">>千早爱音:没事,我在夏威夷学过开飞机,我有二十年的起飞经验<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: It's fine, I learned to fly planes in Hawaii. I've got twenty years of takeoff experience.<<",
      "JP": ">>千早愛音:大丈夫よ。私はハワイで飛行機の操縦を学んだことがあるの。離陸経験は20年あるわ<<",
      "CN": "",
      "KR": ">>ちはやあね: 괜찮아, 저는 하와이에서 비행기 운전하는 법을 배웠거든요. 이륙 경험도 20년 차예요.<<",
      "TW": "千早愛音：沒關係，我在夏威夷學過開飛機，我有二十年的起飛經驗。"
    }
  },
  ">>椎名立希:(这家伙,还去过夏威夷吗)<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Shiina Taki: (That guy, I guess you really did go to Hawaii.)<<",
      "JP": ">>椎名立希:（この人、本当にハワイに行ったことがあるのかしら）<<",
      "CN": "",
      "KR": ">>しいなたけき: (또 하와이에 다녀왔어?<<)",
      "TW": "椎名立希：（這傢伙，還去過夏威夷嗎？）"
    }
  },
  ">>(况且,她有二十岁嘛)<<": {
    "translation": "",
    "MultiLang": {
      "US": ">(Besides, she is twenty years old.)<",
      "JP": ">>(それに、彼女はもう二十歳なんだから)<<",
      "CN": "",
      "KR": ">>(게다가, 이미 스무살이잖아.<<)",
      "TW": "（何況，她都二十歲了啊。）"
    }
  },
  ">>(而且这不是纸飞机嘛)<<": {
    "translation": "",
    "MultiLang": {
      "US": ">(And this is a paper airplane, right?)<",
      "JP": ">>(しかも、ただの紙飛行機ですしね)<<",
      "CN": "",
      "KR": ">>(그게 종이비행기인데다가, 말야.<<)",
      "TW": "（而且這不是紙飛機嘛。）"
    }
  },
  ">>呃啊啊啊!槽点太多都不知道从哪里开始吐起<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Urghhhh! There are too many points to complain about; I don't even know where to start.<<",
      "JP": ">>うわあああ！ツッコムところが多すぎてどこから吐けばいいか分からない<<",
      "CN": "",
      "KR": ">>어흥~! 하소연할 게 너무 많아서 어디부터 해야 할지 모르겠네<<",
      "TW": ">>呃啊啊啊！槽點太多都不知道從哪裡開始吐起<<"
    }
  },
  "**纸飞机将在20秒后起飞**": {
    "translation": "",
    "MultiLang": {
      "US": "**The paper airplane will take off in 20 seconds.**",
      "JP": "**紙飛行機は20秒後に離陸します**",
      "CN": "",
      "KR": "**종이비행기가 이륙하기까지 20초 남았습니다**",
      "TW": "**紙飛機將在20秒後起飛**"
    }
  },
  ">>千早爱音:马上就要起飞了,大家坐稳了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: Takeoff is imminent. Please fasten your seatbelts, everyone.<<",
      "JP": ">>千早愛音:もうすぐ離陸よ、みんな乗ってください<<",
      "CN": "",
      "KR": ">>치하야 아주: 곧 이륙합니다,大家 단단히 앉으세요<<",
      "TW": ">>千早愛音：馬上就要起飛了，大家坐穩了<<"
    }
  },
  "**僵尸将在5秒后传送**": {
    "translation": "",
    "MultiLang": {
      "US": "**Zombies will teleport in 5 seconds.**",
      "JP": "**ゾンビは5秒後に転送されます**",
      "CN": "",
      "KR": "**좀비가 텔레포트하기까지 5초 남았습니다**",
      "TW": "**殭屍將在5秒後傳送**"
    }
  },
  ">>千早爱音:起飞咯!<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: Let's take off!<<",
      "JP": ">>千早愛音:離陸するわ！<<",
      "CN": "",
      "KR": ">>치하야 아주: 이륙합니다!<<",
      "TW": ">>千早愛音：起飛咯！<<"
    }
  },
  ">>千早爱音:啊,飞机居然卡在这里了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: Ah, the plane got stuck here.<<",
      "JP": ">>千早愛音:あ、機体がここで詰まっちゃった<<",
      "CN": "",
      "KR": ">>치하야 아주: 아, 비행기가 여기 걸렸네<<",
      "TW": ">>千早愛音：啊，飛機居然卡在這裡了<<"
    }
  },
  ">>椎名立希:你这家伙到底会不会开飞机啊<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Shiina Taki: Do you actually know how to fly a plane?<<",
      "JP": ">>椎名立希:あなた、ちゃんと操縦できるの？<<",
      "CN": "",
      "KR": ">>이시나 타카: 너 진짜 비행기 몰 줄 아니?<<",
      "TW": ">>椎名立希：你這傢伙到底會不會開飛機啊<<"
    }
  },
  ">>千早爱音:没事,没有飞机照样飞<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: It's fine, we can fly without a plane.<<",
      "JP": ">>千早愛音:大丈夫、機体がなくても飛べるわ<<\"",
      "CN": "",
      "KR": ">>치하야 아주:没关系, 비행기 없어도 날아갈 거야<<\"",
      "TW": ">>千早愛音：沒事，沒有飛機照樣飛<<"
    }
  },
  ">>椎名立希:你这家,嘴里说着什么胡话呢<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Shiina Taki: You're talking nonsense.<<",
      "JP": ">>椎名立希:そんな無茶苦茶なことを言って、いったい何を考えてるの?>>",
      "CN": "",
      "KR": ">>이노미야 타키: 너 요즘 무슨 소리를 하는 거야?<<",
      "TW": "「椎名立希：你这张嘴，到底在胡说什么啊！」"
    }
  },
  ">>不管你了,我要下去了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>I'm leaving, I'm going down.<<",
      "JP": ">>もう放っておくわ、私は降りる?>>",
      "CN": "",
      "KR": ">>그래, 널 버리고 내려갈래.<<",
      "TW": "「不管你了，我先下去了。」"
    }
  },
  ">>高松灯:这里这么高,跳下去不要紧吗?<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Takamatsu Tomori: It's so high here. Is it okay to jump down?<<",
      "JP": ">>高松灯:ここって結構高いよね、落ちても平気?>>",
      "CN": "",
      "KR": ">>타카마스 란: 여기 너무 높은데, 내려가도 괜찮아?<<",
      "TW": "「高松燈：這裡這麼高，跳下去沒關係嗎？」"
    }
  },
  ">>要乐奈:轻如鸿毛<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Ongaku Rana: Light as a feather.<<",
      "JP": ">>要楽奈:羽のようにはるかか<<",
      "CN": "",
      "KR": ">>요라나: 깃털처럼 가볍게.<<",
      "TW": "「要樂奈：輕如鴻毛。」"
    }
  },
  ">>众人:(猫猫叽里咕噜说什么呢)<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Everyone: (What on earth is the cat saying?)<<",
      "JP": ">>众人:(にゃんこ、ごちゃごちゃ何言ってるの)<<",
      "CN": "",
      "KR": ">>일행: (냐옹?).<<",
      "TW": "「眾：（貓音嘟囔著說了些什麼）」"
    }
  },
  ">>长崎素世:话说我们这幅模样要怎么才能上三楼啊<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Nagasaki Seto: Speaking of which, how are we supposed to get to the third floor looking like this?<<",
      "JP": ">>長崎そよ:それにしても、今の姿で3階にはどうやって上がる?>>",
      "CN": "",
      "KR": ">>나가사키 소yo: 그런데 우리가 이 꼴로 어떻게 3층으로 올라갈까?<<",
      "TW": "「長崎素世：話說回來，我們這樣的样子要怎麼上到三樓呢？」"
    }
  },
  ">>千早爱音:看见那些盆栽了吗,我们可以那些藤蔓爬上去<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: See those potted plants? We can climb up using the vines.<<",
      "JP": ">>千早愛音:あのカビの生えた植物に見える？あの蔦をよじ登ったら行けそうよ>>",
      "CN": "",
      "KR": ">>치하야 아이노: 저 화분들 보이? 그 덩굴을 타고 올라갈 수 있어.<<",
      "TW": "「千早愛音：看到那些盆栽了嗎？我們可以順著藤蔓爬上去。」"
    }
  },
  ">>长崎素世:还是你鬼点子多啊!<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Nagasaki Seto: You really are full of clever ideas!<<",
      "JP": ">>長崎そよ:やっぱりあなた、抜かりがないわね！<<",
      "CN": "",
      "KR": ">>나가사키 소yo: 너 정말 영리한걸!<<",
      "TW": "「長崎素世：還是你最會想鬼點子啊！」"
    }
  },
  ">>千早爱音:这么多专辑!<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: So many albums!<<",
      "JP": ">>千早愛音:こんなにアルバムの山!<<",
      "CN": "",
      "KR": ">>치하야 아네: 앨범이 이렇게 많아!<<",
      "TW": ">>千早愛音：這麼多專輯！<<"
    }
  },
  ">>这要是摔下去了,肯定全都用不了了<<": {
    "translation": "",
    "MultiLang": {
      "US": "If we fall from here, they'll definitely all be unusable.",
      "JP": ">>もし落ちたら、絶対全部使えなくなるよ<<",
      "CN": "",
      "KR": ">>이거 떨어지면 다 망가지겠어<<",
      "TW": ">>這要是摔下去了，肯定全都用不了了<<"
    }
  },
  ">>我可不忍心啊,没办法了,只能交给你们了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>I simply can't bear to do it. There's nothing else for it but to leave it in your hands.<<",
      "JP": ">>可哀想だよな。仕方ない、任せたよ<<",
      "CN": "",
      "KR": ">>초반에는 아깝지만 어쩔 수 없지. 너희에게 맡겨!<<",
      "TW": ">>我可不忍心啊，沒辦法了，只能交給你們了<<"
    }
  },
  ">>椎名立希:你这家伙,单纯就是想偷懒吧<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Taki Shiina: You're just trying to slack off, aren't you? <<",
      "JP": ">>椎名立希:あんた、ただサボりたいだけだよね<<",
      "CN": "",
      "KR": ">>시나 태키: 너 그냥 게으른 거잖아<<",
      "TW": ">>椎名立希：你这傢伙，單純就是想偷懶吧<<"
    }
  },
  "**专辑都被推下去了**": {
    "translation": "",
    "MultiLang": {
      "US": "All the albums were pushed down.",
      "JP": "**アルバムがすべて落下した**",
      "CN": "",
      "KR": "**앨범이 모두 떨어졌다**",
      "TW": "**專輯都被推下去了**"
    }
  },
  ">>千早爱音:哎,可怜这些专辑了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Anon Chihaya: Oh, what a pity for those albums.<<",
      "JP": ">>千早愛音:あー、可哀想に……<<",
      "CN": "",
      "KR": ">>치하야 아네: 아, 안타깝다 저 앨범들이...<<",
      "TW": ">>千早愛音：哎，可憐這些專輯了<<"
    }
  },
  ">>算了,正事要紧,我们走吧<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Forget it, let's focus on the main task and move on.<<",
      "JP": ">>まあいいや。大事なのは本題だ、行こう<<",
      "CN": "",
      "KR": ">>할 수 없지, 중요한 게 중요해. 가자<<",
      "TW": ">>算了，正事要緊，我們走吧<<"
    }
  },
  ">>千早爱音:可恶,三楼明明什么都没有<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Anon Chihaya: Darn it, there's nothing on the third floor.<<",
      "JP": ">>千早愛音:くっそ、3階には何もなかったって<<",
      "CN": "",
      "KR": ">>치하야 아네: 짜증, 3층엔 아무것도 없는데<<'",
      "TW": ">>千早愛音：可惡，三樓明明什麼都沒有<<"
    }
  },
  ">>那家伙是不是在耍我们啊<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Is that guy playing us for fools?<<",
      "JP": ">>あの奴らは私たちを騙しているのか<<",
      "CN": "",
      "KR": ">>그家伙是不是 في we啊<<",
      "TW": ">>那傢伙是不是在耍我們啊<<"
    }
  },
  ">>这里也就只有阳台没有去过了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>This place hasn't been searched except for the balcony.<<",
      "JP": ">>ここはベランダしかまだ行っていないな<<",
      "CN": "",
      "KR": ">>여기서는 발코니만 가지 않았어<<",
      "TW": ">>這裡也就只有陽台沒有去過<<"
    }
  },
  ">>没办法了,去阳台上看看吧<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>No choice, let's check the balcony.<<",
      "JP": "仕方ない、ベランダを見てこよう<<",
      "CN": "",
      "KR": "어쩔 수 없으니 발코니로 가자. <<",
      "TW": ">>沒辦法了,去陽台上看看吧<<"
    }
  },
  "**防守25秒等待大门打开**": {
    "translation": "",
    "MultiLang": {
      "US": "**Defend for 25 seconds until the gate opens.**",
      "JP": "**25秒間防衛し、門が開くのを待つ**",
      "CN": "",
      "KR": "**방어 25초 후 대문 열림**",
      "TW": "**防守25秒等待大門打開**"
    }
  },
  "**门打开了**": {
    "translation": "",
    "MultiLang": {
      "US": "**The door opens.**",
      "JP": "**门が開いた**",
      "CN": "",
      "KR": "**문이 열렸다**",
      "TW": "**門已經打開了**"
    }
  },
  ">>千早爱音:终于开门了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: The door finally opened.<<",
      "JP": ">>千早アナ:とうとう開いたな<<",
      "CN": "",
      "KR": "치하야 애인: 드디어 문이 열렸어 <<",
      "TW": ">>千早愛音:終於開門了<<"
    }
  },
  ">>长崎素世:阳台边上好像有人影,我们快过去看看<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Nagasaki Soyo: There seems to be someone on the balcony. Let's go take a look.<<",
      "JP": ">>長崎ソヨコ:ベランダの端に人影がある、早く確認しよう<<",
      "CN": "",
      "KR": "나가사키 소요: 발코니 옆에 사람 그림자가 보이는 것 같아. 빨리 가보자. <<",
      "TW": ">>長崎素世:陽台邊上好像有人影,我們快過去看看<<"
    }
  },
  ">>千早爱音(分身):就没想到你们这么快就到了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon (Clone): I didn't expect you to arrive so quickly.<<",
      "JP": ">>千早アナ(分身):こんなに早く着くと予想していなかったな<<",
      "CN": "",
      "KR": "치하야 애인 (분신): 너희가 이렇게 빨리 올 줄은 몰랐어. <<",
      "TW": ">>千早愛音(分身):就沒想到你們這麼快就到了<<"
    }
  },
  ">>椎名立希:你到底想要干什么!<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Shiina Taki: What exactly are you trying to do!<<",
      "JP": ">>椎名立希:あなたは何がしたいんですか!!<<",
      "CN": "",
      "KR": ">>이시나리 타키: 대체 넌 뭘 원하는 거야!<<",
      "TW": ">>椎名立希：你究竟想幹什麼！<<"
    }
  },
  ">>千早爱音(分身):别急嘛,去二楼的练习台吧<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon (Clone): Take it easy. Let's head to the second-floor practice room.<<",
      "JP": ">>千早愛音(分身):焦らなくて大丈夫よ、二楼の練習スタジオに行きましょう<<",
      "CN": "",
      "KR": ">>치하야 애인(분신): 급하게 가지 말고 2층 연습대로 가자<<",
      "TW": ">>千早愛音（分身）：別著急，去二樓的練習室吧<<"
    }
  },
  ">>你们将在那里接受终极试炼<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>You will undergo your final trial there.<<",
      "JP": ">>そこで貴方たちは最後の試練を受けることになります<<",
      "CN": "",
      "KR": ">>거기서 최종 시험을 받게 될 것이다<<",
      "TW": ">>你們將在那裡接受最終試煉<<"
    }
  },
  ">>话已经说完了,我先溜了,嘿嘿嘿<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>I've said my piece, so I'm off. Hehehe.<<",
      "JP": ">>もう用は済みましたので、私は失礼します。へへへ<<",
      "CN": "",
      "KR": ">>얘기도 다 끝났으니我先 가볼게, 히히히<<",
      "TW": ">>話已經說完了，我先溜了，嘿嘿嘿<<"
    }
  },
  ">>椎名立希:可恶,这家伙居然把我们刷的团团转<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Taki Shiina: Dang it, that guy actually led us on a merry chase.<<",
      "JP": ">>椎名立希:くそ、こいつは私たちを完全に振り回しやがった<<",
      "CN": "",
      "KR": ">>이시나리 타키: 저런, 이 녀석이 우리를 빙빙 돌렸다니<<",
      "TW": ">>椎名立希：該死，這傢伙居然把我們耍得团团轉<<"
    }
  },
  ">>可别让我逮住了,逮住了指定没有她好果汁吃<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Taki Shiina: Don't think you've gotten away. If I catch you, you're dead meat.<<",
      "JP": ">>もし捕まえられたら、絶対許さないわ<<",
      "CN": "",
      "KR": ">>내가 붙잡으면 저 녀석이 좋은 목숨을 건질 것이라고 생각하지 마<<",
      "TW": ">>可別讓我逮到，逮到了肯定沒她好果子吃<<"
    }
  },
  "**请前往练习台**": {
    "translation": "",
    "MultiLang": {
      "US": "**Please proceed to the practice platform.**",
      "JP": "**練習スタジオへ向かう**",
      "CN": "",
      "KR": "**연습대로 이동합니다**",
      "TW": "**請前往練習室**"
    }
  },
  ">>千早爱音:总感觉头有点晕晕的<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: I feel a bit dizzy.<<",
      "JP": ">>千早愛音:少し頭がぼんやりして……<<",
      "CN": "",
      "KR": ">>치하야 애인: 왜인지 머리가 돌돌 도는 것 같아<<",
      "TW": ">>千早愛音：總覺得頭有點暈<<"
    }
  },
  "**防守20秒**": {
    "translation": "",
    "MultiLang": {
      "US": "**Defend for 20 seconds**",
      "JP": "20秒間防衛",
      "CN": "",
      "KR": "**20초 방어**",
      "TW": "防守20秒"
    }
  },
  ">>高松灯:anon酱你没事吧<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Tomori Takamatsu: Anon, are you okay?<<",
      "JP": ">>高松燈:アノンちゃん、大丈夫？<<",
      "CN": "",
      "KR": ">>미타케 토오리: 아논 씨, 괜찮아요?<<",
      "TW": ">>高松燈：匿名醬你沒事吧<<"
    }
  },
  ">>椎名立希:是不是那家伙偷偷对你做了什么<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Taki Shiina: Did that person do something to you secretly?<<",
      "JP": ">>椎名立希:もしかして、あいつが何か仕掛けたの？<<",
      "CN": "",
      "KR": ">>이치카와 타카: 저 녀석이 모르게 당신의 무언가에 손 댔나 봐요.<<",
      "TW": ">>椎名立希：是不是那傢伙偷偷對你做什麼了<<"
    }
  },
  ">>长崎素世:其实...我的头也晕晕的<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Soyo Nagasaki: Actually... my head feels a bit dizzy too.<<",
      "JP": ">>長崎そよ:実は…私の頭もふわふわしてるわ<<",
      "CN": "",
      "KR": ">>나가사키 소요: 사실... 저도 머리가 어지러워져요.<<",
      "TW": ">>長崎素世：其實...我的頭也暈暈的<<"
    }
  },
  ">>椎名立希:你这么一说,我好像也有些困困的...<<": {
    "translation": "",
    "MultiLang": {
      "US": "<<Taki Shiina: Hearing you say that, I do feel a bit sleepy...>>",
      "JP": ">>椎名立希:そう言われてみれば、私もだんだん眠くなってきた…<<",
      "CN": "",
      "KR": ">>이치카와 타카: 그런 말씀 하시니, 저도 좀 졸리네요...<<",
      "TW": ">>椎名立希：你這麼一說，我好像也有些困困的...<<"
    }
  },
  ">>要乐奈:(・ω・＼)SAN值!(／・ω・)危机<<": {
    "translation": "",
    "MultiLang": {
      "US": "<<Rana Yokoyama: (・ω・＼)Sanity Check! (／・ω・) Crisis>>",
      "JP": ">>要楽奈:(・ω・＼)SAN値!(／・ω・)危機<<",
      "CN": ">>要乐奈:(・ω・＼)SAN值!(／・ω・)危机<<",
      "KR": ">>하타 노노: (・ω・＼)SAN 값!(／・ω・) 위기<<",
      "TW": ">>要樂奈：(・ω・＼)SAN值！(／・ω・)危機<<"
    }
  },
  ">>千早爱音:(总感觉,马上就要晕过去了)<<": {
    "translation": "",
    "MultiLang": {
      "US": "<<Anon Chihaya: (I have this feeling I'm about to pass out...)>>",
      "JP": ">>千早愛音:（今にも目の前が暗くなる…）<<",
      "CN": "",
      "KR": ">>치하야 안온:(아무래도 곧 쓰러질 것 같네요)<<",
      "TW": ">>千早愛音：(總感覺，馬上就要暈過去了)<<"
    }
  },
  ">>千早爱音:(难道,只能到此为止了吗)<<": {
    "translation": "",
    "MultiLang": {
      "US": "<<Anon Chihaya: (Could it be that we have to stop here?)>>",
      "JP": ">>千早愛音:（もう、ここで終わりかしら…）<<",
      "CN": "",
      "KR": ">>치하야 안온:(아니면, 여기까지인 걸까요)<<",
      "TW": ">>千早愛音：(難道，只能到此為止了嗎)<<"
    }
  },
  ">>高松灯:anno酱快醒醒<<": {
    "translation": "",
    "MultiLang": {
      "US": "<<Tomori Takamatsu: Anno, wake up quickly.>>",
      "JP": ">>高松燈:アノンちゃん、早く目を開けて<<\"",
      "CN": "",
      "KR": ">>高松燈:아노, 금방 일어나<<",
      "TW": ">>高松燈:安諾醬快醒醒<<"
    }
  },
  ">>千早爱音:头好痛啊...这是什么地方<<": {
    "translation": "",
    "MultiLang": {
      "US": "<<Anon Chihaya: My head hurts so much... Where is this place?>>",
      "JP": ">>千早愛音:頭がすごく痛い…ここはどこ？<<",
      "CN": "",
      "KR": ">>ちはやあね:머리가 정말 아파... 여기는 어디지?>>",
      "TW": ">>千早愛音:頭好痛啊...這是什麼地方<<"
    }
  },
  ">>我们怎么又回到演播厅了<<": {
    "translation": "",
    "MultiLang": {
      "US": "<<How did we end up back in the studio again?\"",
      "JP": ">>我们又回到了演播室<<",
      "CN": "",
      "KR": ">>왜 다시 스튜디오로 돌아왔지?>>",
      "TW": ">>我們怎麼又回到演播廳了<<"
    }
  },
  ">>椎名立希:又是你们,你们究竟想要做什么<<": {
    "translation": "",
    "MultiLang": {
      "US": "<<Taki Shiina: It's you guys again. What exactly do you want to do?>>",
      "JP": ">>椎名立希:又是你们，你们究竟想干什么<<",
      "CN": "",
      "KR": ">>椎名立希:다시 너희들이군, 도대체 뭘 원하는 거지?>>",
      "TW": ">>椎名立希:又是你們,你們究竟想要做什麼<<"
    }
  },
  ">>千早爱音(分身):看来你们都已经醒过来了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon (Clone): It seems you've all woken up now.<<",
      "JP": ">>千早愛音(分身):看来你们都醒过来了<<",
      "CN": "",
      "KR": ">>ちはやあne(분신):보니 너희 모두 정신을 차린 모양이구나?>>",
      "TW": ">>千早愛音(分身):看來你們都已經醒過來了<<"
    }
  },
  ">>好戏马上就要开始上演了!<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>The main show is about to begin!<<",
      "JP": ">>好戏马上就要开始上演了!<<",
      "CN": "",
      "KR": ">>드라마가 곧 시작될 준비를 끝냈어!?>>",
      "TW": ">>好戲馬上就要開始上演了!<<"
    }
  },
  "Full Combo !": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Full Combo !",
      "CN": "Full Combo!",
      "KR": "풀 콤보!",
      "TW": "Full Combo !"
    }
  },
  ">>高松灯:我们...我们做到了!<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Takamatsu Tomori: We... we did it!<<",
      "JP": ">>高松灯:我们…我们做到了!<<",
      "CN": "",
      "KR": ">>高松燈:우리... 우리 성공했어!?>>",
      "TW": ">>高松燈:我們...我們做到了!<<"
    }
  },
  ">>千早爱音(分身):哼哼,别高兴的太早<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon (Clone): Heheh, don't get ahead of yourselves.<<",
      "JP": ">>千早愛音(分身):哼哼,别高兴得太早<<",
      "CN": "",
      "KR": ">>치하야 아네(분신): 음哼, 너무 기뻐하지 마<<",
      "TW": "千早愛音(分身)：哼哼，別高興得太早"
    }
  },
  ">>更大的试炼还在后面等着你们呢<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>A greater trial awaits you ahead.<<",
      "JP": ">>さらに大きな試練が、君たちを待っている<<",
      "CN": "",
      "KR": ">>더 큰 시련이 지금부터 기다리고 있다<<",
      "TW": "更大的試煉還在後面等著你們呢"
    }
  },
  "**即将开启无限试炼模式**": {
    "translation": "",
    "MultiLang": {
      "US": "**Infinite Trial Mode Coming Soon**",
      "JP": "**無限試練モードまもなく開始**",
      "CN": "",
      "KR": "**무한 시련 모드 곧 시작**",
      "TW": "**即將開啟無限試煉模式**"
    }
  },
  "**RTV关卡一**": {
    "translation": "",
    "MultiLang": {
      "US": "**RTV Level 1**",
      "JP": "**RTVレベル1**",
      "CN": "",
      "KR": "**RTV 클리어 - 1층**",
      "TW": "**RTV關卡一**"
    }
  },
  ">>千早爱音:看来这就是我们的最终试炼了<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Chihaya Anon: It seems this is our final trial.<<",
      "JP": ">>千早愛音:これが私たちの最終試練のようね<<",
      "CN": "",
      "KR": ">>치하야 아네: 여기가 우리의 마지막 시련인 것 같군<<",
      "TW": "千早愛音：看來這就是我們的最終試煉了"
    }
  },
  ">>都别愣着了,快来看看要演奏哪首曲子<<": {
    "translation": "",
    "MultiLang": {
      "US": ">>Stop staring and come see which song we'll play<<",
      "JP": ">>みんな、ぼんやりしてないで早く演奏する曲を選ぼう<<",
      "CN": "",
      "KR": ">>이제 막연히 서 있을 틈도 없어, 얼른 연주할 악보를 봐<<",
      "TW": "都別愣著了，快來看看要演奏哪首曲子"
    }
  },
  "**请投票选出游玩的曲目**": {
    "translation": "",
    "MultiLang": {
      "US": "**Please vote for the song you'd like to hear**",
      "JP": "**プレイする楽曲を投票で選んでください**",
      "CN": "",
      "KR": "**플레이할 곡을 투표하여 선택하세요**",
      "TW": "**請投票選出遊玩的曲目**"
    }
