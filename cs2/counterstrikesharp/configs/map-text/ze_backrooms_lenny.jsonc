{
  "I'M PICKING UP SOME VERY STRANGE READINGS ...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "極めて不審な数値を検知した…",
      "CN": "我正在接收一些非常奇怪的读数……",
      "KR": "아주 이상한 수치가 감지되고 있습니다...",
      "TW": "偵測到異常信號..."
    }
  },
  "KEEP HEADING NORTH AND DON'T LINGER ...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "北へ進み、立ち止まらないで…",
      "CN": "继续向北前进，不要停留……",
      "KR": "북쪽으로 계속 나아가고,逗留하지 마십시오...",
      "TW": "持續向北前行，切勿逗留..."
    }
  },
  "A DOOR IS OPENING ...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "扉が開く…",
      "CN": "一扇大门正在打开……",
      "KR": "문이 열리고 있습니다...",
      "TW": "門已開啟..."
    }
  },
  "AN ELEVATOR HAS ARRIVED ...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーター到着…",
      "CN": "电梯已到达……",
      "KR": "엘리베이터가 도착했습니다...",
      "TW": "電梯已抵達..."
    }
  },
  "ELEVATOR CLOSING IN 30 SECONDS ...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "30秒後にエレベーターの扉が閉じます…",
      "CN": "电梯将在30秒后关闭……",
      "KR": "30초 후 엘리베이터 문이 닫힙니다...",
      "TW": "電梯門即將關閉，距離30秒..."
