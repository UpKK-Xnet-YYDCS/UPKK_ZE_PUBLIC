{
  "该死！大家还好么？": {
    "translation": "",
    "MultiLang": {
      "US": "Damn it! Is everyone alright?",
      "JP": "くそ！皆、無事か？",
      "CN": "",
      "KR": "该死！大家还好么？",
      "TW": "該死！大家還好嗎？"
    }
  },
  "我们没事头儿": {
    "translation": "",
    "MultiLang": {
      "US": "We're fine, leader.",
      "JP": "大丈夫です、队长",
      "CN": "",
      "KR": "我们没事头儿",
      "TW": "我們沒事，頭兒。"
    }
  },
  "看来只能找到另外的路出去了": {
    "translation": "",
    "MultiLang": {
      "US": "It looks like we'll have to find another way out.",
      "JP": "どうやら別ルートを探すしかないようだ",
      "CN": "",
      "KR": "看来只能找到另外的路出去了",
      "TW": "看來只能找別的路出去了。"
    }
  },
  "无线电能联系上么？": {
    "translation": "",
    "MultiLang": {
      "US": "Can you establish wireless contact?",
      "JP": "無線で連絡は取れるか？",
      "CN": "",
      "KR": "无线电能联系上么？",
      "TW": "無線电能聯繫得上嗎？"
    }
  },
  "不行 没信号头儿": {
    "translation": "",
    "MultiLang": {
      "US": "Negative. No signal, leader.",
      "JP": "無理です、電波が入りません、隊長",
      "CN": "",
      "KR": "不行 没信号头儿",
      "TW": "不行，沒信號，頭兒。"
    }
  },
  "打起精神来！我一定会带你们出去": {
    "translation": "",
    "MultiLang": {
      "US": "Cheer up! I'll get you all out of here.",
      "JP": "気合を入れ直せ！必ず皆を脱出させる",
      "CN": "",
      "KR": "打起精神来！我一定会带你们出去",
      "TW": "打起精神來！我一定會帶你們出去。"
    }
  }
}
