{
  "该死！大家还好么？": {
    "translation": "",
    "MultiLang": {
      "US": "Damn! Is everyone okay?",
      "JP": "ちくしょう！みんな大丈夫？",
      "CN": "",
      "KR": "该死！大家还好么？",
      "TW": "該死！大家還好嗎？"
    }
  },
  "我们没事头儿": {
    "translation": "",
    "MultiLang": {
      "US": "We're fine, boss.",
      "JP": "僕らのことは気にしないで、隊長！",
      "CN": "",
      "KR": "我们没事头儿",
      "TW": "我們沒事，頭兒。"
    }
  },
  "看来只能找到另外的路出去了": {
    "translation": "",
    "MultiLang": {
      "US": "Looks like we'll have to find another way out.",
      "JP": "どうやら別の出口を探し出すしかないようだ",
      "CN": "",
      "KR": "看来只能找到另外的路出去了",
      "TW": "看來只能另找出路了。"
    }
  },
  "无线电能联系上么？": {
    "translation": "",
    "MultiLang": {
      "US": "Can you reach them via wireless?",
      "JP": "無線は届くか？",
      "CN": "",
      "KR": "无线电能联系上么？",
      "TW": "無線电能聯繫得上嗎？"
    }
  },
  "不行 没信号头儿": {
    "translation": "",
    "MultiLang": {
      "US": "No signal, boss.",
      "JP": "無理だ、電波が掴めない",
      "CN": "",
      "KR": "不行 没信号头儿",
      "TW": "不行，沒信號，頭兒。"
    }
  },
  "打起精神来！我一定会带你们出去": {
    "translation": "",
    "MultiLang": {
      "US": "Cheer up! I'll definitely get you all out.",
      "JP": "気を張ってな！必ず全員を外へ連れて出す",
      "CN": "",
      "KR": "打起精神来！我一定会带你们出去",
      "TW": "打起精神來！我一定會帶你們出去。"
    }
  }
}
