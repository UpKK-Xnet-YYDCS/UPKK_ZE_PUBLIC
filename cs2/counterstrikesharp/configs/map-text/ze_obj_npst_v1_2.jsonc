  "Good Luck !": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "頑張ってください！",
      "CN": "祝你好运！",
      "KR": "행운을 빕니다!",
      "TW": "祝你好運！"
    }
  },
  "<<< The door has opened >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<< ドアが開きました >>>",
      "CN": "<<< 门已开启 >>>",
      "KR": "<<< 문이 열렸습니다 >>>",
      "TW": "<<< 門已開啟 >>>"
    }
  },
  "<<< The yellow door leading to the HUB will open soon >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<< ハブへの黄色のドアが、まもなく開きます >>>",
      "CN": "<<< 通往HUB的黄色门即将开启 >>>",
      "KR": "<<< 곧 허브로 연결되는 노란 문이 열립니다 >>>",
      "TW": "<<< 連通中心區域的黃色門將很快開啟 >>>"
    }
  },
  "<<< The yellow door Area 9 will open in 10 seconds >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<< エリア9の黄色のドアが、10秒後に開きます >>>",
      "CN": "<<< Area 9的黄色门将在10秒后开启 >>>",
      "KR": "<<< 10초 후에 9번 구역의 노란 문이 열립니다 >>>",
      "TW": "<<< 9號區域的黃色門將在 10 秒後開啟 >>>"
    }
  },
  "<<< Get out of here !!! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<< ここから出て！！>>>",
      "CN": "<<< 快离开这里！！！ >>>",
      "KR": "<<< 여기서 나가세요!!! >>>",
      "TW": "<<< 離開這裡！！！>>>"
    }
  },
  "<<< The door is about to open.. >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<<扉が開く直前です...>>>",
      "CN": "<<< 门即将开启.. >>>",
      "KR": "<<< 문이 곧 열립니다... >>>",
      "TW": "<<< 門將會馬上打開... >>>"
    }
  },
  "<<< The door is opening get inside !>>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<<扉が開きます！中へ！>>>",
      "CN": "<<< 门正在开启，快进去！ >>>",
      "KR": "<<< 문이 열리고 있습니다! 안으로 들어오세요! >>>",
      "TW": "<<< 門正在打開，快進來！>>>"
    }
  },
  "The blue door opened !": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "青い扉が開いた！",
      "CN": "蓝色门打开了！",
