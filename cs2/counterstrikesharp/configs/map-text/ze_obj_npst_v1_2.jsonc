    }
  },
  "<<< The door is opening get inside !>>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアが開いている！中に飛び込め！",
      "CN": "门正在打开，快进去！",
      "KR": "문이 열리고 있으니 안으로 들어가세요!",
