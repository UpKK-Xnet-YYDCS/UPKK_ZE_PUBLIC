  "<<< The door has opened >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<< 扉が開きました >>>",
      "CN": "<<< 门已打开 >>>",
      "KR": "<<< 문이 열렸습니다 >>>",
      "TW": "<<< 門已開啟 >>>"
    }
  },
  "<<< The yellow door leading to the HUB will open soon >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<< HUBへ繋がる黄色い扉がまもなく開きます >>>",
      "CN": "<<< 通往HUB的黄色大门即将开启 >>>",
      "KR": "<<< HUB로 이어지는 노란 문이 곧 열릴 예정입니다 >>>",
      "TW": "<<< 通往 HUB 的黃色門即將開啟 >>>"
    }
  },
  "<<< The yellow door Area 9 will open in 10 seconds >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<< 区域9の黄色い扉は10秒後に開きます >>>",
      "CN": "<<< 区域9的黄色大门将在10秒后开启 >>>",
      "KR": "<<< Area 9의 노란 문이 10초 후에 열릴 예정입니다 >>>",
      "TW": "<<< Area 9 的黃色門将在10秒後開啟 >>>"
    }
  },
  "<<< Get out of here !!! >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<< ここで退去せよ！！！ >>>",
      "CN": "<<< 快离开这里！！！>>>",
      "KR": "<<< 이곳에서 벗어나세요!!! >>>",
      "TW": "<<< 快離開這裡！！！>>>"
    }
  },
  "<<< The door is about to open.. >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアが開こうとしている…",
      "CN": "门即将打开……",
      "KR": "문이 곧 열립니다..",
