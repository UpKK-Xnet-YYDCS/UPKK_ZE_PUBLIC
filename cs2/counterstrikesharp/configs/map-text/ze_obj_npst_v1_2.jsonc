  },
  "<<< The electricity should be cut off in a few seconds >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<<数秒以内に、電源が切れるはずです。>>>",
      "CN": "<<< 电力将在几秒内切断 >>>",
      "KR": "<<< 몇 초 후에 전력이 차단될 예정입니다 >>>",
      "TW": "<<< 幾秒鐘後，電力將會被切斷 >>>"
    }
  },
  "<<< Electricity is OFF >>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<<電源がオフになりました。>>>",
      "CN": "<<< 电力已关闭 >>>",
      "KR": "<<< 전력이 꺼졌습니다 >>>",
      "TW": "<<< 電力已關閉 >>>"
    }
  },
  "Lasers are blocking the way": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "レーザーが道を塞いでいます",
      "CN": "激光正在阻挡道路",
      "KR": "레이저가 길을 막고 있습니다",
      "TW": "雷射正在阻擋道路"
    }
  },
  "DON'T TOUCH THE LASERS": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "レーザーには触れないでください",
      "CN": "不要触碰激光",
      "KR": "레이저를 건드리지 마세요",
      "TW": "不要觸碰雷射"
