{
  "- Level 1 -": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "- レベル 1 -",
      "CN": "- 第一关 -",
      "KR": "- 레벨 1 -",
      "TW": "- 第 1 關 -"
    }
  },
  "**Grab a Bizon from the crate!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**クレートからゾロフを取り出せ!**",
      "CN": "**从箱子里拿一把PP-91卡巴松冲锋枪！**",
      "KR": "**창고에서 비손을 챙겨라!**",
      "TW": "**從貨箱裡拿起一把 PPSh-41 衝鋒槍！**"
    }
  },
  "**Split up and meet at the gun shop!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**分かれて、銃砲店に集合しろ!**",
      "CN": "**分开行动，在军械店集合！**",
      "KR": "**둘로 나뉘어 총기 상점에서 만나자!**",
      "TW": "**分頭行動，在軍械店集合！**"
    }
  },
  "**TIP: Look for arrows to help you find your way.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ヒント：案内板を見よう。道しるべになる。**",
      "CN": "**提示：留意箭头以指引方向。**",
      "KR": "**팁: 화살표를 찾아 길을 찾으세요.**",
      "TW": "**小提示：尋找箭頭指引方向。**"
    }
  },
  "**TIP: Find the blue napalm grenades.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ヒント：青色のナパームグレードを見つけろ。**",
      "CN": "**提示：寻找蓝色燃烧弹手雷。**",
      "KR": "**팁: 파란 네이팜 수류탄을 찾아보세요.**",
      "TW": "**小提示：找到藍色的凝固汽油彈。**"
    }
  },
  "**Factory door opening in 3 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "工場の扉が3秒後に開きます。",
      "CN": "**工厂大门将在3秒后开启。**",
      "KR": "**공장 문 3초 후 열림**",
      "TW": "**工廠門將在 3 秒後開啟。**"
    }
  },
  "**2**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "**1**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "**Hit the button to close the gate!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ボタンを押してゲートを閉めろ!",
      "CN": "**按下按钮关闭闸门！**",
      "KR": "**버튼을 눌러 문을 닫으세요!**",
      "TW": "**按按鈕關閉柵門！**"
    }
  },
  "**Hold off the runners while the gate closes!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートが閉まるまで、ランナー達を食い止めろ!",
      "CN": "**在闸门关闭时阻击追兵！**",
      "KR": "**문이 닫히는 동안 추격자들을 저지하세요!**",
      "TW": "**在柵門關閉期間抵擋倖存者！**"
    }
  },
  "**The gun shop is open!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**銃器店オープン！**",
      "CN": "枪店已开业！",
      "KR": "** 총기상이 문을 엽니다!**",
      "TW": "槍店已營業！"
    }
  },
  "**Hold off the runners from the balcony or the window. Don't get edged!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**バルコニーまたは窓からランナーを撃退しろ！近づかれるな！**",
      "CN": "在阳台或窗边阻挡感染者，切勿近身！",
      "KR": "** 발코니나 창문에서 러너들을 막아세요. 너무 가까이 붙지 마세요!**",
      "TW": "從陽台或窗戶阻擋感染者！別被近身！"
    }
  },
  "**Shop is closed!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**店は閉店！**",
      "CN": "商店已关闭！",
      "KR": "** 매장이 폐장되었습니다!**",
      "TW": "商店已關閉！"
    }
  },
  "**Secret exit open!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**秘密の出口開放！**",
      "CN": "隐藏出口已开启！",
      "KR": "** 비밀 출구 개방!**",
      "TW": "秘密出口已開啟！"
    }
  },
  "**Zombies: Line up at the garage door.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ゾンビ：ガレージドア前に並べ。**",
      "CN": "僵尸：在车库门口列队。",
      "KR": "** 좀비: 차고 문 앞에 줄을 서세요.",
      "TW": "殭屍：在車庫門前集結。"
    }
  },
  "**Humans: Get ready to run through the other door!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**人間：別の扉を通って逃走する準備をしろ！**",
      "CN": "幸存者：准备从另一扇门逃脱！",
      "KR": "** 인간: 다른 문을 통과할 준비를 하세요!",
      "TW": "人類：準備從另一扇門逃脫！"
    }
  },
  "**Garage door opening in 5 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ガレージドアが5秒後に開きます！**",
      "CN": "车库门将在5秒后打开！",
      "KR": "** 차고 문이 5초 후에 열립니다!**",
      "TW": "車庫門五秒後開啟！"
    }
  },
  "**4**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "**3**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "**RUN!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**走れ！**",
      "CN": "快跑！",
      "KR": "** 도망치세요!**",
      "TW": "快跑！"
    }
  },
  "**Hit the filter button!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "フィルターボタンを押せ！",
      "CN": "按下过滤按钮！",
      "KR": "**필터 버튼 누르기!**",
      "TW": "按下滑動過濾按鈕！"
    }
  },
  "**Get in the filter!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "フィルターへ進入しろ！",
      "CN": "进入过滤器！",
      "KR": "**필터 안에 들어가기!**",
      "TW": "進入過濾器！"
    }
  },
  "**Blow up the stairs to delay the runners!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "階段を爆破して追手を遅らせろ！",
      "CN": "炸毁楼梯以延缓跑步者！",
      "KR": "**출주자들을 지연시키기 위해 계단을 폭파하기!**",
      "TW": "炸毀樓梯以延緩追擊者！"
    }
  },
  "**Humans: Initiate the self-destruct sequence.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "人類：自爆シークエンスを開始",
      "CN": "人类：启动自毁程序。",
      "KR": "**인간: 자폭 시퀀스 시작.**",
      "TW": "人類：啟動自毀程序。」"
    }
  },
  "**Emergency Elevator now functional.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "非常用エレベーター、動作を確認",
      "CN": "紧急电梯现已可用。",
      "KR": "**비상 계단 현재 사용 가능.**",
      "TW": "緊急電梯恢復正常運作。」"
    }
  },
  "**Call the elevator!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーターを呼び出せ！",
      "CN": "呼叫电梯！",
      "KR": "**사다리 호출하기!**",
      "TW": "呼叫電梯！」"
    }
  },
  "**Elevator arrives in 25 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーター到着まで25秒",
      "CN": "电梯将在25秒后到达。",
      "KR": "**사다리 25초 후에 도착합니다.**",
      "TW": "電梯將在25秒後抵達。」"
    }
  },
  "**Elevator leaves in 3 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーター出発まで3秒",
      "CN": "电梯将在3秒后离开。",
      "KR": "**사들이 3초 후에 떠납니다.**",
      "TW": "電梯將於3秒後離開。」"
    }
  },
  "**Zombies: Go through the ventilation system and enter the elevator.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビ達：換気口から進んでエレベーターへ侵入",
      "CN": "僵尸正通过通风管道进入电梯。",
      "KR": "**좀비: 환기구를 통과해 엘리베이터에 진입하세요.**",
      "TW": "殭屍：穿過通風系統並進入電梯。"
    }
  },
  "**The runners are trying to get in! Hold them off!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ランナーが襲いかかってくる！阻止せよ！",
      "CN": "逃亡者试图冲入！挡住他们！",
      "KR": "**달리는 자들이 들어오려 합니다! 저들을 막아주세요!**",
      "TW": "倖存者正試圖入侵！阻擋他們！"
    }
  },
  "**Elevator door opens in 10 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーターの扉が開くまで10秒",
      "CN": "电梯门将在10秒后打开！",
      "KR": "엘리베이터문이 10초 후에 열립니다!\"**",
      "TW": "電梯門 10 秒後開啟！"
    }
  },
  "**Initiate the house's lockdown system!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "建物のローカウンドシステムを起動せよ！",
      "CN": "启动房屋封锁系统！",
      "KR": "**가옥의 잠금 시스템을 시작하세요!**",
      "TW": "啟動建築的封鎖系統！"
    }
  },
  "**The bunker will open in 40 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バンカーが開放されるまで40秒",
      "CN": "避难所将在40秒后开启！",
      "KR": "**벙커가 40초 후에 열립니다!**",
      "TW": "避難所 40 秒後開啟！"
    }
  },
  "**Hold off the runners until then.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "その間ランナーを阻止せよ",
      "CN": "在此之前挡住逃亡者。",
      "KR": "그 때까지 달리는 자들을 막아주세요.",
      "TW": "在此之前阻擋倖存者。"
    }
  },
  "**Bunker opens in 5 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バンカーが5秒で開放",
      "CN": "避难所将在5秒后开启。",
      "KR": "**벙커가 5초 후에 열립니다.**",
      "TW": "避難所 5 秒後開啟。"
    }
  },
  "**Bunker is open!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バンカーの扉が開いた！",
      "CN": "避难所已开启！",
      "KR": "**벙커가 열렸습니다!**",
      "TW": "避難所已開啟！"
    }
  },
  "**Bunker is closing in 3 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ベントが3秒後に閉じます。",
      "CN": "掩体即将关闭，剩余3秒。",
      "KR": "** 벙커가 3초 후 닫힙니다.**",
      "TW": "**碉堡將在3秒後關閉。**"
    }
  },
  "- Level 2 -": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "- レベル 2 -",
      "CN": "- 第2关 -",
      "KR": "- 레벨 2 -",
      "TW": "- 第2關 -"
    }
  },
  "**Shop door is malfunctioning!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ショップのドアが故障しています！",
      "CN": "商店门故障！",
      "KR": "** 샵 문이 고장 났습니다!**",
      "TW": "**商店門故障中！**"
    }
  },
  "**The elevator shaft is open! Slide down on the wires.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーターシャフトが空いています！ケーブルに沿ってスライドしてください。",
      "CN": "电梯井已打开！沿钢索滑下。",
      "KR": "** 엘리베이터 샤프트가 열려 있습니다! 선로를 따라 미끄러지세요.**",
      "TW": "**電梯井敞開！沿鋼索滑降。**"
    }
  },
  "**Garage door will open in 40 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ガレージのドアは40秒後に開きます。",
      "CN": "车库门将在40秒后打开。",
      "KR": "** 차고 문이 40초 후 열립니다.**",
      "TW": "**車庫門將在40秒後開啟。**"
    }
  },
  "**Garage door is open!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ガレージのドアが開いています！",
      "CN": "车库门已打开！",
      "KR": "** 차고문이 열렸습니다!**",
      "TW": "**車庫門已開啟！**"
    }
  },
  "**Get into the tank to survive the meltdown!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "メルトダウンから生き残るため、戦車に乗り込みましょう！",
      "CN": "进入坦克以在反应堆熔毁中存活！",
      "KR": "** 융해 상태에서 생존하려면 탱크에 타세요!**",
      "TW": "**進入坦克以在熔毀中存活！**"
    }
  },
  "- Level 3 -": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "- レベル 3 -",
      "CN": "- 第3关 -",
      "KR": "- 레벨 3 -",
      "TW": "- 第3關 -"
    }
  },
  "**Secret exit closed!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**秘密の出口は閉ざされている！**",
      "CN": "**秘密出口已关闭！**",
      "KR": "**비밀 출구 닫힘!**",
      "TW": "秘密出口已關閉！"
    }
  }
}
