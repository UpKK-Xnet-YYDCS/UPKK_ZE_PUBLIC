{
  "- Level 1 -": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "- レベル 1 -",
      "CN": "- 关卡 1 -",
      "KR": "- 레벨 1 -",
      "TW": "- 第一關 -"
    }
  },
  "**Grab a Bizon from the crate!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**コンテナからピゾンを取り出せ**",
      "CN": "**从箱子里拿走一只Bizon！**",
      "KR": "**상자에서 비손을 꺼내세요!**",
      "TW": "**從貨箱中取用波波衝鋒槍！**"
    }
  },
  "**Split up and meet at the gun shop!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ばらばらに分かれて、銃店に集合！**",
      "CN": "**分开行动，在枪店集合！**",
      "KR": "**반으로 나누어 무기고 앞에서 만나요!**",
      "TW": "**分頭行動，到槍械店集合！**"
    }
  },
  "**TIP: Look for arrows to help you find your way.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ヒント：矢印を探して道順を確認しよう。**",
      "CN": "**提示：寻找箭头以帮助你找到方向。**",
      "KR": "**팁: 방향을 잡을 수 있도록 화살표를 찾아보세요.**",
      "TW": "**提示：請留意箭頭標記，這能幫助您找到正確路線。**"
    }
  },
  "**TIP: Find the blue napalm grenades.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ヒント：青いナパーム手榴弾を見つけよう。**",
      "CN": "**提示：寻找蓝色的凝固汽油弹。**",
      "KR": "**팁: 파란 네이팜 폭탄을 찾아주세요.**",
      "TW": "**提示：請尋找藍色凝固汽油彈。**"
    }
  },
  "**Factory door opening in 3 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**工場のドアが3秒後に開きます。**",
      "CN": "**工厂大门将在3秒后开启。**",
      "KR": "**공장 문 3초 후 개방.**",
      "TW": "廠房大門 3 秒後開啟。"
    }
  },
  "**2**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "**1**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "**Hit the button to close the gate!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ボタンを押してゲートを閉めよ！**",
      "CN": "**按下按钮以关闭闸门！**",
      "KR": "**버튼을 눌러 게이트를 닫으세요!**",
      "TW": "**按下按鈕關閉柵門！**"
    }
  },
  "**Hold off the runners while the gate closes!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ゲートが閉じる間にランナーを食い止めておけ！**",
      "CN": "**在闸门关闭时抵御跑尸的袭击！**",
      "KR": "**게이트가 닫히는 동안 추격자들과 교전하세요!**",
      "TW": "**在柵門關閉時抵擋殭屍的攻擊！**"
    }
  },
  "**The gun shop is open!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "武器店が開店しました！",
      "CN": "武器店营业中！",
      "KR": "** 총기 가게가 문을 엽니다!**",
      "TW": "槍店已開放！"
    }
  },
  "**Hold off the runners from the balcony or the window. Don't get edged!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バルコニーや窓からランナーを押し留めろ。背後をつくな！",
      "CN": "从阳台或窗户阻击僵尸，别被近身！",
      "KR": "** 발코니나 창문에서 러너들을 저지하십시오. 조종당하지 마세요!**",
      "TW": "從陽台或窗戶防禦喪屍，別被近身！"
    }
  },
  "**Shop is closed!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "店は営業終了です！",
      "CN": "店铺已关门！",
      "KR": "** 가게가 닫습니다!**",
      "TW": "商店已關閉！"
    }
  },
  "**Secret exit open!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "隠し出口開放！",
      "CN": "秘密出口已开启！",
      "KR": "** 비밀 출구 열림!**",
      "TW": "秘密出口已開啟！"
    }
  },
  "**Zombies: Line up at the garage door.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビ：ガレージの扉の前に集合。",
      "CN": "僵尸：在车库门口集结。",
      "KR": "** 좀비: 차고 문 앞에 일렬로 줄서기.**",
      "TW": "喪屍：在車庫門排好隊。"
    }
  },
  "**Humans: Get ready to run through the other door!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "人間：他の扉から逃げ出す準備をしろ！",
      "CN": "人类：准备好从另一扇门冲出！",
      "KR": "** 인간: 다른 문을 통해 뛰쳐나갈 준비 하세요!**",
      "TW": "人類：準備從另一道門衝出去！"
    }
  },
  "**Garage door opening in 5 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ガレージの扉が5秒後に開きます！",
      "CN": "车库门将在5秒后打开！",
      "KR": "** 차고 문 5초 후 개방!**",
      "TW": "車庫門將在5秒後開啟！"
    }
  },
  "**4**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "**3**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  "**RUN!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "走れ！",
      "CN": "快跑！",
      "KR": "** 도주!**",
      "TW": "快跑！"
    }
  },
  "**Hit the filter button!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "フィルターボタンを押せ！",
      "CN": "**点击过滤器按钮！**",
      "KR": "**필터 버튼을 누르세요!**",
      "TW": "**點擊過濾器按鈕！**"
    }
  },
  "**Get in the filter!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "フィルターの中に入れ！",
      "CN": "**进入过滤器中！**",
      "KR": "**필터 안으로 들어오세요!**",
      "TW": "進入過濾器中！"
    }
  },
  "**Blow up the stairs to delay the runners!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "階段を爆破して追跡者を遅らせろ！",
      "CN": "**炸毁楼梯以延缓追赶者！**",
      "KR": "**계단을 폭파해 추격자들을 지연시키세요!**",
      "TW": "**炸毀階梯以延緩追兵！**"
    }
  },
  "**Humans: Initiate the self-destruct sequence.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "人間：自己破壊プログラムを開始せよ。",
      "CN": "**人类：启动自毁程序。**",
      "KR": "인간: 자기파괴 시퀀스를 시작하세요.**",
      "TW": "人類：啟動自毀序列。"
    }
  },
  "**Emergency Elevator now functional.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "緊急エレベーター、稼働開始。",
      "CN": "**紧急电梯现已恢复运行。**",
      "KR": "**비상용 엘리베이터 작동 중.**",
      "TW": "**緊急電梯現已修復。**"
    }
  },
  "**Call the elevator!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーターを呼べ！",
      "CN": "**呼叫电梯！**",
      "KR": "**엘리베이터를 호출하세요!**",
      "TW": "**呼叫電梯！**"
    }
  },
  "**Elevator arrives in 25 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーター到着まで25秒。",
      "CN": "**电梯将在25秒后到达。**",
      "KR": "**엘리베이터 도착까지 25초 남았습니다.**",
      "TW": "**電梯將在 25 秒後到達。**"
    }
  },
  "**Elevator leaves in 3 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーター出発まで3秒。",
      "CN": "**电梯将在3秒后离开。**",
      "KR": "**엘리베이터 출발까지 3초 남았습니다.**",
      "TW": "**電梯將在 3 秒後離開。**"
    }
  },
  "**Zombies: Go through the ventilation system and enter the elevator.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビ：換気システムを通ってエレベーターに入れ。",
      "CN": "僵尸：通过通风系统进入电梯。",
      "KR": "** 좀비: 환기 시스템을 통해 승강기로 진입하세요.**",
      "TW": "殭屍：穿過通風系統進入電梯。"
    }
  },
  "**The runners are trying to get in! Hold them off!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ランナーが入ってくる！彼らを止めておけ！",
      "CN": "跑尸者试图闯入！拦住他们！",
      "KR": "** 도망치는 자들이 들어오려 합니다! 저들을 막아주세요!**",
      "TW": "感染者試圖闖入！頂住壓力！"
    }
  },
  "**Elevator door opens in 10 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーターのドアが10秒後に開きます！",
      "CN": "电梯门将在10秒后开启！",
      "KR": "** 승강기 문이 10초 후에 열립니다!**",
      "TW": "電梯門將在10秒後開啟！"
    }
  },
  "**Initiate the house's lockdown system!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "館のローカウンドダウンシステムを起動せよ！",
      "CN": "启动房屋封锁系统！",
      "KR": "** 주택의 봉쇄 시스템을 시작하세요!**",
      "TW": "啟動房屋禁閉系統！"
    }
  },
  "**The bunker will open in 40 seconds!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ベランダが40秒後に開きます！",
      "CN": "掩体将在40秒后开启！",
      "KR": "** 벙커가 40초 후에 열립니다!**",
      "TW": "庇護庫將在40秒後開啟！"
    }
  },
  "**Hold off the runners until then.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "それまでランナーを止めろ。",
      "CN": "在此之前阻挡跑尸者。",
      "KR": "** 그때까지 도망치는 자들을 막아주세요.**",
      "TW": "撐到那時。"
    }
  },
  "**Bunker opens in 5 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ベランダが5秒後に開きます。",
      "CN": "掩体将在5秒后开启。",
      "KR": "** 벙커가 5초 후에 열립니다.**",
      "TW": "庇護庫將在5秒後開啟。"
    }
  },
  "**Bunker is open!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ベランダが開きました！",
      "CN": "掩体已开启！",
      "KR": "** 벙커가 열렸습니다!**",
      "TW": "庇護庫已開啟！"
    }
  },
  "**Bunker is closing in 3 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ベントが閉鎖されます。残り3秒。**",
      "CN": "掩体将在3秒后关闭。",
      "KR": "**벙커가 3초 안에 닫힙니다.**",
      "TW": "封閉式掩體將在3秒後關閉。"
    }
  },
  "- Level 2 -": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "- レベル 2 -",
      "CN": "- 第2关 -",
      "KR": "- 레벨 2 -",
      "TW": "- 第2關 -"
    }
  },
  "**Shop door is malfunctioning!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ショップのドアが故障中！**",
      "CN": "商店门出现故障！",
      "KR": "**상점 문이 고장 났습니다!**",
      "TW": "商店門故障！"
    }
  },
  "**The elevator shaft is open! Slide down on the wires.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**エレベーターシャフトが開いています！ワイヤーを滑り降りてください。**",
      "CN": "电梯井是开放的！沿钢缆滑下。",
      "KR": "**엘리베이터 샤프트가 열려 있습니다! 와이어를 타고 슬라이드하세요.**",
      "TW": "電梯井已打開！沿著繩索滑下。"
    }
  },
  "**Garage door will open in 40 seconds.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ガレージのドアが40秒後に開きます。**",
      "CN": "车库门将在40秒后开启。",
      "KR": "**차고문이 40초 안에 열립니다.**",
      "TW": "車庫門將在40秒後開啟。"
    }
  },
  "**Garage door is open!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ガレージのドアが開きました！**",
      "CN": "车库门已打开！",
      "KR": "**차고문이 열렸습니다!**",
      "TW": "車庫門已打開！"
    }
  },
  "**Get into the tank to survive the meltdown!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "meltdown を生き残るため、戦車に乗ってください！」**",
      "CN": "进入坦克以在熔毁中生存！",
      "KR": "**멜tdown을 생존하려면 탱크에 탑승하세요!**",
      "TW": "進入坦克以在熔毀中存活！"
    }
  },
  "- Level 3 -": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "- レベル 3 -",
      "CN": "- 第3关 -",
      "KR": "- 레벨 3 -",
      "TW": "- 第3關 -"
    }
  },
  "**Secret exit closed!**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**秘密の出口は閉鎖されている！**",
      "CN": "秘密出口已关闭！",
      "KR": "비밀 출구 봉쇄!",
      "TW": "秘密出口已關閉！"
    }
  },
  "**Zombies: Run to the red light.**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビ：赤信号へ走れ。",
      "CN": "僵尸：奔向红灯。",
      "KR": "좀비: 빨간 불로 뛰어들어.",
      "TW": "殭屍：奔向紅光。"
    }
  },
  "**Unverified Lifeform Detected! Enabling Shields.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "未確認の生命体を検出！シールド有効化。",
      "CN": "检测到未确认生命体！盾牌已启用。",
      "KR": "미확인 생명체 감지! 방패 활성화.",
      "TW": "偵測到未經確認的生命體！啟動護盾。"
    }
  }
}
