{
  "** [HARD MODE] **": {
    "translation": "** [困难模式] **",
    "MultiLang": {
      "US": "",
      "JP": "** [ハードモード] **",
      "CN": "** [硬核模式] **",
      "KR": "** [하드 모드] **",
      "TW": "** [困難模式] **"
    }
  },
  "** MAP BY SLAYERDRAGON & NOCTALI **": {
    "translation": "** 地图作者：SLAYERDRAGON & NOCTALI 翻译：Asteri3m，Ayanami♪ **",
    "MultiLang": {
      "US": "",
      "JP": "** マップ制作：SLAYERDRAGON & NOCTALI **",
      "CN": "** 地图制作：SLAYERDRAGON & NOCTALI **",
      "KR": "** 지도 제작: 슬레이어드래곤 & 녹탈리 **",
      "TW": "** 地圖由 SLAYERDRAGON 和 NOCTALI 製作 **"
    }
  },
  "** Be aware of fake donations - groups and profiles ! **": {
    "translation": "** 警惕假的捐助渠道 - Steam群组和个人资料！**",
    "MultiLang": {
      "US": "",
      "JP": "** 偽の寄付や、偽のグループ・プロフィールに注意してください！ **",
      "CN": "** 请注意假捐款——假冒的团队和个人资料！**",
      "KR": "** 가짜 기부 그룹 및 프로필에 유의하십시오! **",
      "TW": "** 請注意假冒捐款——無論是群組還是個人檔案！ **"
    }
  },
  "** A player has learned Earth magick. **": {
    "translation": "** 一名玩家捡起了大地权杖。**",
    "MultiLang": {
      "US": "",
      "JP": "** プレイヤーが大地の魔法を習得しました。 **",
      "CN": "** 一名玩家学会了大地魔法。**",
      "KR": "** 한 플레이어가 땅의 마법을 습득했습니다. **",
      "TW": "** 一名玩家已學會大地魔法。 **"
    }
  },
  "** Defend until the guards open the airport. **": {
    "translation": "** 防守，直到守卫开放机场。**",
    "MultiLang": {
      "US": "",
      "JP": "** 警備員が空港を開けるまで防衛してください。 **",
      "CN": "** 坚守防线，直到守卫打开机场大门。**",
      "KR": "** 경비원이 공항 문을 열 때까지 방어하십시오. **",
      "TW": "** 守衛直到守衛開啟機場為止。 **"
    }
  },
  "** Airport opened. **": {
    "translation": "** 机场已开放。**",
    "MultiLang": {
      "US": "",
      "JP": "** 空港が開きました。 **",
      "CN": "** 机场已开放。**",
      "KR": "** 공항이 개방되었습니다. **",
      "TW": "** 機場已開啟。 **"
    }
  },
  "** Defend 30 seconds until the guards open the hallway. **": {
    "translation": "** 防守30秒，直到守卫开放道路。**",
    "MultiLang": {
      "US": "",
      "JP": "** 警備員が廊下を開けるまで30秒間防衛してください。 **",
      "CN": "** 坚守30秒，直到守卫打开走廊。**",
      "KR": "** 경비율이 복도를 열 때까지 30초 동안 방어하십시오. **",
      "TW": "** 在守衛開啟走廊前堅持 30 秒。 **"
    }
  },
  "** A player has learned Water magick. **": {
    "translation": "** 一名玩家捡起了水花权杖。**",
    "MultiLang": {
      "US": "",
      "JP": "** プレイヤーが水の魔法を習得しました。 **",
      "CN": "** 一名玩家学会了水之魔法。**",
      "KR": "** 한 플레이어가 물의 마법을 습득했습니다. **",
      "TW": "** 一名玩家已學會水魔法。 **"
    }
  },
  "** 5 Seconds left **": {
    "translation": "** 还剩5秒 **",
    "MultiLang": {
      "US": "",
      "JP": "残り5秒",
      "CN": "**剩余 5 秒**",
      "KR": "남은 시간 5초",
      "TW": "**剩餘 5 秒**"
    }
  },
  "** Defend here so the guards will open the gates to the city ! **": {
    "translation": "** 20秒，防守这里，直到守卫打开通往城市的门！ **",
    "MultiLang": {
      "US": "",
      "JP": "ここを守れ！守衛が城門を開ける！",
      "CN": "**在此防守，迫使守卫打开城门！**",
      "KR": "지켜서 경비병들이 성문으로 들어오게 하세요!",
      "TW": "**在此防守，讓衛兵開啟城門！**"
    }
  },
  "** A player has learned Wind magick. **": {
    "translation": "** 一名玩家捡起了飓风权杖。**",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが風の魔法を習得しました。",
      "CN": "**一名玩家习得了风魔法。**",
      "KR": "플레이어가 바람 마법을 습득했습니다.",
      "TW": "**一名玩家習得了風系魔法。**"
    }
  },
  "** A player has learned Heal magick. **": {
    "translation": "** 一名玩家捡起了治疗权杖。**",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが回復の魔法を習得しました。",
      "CN": "**一名玩家习得了治愈魔法。**",
      "KR": "플레이어가 치료 마법을 습득했습니다.",
      "TW": "**一名玩家習得了治療魔法。**"
    }
  },
  "** Cover here till the boxes explode **": {
    "translation": "** 在这里防守25秒直到箱子被爆破 **",
    "MultiLang": {
      "US": "",
      "JP": "箱が爆発するまでここを守り抜け！",
      "CN": "**在此掩护，直到箱子爆炸**",
      "KR": "상자가 폭발할 때까지 여기서 커버하세요",
      "TW": "**在這裡掩護直到箱子爆炸**"
    }
  },
  "** A player has learned Electro magick. **": {
    "translation": "** 一名玩家捡起了雷电权杖。**",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが雷の魔法を習得しました。",
