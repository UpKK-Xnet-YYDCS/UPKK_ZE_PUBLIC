{
  "***Tram leaving in 10secs.***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "三日月、10秒後に発車します。",
      "CN": "***电车将在10秒后发车。***",
      "KR": "***트램, 10초 후 출발.***",
      "TW": "***十秒後有列車離站。***"
    }
  },
  "***Both boats leaving shortly..***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "両船 shortlyに出港します。",
      "CN": "***两艘船只即将出发。***",
      "KR": "***보트들 곧 출발합니다...***",
      "TW": "***兩艘船即將離航……***"
    }
  },
  "***They look very strange..***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "非常に奇妙だ。。.",
      "CN": "***它们看起来非常奇怪。***",
      "KR": "***꽤 이상해 보이는군...***",
      "TW": "***它們看起來很奇怪……***"
    }
  },
  "***Boat 3 leaving in 10secs.***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ボート3、10秒後に発車します。",
      "CN": "3号船只将在10秒后发车。***",
      "KR": "***보트 3호, 10초 후 출발.***",
      "TW": "***三號船十秒後離航。***"
    }
  },
  "***First shortcuts opening in 15secs.***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "最初のショートカット、15秒後に開門します。",
      "CN": "***捷径即将在15秒后开启。***",
      "KR": "***첫 번째 지름길, 15초 후 개방.***",
      "TW": "***五秒後開啟捷径。***"
    }
  },
  "***Ice Wall breaking in 10secs.***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "氷の壁、10秒後に崩壊します。",
      "CN": "冰墙将在10秒后碎裂。***",
      "KR": "***얼음 벽, 10초 후 붕괴.***",
      "TW": "***十秒後冰牆崩裂。***"
    }
  },
  "***Final Boat leaving in 75secs.***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "最終船、75秒後に発船します。",
      "CN": "最后一艘船将于75秒后离港。***",
      "KR": "***최종 보트, 75초 후 출발.***",
      "TW": "***七十五秒後有最後一艘船離航。***"
    }
  },
  "***WashTub leaving in 65secs.***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "洗濯槽、65秒後に出港します。",
      "CN": "***浴缸号将于65秒后离港。***",
      "KR": "***워시터브 호, 65초 후 출발.***",
      "TW": "***六十五秒後洗衣盆號離航。***"
    }
  },
  "***Second shortcuts opening in 15secs.***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "***2番目のショートカット、15秒後に開く。***",
      "CN": "***15秒后开启辅助功能快捷键。***",
      "KR": "***2초 바로가기 15초 후 개방.***",
      "TW": "***15秒後開啟快捷方式***"
    }
