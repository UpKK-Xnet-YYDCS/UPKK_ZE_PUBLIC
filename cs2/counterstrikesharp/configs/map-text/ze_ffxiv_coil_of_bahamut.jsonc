    }
  },
  ">>Bahamut<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>バハムート<<",
      "CN": ">> Bahamut <<",
      "KR": ">>바하무트<<",
      "TW": "<< Bahamut >>"
    }
  },
  "Stage -> Bahamut": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ステージ → バハムート",
      "CN": "关卡 -> Bahamut",
      "KR": ".stage -> 바하무트",
      "TW": "階段 -> Bahamut"
    }
  },
  ">>Bahamut is going to wake up in 10 seconds<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>バハムートが10秒後に覚醒します<<",
      "CN": ">>Bahamut将在10秒后苏醒<<",
      "KR": ">>바하무트가 10초 후에 깨어납니다.<<",
      "TW": ">>Bahamut將在10秒後甦醒<<"
    }
  },
  ">>From red moon I descend, a hail of stars to bring! <<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>紅色の月より降臨、星雨を撒き散らす<<",
      "CN": ">>自红月之中降临，携繁星之雨！<<",
      "KR": ">>붉은 달에서 내리니, 별의 비를 선사하리라! <<",
      "TW": ">>我從紅月降臨，帶來星辰暴雨！<<"
    }
  },
  ">> Gleaming steel, take fire and descend! <<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>輝く鋼鉄、火を帯びて降下せよ<<",
      "CN": ">>璀璨利刃，点火降临！<<",
      "KR": ">> 빛나는 강철은 불꽃을 안고 내려오라! <<",
      "TW": ">>閃亮鋼甲，點火降世！<<"
    }
  },
  ">> From red moon I draw steel, in my descent to bare! <<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>紅色の月より鋼を引き抜き、降下の際に裸にする<<",
      "CN": ">>自红月抽剑而出，于降临中展露锋芒！<<",
      "KR": ">> 붉은 달에서 강철을 뽑아, 내리쬐며 드러내리라! <<",
      "TW": ">>我從紅月抽取鋼甲，為降臨而顯露！<<"
    }
  },
  ">>Bahamut is going to destroy us with trillions of nuclear explosions<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>バハムートは数兆の核爆発で我々を破壊しようとする<<",
      "CN": ">>Bahamut将以数万亿核爆摧毁我们<<",
      "KR": ">>바하무트는 수조기의 핵폭발로 우리를 파멸시킬 것이다<<",
      "TW": ">>Bahamut將以數兆核爆消滅我們<<"
    }
  },
  ">>0<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "",
      "CN": "",
      "KR": "",
      "TW": ""
    }
  },
  ">>The phoenix's shrill cry curs through the pall of desperation!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>絶望の闇を穿つ不死鳥の鋭い鳴き声<<",
      "CN": ">>凤凰的尖锐啼鸣穿透绝望的阴霾！<<",
      "KR": ">>황망한 어둠을 가르고 페닉스의 날카로운 울음소리!<<",
      "TW": ">>鳳凰尖銳的啼叫穿透絕望的濃霧！<<"
    }
  },
  ">>AFK 12s<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>AFK 12秒<<>",
      "CN": ">>AFK 12秒<<",
      "KR": ">>AFK 12초<<",
      "TW": ">>AFK 12秒<<"
    }
  },
  ">>Zenos : Yout won't stay alive from here.<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>ゼノス：ここから先では、お前ら生き残れないよ。<<",
      "CN": ">>芝诺斯：你活不过去。<<",
      "KR": ">>제노스: 너는 여기서 살아남지 못 할 것이다.<<",
      "TW": ">>佐戴斯：你到這裡為止活不下去了。<<"
    }
  },
  ">>A zombie got some power from Ramuh<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>ゾンビがラムウからの力を得た<<",
      "CN": ">>一名僵尸获得了拉姆的力量。<<",
      "KR": ">>좀비가 라무의 힘을 얻었다.<<",
      "TW": ">>喪屍獲得了拉姆的力量。<<"
    }
  },
  ">>A zombie got some power from Titan<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>ゾンビがタイタンからの力を得た<<",
      "CN": ">>一名僵尸获得了泰坦的力量。<<",
      "KR": ">>좀비가 타이탄의 힘을 얻었다.<<",
      "TW": ">>喪屍獲得了泰坦的力量。<<"
    }
  },
  ">>Truth<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>真実<<",
      "CN": ">>真理 <<",
      "KR": ">>진리<<",
      "TW": ">>真相<<"
    }
  },
  ">> Repelling Cannon <<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">> 反動推進砲 <<",
      "CN": ">>反击炮 <<",
      "KR": ">> 반발 포 <<",
      "TW": ">>驅散砲 <<"
    }
  },
  ">>Aggression<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>攻勢<<",
      "CN": ">>攻击性<<",
      "KR": ">>공격성<<",
      "TW": ">>侵略性<<"
    }
  },
  ">>From on high I descend, a hail of stars to bring!<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>高くより我 descending、星雨をもたらさん！<<",
      "CN": ">>自高处降临，带来星辰之雨！<<",
      "KR": ">>높은 곳에서 내리니, 별들의 우레를 가져오리라!<<",
      "TW": ">>我由高空降臨，為世人降下星辰之雨！<<"
    }
  },
  ">> From red moon I descend, upon burning earth to tread! <<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>赤き月より我 descending、焦土の上を踏まん！ <<",
      "CN": ">> 自红月降临，踏足烈焰大地！ <<",
      "KR": ">>붉은 달에서 내리니, 불타는 땅을 밟으리라! <<",
      "TW": ">>我從紅月降臨，踏足被焚燒的大地！ <<"
    }
  },
  ">> Gleaming steel, plunge and take fiery edge! <<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">> 輝く鋼鉄、潜り込み焔の刃を取り取れ！ <<",
      "CN": "闪亮的钢铁，猛击并燃起灼热锋芒！",
      "KR": "빛나는 강철, 돌진하여 뜨거운 날카로움을 가져라!",
      "TW": ">> 鑄就鋒鋼，潛入烈焰！ <<"
    }
  }
}
