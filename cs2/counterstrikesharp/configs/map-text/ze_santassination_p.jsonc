  },
  "YOU AND EVERYONE YOU KNOW WILL DIE ONE DAY": {
    "translation": "你和你认识的所有人终有一天会离世",
    "MultiLang": {
      "US": "",
      "JP": "あなたもあなたの知り合いもいつかは死ぬんだ",
      "CN": "你和你认识的所有人总有一天会死",
      "KR": "당신과 당신이 아는 모든 사람은 언젠가 죽습니다",
      "TW": "你和你認識的所有人終有一死"
    }
  },
  "^That was the stupidest thing i've ever heard as a map": {
    "translation": "^这是我听过的最愚蠢的地图",
    "MultiLang": {
      "US": "",
      "JP": "^それは今まで聞いた中で最も馬鹿げたマップだよ",
      "CN": "^那是我听过的最愚蠢的地图设计",
      "KR": "^그건 제가 들어본 mappa 중 가장 멍청한 것이었습니다",
      "TW": "^這是做地圖以來我聽過最蠢的主意"
    }
  },
  "^This fella is a silly-willy that everyone should point and laugh at!": {
    "translation": "^这个家伙真是个傻瓜，大家都应该指着他笑！",
    "MultiLang": {
      "US": "",
      "JP": "^こいつはみんなが指差して笑うべきおバカさんだ！",
      "CN": "^这家伙是个让人想指着他嘲笑的大傻瓜！",
      "KR": "^이 녀석은 모두 손가락질하고 웃어야 할 바보입니다!",
      "TW": "^這傢伙是個傻瓜，每個人都應該指著他大笑！"
    }
  },
  "^Wtf are you even talking about?": {
    "translation": "^你到底在说什么？",
