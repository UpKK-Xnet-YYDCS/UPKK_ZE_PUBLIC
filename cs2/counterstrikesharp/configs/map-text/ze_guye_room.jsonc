{
  "v0.1_2": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "v0.1_2",
      "CN": "v0.1_2",
      "KR": "v0.1_2",
      "TW": "v0.1_2"
    }
  },
  "防守30秒": {
    "translation": "",
    "MultiLang": {
      "US": "Hold for 30 seconds",
      "JP": "30秒間防衛せよ",
      "CN": "",
      "KR": "30초 동안 방어.",
      "TW": "防守30秒"
    }
  },
  "撤退,想办法到床上去。": {
    "translation": "",
    "MultiLang": {
      "US": "Fall back, get to the bed.",
      "JP": "撤退だ。ベッドへ逃げろ。",
      "CN": "",
      "KR": "후퇴, 침대로 이동하는 방법을 생각해봐.",
      "TW": "撤退，設法前往床鋪。"
    }
  },
  "路被该死的乐事薯片挡住了，防守30秒。": {
    "translation": "",
    "MultiLang": {
      "US": "The path is blocked by damn Lay's chips. Hold for 30 seconds.",
      "JP": "ルートがそのやっかいなチップスで塞がれている。30秒間防衛せよ。",
      "CN": "",
      "KR": "길이 저 개팔린 레전드리칩스로 막혔어. 30초 동안 방어.",
      "TW": "路被該死的樂事洋芋片擋住，防守30秒。"
    }
  },
  "撤退,我们能继续前进了。": {
    "translation": "",
    "MultiLang": {
      "US": "Fall back, we can proceed.",
      "JP": "撤退だ。移動継続可能。",
      "CN": "",
      "KR": "후퇴, 계속 진군 가능.",
      "TW": "撤退，我們能繼續前進了。"
    }
  },
  "屋主人还玩三角洲？防守30秒。": {
    "translation": "",
    "MultiLang": {
      "US": "The homeowner still plays Delta? Hold for 30 seconds.",
      "JP": "家の人、デスストロークやってんのか？30秒間防衛せよ。",
      "CN": "",
      "KR": "집주인은 드타까지 한다고? 30초 동안 방어.",
      "TW": "屋主還玩三角洲？防守30秒。"
    }
  },
  "防守40秒": {
    "translation": "",
    "MultiLang": {
      "US": "Hold for 40 seconds",
      "JP": "40秒間防衛せよ",
      "CN": "",
      "KR": "40초 동안 방어.",
      "TW": "防守40秒"
    }
  },
  "防守30秒,我们要跳下去。": {
    "translation": "",
    "MultiLang": {
      "US": "Hold for 30 seconds, then jump.",
      "JP": "30秒間防衛しろ。飛び降りるぞ。",
      "CN": "",
      "KR": "30초 동안 방어. 추락했어.",
      "TW": "防守30秒，我們要跳下去。"
    }
  },
  "快上平台！": {
    "translation": "",
    "MultiLang": {
      "US": "Get to the platform!",
      "JP": "プラットフォームに乗れ！",
      "CN": "",
      "KR": "빨리 플랫폼으로 가세요!",
      "TW": "快上平台！"
    }
  },
  "似乎有什么事情要发生。": {
    "translation": "",
    "MultiLang": {
      "US": "It seems like something is about to happen.",
      "JP": "何か起こりそうだ。",
      "CN": "",
      "KR": "무슨 일이 일어날 것 같습니다.",
      "TW": "似乎有什麼事情要發生。"
    }
  },
  "map by 佐贺": {
    "translation": "",
    "MultiLang": {
      "US": "Map by Sage",
      "JP": "マップ制作：佐賀",
      "CN": "",
      "KR": "지도 제작: 자하",
      "TW": "地圖由佐賀製作"
    }
  },
  "ze_guye_room 试玩版，不代表最终品质。": {
    "translation": "",
    "MultiLang": {
      "US": "Demo for ze_guye_room; this does not represent final quality.",
      "JP": "ze_guye_room 試作版。最終的な品質を保証するものではありません。",
      "CN": "",
      "KR": "ze_guye_room 트레일 빌드. 최종 품질을 대표하지 않습니다.",
      "TW": "ze_guye_room 試玩版，不代表最終品質。"
    }
  },
  "第一关": {
    "translation": "",
    "MultiLang": {
      "US": "Stage 1",
      "JP": "第一关",
      "CN": "",
      "KR": "1단계",
      "TW": "第一關"
    }
  },
  "第二关": {
    "translation": "",
    "MultiLang": {
      "US": "Stage 2",
      "JP": "第二关",
      "CN": "",
      "KR": "2단계",
      "TW": "第二關"
    }
  },
  "撤退": {
    "translation": "",
    "MultiLang": {
      "US": "Retreat",
      "JP": "撤退",
      "CN": "",
      "KR": "후퇴",
      "TW": "撤退"
    }
  },
  "防守30秒,等待可乐消失": {
    "translation": "",
    "MultiLang": {
      "US": "Hold out for 30 seconds until Cola disappears.",
      "JP": "30秒間防衛し、コーラの消失を待つ",
      "CN": "",
      "KR": "30초 동안 방어하고, 콜라가 사라질 때까지 기다리세요.",
      "TW": "防守30秒，等待可樂消失"
    }
  },
  "撤退,这些彩虹门到底是什么？": {
    "translation": "",
    "MultiLang": {
      "US": "Retreat. What exactly are these rainbow doors?",
      "JP": "撤退！これらの虹のポータルは一体何だ？",
      "CN": "",
      "KR": "후퇴. 이 무지개 문은 대체 뭐야?",
      "TW": "撤退！這些彩虹門到底是什麼？"
    }
  },
  "防守25秒直到怡宝瓶子消失": {
    "translation": "",
    "MultiLang": {
      "US": "Survive for 25 seconds until the Yi Bao bottle disappears.",
      "JP": "25秒間防衛して、イージャーのボトルが消えるのを待て",
      "CN": "",
      "KR": "이바오 병이 사라질 때까지 25초간 방어",
      "TW": "防守25秒，直到怡寶瓶子消失"
    }
  },
  "撤退。只是...这是什么地方？": {
    "translation": "",
    "MultiLang": {
      "US": "Retreat. But... what is this place?",
      "JP": "撤退。ただ……ここはどこだ？",
      "CN": "",
      "KR": "후퇴. 혹시... 여기는 어디지?",
      "TW": "撤退。只是……這是什麼地方？"
    }
  },
  "防守30秒，看起来小黄鸭会帮我们": {
    "translation": "",
    "MultiLang": {
      "US": "Survive for 30 seconds; it looks like the little yellow duck will help us.",
      "JP": "30秒間防衛しろ。黄色いアヒルが助けてくれるはずだ",
      "CN": "",
      "KR": "30초간 방어, 노란 오리 친구가 도와줄 것 같아",
      "TW": "防守30秒，看起來小黃鴨會幫助我們"
    }
  },
  "小黄鸭:上来吧，我带你们走": {
    "translation": "",
    "MultiLang": {
      "US": "Little Yellow Duck: Get on board. I'll take you away.",
      "JP": "黄色いアヒル：乗ってこい、案内する",
      "CN": "",
      "KR": "노란 오리: 타, 내가 데려다줄게",
      "TW": "小黃鴨：快上，我帶你們走"
    }
  },
  "那是什么？为什么电竞房里的飞船会在这？": {
    "translation": "",
    "MultiLang": {
      "US": "What is that? Why are ships in the esports room appearing here?",
      "JP": "あれは何か？なぜゲーミングハウスの宇宙船がここにあるんだ？",
      "CN": "",
      "KR": "저건 뭐지? 왜 Esports 방선의 우주선이 여기에 있는 거야?",
      "TW": "那是什麼？為什麼電競房裡的飛船會在這裡？"
    }
  },
  "为什么水面上会有switch？这个房间是怎么回事？": {
    "translation": "",
    "MultiLang": {
      "US": "Why is there a switch on the water? What's going on in this room?",
      "JP": "水面の上にSwitchが！？この部屋はどういうわけだ？",
      "CN": "",
      "KR": "수면에 스위치가? 이 방은 대체 무슨 일인가?",
      "TW": "為什麼水面上會有Switch？這個房間到底是怎麼回事？"
    }
  },
  "防守40秒，彩虹门会把我们送到哪？": {
    "translation": "",
    "MultiLang": {
      "US": "Survive for 40 seconds. Where will the rainbow portal take us?",
      "JP": "40秒間防衛しろ。虹のポータルは私たちをどこへ連れて行く？",
      "CN": "",
      "KR": "40초간 방어, 무지개 문이 우리를 어디로 데려갈까?",
      "TW": "防守40秒，彩虹門會把我們送到哪裡？"
    }
  },
  "轰鸣声:注意躲避周围的飞船": {
    "translation": "",
    "MultiLang": {
      "US": "Roaring Sound: Beware of the surrounding ships.",
      "JP": "轟音：周囲の宇宙船を避けてください",
      "CN": "",
      "KR": "굉음: 주변의 우주선을 피하세요",
      "TW": "轟鳴聲：注意躲避周圍的飛船"
    }
  },
  "龙车!龙车!龙车!注意!": {
    "translation": "",
    "MultiLang": {
      "US": "Dragon Car! Dragon Car! Dragon Car! Watch out!",
      "JP": "龍車！龍車！龍車！注意！",
      "CN": "",
      "KR": "룡차! 룡차! 룡차! 주의!",
      "TW": "龍車！龍車！龍車！注意！"
    }
  },
  "激光声:远离飞机正前方": {
    "translation": "",
    "MultiLang": {
      "US": "Laser sound: Stay away from directly in front of the plane",
      "JP": "レーザー音：機体の正面から離れてください",
      "CN": "",
      "KR": "레이저 소리: 항공기 정면에서 멀리 피하세요",
      "TW": "雷射聲：遠離飛機正前方"
    }
  },
  "投弹声:注意飞机投下的炸弹": {
    "translation": "",
    "MultiLang": {
      "US": "Bomb drop sound: Beware of bombs dropped by the plane",
      "JP": "爆撃音：機体から投下される爆弾に注意してください",
      "CN": "",
      "KR": "폭탄 투하 소리: 항공기에서 투하된 폭탄에 주의하세요",
      "TW": "投彈聲：注意飛機投下的炸彈"
    }
  },
  "快远离飞机投放的僵尸": {
    "translation": "",
    "MultiLang": {
      "US": "Quickly stay away from zombies dropped by the plane",
      "JP": "機体が投下したゾンキーからすぐに離れてください",
      "CN": "",
      "KR": "항공기가 투하한 좀비에게서 멀리 피하세요",
      "TW": "快遠離飛機投放的殭屍"
    }
  },
  "cialalalala:快去特效里面": {
    "translation": "",
    "MultiLang": {
      "US": "Cialalalala: Go to the special effects area",
      "JP": "シアラララ：エフェクトの中へ急げ",
      "CN": "",
      "KR": "cialalalala: 효과 화면으로 이동하세요",
      "TW": "快去特效裡面"
    }
  },
  "地图状态:试玩版，全流程未完成": {
    "translation": "",
    "MultiLang": {
      "US": "Map status: Trial version, full process not completed",
      "JP": "マップ状態：プレイアブル版、全流程完了していません",
      "CN": "",
      "KR": "지도 상태: 체험판, 전체 코스 미완성",
      "TW": "地圖狀態：試玩版，全流程未完成"
    }
  },
  "第三关": {
    "translation": "",
    "MultiLang": {
      "US": "Level 3",
      "JP": "第3关",
      "CN": "",
      "KR": "3관",
      "TW": "第三關"
    }
  },
  "防守30秒后进入彩虹门": {
    "translation": "",
    "MultiLang": {
      "US": "After defending for 30 seconds, enter the Rainbow Gate",
      "JP": "30秒の防衛終了後、レインボーゲートへ",
      "CN": "",
      "KR": "30초 방어 후 레인보우 게이트 진입",
      "TW": "防守30秒後進入彩虹門"
    }
  },
  "看起来没有路了,是死局了么？": {
    "translation": "",
    "MultiLang": {
      "US": "Looks like there's no way through. Is this a dead end?",
      "JP": "もう道がないようだ……これで詰んだか？",
      "CN": "",
      "KR": "길이 없어 보이는데, 죽은 길인가?",
      "TW": "看起來沒有路了，是死局了嗎？"
    }
  },
  "死!者!稣!生!": {
    "translation": "",
    "MultiLang": {
      "US": "DEAD! MAN! LIVING!",
      "JP": "死!者!よ、蘇れ!",
      "CN": "",
      "KR": "사!자!예!수!생!",
      "TW": "死!者!稣!生!"
    }
  },
  "防守30秒,这是最后一个守点了": {
    "translation": "",
    "MultiLang": {
      "US": "Defend for 30 seconds. This is the final holdout point.",
      "JP": "防衛30秒。最後の守備ポイントだ",
      "CN": "",
      "KR": "30초 방어, 마지막 점방입니다",
      "TW": "防守30秒，這是最後一個守點"
    }
  },
  "生存关卡": {
    "translation": "",
    "MultiLang": {
      "US": "Survival Stage",
      "JP": "サバイバルモード",
      "CN": "",
      "KR": "서바이벌 맵",
      "TW": "生存關卡"
    }
  },
  "生存180秒": {
    "translation": "",
    "MultiLang": {
      "US": "Survive for 180 seconds",
      "JP": "180秒間生存",
      "CN": "",
      "KR": "180초 서바이벌",
      "TW": "生存180秒"
    }
  },
  "试玩版,不代表最终品质,map by 佐贺": {
    "translation": "",
    "MultiLang": {
      "US": "Demo version. Does not represent final quality. Map by Sagara.",
      "JP": "プレイアブル版。完成品の品質を代表するものではありません。Map by 佐賀",
      "CN": "",
      "KR": "트라이얼 버전, 최종 퀄리티를 반영하지 않음. map by 사가",
      "TW": "試玩版，不代表最終品質，map by 佐賀"
    }
  },
