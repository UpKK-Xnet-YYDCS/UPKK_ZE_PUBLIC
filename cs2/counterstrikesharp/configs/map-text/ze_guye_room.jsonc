      "TW": "第三關"
    }
  },
  "飞行棋开始,请远离棋子,站在棋盘上": {
    "translation": "",
    "MultiLang": {
      "US": "Game of War has begun. Please stay away from the pieces and stand on the board.",
      "JP": "飛行将棋開始、駒を避け、盤に乗ってください",
      "CN": "",
      "KR": "비행기 체스 시작, 말에 주의하고 보드 위에 서 있으세요",
      "TW": "飛行棋開始,請遠離棋子,站在棋盤上"
    }
  },
  "小游戏": {
    "translation": "",
    "MultiLang": {
      "US": "Mini-Game",
      "JP": "ミニゲーム",
      "CN": "",
      "KR": "미니게임",
      "TW": "小遊戲"
    }
  },
  "循环格子": {
    "translation": "",
    "MultiLang": {
      "US": "Looping Tiles",
      "JP": "ループグリッド",
      "CN": "",
      "KR": "반복 격자",
      "TW": "循環格子"
    }
  },
  "你在飞行棋游戏中获胜了,恭喜!现在清理残余的僵尸!": {
    "translation": "",
    "MultiLang": {
      "US": "You won the Game of War! Congratulations! Now clean up the remaining zombies!",
      "JP": "飛行将棋で勝利しました！おめでとうございます。残りゾンビを処理してください！",
      "CN": "",
      "KR": "비행기 체스 게임에서 승리하셨습니다, 축하합니다! 이제 잔여 좀비를 처치하세요!",
      "TW": "你在飛行棋遊戲中獲勝了,恭喜!現在清理殘餘的殭屍!"
    }
  }
}
