  "ze_guye_room 作者:佐贺": {
    "translation": "",
    "MultiLang": {
      "US": "ze_guye_room by Zhege",
      "JP": "作者: 佐賀 ze_guye_room",
      "CN": "",
      "KR": "ze_guye_room 제작자: 사가",
      "TW": "ze_guye_room 作者:佐賀"
    }
  },
  "第3关": {
