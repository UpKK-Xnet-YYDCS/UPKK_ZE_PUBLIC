    }
  },
  "> 20秒后将传送全体人类进入里世界. <": {
    "translation": "",
    "MultiLang": {
      "US": "< All Humans will be teleported into the Underworld in 20 seconds. >",
      "JP": "> 20秒後に人類全員を裏世界へ転送します。 <",
      "CN": "",
      "KR": "> 20초 뒤 전체 인류가 안쪽으로 텔레포트됩니다. <",
      "TW": "> 20秒後將傳送全體人類進入裡世界. <"
    }
  },
  "> 10秒后全体僵尸进入里世界. <": {
    "translation": "",
    "MultiLang": {
      "US": "< All Zombies will enter the Underworld in 10 seconds. >",
      "JP": "> 10秒後にゾンビ全員が裏世界へ移動します。 <",
      "CN": "",
      "KR": "> 10초 뒤 전僵尸이 안쪽으로 들어갑니다. <",
      "TW": "> 10秒後全體殭屍將進入裡世界. <"
    }
  },
