  "-- Teleport in 1s --": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "-- テレポートまで1秒 --",
      "CN": "-- 1秒后传送 --",
      "KR": "-- 1초 후 텔레포트 --",
      "TW": "-- 1秒後傳送 --"
    }
  },
  "-- Hurry! Plug the hole with that apple! --": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "-- 急いで！そのリンゴで穴をふさいで！ --",
      "CN": "-- 快！用那个苹果堵住洞口！ --",
      "KR": "-- 빨리! 그 사과로 구멍을 막아라! --",
      "TW": "-- 快！用那顆蘋果堵住漏洞！--"
    }
  },
  "-- Shhh, it looks like that big guy is sleeping --": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "――静かに、あの大きな奴が寝てるようだ――",
      "CN": "-- 嘘，看起来那个大块头正在睡觉 --",
      "KR": "-- 쉬, 그 큰 놈이 자고 있는 것 같다 --",
      "TW": "-- 噓，看來那個大傢伙正在睡覺 --"
    }
  },
  "-- We better walk over quietly --": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "――ゆっくり近づこう――",
      "CN": "-- 我们最好悄悄走过去 --",
      "KR": "-- 조용히 다가가는 게 좋겠다 --",
      "TW": "-- 我們最好輕聲走过去 --"
    }
  },
  "-- Ooooh, that guy is awake, RUN! --": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "――おい、あの奴が目覚めたぞ！ 逃げるんだ！",
      "CN": "-- 哦，那个人醒了，快跑！ --",
      "KR": "-- 오오, 그 놈이 깨쳤다, 도망쳐! --",
      "TW": "-- 喔，那個人醒來了，快跑！ --"
    }
  },
  "\"检测到服务器无Lua Unlocker插件\"": {
    "translation": "",
    "MultiLang": {
      "US": "No Lua Unlocker plugin detected on the server",
      "JP": "サーバーにLua Unlockerプラグインが検出されませんでした",
      "CN": "",
      "KR": "\"서버에 Lua Unlocker 플러그인이 없습니다\"",
      "TW": "偵測到伺服器沒有 Lua Unlocker 外掛程式"
    }
  },
  "\"BOSS战无法进行。跳过\"": {
    "translation": "",
    "MultiLang": {
      "US": "BOSS battle cannot proceed. Skipping.",
      "JP": "BOSS戦は実行できません。スキップ",
      "CN": "",
      "KR": "\"BOSS 전을 진행할 수 없습니다. 건너뜀\"",
      "TW": "無法進行 BOSS 戰。跳過"
    }
  },
  "\"Lua Unlocker Plugin Needed\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Lua Unlocker プラグインが必要です",
      "CN": "需要Lua解锁器插件",
      "KR": "\"Lua Unlocker 플러그인이 필요합니다\"",
      "TW": "需要 Lua Unlocker 外掛程式"
    }
  },
  "\"Server Dont have it. Skip BOSS Fight\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "サーバーにはありません。ボス戦をスキップします",
      "CN": "服务器没有该物品，跳过BOSS战",
      "KR": "\"서버에 없습니다. BOSS 전투 건너뛰기\"",
      "TW": "伺服器未安裝。跳過 BOSS 戰"
    }
  },
