{
  "还有30秒": {
    "translation": "",
    "MultiLang": {
      "US": "30 seconds remaining",
      "JP": "あと30秒",
      "CN": "",
      "KR": "30초 후",
      "TW": "還有30秒"
    }
  },
  "你们要在这等你们队友不要抛弃他们": {
    "translation": "",
    "MultiLang": {
      "US": "Wait here for your teammates; do not abandon them.",
      "JP": "队友の到着を待って、彼らを見捨てないでください",
      "CN": "",
      "KR": "팀원들을 버리지 말고 여기에서 대기를 계속하세요.",
      "TW": "請在這裡等待您的隊友，不要丟下他們。"
    }
  },
  "门还要30秒别着急": {
    "translation": "",
    "MultiLang": {
      "US": "The door will close in 30 seconds. Stay calm.",
      "JP": "門はあと30秒開きます、焦らないで",
      "CN": "",
      "KR": "문이 30초 후에 열리니 기다리세요.",
      "TW": "門還有30秒才開，別著急。"
    }
  },
  "僵尸会被阻拦15秒": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies will be blocked for 15 seconds.",
      "JP": "ゾンビーの進路が15秒間阻害されます",
      "CN": "",
      "KR": "좀비는 15초간 멈출 것입니다.",
      "TW": "殭屍會被阻擋15秒。"
    }
  },
  "你们有45秒的时间找到出口": {
    "translation": "",
    "MultiLang": {
      "US": "You have 45 seconds to find the exit.",
      "JP": "脱出口まで45秒あります",
      "CN": "",
      "KR": "출구를 찾기까지 45초가 주어집니다.",
      "TW": "你們有45秒的時間尋找出口。"
    }
  },
  "已经有人到达通往上面的门将在10秒后关闭": {
    "translation": "",
    "MultiLang": {
      "US": "Some players have reached the upper door. It will close in 10 seconds.",
      "JP": "すでに到着した者がいます。上の門は10秒後に閉じます",
      "CN": "",
      "KR": "몇몇 인원이 상부로 통하는 문에 도달했으며, 그 문은 10초 후 닫힙니다.",
      "TW": "已有人到達通往上方的門，10秒後將關閉。"
    }
  },
  "平台还有55秒上升": {
    "translation": "",
    "MultiLang": {
      "US": "The platform will rise in 55 seconds.",
      "JP": "プラットフォームはあと55秒で上昇します",
      "CN": "",
      "KR": "플랫폼이 55초 후에 상승합니다.",
      "TW": "平台還有55秒上升。"
    }
  }
