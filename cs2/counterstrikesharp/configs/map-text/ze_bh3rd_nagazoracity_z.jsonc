  },
  "该死!死士上直升机了,任务失败!": {
    "translation": "该死!死士上直升机了,任务失败!",
    "MultiLang": {
      "US": "Damn! The Kamikaze squad is on the helicopter. Mission failed!",
      "JP": "くそっ！死士がヘリに乗り込んだ、任務失敗だ！",
      "CN": "该死!死士上直升机了,任务失败!",
      "KR": "커밋! 사수가 헬기에 탑승했다. 임무 실패!",
      "TW": "該死！死士登上直升機了，任務失敗！"
    }
  },
  "资料搜集完毕!": {
