      "CN": "直升机即将到达,我们撤退!",
      "KR": "헬기 곧 도착, 철수!",
      "TW": "直升機即將抵達，我們撤退！"
    }
  },
  "等待水中崩坏能浓度下降!": {
    "translation": "等待水中崩坏能浓度下降!",
    "MultiLang": {
      "US": "Wait for the Leaftype concentration in the water to decrease!",
      "JP": "水中崩壊能濃度の下降を待機中！",
      "CN": "等待水中崩坏能浓度下降!",
      "KR": "수중 붕괴능 농도 감소 대기!",
      "TW": "等待水中崩坏能濃度下降！"
