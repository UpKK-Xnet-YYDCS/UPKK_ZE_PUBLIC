  "\"<<30s>>\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "\"<<30s>>\"",
      "CN": "\"<<30秒>>\"",
      "KR": "<<30초>>",
      "TW": "\"<30s>\""
    }
  },
  "\"终于把钢盔团赶出去了！再去操场看看还有没有漏网之鱼吧！\"": {
    "translation": "",
    "MultiLang": {
      "US": "\"Finally drove out the Steel Hat Battalion! Go check the playground for any stragglers!\"",
      "JP": "「ついにヘルメット団を追放した！もう一度演習場をチェックして、逃げた奴がいないか確認しよう！」",
      "CN": "",
      "KR": "드디어 철모단을 쫓아냈어! 운동장까지 가서 혹시 남은 놈은 없는지 확인해보자!",
      "TW": "「終於把鋼盔團趕出去了！再去操場看看還有沒有漏網之魚吧！」"
    }
  },
  "\"把剩余的钢盔团团员驱逐出去吧！\"": {
    "translation": "",
    "MultiLang": {
      "US": "\"Drive out the remaining members of the Steel Hat Battalion!\"",
      "JP": "「残りのヘルメット団員をすべて排除し、この地から追い出せ！」",
      "CN": "",
      "KR": "남아있는 철모단원을 완전히 쫓아내자!",
      "TW": "「把剩餘的鋼盔團團員驅逐出去吧！」"
    }
  }
}
