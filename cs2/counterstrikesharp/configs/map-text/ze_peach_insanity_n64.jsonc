{
  "MAP BY BLUE BLUE": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "作図：ブルー・ブルー",
      "CN": "MAP BY BLUE BLUE",
      "KR": "MAP BY BLUE BLUE",
      "TW": "地圖作者：BLUE BLUE"
    }
  },
  "*** THE BASIN WILL OPEN IN 10 SECONDS ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ベイシン、10秒後にオープンします ***",
      "CN": "*** 水池将在10秒后打开 ***",
      "KR": "*** 호수가 10초 후에 열립니다 ***",
      "TW": "*** 盆地將在 10 秒後開啟 ***"
    }
  },
  "*** LET'S A GO ! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 行くぞ！！ ***",
      "CN": "*** 行动！ ***",
      "KR": "*** 출발 ! ***",
      "TW": "*** 我們走吧！***"
    }
  },
  "*** 5 SECONDS LEFT !!!! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** あと5秒！！！！ ***",
      "CN": "*** 剩余5秒 !!!! ***",
      "KR": "*** 5초 남았습니다 !!!! ***",
      "TW": "*** 只剩 5 秒！！！！***"
    }
  },
  "*** THE MANSION WILL OPEN IN 20 SECONDS ! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** マンション、20秒後にオープンします！ ***",
      "CN": "*** 别墅将在20秒后开启 ! ***",
      "KR": "*** 저택이 20초 후에 열립니다 ! ***",
      "TW": "*** 宅邸將在 20 秒後開啟！***"
    }
  },
  "*** IT'S OPEN ! QUICK COME IN ! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 開いたぞ！ おいで！！ ***",
      "CN": "*** 打开了！快进来！ ***",
      "KR": "*** 오픈되었습니다 ! 빨리 들어오세요 ! ***",
      "TW": "*** 門開了！趕快進來！***"
    }
  },
  "*** THIS DOOR IS LOCKED, BUT THIS MANSION IS FALLING APART ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** この扉はロックされていますが、このマンションは崩壊中です ***",
      "CN": "*** 此门已上锁，但这座别墅正在崩塌 ***",
      "KR": "*** 이 문은 잠겨 있지만 이 저택은崩壊하고 있습니다 ***",
      "TW": "*** 這扇門已上鎖，但宅邸正在倒塌 ***"
    }
  },
  "*** GIVE ME 20 SECONDS, I'M SURE I CAN BREAK THIS WALL ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 私に20秒くれ、この壁は絶対壊せる ***",
      "CN": "*** 给我20秒，我肯定能砸开这面墙 ***",
      "KR": "*** 20초만 주세요, 이 벽을 무너뜨릴 수 있습니다 ***",
      "TW": "*** 給我 20 秒，我保證能打穿這面牆 ***"
    }
  },
  "*** COMES DEFEND THIS ROOM ! I FEEL SOMETHING WILL HAPPEN...***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "この部屋を守れ！何か起ころうとしている…",
      "CN": "快防守这个房间！我感觉会有事情发生……",
      "KR": "*** 여기 방을 방어하시오! 무언가 일어날 것 같습니다...***",
      "TW": "*** COMES DEFEND THIS ROOM ! I FEEL SOMETHING WILL HAPPEN...***"
    }
  },
  "*** DEFEND THE LIBRARY 30 SECONDS ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "図書館を守れ／30秒",
      "CN": "防守图书馆30秒",
      "KR": "*** 서고 30초간 방어하시오 ***",
      "TW": "*** DEFEND THE LIBRARY 30 SECONDS ***"
    }
  },
  "*** THE BALCONY DOORS WILL OPEN IN 20 SECONDS ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バルコニーのドアが20秒後に開きます",
      "CN": "阳台门将在20秒后打开",
      "KR": "*** 발코니 문이 20초 후에 열립니다 ***",
      "TW": "*** THE BALCONY DOORS WILL OPEN IN 20 SECONDS ***"
    }
  },
  "*** GO GO GO ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "行け行け！go go go！",
      "CN": "冲啊冲啊冲",
      "KR": "*** 서둘러 서둘러 ***",
      "TW": "*** GO GO GO ***"
    }
  },
  "*** DEFEND THE ROOF FOR 20 SECONDS ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "屋根を守れ／20秒",
      "CN": "防守屋顶20秒",
      "KR": "*** 옥상 20초간 방어하시오 ***",
      "TW": "*** DEFEND THE ROOF FOR 20 SECONDS ***"
    }
  },
  "*** OK KEEP CLIMBING ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "OK、登り続ける",
      "CN": "好的，继续爬！",
      "KR": "*** 알겠어 계속 오르지 ***",
      "TW": "*** OK KEEP CLIMBING ***"
    }
  },
  "*** OH NO ! KING BOO IS COMING ! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "いけない！キングブースがやってきた！",
      "CN": "哦不！国王 Boo 来了！",
      "KR": "*** 안 돼! 킹부우가 다가온다! ***",
      "TW": "*** OH NO ! KING BOO IS COMING ! ***"
    }
  },
  "*** DON'T TRY TO KILL IT, HE'S ALREADY DEAD ! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "倒そうとしないで！彼はもう死んでいる！",
      "CN": "别试图杀死它，他已经死了！",
      "KR": "*** 죽이려고 하지 마라, 그는 이미 죽었다! ***",
      "TW": "*** DON'T TRY TO KILL IT, HE'S ALREADY DEAD ! ***"
    }
  },
  "*** JUST RUN, GO TO THE NORTH !! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 走れ、北へ向かえ！！***",
      "CN": "*** 只管跑，往北边去！！***",
      "KR": "*** 그냥 달려! 북쪽 방향으로 가!! ***",
      "TW": "*** 快跑，往北邊去！！***"
    }
  },
  "*** WARNING ! BEHIND YOU !!! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 警告！あなたの後ろだ！！！***",
      "CN": "*** 警告！你身后有东西！！！***",
      "KR": "*** 경고! 너 뒤에 !!! ***",
      "TW": "*** 警告！你後面有東西！！！***"
    }
  },
  "*** HUMANS, YOU'RE WAY TOO BORING ! TAKE THIS KEY AND GET OUT OF MY MANSION ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** お前たちは人間かよ、あまりにも退屈だ！これを受け取れ、そして私の屋敷から出ていけ***",
      "CN": "*** 人类，你们太无聊了！拿着这把钥匙，离开我的宅邸***",
      "KR": "*** 인간들, 너희는 정말 심심해! 이 열쇠 가지고 내 저택에서 꺼져 ***",
      "TW": "*** 人類，你們太無聊了！拿著這把鑰匙，從我的宅邸滾出去***"
    }
  }
}
