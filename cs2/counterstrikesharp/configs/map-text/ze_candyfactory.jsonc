{
  "我在哪？": {
    "translation": "",
    "MultiLang": {
      "US": "Where am I?",
      "JP": "ここはどこだ？",
      "CN": "",
      "KR": "내가 어디 있나?",
      "TW": "我在哪裡？"
    }
  },
  "我深陷于雪地": {
    "translation": "",
    "MultiLang": {
      "US": "I'm trapped in the snowfield.",
      "JP": "私は雪に包まれている",
      "CN": "",
      "KR": "나는 눈밭에 빠져든다",
      "TW": "我深陷雪地之中"
    }
  },
  "我蹒跚寒风中": {
    "translation": "",
    "MultiLang": {
      "US": "I stumble through the biting wind.",
      "JP": "冷たい風を歩む",
      "CN": "",
      "KR": "찬바람 속에 뚝뚝 걸어가네",
      "TW": "我在寒風中蹣跚前行"
    }
  },
  "我被纯白吞噬": {
    "translation": "",
    "MultiLang": {
      "US": "I'm swallowed by pure white.",
      "JP": "純白に飲み込まれる",
      "CN": "",
      "KR": "순백의 세계에 삼켜지는 것",
      "TW": "我被純白吞沒"
    }
  },
  "我探索": {
    "translation": "",
    "MultiLang": {
      "US": "I explore",
      "JP": "私は探検する",
      "CN": "",
      "KR": "탐험한다",
      "TW": "我不斷探索"
    }
  },
  "我双靴踏冰层": {
    "translation": "",
    "MultiLang": {
      "US": "My boots tread on ice.",
      "JP": "靴で氷の上を歩く",
      "CN": "",
      "KR": "내 부츠가 빙판 위를 울린다",
      "TW": "雙靴踏過冰層"
    }
  },
  "我呼吸凝白雾": {
    "translation": "",
    "MultiLang": {
      "US": "I breathe out white fog.",
      "JP": "呼吸は白い息になる",
      "CN": "",
      "KR": "하얀 김을 쉬어내네",
      "TW": "呼出凝成白霧的氣息"
    }
  },
  "我预感将迷失": {
    "translation": "",
    "MultiLang": {
      "US": "I feel I'm losing my way.",
      "JP": "私は道に迷う予感がする",
      "CN": "",
      "KR": "나는 길을 잃을 것을 예감한다",
      "TW": "預感即將迷失"
    }
  },
  "我发现": {
    "translation": "",
    "MultiLang": {
      "US": "I found",
      "JP": "わかった",
      "CN": "",
      "KR": "나를 발견했어",
      "TW": "我發現"
    }
  },
  "巨形糖果漂浮天空": {
    "translation": "",
    "MultiLang": {
      "US": "Giant candy floating in the sky",
      "JP": "巨大なキャンディが空に浮かんでいる",
      "CN": "",
      "KR": "거대한 사탕이 하늘을 떠다녀",
      "TW": "巨型糖果漂浮於天際"
    }
  },
  "辐射尘埃弥漫空气": {
    "translation": "",
    "MultiLang": {
      "US": "Radioactive dust fills the air",
      "JP": "放射能の塵が空気中に漂っている",
      "CN": "",
      "KR": "방사능 먼지가 공기 중에 퍼져 있어",
      "TW": "輻射塵埃瀰漫空氣中"
    }
  },
  "舌头留下难移糖霜": {
    "translation": "",
    "MultiLang": {
      "US": "Tongue coated with stubborn sugar霜",
      "JP": "舌に残る取れない砂糖",
      "CN": "",
      "KR": "혀에는 지워지지 않는 설탕이 남아",
      "TW": "舌頭沾上難以去除的糖霜"
    }
  },
  "身体机能即将崩溃": {
    "translation": "",
    "MultiLang": {
      "US": "Body functions about to collapse",
      "JP": "身体機能がまもなく崩壊する",
