      "KR": "신체 기능 붕괴 임박",
      "TW": "身體機能即將崩潰"
    }
  },
  "我清醒": {
    "translation": "",
    "MultiLang": {
      "US": "I am awake",
      "JP": "私は目覚めた",
      "CN": "",
      "KR": "나는 깨어 있어",
