{
  "\"ze_name_defense\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ze_name_defense",
      "CN": "ze_name_defense",
      "KR": "ze_name_defense",
      "TW": "ze_name_defense"
    }
  },
  "\"Author:Charlie\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "作者:Charlie",
      "CN": "作者：Charlie",
      "KR": "작성자: Charlie",
      "TW": "作者：Charlie"
    }
  },
  "\"This is my first map. Please comment on workshop page if any question exists.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "これが私の最初のマップです。何か質問があれば、ワークショップページでコメントしてください。",
      "CN": "这是我的第一个地图。如有任何问题，请在工作坊页面留言。",
      "KR": "이것은 제가 만든 첫 번째 맵입니다. 질문이 있으시면 워크샵 페이지에 댓글을 남겨주세요.",
      "TW": "这是我的第一个地图。如有任何问题，请在创意工坊页面留言。"
    }
  },
  "\"Head for stage1.Defend somewhere for 60s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ステージ1へ。60秒間、どこかで防衛。",
      "CN": "前往第一关。在某个地点防御 60 秒。",
      "KR": "1단계로 이동하세요. 60초 동안 어딘가에서 방어하세요.",
      "TW": "前往第一关。在某个地点防御 60 秒。"
    }
  },
  "\"Head for stage2.Defend somewhere for 60s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ステージ2へ。60秒間、どこかで防衛。",
      "CN": "前往第二关。在某个地点防御 60 秒。",
      "KR": "2단계로 이동하세요. 60초 동안 어딘가에서 방어하세요.",
      "TW": "前往第二关。在某个地点防御 60 秒。"
    }
  },
  "\"Head for last stage.Defend somewhere for 60s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "最終ステージへ。60秒間、どこかで防衛。",
      "CN": "前往最后一关。在某个地点防御 60 秒。",
      "KR": "마지막 단계로 이동하세요. 60초 동안 어딘가에서 방어하세요.",
      "TW": "前往最后一关。在某个地点防御 60 秒。"
    }
  },
  "\"Prohibit implying map name. \"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "マップ名を示唆する表現は禁止します。",
      "CN": "禁止暗示地图名称。",
      "KR": "맵 이름을 암시하는 행위는 금지됩니다.",
      "TW": "禁止在地图名称中暗示任何内容。"
    }
  },
  "Zombie will be released 15s later.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビが15秒後に出現します。",
      "CN": "僵尸将在 15s 后释放。",
      "KR": "15초 후에 좀비가 나타납니다.",
      "TW": "喪屍將在 15 秒後釋放。"
    }
  },
  "ze_name_defense by Charlie": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ze_name_defense by Charlie",
      "CN": "ze_name_defense 由 Charlie 制作",
      "KR": "ze_name_defense by Charlie",
      "TW": "ze_name_defense 由 Charlie 製作"
    }
  },
  "Defend here for 45s.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ここで45秒間防衛せよ。",
      "CN": "在此防御 45s。",
      "KR": "여기서 45초 동안 방어하세요.",
      "TW": "在此防禦 45 秒。"
    }
  },
  "Head for next stage.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "次のステージへ進め。",
      "CN": "前往下一关。",
      "KR": "다음 스테이지로 이동합니다.",
      "TW": "前往下一關。"
    }
  },
  "Laser and bullet competition starts in 15s.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "レーザーと弾丸のコンテストが15秒後に開始されます。",
      "CN": "激光与子弹竞赛将在 15s 后开始。",
      "KR": "레이저와 총알 대결이 15초 후에 시작됩니다.",
      "TW": "雷射與子彈大賽將在 15 秒後開始。"
    }
  },
  "Noob has been cleared.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "Noobをクリアしました。",
      "CN": "菜鸟已清除。",
      "KR": "Noob을 클리어했습니다.",
      "TW": "新手關卡已通關。"
    }
  },
  "You've won the championship again.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "再び優勝を果たしました！",
      "CN": "你再次赢得了冠军。",
      "KR": "다시 한번 챔피언십에서 우승하셨습니다.",
      "TW": "你再次贏得了冠軍。"
    }
  },
  "Enjoy your spoils.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "戦利品を楽しんでください。",
      "CN": "尽情享受你的战利品吧。",
      "KR": "전리품을 즐기세요.",
      "TW": "盡情享受你的戰利品吧。"
    }
  },
  "Head for last stage.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "最終ステージへ向かえ。",
      "CN": "前往最后一关。",
      "KR": "마지막 스테이지로 이동하세요.",
      "TW": "前往最後關卡。"
    }
  },
  "Prohibit suggesting map name.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "マップ名の提示を禁止する。",
      "CN": "禁止建议地图名称。",
      "KR": "맵 이름 언급 금지.",
      "TW": "禁止建議地圖名稱。"
    }
  },
  "Audio gun 2 has been picked up.It can play music with 20s cooldown.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "オーディオガン2を拾得しました。20秒のクールタイムで音楽を再生できます。",
      "CN": "已拾取音频枪 2。可以播放音乐，冷却时间为 20s。",
      "KR": "오디오 건 2를 획득했습니다. 20초의 재사용 대기시간 후 음악을 재생할 수 있습니다.",
      "TW": "已拾取音效槍 2。可播放音樂，冷卻時間為 20s。"
    }
  }
}
