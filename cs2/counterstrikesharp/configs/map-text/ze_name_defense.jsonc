  "\"Author:Charlie\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "作者:Charlie",
      "CN": "作者：Charlie",
      "KR": "작성자: Charlie",
      "TW": "作者：Charlie"
    }
  },
  "\"This is my first map. Please comment on workshop page if any question exists.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "これが私の最初のマップです。何か質問があれば、ワークショップページでコメントしてください。",
      "CN": "这是我的第一个地图。如有任何问题，请在工作坊页面留言。",
      "KR": "이것은 제가 만든 첫 번째 맵입니다. 질문이 있으시면 워크샵 페이지에 댓글을 남겨주세요.",
      "TW": "这是我的第一个地图。如有任何问题，请在创意工坊页面留言。"
    }
  },
  "\"Head for stage1.Defend somewhere for 60s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ステージ1へ。60秒間、どこかで防衛。",
      "CN": "前往第一关。在某个地点防御 60 秒。",
      "KR": "1단계로 이동하세요. 60초 동안 어딘가에서 방어하세요.",
      "TW": "前往第一关。在某个地点防御 60 秒。"
    }
  },
  "\"Head for stage2.Defend somewhere for 60s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ステージ2へ。60秒間、どこかで防衛。",
      "CN": "前往第二关。在某个地点防御 60 秒。",
      "KR": "2단계로 이동하세요. 60초 동안 어딘가에서 방어하세요.",
      "TW": "前往第二关。在某个地点防御 60 秒。"
    }
  },
  "\"Head for last stage.Defend somewhere for 60s.\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "最終ステージへ。60秒間、どこかで防衛。",
      "CN": "前往最后一关。在某个地点防御 60 秒。",
      "KR": "마지막 단계로 이동하세요. 60초 동안 어딘가에서 방어하세요.",
      "TW": "前往最后一关。在某个地点防御 60 秒。"
    }
  },
  "\"Prohibit implying map name. \"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "マップ名を示唆する表現は禁止します。",
      "CN": "禁止暗示地图名称。",
      "KR": "맵 이름을 암시하는 행위는 금지됩니다.",
      "TW": "禁止在地图名称中暗示任何内容。"
    }
  }
}
