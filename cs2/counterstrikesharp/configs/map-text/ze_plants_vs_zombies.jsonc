    }
  },
  "<<山谷的路将在40秒后打开>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<The valley path will open in 40 seconds.>>",
      "JP": "<<40秒後に谷間の道が開きます>>",
      "CN": "",
      "KR": "<<곡밭 길은 40초 후 열립니다>>",
      "TW": "<<山谷的路將在40秒後打開>>"
    }
  },
  "<<门将在40秒后打开>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<The gate will open in 40 seconds.>>",
      "JP": "<<40秒後に扉が開きます>>",
      "CN": "",
      "KR": "<<문이 40초 후 열립니다>>",
      "TW": "<<門將在40秒後打開>>"
    }
  },
  "<<障碍物将在90秒后清理>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<Obstacles will be cleared in 90 seconds.>>",
      "JP": "<<90秒後に障害物が除去されます>>",
      "CN": "",
      "KR": "<<장애물이 90초 후 제거됩니다>>",
      "TW": "<<障礙物將在90秒後清理>>"
    }
  },
  "“障碍物清理干净了，我们快走”": {
    "translation": "",
    "MultiLang": {
      "US": "\"Obstacles cleared, let's move quickly.\"",
      "JP": "障害物を片付けたから、さっさと進もう",
      "CN": "",
      "KR": "장애물이 처리되었습니다. 빨리 가요.",
      "TW": "障碍物已清除，我們快點走"
    }
  },
  "<<大门将在30秒后开启>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<The main gate will open in 30 seconds.>>",
      "JP": "<<30秒後に大門が開きます>>",
      "CN": "",
      "KR": "<<대문이 30초 후에 열립니다.>>",
      "TW": "<<大門將于30秒後開啟>>"
    }
  },
  "\"Ciallo(∠・ω_ )⌒☆\"": {
    "translation": "",
    "MultiLang": {
      "US": "\"Ciallo(∠・ω_ )⌒☆\"",
      "JP": "",
      "CN": "\"Ciallo(∠・ω_ )⌒☆\"",
      "KR": "\"Ciallo(∠・ω_ )⌒☆\"",
      "TW": "Ciallo(∠・ω_ )⌒☆"
    }
  },
  "“再坚持30秒”": {
    "translation": "",
    "MultiLang": {
      "US": "\"Hold on for another 30 seconds.\"",
      "JP": "あと30秒、頑張って！",
      "CN": "",
      "KR": "30초 더 버티세요.",
      "TW": "再堅持30秒"
    }
  },
  "“请防守70秒”": {
    "translation": "",
    "MultiLang": {
      "US": "\"Please defend for 70 seconds.\"",
      "JP": "70秒間防衛してください",
      "CN": "",
      "KR": "70초 동안 방어하세요.",
      "TW": "請防守70秒"
    }
  },
  "<<已升级豌豆射手为双发射手>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<Upgraded Peashooter to Repeater.>>",
      "JP": "<<ピーマンアタッカーが二連発ピーマンアタッカーにアップグレードされました>>",
      "CN": "",
      "KR": "<<피네이셔 피리터가 더블 쏘기 피니셔로 업그레이드되었습니다.>>",
      "TW": "<<豌豆射手已升級為雙發射手>>"
    }
  },
  "<<升级的植物将在下一回合生效>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<Upgraded plants will take effect in the next turn>>",
      "JP": "<アップグレードされた植物は次のラウンドから発動します>",
      "CN": "",
      "KR": "<<업그레이드된 식물은 다음 턴에 발효됩니다.>>",
      "TW": "<<升級後的植物将在下一回合生效>>"
    }
  },
  "“我们失败了，僵尸进入了安全区......”": {
    "translation": "",
    "MultiLang": {
      "US": "\"We failed, the zombies entered the safe zone...\"",
      "JP": "私たちは敗北しました。ゾンビが安全区域に侵入しました……",
      "CN": "",
      "KR": "우리는 실패했습니다. 좀비가 안전 지역으로 진입했습니다......",
      "TW": "我們失敗了，殭屍進入了安全區……"
    }
  },
  "<<热身关卡>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<Warmup Level>>",
      "JP": "<<热身关卡>>",
      "CN": "",
      "KR": "<<热身关卡>>",
      "TW": "熱身關卡"
    }
  },
  "<<The text language has been switched. The function will take effect in the next round>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "言語が切り替えられました。次ラウンドから反映されます",
      "CN": "<<语言已切换。该功能将在下一轮生效>>",
      "KR": "<<언어가 변경되었습니다. 다음 라운드부터 적용됩니다.>>",
      "TW": "<<語言已切換。下輪遊戲生效>>"
    }
  },
  "MAP:Plants Vs. Zombies": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "MAP：植物対ゾンビ",
      "CN": "地图：植物大战僵尸",
      "KR": "MAP: 플랜츠 대 좀비",
      "TW": "地圖：植物對戰殭屍"
    }
  },
  "Mapper：<花泽爱吃香菜>": {
    "translation": "",
    "MultiLang": {
      "US": "Mapper: <HuaZeAiChiCai>",
      "JP": "Mapper：<花泽爱吃香菜>",
      "CN": "",
      "KR": "맵 제작자:<花泽爱吃香菜>",
      "TW": "圖層製作者：<花澤愛香菜>"
    }
  },
  "'Welcome to the world of Plants vs. Zombies!'": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "'植物対ゾンビの世界へようこそ！'",
      "CN": "欢迎来到植物大战僵尸的世界！",
      "KR": "'플랜츠 vs 좀비 세계에 오신 것을 환영합니다!'",
      "TW": "歡迎來到植物對戰殭屍的世界！"
    }
  },
  "'This world has undergone a zombie transformation. The zombie virus has spread to the peaceful town'": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "'この世界はゾンビ化しました。ゾンビウイルスが平和な街に広まりました'",
      "CN": "这个世界已陷入僵尸化的命运。僵尸病毒蔓延到了这座宁静的小镇。",
      "KR": "'이 지역은 좀비로 변했습니다. 좀비 바이러스가 평화로운 마을에 퍼졌습니다.'",
      "TW": "這個世界已遭受殭屍感染。殭屍病毒蔓延到了寧靜小鎮"
    }
  },
  "'All the residents of the Neighborville have already evacuated'": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "'ネバーバスの全住民はすでに避難済みです'",
      "CN": "邻家镇的居民早已疏散。",
      "KR": "'네이버빌 주민들은 모두 대피했습니다.'",
      "TW": "鄰居鎮的所有居民已疏散"
    }
  },
  "'I once heard from an expert that Crazy Dave from Neighborville had a way to fight off zombies'": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "'元々、ある専門家の話を聞いて、ネバーバスのクレイジー・デブがゾンビを退治する方法を持っていると知りました'",
      "CN": "我听说有一位专家透露，来自邻家镇的疯狂戴夫有办法抵御僵尸。",
      "KR": "'전 네이버빌의 크레이지 데이브가 좀비를 퇴치할 방법을 갖고 있다는 이야기를 들었습니다.'",
      "TW": "我曾聽專家說，瘋狂戴夫有辦法擊退殭屍"
    }
  },
  "'Now,take your plant and go find Dave to fight the zombies!'": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "'さあ、植物を持ってデブのところへ行き、ゾンビと戦いましょう！'",
      "CN": "现在，带上你的植物去找戴夫一起对抗僵尸吧！",
      "KR": "이제 식물을 챙겨서戴夫를 만나고 좀비와 싸우러 가세요!",
      "TW": "現在，拿起你的植物去找戴夫對付殭屍！"
    }
  },
  "<<The door will open in 5 seconds>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<5秒後に扉が開きます>>",
      "CN": "<<门将在5秒后开启>>",
      "KR": "<<문이 5초 후에 열립니다>>",
      "TW": "<<門將在5秒後開啟>>"
    }
  },
  "<<If you want to grow plants, you need to collect sufficient sun>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<植物を育てるには、十分な陽光を集める必要があります>>",
      "CN": "<<如果你想种植植物，需要收集足够的阳光>>",
      "KR": "<<식물을 재배하려면 충분한 해바라기를 모아야 합니다>>",
      "TW": "<<若想種植植物，需先收集足夠的阳光>>"
    }
  },
  "<<Sun can naturally fall from the sky during the day>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<陽光は昼間に空から自然に降ってきます>>",
      "CN": "<<白天时太阳会自然从天上掉落>>",
      "KR": "<<낮에는 해바라기가 하늘에서 자연스럽게 떨어질 수 있습니다>>",
      "TW": "<<白天陽光會自然從天而降>>"
    }
  },
  "<<It can also be produced by sun plants>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<日光植物でも産出できます>>",
      "CN": "<<它也可以通过向日葵产出>>",
      "KR": "<<해바라기 식물을 통해 생산할 수도 있습니다>>",
      "TW": "<<亦可由產陽植物產生>>"
    }
  },
  "<<If you want to get plenty of sun quickly, then plant a sunflower first>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<陽光をすばやくたくさん得たい場合は、まずヒマワリを植えてください>>",
      "CN": "<<如果你想快速获得大量阳光，请先种一颗向日葵>>",
      "KR": "<<급하게 많은 해바라기를 얻고 싶다면, 먼저 해바라기 식물을 심으세요>>",
      "TW": "<<若想快速獲得大量阳光，請先種植向日葵>>"
    }
  },
  "<<The road will be cleared up in 40 seconds>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<40秒後に道が通行可能になります>>",
      "CN": "<<道路将在40秒后清理完毕>>",
      "KR": "<<40초 후에 길이 막히지 않습니다>>",
      "TW": "<<道路將在40秒後清空>>"
    }
  },
  "<<任务失败>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<Mission Failed>>",
      "JP": "<<任務失敗>>",
      "CN": "",
      "KR": "<<임무 실패>>",
      "TW": "<<任務失敗>>"
    }
  },
  "<<已升级双发射手为机枪射手>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<Repeater upgraded to Gatling Pea>>",
      "JP": "<<二連射シューターを機銃シューターにアップグレードしました>>",
      "CN": "",
      "KR": "<<이중 발사기가 기관총 사수로 업그레이드됨>>",
      "TW": "<<已升級雙發射手為機槍射手>>"
    }
  },
  "<<已解锁玉米加农炮>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<Cornpult unlocked>>",
      "JP": "<<コーンパンツィャン unlocked>>",
      "CN": "",
      "KR": "<<옥수인 대포 해금됨>>",
      "TW": "<<已解鎖玉米加農炮>>"
    }
  },
  "欢迎到此地图的创意工坊链接下留言": {
    "translation": "",
    "MultiLang": {
      "US": "Leave a comment in the workshop link for this map.",
      "JP": "このマップのクリエイターワークスプレイスのコメント欄に投稿してください",
      "CN": "",
      "KR": "이 맵의 워크샵 링크 하단에 댓글을 남겨주세요.",
      "TW": "歡迎到此地圖的創意工坊連結下留言"
    }
  },
  "我们花费了一个月左右的时间制作了这张地图": {
    "translation": "",
    "MultiLang": {
      "US": "We spent about a month creating this map",
      "JP": "このマップを作るのに約1か月かかりました",
      "CN": "",
      "KR": "이 맵을 만드는 데 약 한 달 정도가 걸렸습니다.",
      "TW": "我們花費了一個月左右的時間製作了這張地圖"
    }
  },
  "如遇到任何bug或者有什么建议": {
    "translation": "",
    "MultiLang": {
      "US": "If you encounter any bugs or have suggestions",
      "JP": "バグが見つかった場合やご提案がある場合は",
      "CN": "",
      "KR": "버그나 제안 사항이 있으시다면",
      "TW": "如遇到任何bug或有任何建議"
    }
  },
  "祝你玩得愉快": {
    "translation": "",
    "MultiLang": {
      "US": "Have fun",
      "JP": "楽しんでください",
      "CN": "",
      "KR": "즐겁게 플레이하세요!",
      "TW": "祝你玩得愉快"
    }
  },
  "<<Level 0>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<Level 0>>",
      "CN": "<<等级 0>>",
      "KR": "<<레벨 0>>",
      "TW": "<<Level 0>>"
    }
  },
  "“僵尸进入安全区了，快种些植物干掉他们”": {
    "translation": "",
    "MultiLang": {
      "US": "\"Zombies have entered the safe zone. Plant some defenses to take them down.\"",
      "JP": "ゾンビが安全地帯に入りました！速攻で植物を配置して倒してください！",
      "CN": "",
      "KR": "\"좀비들이 안전 구역에 진입했습니다. 빨리 식물을 심어서 없애세요.\"",
      "TW": "「殭屍進入安全區了，快種些植物幹掉他們」"
    }
  }
}
