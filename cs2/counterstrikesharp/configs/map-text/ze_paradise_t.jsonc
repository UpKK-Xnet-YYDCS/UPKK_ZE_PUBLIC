{
  "** Magma chamber charges detonated. Wilmekea Peak has become unstable! **": {
    "translation": "** 岩浆库已引爆。威尔梅基亚峰已变得不稳定！**",
    "MultiLang": {
      "US": "",
      "JP": "マグマチャンバーの電荷が爆発しました。ウィルメケア峰が不安定化しました！",
      "CN": "** 岩浆室电荷爆炸。威尔梅基亚峰已变得不稳定！ **",
      "KR": "** 마그마 챔버 장전 폭파. 윌메케아 산이 불안정해졌습니다! **",
      "TW": "**岩漿室引信已引爆。威爾米克亞峰已處於不穩定狀態！**"
    }
  },
  "** V-22 Operator: Extraction complete. Dust off in 10... **": {
    "translation": "** V-22 操作员：提取完成。10秒后起飞... **",
    "MultiLang": {
      "US": "",
      "JP": "V-22オペレーター：抽出完了。10秒で離脱します…",
      "CN": "** V-22操作员：撤离完成。10秒后离开！ **",
      "KR": "** V-22 조종사: 인출 완료. 추락 10초... **",
      "TW": "**V-22 操作員：撤離完成。10 秒後準備行動...**"
    }
  },
  "** V-22 Operator: SAM launch detected. Taking evasive maneuvers... **": {
    "translation": "** V-22 操作员：检测到地空导弹发射。正在采取规避措施... **",
    "MultiLang": {
      "US": "",
      "JP": "V-22オペレーター：SAM発射を検知。回避行動を開始します…",
      "CN": "** V-22操作员：检测到SAM发射。正在采取规避机动... **",
      "KR": "** V-22 조종사: SAM 발사 감지. 회피 기동 실행 중... **",
      "TW": "**V-22 操作員：偵測到防空飛彈發射。正在進行規避動作...**"
    }
  },
  "** Wilmekea has gone critical. 10 seconds until eruption! **": {
    "translation": "** 威尔梅基亚峰岩浆房的体积已达到临界状态。距离喷发还有10秒！**",
    "MultiLang": {
      "US": "",
      "JP": "ウィルメケアが臨界状態に達しました。噴火まで残り10秒！",
      "CN": "** 威尔梅基亚已陷入临界状态。距离喷发还有10秒！",
      "KR": "** 윌메케아 임계치 도달. 분출까지 10초! **",
      "TW": "**威爾米克亞峰已進入臨界狀態。距離噴發還有 10 秒！**"
    }
  },
  "** Zodiac Operator: Jaw's cousin is closing on our six! Shoot her! **": {
    "translation": "** Zodiac操作员：Jaw的表亲正逼近我们的后方！开火！**",
    "MultiLang": {
      "US": "",
      "JP": "黄道帯オペレーター：ジャウの従兄が背後に接近中！撃て！",
      "CN": "** 黄道星座操作员：Jaw的表弟正从后方接近！击落她！",
      "KR": "** 조디악 조종사: 갱의 사촌이 우리 배후로 접근 중! 쏴!",
      "TW": "**黃道星座操作員：傑的堂妹正從後方逼近我方！開火！**"
    }
  },
  "5 seconds": {
    "translation": "5秒",
    "MultiLang": {
      "US": "",
      "JP": "5秒",
      "CN": "5秒",
      "KR": "5초",
      "TW": "5 秒"
    }
  },
  "HINT: 'Crouch' into the hang gliders and then stand up inside.": {
    "translation": "提示：'蹲下'进入滑翔伞内，然后在里面站起。",
    "MultiLang": {
      "US": "",
      "JP": "ヒント：ハンググライダーに「しゃがみ」動作を行い、内部で立ってください。",
      "CN": "提示：趴下进入滑翔翼，然后在内部站起来。",
      "KR": "힌트: 글라이더 안에 '앉았다' 일어나세요.",
      "TW": "提示：蹲下進入滑翔傘，然後在裡面站起來。"
    }
  },
  "HINT: Cut the boat cable!": {
    "translation": "提示：剪断船缆！",
    "MultiLang": {
      "US": "",
      "JP": "ヒント：ボートのケーブルを切断せよ！",
      "CN": "提示：切断船只缆绳！",
      "KR": "힌트: 배의 로프를 끊으세요!",
      "TW": "提示：剪斷船隻纜線！"
    }
  },
  "HINT: Ocean currents will impede progress.": {
    "translation": "提示：洋流会影响进展。",
    "MultiLang": {
      "US": "",
      "JP": "ヒント：海流が進行を妨げます。",
      "CN": "提示：洋流会阻碍你的前进。",
      "KR": "힌트: 해류가 진행을 방해합니다.",
      "TW": "提示：洋流會影響進度。"
    }
  },
  "HINT: SWIM AROUND THE BUOY TO REACH WILMEKEA PEAK!": {
    "translation": "提示：绕过浮标游泳，以到达威尔梅基亚峰！",
    "MultiLang": {
      "US": "",
      "JP": "ブイの周りを泳いでウィルメキア頂上を目指せ！",
      "CN": "提示：绕着浮标游泳以到达威尔米克亚峰！",
      "KR": "부표 주변을 수영하여 빌메케아 피크에 도달하세요!",
      "TW": "提示：繞過浮標即可抵達威爾梅基亞峰！"
    }
  },
  "SECRET: Updraft detected!": {
    "translation": "彩蛋：探测到上升气流！",
    "MultiLang": {
      "US": "",
      "JP": "シークレット：上昇気流を検出しました！",
      "CN": "秘密：检测到上升气流！",
      "KR": "상승 기류 감지됨!",
      "TW": "秘密：偵測到上升氣流！"
    }
  },
  "**Missile attack!!**": {
    "translation": "**导弹攻击！！**",
    "MultiLang": {
      "US": "",
      "JP": "**ミサイル攻撃！！**",
      "CN": "**导弹袭击！！**",
      "KR": "**미사일 공격!!**",
      "TW": "**飛彈襲擊！！**"
    }
  },
  "**The zombies will parachute into the volcano in 40 seconds**": {
    "translation": "**僵尸将在40秒后跳伞进入火山**",
    "MultiLang": {
      "US": "",
      "JP": "**ザンビが40秒後に火口へ降下します。**",
      "CN": "**僵尸将在40秒内跳伞进入火山**",
      "KR": "**좀비들이 40초 후 화산으로 낙하산 강하합니다.**",
      "TW": "**殭屍將於 40 秒後跳傘進入火山**"
    }
  }
