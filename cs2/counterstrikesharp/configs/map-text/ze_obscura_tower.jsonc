{
  ">>> WARMUP ROUND <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>> 予選ラウンド <<<",
      "CN": ">>> 热身环节 <<<",
      "KR": "<<< 예선 라운드 >>>",
      "TW": "<<< 熱身賽階段 >>>"
    }
  },
  ">>> WARMUP OVER <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>> 予選終了 <<<",
      "CN": ">>> 热身结束 <<<",
      "KR": "<<< 예선 종료 >>>",
      "TW": "<<< 熱身賽結束 >>>"
    }
  },
  ">>*** TELEPORT WILL OPEN IN 20 SECONDS***<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>*** 20秒後にテレポートポイントが開きます ***<<",
      "CN": ">>***传送门将在 20 秒后开启***<<",
      "KR": ">>*** 20초 후 텔레포트 열림***<<",
      "TW": ">>*** teleport 將在 20 秒後開啟***<<"
    }
  },
  ">>*** FIND A BOOK IN HOUSE AND A KEY SEWERAGE***<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>*** 家の中で本を見つけ、鍵となる廃水溝を探す ***<<",
      "CN": ">>***请在屋内找到一本书，以及一把下水道的钥匙***<<",
      "KR": ">>*** 건물에서 책을 찾고, 하수구 키를 획득하세요***<<",
      "TW": ">>*** 在房屋內找到一本書及一把下水道鑰匙***<<"
    }
  },
  "*** PLAYER FOUND A BOOK ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** プレイヤーは本を発見 ***",
      "CN": "*** 玩家找到了一本书 ***",
      "KR": "*** 플레이어가 책을 찾았습니다 ***",
      "TW": "*** 玩家已獲得書籍 ***"
    }
  },
  ">>*** FIND A BOOK TO DISABLE MAGIC BARRIER***<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>*** 魔法のバリアを解除するための本を探す ***<<",
      "CN": ">>***请找到一本书以禁用魔法屏障***<<",
      "KR": ">>*** 마법 장벽을 비활성화할 책을 찾으세요***<<",
      "TW": ">>*** 請找到一本書以解除魔法屏障***<<"
    }
  },
  ">>*** GATES WILL CLOSED AT 30 SECONDS***<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>*** 30秒後にゲートは閉じます ***<<",
      "CN": ">>***大门将在 30 秒后关闭***<<",
      "KR": ">>*** 30초 후문이 닫힙니다***<<",
      "TW": ">>*** 30 秒後大門將關閉***<<"
    }
  },
  ">>*** YOU LOSE***<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>*** 敗北 ***<<",
      "CN": ">>***你输了***<<",
      "KR": ">>*** 패배했습니다***<<",
      "TW": ">>*** 您已敗北***<<"
    }
  },
  ">>*** HUMANS WIN***<<": {
