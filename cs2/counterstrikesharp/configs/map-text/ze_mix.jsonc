  "▲它是一条龙▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲It's a dragon▲",
      "JP": "▲それは竜だ▲",
      "CN": "",
      "KR": "▲그것은 용이야▲",
      "TW": "▲那是一條龍▲"
    }
  },
  "▲它挡住了我们的去路▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲It's blocking our path▲",
      "JP": "▲進路を塞がれている▲",
      "CN": "",
      "KR": "▲우리의 길을 막고 있어▲",
      "TW": "▲它擋住了我們的去路▲"
    }
  },
  "▲我们必须杀死它▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲We must kill it▲",
      "JP": "▲あいつを仕留めるしかない▲",
      "CN": "",
      "KR": "▲그것을 죽여야 해▲",
      "TW": "▲我們必須殺死它▲"
    }
  },
  "▲小心它的攻击▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ Beware of its attacks ▲",
      "JP": "▲攻撃に注意してね▲",
      "CN": "",
      "KR": "▲공격에 주의해라▲",
      "TW": "▲小心它的攻擊▲"
    }
  },
  "▲我们刚刚得到好消息▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ We just got some good news ▲",
      "JP": "▲今、素晴らしい知らせを受け取ったんだって▲",
      "CN": "",
      "KR": "▲剛剛 좋은 소식이 들어왔다▲",
      "TW": "▲我們剛剛得到好消息▲"
    }
  },
  "▲直升机正在赶来▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ A helicopter is en route ▲",
      "JP": "▲ヘリコプターがまもなく到着するってよ▲",
      "CN": "",
      "KR": "▲헬기가 도착 중이다▲",
      "TW": "▲直升機正在趕來▲"
    }
  },
  "▲我们必须活着▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ We must survive ▲",
      "JP": "▲私たちは生きなきゃだめだよ▲",
      "CN": "",
      "KR": "▲우리는 살아남아야 해▲",
      "TW": "▲我們必須活着▲"
    }
  },
  "▲往下跳▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ Jump down ▲",
      "JP": "▲飛び降りて！▲",
      "CN": "",
      "KR": "▲아래로 뛰라▲",
      "TW": "▲往下跳▲"
    }
  },
  "▲直升机即将到达▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ The helicopter is arriving shortly ▲",
      "JP": "▲ヘリコプターがもうすぐ到着するよ▲",
      "CN": "",
      "KR": "▲헬기가 곧 도착한다▲",
      "TW": "▲直升機即將到達▲"
    }
  },
  "▲龙又出现了▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ The Dragon is back ▲",
      "JP": "▲またドラゴンが出てきたみたいだ▲",
      "CN": "",
      "KR": "▲용이 다시 나타났다▲",
      "TW": "▲龍又出現了▲"
    }
  },
  "▲直升机很快到达▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ The helicopter will arrive soon ▲",
      "JP": "▲ヘリコプターはもうすぐ到着するよ▲",
      "CN": "",
      "KR": "▲헬기가 곧 도착한다▲",
      "TW": "▲直升機很快到達▲"
    }
  },
  "▲出于安全考虑▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ For safety's sake ▲",
      "JP": "▲安全上の理由から▲",
      "CN": "",
      "KR": "▲안전상의 이유로 ▲",
      "TW": "▲出於安全考慮▲"
    }
  },
  "▲它只停留一小会▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ It only stays for a moment ▲",
      "JP": "▲それは少しの間だけ滞在します▲",
      "CN": "",
      "KR": "▲그것은 잠시만 머무릅니다 ▲",
      "TW": "▲它只停留一會兒▲"
    }
  },
  "▲所以不要停下▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ So don't stop ▲",
      "JP": "▲だから止まらないで▲",
      "CN": "",
      "KR": "▲그래서 멈추지 마세요 ▲",
      "TW": "▲所以不要停下▲"
    }
  },
  "▲尽可能地向前跑▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ Run forward as much as you can ▲",
      "JP": "▲できる限り前に走りなさい▲",
      "CN": "",
      "KR": "▲알 수 있는 한 멀리까지 달리기 ▲",
      "TW": "▲盡可能向前跑▲"
    }
  },
  "▲消灭这条龙▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ Defeat this dragon ▲",
      "JP": "▲この竜を倒せ▲",
      "CN": "",
      "KR": "▲이 용을 처치하세요 ▲",
      "TW": "▲消滅這條龍▲"
    }
  },
  "▲祝好运▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ Good luck ▲",
      "JP": "▲幸運を祈る▲",
      "CN": "",
      "KR": "▲행운을 빕니다 ▲",
      "TW": "▲祝好運▲"
    }
  },
  "▲跑▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ Run ▲",
      "JP": "▲走れ▲",
      "CN": "",
      "KR": "▲달리기 ▲",
      "TW": "▲跑▲"
    }
  },
  "▲一位勇士找到了武器：喷漆▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲ A warrior found a weapon: spray paint ▲",
      "JP": "▲勇者が武器を見つけました：スプレーペイント▲",
      "CN": "",
      "KR": "▲한 용사가 무기를 찾았습니다: 스프레이 페인트 ▲",
      "TW": "▲一位勇士找到了武器：噴漆▲"
    }
  },
  "▲一位勇士找到了武器：奶▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲A warrior has found a weapon: Milk ▲",
      "JP": "▲一人の勇者が武器を発見した：ミルク▲",
      "CN": "",
      "KR": "▲영겁의 방부제: 모유▲",
      "TW": "▲一位勇士找到了武器：奶▲"
    }
  },
  "▲一位勇士找到了武器：震荡波▲": {
    "translation": "",
    "MultiLang": {
      "US": "▲A warrior has found a weapon: Shockwave ▲",
      "JP": "▲一人の勇者が武器を発見した：ショックウェーブ▲",
      "CN": "",
      "KR": "▲영겁의 방부제: 여파▲",
      "TW": "▲一位勇士找到了武器：震盪波▲"
    }
  }
}
