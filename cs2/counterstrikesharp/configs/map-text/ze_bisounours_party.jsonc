    }
  },
  "*** YOU HAVE 20 SECS TO ESCAPE! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 脱出には20秒しかない！***",
      "CN": "*** 你有20秒时间逃生！***",
      "KR": "*** 도망칠 시간이 20초입니다! ***",
      "TW": "*** 你只有20秒逃離！***"
    }
  },
  "*** OH NO IT'S PEDOBEAR! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** おや、ペドベアだ！***",
      "CN": "*** 哦不，是佩多熊！***",
      "KR": "*** 오, 페도베어가 나타났다! ***",
      "TW": "*** 天啊！佩多熊來了！***"
    }
  },
  "*** SHOOT AND DODGE HIS ATTACKS! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 攻撃を避けながら撃て！***",
      "CN": "*** 射击并闪避他的攻击！***",
      "KR": "*** 그의 공격을 쏘아 맞히면서 피하세요! ***",
      "TW": "*** 射擊並閃避他的攻擊！***"
    }
  },
  "*** YOU HAVE 2 MINUTES TO KILL PEDOBEAR! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ペドベアを倒すまで2分間！ ***",
