    }
  },
  "*** Get ready to run!!! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 準備はいいか？走り出すぞ！ ***",
      "CN": "*** 准备好奔跑！！！ ***",
      "KR": "*** 지금부터 달리세요!!! ***",
