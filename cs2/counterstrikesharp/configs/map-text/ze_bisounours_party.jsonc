{
  "**Map made by Raphi**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**マップ作成者: Raphi**",
      "CN": "**地图由 Raphi 制作**",
      "KR": "**지도 제작자: 라피**",
      "TW": "**地圖由 Raphi 製作**"
    }
  },
  "*** FALL BACK! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** バック！ ***",
      "CN": "*** 后退！ ***",
      "KR": "*** 후퇴하라! ***",
      "TW": "*** 往後撤退！ ***"
    }
  },
  "*** PROTECT THE CASTLE! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 城を守れ！ ***",
      "CN": "*** 保护城堡！ ***",
      "KR": "*** 성을 지키라! ***",
      "TW": "*** 守護城堡！ ***"
    }
  },
  "*** FALL BACK TO THE RAINBOW! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** レインボーへ後退せよ！ ***",
      "CN": "*** 退回彩虹！ ***",
      "KR": "*** 비를 피해서 무지개로 후퇴하라! ***",
      "TW": "*** 往彩虹處撤退！ ***"
    }
  },
  "*** HOLD IT! 15 seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「待て！」15秒！",
      "CN": "*** 停下！ 15 秒！ ***",
      "KR": "*** 멈춰! 15초! ***",
      "TW": "*** 停下！ 15 秒！ ***"
    }
  },
  "*** King Pedobear will let you pass in 30 secs! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「キング・ペドベアーが30秒後に通過を許可します！」",
      "CN": "*** 国王佩多熊将在 30 秒后允许你通过！ ***",
      "KR": "*** 킹 페도베어가 30초 후에 통과를 허락합니다! ***",
      "TW": "*** 國王佩多熊會在 30 秒後允許你通過！ ***"
    }
  },
  "*** You can pass! Go go go! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「通過できます！行け行け！」",
      "CN": "*** 你可以前进！ 快！ ***",
      "KR": "*** 통과할 수 있습니다! 가세요! ***",
      "TW": "*** 你可以通過了！ 快！快！ ***"
    }
  },
  "*** SURVIVE 60 SECS! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「60秒生き延びろ！」",
      "CN": "*** 坚持 60 秒！ ***",
      "KR": "*** 60초 동안 버텨라! ***",
      "TW": "*** 存活 60 秒！ ***"
    }
  },
  "*** 5 SECONDS! *** ": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「5秒！」",
      "CN": "*** 5 秒！ ***",
      "KR": "*** 5초! ***",
      "TW": "*** 5 秒！ ***"
    }
  },
  "*** RUN! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「走れ！」",
      "CN": "*** 跑！ ***",
      "KR": "*** 달려! ***",
      "TW": "*** 跑！ ***"
    }
  },
  "*** King Pedobear will let you pass in 40 secs ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「キング・ペドベアーが40秒後に通過を許可します」",
      "CN": "*** 国王佩多熊将在 40 秒后允许你通过 ***",
      "KR": "*** 킹 페도베어가 40초 후에 통과를 허락합니다 ***",
      "TW": "*** 國王佩多熊會在 40 秒後允許你通過 ***"
    }
  },
  "*** King Pedobear has allowed you to pass! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "「キング・ペドベアーが通過を許可しました！」",
      "CN": "*** 国王佩多熊已经允许你通过了！",
      "KR": "*** 킹 페도베어가 통과를 허락했습니다! ***",
      "TW": "*** 國王佩多熊允許你通過了！"
    }
  },
  "*** The rainbow will be open in 30 secs ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** レインボーは30秒後に開きます ***",
      "CN": "*** 彩虹将在 30 秒后开启 ***",
      "KR": "*** 무지개가 30초 후에 열립니다 ***",
      "TW": "*** 彩虹将在 30 秒后开启 ***"
    }
  },
  "*** YOU HAVE 20 SECS TO ESCAPE! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 20秒以内に脱出しなければなりません！ ***",
      "CN": "*** 你有 20 秒的时间逃脱！***",
      "KR": "*** 20초 안에 탈출하세요! ***",
      "TW": "*** 你有 20 秒的时间逃脱！***"
    }
  },
  "*** OH NO IT'S PEDOBEAR! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** うわー、ペドベアだ！ ***",
      "CN": "*** 糟糕，是佩多熊！***",
      "KR": "*** 으악, 페도베어다! ***",
      "TW": "*** 糟糕！是佩多熊！***"
    }
  },
  "*** SHOOT AND DODGE HIS ATTACKS! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 撃って、彼の攻撃をかわしなさい！ ***",
      "CN": "*** 射击并躲避他的攻击！***",
      "KR": "*** 공격을 피하면서 공격하세요! ***",
      "TW": "*** 射击并躲避他的攻击！***"
    }
  },
  "*** YOU HAVE 2 MINUTES TO KILL PEDOBEAR! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ペドベアを倒すまで2分です！ ***",
      "CN": "*** 你有 2 分钟的时间消灭佩多熊！***",
      "KR": "*** 페도베어를 처치할 때까지 2분이 남았습니다! ***",
      "TW": "*** 你有 2 分钟的时间消灭佩多熊！***"
    }
  },
  "*** You killed Pedobear! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ペドベアを倒しました！ ***",
      "CN": "*** 你消灭了佩多熊！***",
      "KR": "*** 페도베어를 처치했습니다! ***",
      "TW": "*** 你消灭了佩多熊！***"
    }
  },
  "*** Escape from the sky now! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 今すぐ空から脱出しよう！ ***",
      "CN": "*** 现在从天空中逃脱！***",
      "KR": "*** 지금 하늘에서 탈출하세요! ***",
      "TW": "*** 现在从天空中逃脱！***"
    }
  },
  "*** Hold 30 secs! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 30秒間耐えろ！ ***",
      "CN": "*** 坚持 30 秒！***",
      "KR": "*** 30초 동안 버티세요! ***",
      "TW": "*** 坚持 30 秒！***"
    }
  },
  "*** GET INSIDE THE HOUSE! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 家に侵入しろ！ ***",
      "CN": "*** 冲进房子！ ***",
      "KR": "*** 집 안으로 들어가세요! ***",
      "TW": "*** 進入房子！ ***"
    }
  },
  "*** SURVIVE 60 SECONDS! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 60秒生き残れ！ ***",
      "CN": "*** 坚持 60 秒！ ***",
      "KR": "*** 60초 동안 생존하세요! ***",
