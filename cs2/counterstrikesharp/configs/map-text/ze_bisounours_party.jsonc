  },
  "*** 5 SECONDS! *** ": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 5秒だ！***",
      "CN": "*** 只剩5秒！***",
      "KR": "*** 5초 남았습니다! ***",
