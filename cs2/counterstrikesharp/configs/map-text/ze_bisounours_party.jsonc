  "*** ITS PEDOBEAR AGAIN! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 又是PEDOBEAR！***",
      "CN": "*** 又是佩多熊！ ***",
      "KR": "*** 또 페도베어입니다! ***",
      "TW": "*** 又是佩多熊！***"
