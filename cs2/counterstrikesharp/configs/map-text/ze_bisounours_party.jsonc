    }
  },
  "*** Get to the roof for the escape! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 逃げるために屋上を目指せ！ ***",
      "CN": "*** 登上屋顶，逃脱！ ***",
      "KR": "*** 탈출하려면 옥상으로 가세요! ***",
      "TW": "*** 前往屋頂，尋找逃脫路線！ ***"
    }
  },
  "*** Ladder barrier disappears in 30 seconds ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 梯子障壁将在30秒后消失 ***",
      "CN": "*** 梯子屏障将在 30 秒后消失 ***",
