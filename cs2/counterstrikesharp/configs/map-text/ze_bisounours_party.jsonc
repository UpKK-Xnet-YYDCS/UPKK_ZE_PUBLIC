  },
  "*** FALL BACK! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 後退せよ！ ***",
      "CN": "*** 撤退！ ***",
      "KR": "*** 후퇴! ***",
      "TW": "*** 後退！ ***"
    }
  },
  "*** PROTECT THE CASTLE! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** 城を守れ！ ***",
      "CN": "*** 保护城堡！ ***",
      "KR": "*** 성을 수호하라! ***",
      "TW": "*** 保護城堡！ ***"
    }
  },
  "*** FALL BACK TO THE RAINBOW! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** レインボーへ後退せよ！ ***",
      "CN": "*** 撤退到彩虹处！ ***",
      "KR": "*** 무지개 쪽으로 후퇴! ***",
      "TW": "*** 撤退到彩虹區！ ***"
    }
  },
  "*** HOLD IT! 15 seconds! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** Hold it! 15 seconds! ***",
      "CN": "*** 坚守阵地！15秒！***",
      "KR": "*** 버티시오! 15초간! ***",
      "TW": "*** 堅持住！15 秒！ ***"
    }
  },
  "*** King Pedobear will let you pass in 30 secs! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** King Pedobear will let you pass in 30 secs! ***",
      "CN": "*** 30秒后佩多熊国王将放行！***",
      "KR": "*** King Pedobear님이 30초 뒤에 통과를 허가합니다! ***",
      "TW": "*** 30 秒後國王 Pedobear 將放行！ ***"
    }
  },
  "*** You can pass! Go go go! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** You can pass! Go go go! ***",
      "CN": "*** 可以通行！快冲！***",
      "KR": "*** 통과 가능! 얼른 가시오! ***",
      "TW": "*** 可以通過了！快衝！ ***"
    }
  },
  "*** SURVIVE 60 SECS! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** SURVIVE 60 SECS! ***",
      "CN": "*** 存活60秒！***",
      "KR": "*** 60초간 생존하라! ***",
      "TW": "*** 存活 60 秒！ ***"
