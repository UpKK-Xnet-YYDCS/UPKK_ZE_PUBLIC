  },
  "*** Congratulations! You have claimed the throne! ***": {
    "translation": "***恭喜！你已夺得王座！***",
    "MultiLang": {
      "US": "",
      "JP": "*** おめでとう！王座を掴み取りました！ ***",
      "CN": "*** 恭喜！你已加冕为王 ***",
      "KR": "*** 축하합니다! 왕좌를 차지하셨습니다! ***",
      "TW": "*** 恭喜！您已登上帝位！***"
    }
  },
  "*** Do it. And call me daddy ***": {
    "translation": "***去做吧。叫我爸爸***",
    "MultiLang": {
      "US": "",
      "JP": "*** 実行する。そして僕のお父さんと呼ぶんだ ***",
      "CN": "*** 做吧。然后叫我爸爸 ***",
      "KR": "*** 해보세요. 그리고 저를 아빠라고 불러 주세요.",
      "TW": "*** 行動吧，然後叫我爸爸 ***"
    }
  },
  "*** Ice Nova has been acquired ***": {
    "translation": "***冰霜新星已被获取***",
    "MultiLang": {
