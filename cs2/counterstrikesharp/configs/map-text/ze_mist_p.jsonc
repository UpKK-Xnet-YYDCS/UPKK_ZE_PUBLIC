    }
  },
  "*** Normal mode enabled ***": {
    "translation": "***正常模式***",
    "MultiLang": {
      "US": "",
      "JP": "*** 通常モード有効 ***",
      "CN": "*** 已启用普通模式 ***",
      "KR": "*** 보통 모드 활성화 ***",
      "TW": "*** 已啟用普通模式 ***"
    }
  },
  "*** Or don't. What do I care? I'm not your daddy ***": {
    "translation": "***或者不。管我什么事？我又不是你爸爸***",
    "MultiLang": {
      "US": "*** Or don't. Why should I care? I'm not your daddy ***",
      "JP": "*** しなくてもいい。どうでもいいや。僕は君のお父さんじゃないから ***",
      "CN": "*** 随你便。我管不着。我又不是你爸爸 ***",
      "KR": "*** 아니면 하지 마세요. 제가 신경 쓰나요? 저는 당신의 아빠가 아닙니다.",
      "TW": "*** 或者別做。我管不著，我又不是你爸爸***"
    }
  },
  "*** Practice mode enabled ***": {
    "translation": "***练习模式***",
    "MultiLang": {
