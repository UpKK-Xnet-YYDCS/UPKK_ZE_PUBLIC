  "*** Static Field has been acquired ***": {
    "translation": "***静电力场已被获取***",
    "MultiLang": {
      "US": "*** Static Field Acquired ***",
      "JP": "*** 静電気フィールド習得 ***",
      "CN": "*** 已获得静滞力场 ***",
      "KR": "*** 정적 장 획득 ***",
      "TW": "***已獲得 Static Field***"
    }
  },
  "*** The mechanism is broken. Ring the bell manually. ***": {
    "translation": "***开关已损坏。去手动敲响铃铛。***",
    "MultiLang": {
      "US": "",
      "JP": "*** 装置が故障しています。手動でベルを鳴らしてください。 ***",
      "CN": "*** 机制损坏。请手动按铃。 ***",
      "KR": "*** 기구가 고장났습니다. 수동으로 종을鳴らしてください ***",
      "TW": "***機關損壞。請手動敲鐘。***"
    }
  },
  "*** Toxic Haze has been acquired ***": {
    "translation": "***毒性烟雾已被获取***",
    "MultiLang": {
      "US": "*** Toxic Haze Acquired ***",
      "JP": "*** 有毒な霧習得 ***",
      "CN": "*** 已获得毒雾 ***",
      "KR": "*** 유독 안개 획득 ***",
      "TW": "***已獲得 Toxic Haze***"
    }
  },
  "*** You can restart the round now ***": {
    "translation": "***你现在可以重启回合***",
    "MultiLang": {
      "US": "",
      "JP": "*** ラウンドをやり直すことができます ***",
      "CN": "*** 您现在可以重新开始回合 ***",
      "KR": "*** 이제 라운드를 재시작할 수 있습니다 ***",
      "TW": "***您現在可以重新開始回合了***"
    }
  },
  "*** You have failed to slay the dragon in time! ***": {
    "translation": "***你未能及时杀死龙！***",
    "MultiLang": {
      "US": "",
      "JP": "*** ドラゴンを時間内に倒し損ねました！ ***",
      "CN": "*** 您未能及时屠龙！ ***",
      "KR": "*** 드래곤을 제시간에 처치하지 못했습니다! ***",
      "TW": "***您未能在規定時間內屠殺巨龍！***"
    }
  }
