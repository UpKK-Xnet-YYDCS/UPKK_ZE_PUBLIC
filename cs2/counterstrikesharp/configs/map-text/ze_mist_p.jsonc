  "*** Cleansing Aura has been acquired ***": {
    "translation": "***净化光环已被获取***",
    "MultiLang": {
      "US": "*** Cleansing Aura Acquired ***",
      "JP": "*** クレンジングオーラを獲得しました ***",
      "CN": "*** 获得净化光环 ***",
