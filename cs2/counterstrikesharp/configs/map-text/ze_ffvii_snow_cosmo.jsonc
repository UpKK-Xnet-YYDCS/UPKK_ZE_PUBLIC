{
  "** EXTREME mode is beaten. Get ready for your last challenge ...**": {
    "translation": "** 已通关极限模式。准备迎接最后的挑战...**",
    "MultiLang": {
      "US": "",
      "JP": "**EXTREMEモードをクリアしました。最後の挑戦に備えてください...**",
      "CN": "** 已通关“极限”模式。请准备好迎接最后的挑战……**",
      "KR": "** 극한 모드 클리어! 마지막 도전에 대비하세요 ...**",
      "TW": "** 已擊敗「極限」模式。準備好面對你的最終挑戰吧...**"
    }
  },
  "** Nades do more damage. **": {
    "translation": "** 手雷能造成更多的伤害。**",
    "MultiLang": {
      "US": "",
      "JP": "**ナデスはより多くのダメージを与えます。**",
      "CN": "** 手榴弹伤害增加。**",
      "KR": "** 레이스 폭탄 피해 증가. **",
      "TW": "** 手榴彈造成的傷害更高。**"
    }
  },
  "**...Are you surprised?...**": {
    "translation": "**...你惊讶吗？...**",
    "MultiLang": {
      "US": "",
      "JP": "...驚きましたか？...",
      "CN": "**…你感到惊讶吗？…**",
      "KR": "** 놀랐나요?...**",
      "TW": "...你感到驚訝嗎？..."
    }
  },
  "**...Didn't you expect me?...**": {
    "translation": "**...你没想到我会来吗？...**",
    "MultiLang": {
      "US": "",
      "JP": "...私が現れるとは予想していませんでしたか？...",
      "CN": "**…没料到是我吧？…**",
      "KR": "... 예상 못 했나요?...",
      "TW": "...你沒料到會是我吧？..."
    }
  },
  "**...Oh okay i'm disappearing...**": {
    "translation": "**...好吧，我消失了...**",
    "MultiLang": {
      "US": "",
      "JP": "...では、消えますね...",
      "CN": "**…哦，好吧，我要消失了……**",
      "KR": "... 음, 그렇다면 사라질게요...",
      "TW": "...好喔，我要消失了..."
    }
  },
