  "**找到部分暗淡的水晶**": {
    "translation": "",
    "MultiLang": {
      "US": "Found partial dimmed crystals",
      "JP": "一部の色あせた水晶を見つけました",
      "CN": "",
      "KR": "어두워진 크리스탈 일부 발견",
      "TW": "找到部分暗淡的水晶"
    }
  },
  "起暴雪了!我们要多加小心!": {
    "translation": "",
    "MultiLang": {
      "US": "Blizzard incoming! Stay alert!",
      "JP": "吹雪だ！気をつけて行動しよう！",
      "CN": "起暴雪了！我们得多加小心！",
      "KR": "폭설이 내리고 있습니다! 주의하십시오!",
      "TW": "起暴雪了！我們要多加小心！"
    }
  },
  "找到隐藏的净化水晶!": {
    "translation": "",
    "MultiLang": {
      "US": "Found hidden purification crystals!",
      "JP": "隠れた浄化の水晶を見つけよ！",
      "CN": "",
      "KR": "숨겨진 정화 크리스탈 발견!",
      "TW": "找到隱藏的淨化水晶！"
    }
  },
  "**一名玩家拾取了【寒霜剑2】**": {
    "translation": "",
    "MultiLang": {
      "US": "**A player picked up [Frost Sword 2]**",
      "JP": "**プレイヤーが【フロストソード2】を拾いました**",
      "CN": "***一名玩家拾取了***",
      "KR": "**플레이어가 【허시드 블레이드 2】을 획득했습니다**",
      "TW": "**一名玩家拾取了【寒霜劍2】**"
    }
  },
  "阿拉斯已被击败,我们需要尽快去净化精灵身上的诅咒!": {
    "translation": "",
    "MultiLang": {
      "US": "Aras has been defeated. We must purify the elves' curse as soon as possible!",
      "JP": "アラスクが倒されました。エルフ身上的な呪いを浄化するために、急ぎ向かいます！",
      "CN": "阿拉斯已遭击败,我们需尽快去解除精灵身上的诅咒!",
      "KR": "알라스가 격파되었습니다. 엘프身上的 저주를 조속히 정화해야 합니다!",
      "TW": "阿拉斯已被擊敗，我們需要盡快去淨化精靈身上的詛咒！"
    }
  },
  "正在净化祭坛[20]": {
    "translation": "",
    "MultiLang": {
      "US": "Purifying altar [20]",
      "JP": "祭壇を浄化中[20]",
      "CN": "",
      "KR": "제단 [20] 정화 중",
      "TW": "正在淨化祭壇[20]"
    }
  },
  "净化水晶已准备就绪!": {
    "translation": "",
    "MultiLang": {
      "US": "Purification crystals ready!",
      "JP": "浄化水晶の準備完了！",
      "CN": "",
      "KR": "정화 크리스탈 준비 완료!",
      "TW": "淨化水晶已準備就緒！"
    }
  },
  "僵尸传送点10秒后移动!": {
    "translation": "",
    "MultiLang": {
      "US": "Zombie teleport point moves in 10 seconds!",
      "JP": "ゾンビの転送地点が10秒後に移動します！",
      "CN": "",
      "KR": "좀비 전송지점이 10초 후에 이동합니다!",
      "TW": "殭屍傳送點10秒後移動！"
    }
  },
  "getin!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "乗ってこい！",
      "CN": "上车！",
      "KR": "탑승하세요!",
      "TW": "getin!"
    }
  },
  "剑指权力顶峰,不死不朽!": {
    "translation": "",
    "MultiLang": {
      "US": "Aim for the pinnacle of power, undying and immortal!",
      "JP": "権力の頂点へ剑を指し、不死不滅を目指せ！",
      "CN": "",
      "KR": "권력의 정점을 향해 다가가고, 불멸이 되라!",
      "TW": "劍指權力頂峰，不死不朽！"
    }
  },
  "开始突袭!": {
    "translation": "",
    "MultiLang": {
      "US": "Start raid!",
      "JP": "襲撃開始！",
      "CN": "",
      "KR": "습격 개시!",
      "TW": "開始突襲！"
    }
  },
  "我不擅长捉弄人,但这次,祝你好运!": {
    "translation": "",
    "MultiLang": {
      "US": "I'm not good at pulling pranks, but this time, good luck!",
      "JP": "悪戯は得意じゃないけど、今回はお前を助けてやるから、幸運を祈るよ！",
      "CN": "",
      "KR": "장난치는 것은 서툴지만, 이번에는 운을 빕니다!",
      "TW": "我不擅長捉弄人，但這次，祝你好運！"
    }
  },
  "我接受挑战，来吧，稍后我会追逐你!": {
    "translation": "",
    "MultiLang": {
      "US": "I accept the challenge. Come on, I'll chase you later!",
      "JP": "挑戦を受けよう。さあ来い、後で追跡してやる！",
      "CN": "",
      "KR": "도전을 받아들이겠습니다. 어서 오십시오, 곧 저를 쫓으실 테죠!",
      "TW": "我接受挑戰，來吧，稍後我會追逐你！"
    }
  },
  "魔王会迎难而上，我亦是如此!": {
    "translation": "",
    "MultiLang": {
      "US": "The Demon King will face difficulties head-on, and so will I!",
      "JP": "魔王は難局に立ち向かう。私も同様だ！",
      "CN": "",
      "KR": "마왕은 역경을 딛고 일어나고, 나도 마찬가집니다!",
      "TW": "魔王會迎難而上，我亦是如此！"
    }
  },
  "臣服于我!": {
    "translation": "",
    "MultiLang": {
      "US": "Submit to me!",
      "JP": "我が下に加われ！",
      "CN": "",
      "KR": "복종하십시오!",
      "TW": "臣服於我！"
    }
  },
  "不再是不死之身了，为什么是我": {
    "translation": "",
    "MultiLang": {
      "US": "No longer immortal, why is it me?",
      "JP": "不死の身ではなくなった。なぜ私が？",
      "CN": "不再拥有不死之身，为什么是我",
      "KR": "이제 불사신이 아니다, 왜 내가?",
      "TW": "不再是不死之身，為何是我？"
    }
  },
  "**僵尸神器：雷沃尔熊人**": {
    "translation": "",
    "MultiLang": {
      "US": "Zombie Artifact: Revolt Bearman",
      "JP": "**ゾンビ神器：レヴォルのクマ人間**",
      "CN": "",
      "KR": "**좀비 장비: 레볼 브루트**",
      "TW": "**殭屍神器：雷沃爾熊人**"
    }
  },
  "我们来到了什么地方?": {
    "translation": "",
    "MultiLang": {
      "US": "Where have we arrived?",
      "JP": "ここはどこだ？",
      "CN": "",
      "KR": "우리는 어디에 있는가?",
      "TW": "我們置身何處？"
    }
  },
  "这里看上去一片死寂": {
    "translation": "",
    "MultiLang": {
      "US": "It seems like a dead zone here.",
      "JP": "ここは死の寂静に包まれているようだ",
      "CN": "这里看似1片寂静",
      "KR": "여기는 죽음의 침묵으로 가득 차 있다.",
      "TW": "此地死氣沉沉。"
    }
  },
  "亡城的屏障将在55秒后升起": {
    "translation": "",
    "MultiLang": {
      "US": "The barrier of the Dead City will rise in 55 seconds.",
      "JP": "亡都のバリアが55秒後に展開します",
      "CN": "",
      "KR": "죽은 도시의 보호막이 55초 후에 생성됩니다.",
      "TW": "亡城之屏障將於55秒後升起。"
    }
  },
  "我们再坚持一会,屏障将于10秒后形成!": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on a little longer! The barrier will form in 10 seconds!",
      "JP": "もう少し辛抱だ！バリアが10秒以内に形成される！",
      "CN": "",
      "KR": "잠시만 더 버티자! 보호막이 10초 후에 생성됩니다!",
      "TW": "再撐一會兒，屏障即將於10秒後形成！"
    }
  },
  "在天罚面前,跪下!": {
    "translation": "",
    "MultiLang": {
      "US": "Prostrate before the Divine Wrath!",
      "JP": "天罰の前にな、膝をつけ！",
      "CN": "在天罚面前，跪下！",
      "KR": "천벌 앞에서 엎드려라!",
      "TW": "在天罰面前，跪下！"
    }
  },
  "命定之死前的苟延残喘罢了!": {
    "translation": "",
    "MultiLang": {
      "US": "This is merely a desperate struggle before destiny's final blow!",
      "JP": "定められた死を前にした、ひ弱な抵抗にすぎない！",
      "CN": "",
      "KR": "정해진 죽음 앞에서의 간신한 부활이로군!",
      "TW": "不過是命定之死前的苟延殘喘！"
    }
  }
}
