    }
  },
  "**发生了意料之外的事情，水开始上涨了！**": {
    "translation": "",
    "MultiLang": {
      "US": "Something unexpected happened. The water is rising!",
      "JP": "想定外の出来事が起き、水が上昇し始めた！",
      "CN": "**发生意外事情，水开始上涨了！**",
      "KR": "**예상치 못한 일이 발생했습니다. 물이 차오르기 시작합니다!**",
      "TW": "發生了意料之外的事情，水位開始上漲！"
    }
  },
  "**25秒后门打开**": {
    "translation": "",
    "MultiLang": {
