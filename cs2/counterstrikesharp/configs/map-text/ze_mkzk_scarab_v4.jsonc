{
  "ze_MkZk_Scarab_v4": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ze_MkZk_Scarab_v4",
      "CN": "ze_MkZk_Scarab_v4",
      "KR": "ze_MkZk_Scarab_v4",
      "TW": "ze_MkZk_Scarab_v4"
    }
  },
  "Enter the gates and follow the eye to find the ancient portal.": {
    "translation": "进入大门并根据眼睛找到古老的传送入口",
    "MultiLang": {
      "US": "",
      "JP": "門を抜け、目印に従って古代のポータルを探してください。",
      "CN": "进入大门，跟随眼睛的指引找到远古传送门。",
      "KR": "게이트를 통과하여 눈 모양의 문양을 따라가면 고대의 포털이 나타납니다.",
      "TW": "進入大門，跟隨眼睛的指引找到古代傳送門。"
    }
  },
  "But be vigilant...": {
    "translation": "但是要保持警惕",
    "MultiLang": {
      "US": "",
      "JP": "しかし警戒を緩めないで…",
      "CN": "但务必保持警惕……",
      "KR": "하지만 경계하십시오...",
      "TW": "但要保持警惕……"
    }
  },
  "...death will come over those who dont see the scarab.": {
    "translation": "死亡会降临到那些没有注意到圣甲虫的人",
    "MultiLang": {
      "US": "",
      "JP": "...スカラブが見えない者たちには死が訪れます。",
      "CN": "……那些看不见圣甲虫的人终将面对死亡。",
      "KR": "...사막 딱정벌레를 보지 못하는 자에게는 죽음이 올 것입니다.",
      "TW": "……那些沒看見聖甲蟲的人將面臨死亡。"
    }
  },
