  "?????:Karllllllllllllllllllllllllllllllllllllllllllllllll": {
    "translation": "?????：Karllllllllllllllllllllllllllllllllllllllllllllllll",
    "MultiLang": {
      "US": "",
      "JP": "?????*カーーーーーール…………………",
      "CN": "?????:卡aaaaa里iiiiiiiiillllllllllllllllll",
