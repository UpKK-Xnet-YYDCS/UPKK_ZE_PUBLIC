  "????:Do you remember your name?": {
    "translation": "????：你还记得你的名字吗？",
    "MultiLang": {
      "US": "",
      "JP": "????:あなたの名前を覚えていますか？",
      "CN": "????:你记得你的名字吗？",
      "KR": "???:이름 기억나세요?",
      "TW": "????: 你記得你的名字嗎？"
    }
  },
  "????:Don't remember? It's ok, my name is Kiki": {
    "translation": "????：不记得了？没关系，我叫Kiki",
    "MultiLang": {
      "US": "",
      "JP": "????:思い出せない？いいですよ。私の名前はキキです",
      "CN": "????:不记得？没关系，我叫基奇",
      "KR": "???:모르시더라도 괜찮아요. 제 이름은 키키예요.",
      "TW": "????: 不記得？沒關係，我的名字是琪琪"
    }
  },
  "????:wake up....": {
