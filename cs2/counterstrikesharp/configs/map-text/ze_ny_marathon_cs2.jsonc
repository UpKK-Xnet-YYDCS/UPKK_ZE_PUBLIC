{
  ">> marathon <<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">> マラソン <<",
      "CN": ">> 马拉松 <<",
      "KR": ">> 마라톤 <<",
      "TW": ">> 馬拉松 <<"
    }
  },
  "*** NY MARATHON: GET READY TO RUN! ***": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "*** ニューヨークマラソン：走れ！準備は完了だ！ ***",
      "CN": "*** 纽约马拉松：准备开跑！***",
      "KR": "*** 뉴욕 마라톤: 달릴 준비를 하세요! ***",
      "TW": "*** 紐約馬拉松：準備好起跑！***"
    }
  },
  "* [[ NYCRockRadio FM 81.2 :: M.O.D. - Surfin' USA ]] *": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "* [[ NYCRockRadio FM 81.2 :: M.O.D. - Surfin' USA ]] *",
      "CN": "* [[ NYCRockRadio FM 81.2 :: M.O.D. - 冲浪美国 ]] *",
      "KR": "* [[ NYCRockRadio FM 81.2 :: M.O.D. - Surfin' USA ]] *",
      "TW": "* [[ NYCRockRadio FM 81.2 :: M.O.D. - Surfin' USA ]] *"
    }
  },
  "** 我们需要坚守住!公园的大门将在20秒后打开! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Hold the line! The park gate opens in 20 seconds! **",
      "JP": "** 我々は耐え抜かなければ！公園の門は20秒後に開く！**",
      "CN": "",
      "KR": "** 우리는 버텨야 합니다! 공원 문이 20초 후에 열립니다! **",
      "TW": "** 我們必須守住！公園大門將在20秒後開啟！**"
    }
  },
  "* [[ NYCRockRadio FM 81.2 :: Arzachel - Leg ]] *": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "* [[ NYCRockRadio FM 81.2 :: Arzachel - Leg ]] *",
      "CN": "* [[ NYCRockRadio FM 81.2 :: Arzachel - 腿 ]] *",
      "KR": "* [[ NYCRockRadio FM 81.2 :: Arzachel - Leg ]] *",
      "TW": "* [[ NYCRockRadio FM 81.2 :: Arzachel - Leg ]] *"
    }
  },
  "** 最后再坚守5秒! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Hold for 5 more seconds! **",
      "JP": "** あと5秒、耐え抜け！**",
      "CN": "*** 再坚持5秒! ***",
      "KR": "** 마지막으로 5초만 더 버텨주세요! **",
      "TW": "** 最後再撐5秒！**"
    }
  },
  "** 守住那堵破墙! 大门将会在25秒后打开! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Defend that broken wall! The gate opens in 25 seconds! **",
      "JP": "** あの崩れかけた壁を守れ！門は25秒後に開く！**",
      "CN": "",
      "KR": "** 그 허름한 담장을 지켜내세요! 문이 25초 후에 열립니다! **",
      "TW": "** 守住那堵破牆！大門將在25秒後開啟！**"
    }
  },
  "** 在坚守10秒!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Hold for 10 more seconds!!! **",
      "JP": "** もう10秒、耐え抜くのだ！！！”",
      "CN": "",
      "KR": "** 추가로 10초만 더 버텨주세요!!! **",
      "TW": "** 再堅持10秒！！！**"
    }
  },
  "** 到达检查点，站在白圈上来解锁大门 **": {
    "translation": "",
    "MultiLang": {
      "US": "Reach the checkpoint and stand in the white circle to unlock the gate.",
      "JP": "チェックポイントに到達し、白い円の中に立って扉を解除",
      "CN": "",
      "KR": "** 체크포인트에 도착하여 흰 원 안에 서서 문을 해제하세요 **",
      "TW": "** 到達檢查點，站在白圈上來解鎖大門 **"
    }
  },
  "** 检查点已启用! **": {
    "translation": "",
    "MultiLang": {
      "US": "Checkpoint activated!",
      "JP": "チェックポイントが有効化されました！",
      "CN": "",
      "KR": "** 체크포인트 활성화! **",
      "TW": "** 檢查點已啟用! **"
    }
  },
  "** Afk和乌龟将在20秒内传送到检查点 **": {
    "translation": "",
    "MultiLang": {
      "US": "AFK and slow players will be teleported to the checkpoint within 20 seconds.",
      "JP": "AFKおよび亀甲状態は20秒後にチェックポイントへテレポートされます",
      "CN": "",
      "KR": "** AFK 상태나 느린 플레이어는 20초 내에 체크포인트로 이전됩니다 **",
      "TW": "** 離線和烏龜將在20秒內傳送到檢查點 **"
    }
  },
  "** 坚守住!车站门将在25秒后打开!! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Hold the line! The station gate opens in 25 seconds!! **",
      "JP": "持ちこたえて！駅舎の扉は25秒後に開きます！！",
      "CN": "",
      "KR": "** 버티세요! 문이 25초 후에 열립니다!! **",
      "TW": "** 堅持住!車站門將在25秒後打開!! **"
    }
  },
  "** 坚守住!车站门将在10秒后打开! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Hold the line! The station door will open in 10 seconds! **",
      "JP": "持ちこたえて！駅舎の扉は10秒後に開きます！",
      "CN": "",
      "KR": "** 버티세요! 문이 10초 후에 열립니다! **",
      "TW": "** 堅持住!車站門將在10秒後打開! **"
    }
  },
  "** 跳过火车!我们得去另一边!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Skip the train! We have to get to the other side!!! **",
      "JP": "列車をスキップ！反対側に行かなければ！！",
      "CN": "",
      "KR": "** 기차를 건너뛰자! 반대편으로 가야 해!!! **",
      "TW": "** 跳過火車!我們得去另一邊!!! **"
    }
  },
  "** 我们必须在这里抵抗，直到门打开!(25s) **": {
    "translation": "",
    "MultiLang": {
      "US": "** We must resist here until the door opens! (25s) **",
      "JP": "扉が開くまでここで耐え忍びましょう！(25秒)",
      "CN": "",
      "KR": "** 문이 열릴 때까지 여기서 버티자! (25초) **",
      "TW": "** 我們必須在這裡抵抗，直到門打開!(25s) **"
    }
  },
  "** 再坚守10秒! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Hold for another 10 seconds! **",
      "JP": "あと10秒持ちこたえて！",
      "CN": "** 再坚持10秒! **",
      "KR": "** 또 10초만 버텨줘! **",
      "TW": "** 再堅持10秒! **"
    }
  },
  "* [[ NYCRockRadio FM 81.2 :: Steppenwolf - Born To Be Wild ]] *": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "* [[ ニューヨークロックラジオ FM 81.2 :: ステッペンヴォルフ - Born To Be Wild ]] *",
      "CN": "* [[ NYCRockRadio FM 81.2 :: Steppenwolf - 为狂野而生 ]] *",
      "KR": "* [[ NYCRockRadio FM 81.2 :: Steppenwolf - Born To Be Wild ]] *",
      "TW": "* [[ NYCRockRadio FM 81.2 :: Steppenwolf - 生來狂野 ]] *"
    }
  },
  "** Afk和乌龟将在20秒内传送到检查点. **": {
    "translation": "",
    "MultiLang": {
      "US": "** Afk and Turtles will teleport to the checkpoint within 20 seconds. **",
      "JP": "** アフクと亀は20秒以内にチェックポイントへテレポートされます。**",
      "CN": "",
      "KR": "** 애프크와 거북이가 20초 이내에 체크포인트로 텔레포트됩니다. **",
      "TW": "** Afk和烏龜將在20秒內傳送到檢查點. **"
    }
  },
  "** 引擎区域大门30秒后打开 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Engine area gate opens in 30 seconds **",
      "JP": "** エンジン区域の扉は30秒後に開きます。**",
      "CN": "*** 发动机区域大门10秒后打开 ***",
      "KR": "** 엔진 지구 정문이 30초 후에 열립니다. **",
      "TW": "** 引擎區域大門30秒後打開 **"
    }
  },
  "** 引擎区域大门将在15秒后打开 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Engine area gate opens in 15 seconds **",
      "JP": "** エンジン区域の扉は15秒後に開きます。**",
      "CN": "",
      "KR": "** 엔진 지구 정문이 15초 후에 열립니다. **",
      "TW": "** 引擎區域大門將在15秒後打開 **"
    }
  },
  "** 引擎区域的大门将在5秒后打开，坚守住!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Engine area gate opens in 5 seconds, hold the line!!! **",
      "JP": "** エンジン区域の扉は5秒後に開きます。持ちこたえてください!!!**",
      "CN": "",
      "KR": "** 엔진 지구 정문이 5초 후에 열립니다. 버티세요!!! **",
      "TW": "** 引擎區域的大門將在5秒後打開，堅守住!!! **"
    }
  },
  "** 阀门室的门将在15秒后打开 **": {
    "translation": "",
    "MultiLang": {
      "US": "The valve room door will open in 15 seconds",
      "JP": "** 弁室の扉は15秒後に開きます。**",
      "CN": "",
      "KR": "** 밸브실문이 15초 후에 열립니다. **",
      "TW": "** 閥門室的門將在15秒後打開 **"
    }
  },
  "** 阀室门将在5秒后开启。坚守住!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "The valve room door will open in 5 seconds. Hold the line!!!",
      "JP": "** 弁室の扉は5秒後に開きます。持ちこたえてください!!!**",
      "CN": "",
      "KR": "** 밸브실문이 5초 후에 열립니다. 버티세요!!! **",
      "TW": "** 閥室門將在5秒後開啟。堅守住!!! **"
    }
  },
  "** 点按E启动阀门!我们需要把有毒废物排出去!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "Press E to activate the valve! We need to vent the toxic waste!!!",
      "JP": "** Eキーを押してバルブを起動!有毒廃液を排出する必要がある!!!**",
      "CN": "",
      "KR": "** E를 눌러 밸브를 가동하세요! 유독 폐기물을 배출해야 합니다!!! **",
      "TW": "** 點按E啟動閥門!我們需要把有毒廢物排出去!!! **"
    }
  },
  "** 这能消灭那些该死的僵尸! **": {
    "translation": "",
    "MultiLang": {
      "US": "This will eliminate those damn zombies!",
      "JP": "これであの忌まわしいゾンビを殲滅できる！",
      "CN": "",
      "KR": "이것으로那些该死的僵尸을 쓸어버릴 수 있어!",
      "TW": "** 這能消滅那些該死的殭屍！ **"
    }
  },
  "** 左阀门已完全打开! **": {
    "translation": "",
    "MultiLang": {
      "US": "Left valve fully opened!",
      "JP": "左バルブが完全に解放された！",
      "CN": "",
      "KR": "왼쪽 밸브가 완전히 열렸어!",
      "TW": "** 左閥門已完全開啟！ **"
    }
  },
  "** 右阀门已完全打开! **": {
    "translation": "",
    "MultiLang": {
      "US": "Right valve fully opened!",
      "JP": "右バルブが完全に解放された！",
      "CN": "",
      "KR": "오른쪽 밸브가 완전히 열렸어!",
      "TW": "** 右閥門已完全開啟！ **"
    }
  },
  "** 两个阀门都已解锁!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "Both valves unlocked!!!",
      "JP": "両方のバルブがアンロックされた！！！",
      "CN": "两个阀门均已解锁!!!",
      "KR": "두 밸브가 모두 해제되었어!!!",
      "TW": "** 兩個閥門都已解鎖！！！**"
    }
  },
  "** 防守15秒!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "Defend for 15 seconds!!!",
      "JP": "15秒間防衛せよ！！！",
      "CN": "",
      "KR": "15초 동안 방어!!!",
      "TW": "** 防守15秒！！！**"
    }
  },
