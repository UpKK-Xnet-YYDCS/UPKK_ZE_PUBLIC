  "* [[ NYCRockRadio FM 81.2 :: Arthur Brown - I've Got Money ]] *": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "[[ NYCRockRadio FM 81.2 :: Arthur Brown - I've Got Money ]]",
      "CN": "* [[ NYCRockRadio FM 81.2 :: Arthur Brown - 我有钱 ]] *",
      "KR": "* [[ NYCRockRadio FM 81.2 :: Arthur Brown - I've Got Money ]] *",
      "TW": "* [[ NYCRockRadio FM 81.2 :: Arthur Brown - I've Got Money ]] *"
    }
  },
  "** 噢,不!隧道被锁上了!我们得等一会儿(30s) **": {
    "translation": "",
    "MultiLang": {
      "US": "** Oh, no! The tunnel is locked! We have to wait for a while (30s) **",
      "JP": "ああ、ついにトンネルが封鎖された！30秒待たなければならない",
      "CN": "** 噢，不！隧道被锁上了！我们得等等(30s) **",
      "KR": "아, 안 돼! 터널이 잠겼어! 잠시 기다려야 해 (30초)",
      "TW": "** 噢,不!隧道被鎖上了!我們得等一會兒(30s) **"
    }
  },
  "** 还剩15秒!继续防守! **": {
    "translation": "",
    "MultiLang": {
      "US": "** 15 seconds remaining! Keep defending! **",
      "JP": "** 残り15秒！防御を継続せよ！ **",
      "CN": "",
      "KR": "** 15초 남았습니다! 계속 방어하세요! **",
      "TW": "** 剩餘15秒！繼續防守！**"
    }
  },
  "** 最后5秒 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Last 5 seconds **",
      "JP": "** 最終5秒 **",
      "CN": "",
      "KR": "** 마지막 5초 **",
      "TW": "** 最後5秒**"
    }
  },
  "* [[ NYCRockRadio FM 81.2 :: Granicus - Cleveland Ohio ]] *": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "* [[ NYCRockRadio FM 81.2 :: グラニカス - クリーブランド オハイオ ]] *",
      "CN": "* [[ NYCRockRadio FM 81.2 :: Granicus - 俄亥俄州克利夫兰 ]] *",
      "KR": "* [[ NYCRockRadio FM 81.2 :: Granicus - Cleveland Ohio ]] *",
      "TW": "* [[ NYCRockRadio FM 81.2 :: Granicus - Cleveland Ohio ]] *"
    }
  },
  "*** 快启动直升机引擎！ ***": {
    "translation": "",
    "MultiLang": {
      "US": "*** Start the helicopter engines quickly! ***",
      "JP": "*** ヘリコプターのエンジン始動を急げ！ ***",
      "CN": "",
      "KR": "*** 헬리콥터 엔진 시동 시작하세요! ***",
      "TW": "*** 快啟動直升機引擎！***"
    }
  },
  "** The helicopter is leaving in 30 seconds. RESIST! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ハチビキは30秒後に発進します。抵抗せよ！ **",
      "CN": "**直升机将在30秒后起飞。反抗！**",
      "KR": "** 헬기가 30초 후에 떠납니다. 저항하십시오! **",
      "TW": "** 直升機30秒後離開。反抗！**"
    }
  },
  "* [[ NYCRockRadio FM 81.2 :: Buffalo - Shylock ]] *": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "* [[ NYCRockRadio FM 81.2 :: バッファロー - シーロック ]] *",
      "CN": "* [[ NYCRockRadio FM 81.2 :: Buffalo - Shylock ]] *",
      "KR": "* [[ NYCRockRadio FM 81.2 :: Buffalo - Shylock ]] *",
      "TW": "* [[ NYCRockRadio FM 81.2 :: Buffalo - Shylock ]] *"
    }
  },
  "** C'mon! 15 more seconds! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** さあ！残り15秒だ！ **",
      "CN": "**快点！只剩15秒了！**",
      "KR": "** 어서! 15초 더 남았습니다! **",
      "TW": "** 加油！再加15秒！**"
    }
  },
  "** Last 5 seconds! HOLD!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 最後の5秒！耐えろ！！ **",
      "CN": "**最后5秒！坚持住！！！**",
      "KR": "** 마지막 5초! 버티세요!!!**",
      "TW": "** 最後5秒！堅持住！！**"
    }
  },
  "** 坚持住，需要15秒来开门 !!! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Hold on, it takes 15 seconds to open the door !!! **",
      "JP": "** もう少し！ドアを開けるまで15秒待って！**",
      "CN": "",
      "KR": "** 버티세요, 문 여는 데 15초가 남았습니다! **",
      "TW": "** 堅持住，需要15秒來開門 !!! **"
    }
  },
  "** 再守5秒 !!! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Hold for another 5 seconds !!! **",
      "JP": "**あと5秒持て！！**",
      "CN": "",
      "KR": "** 5초만 더 버텨주세요! **",
      "TW": "** 再守5秒 !!! **"
    }
  },
  "** 公园大门将在20秒后打开! **": {
    "translation": "",
    "MultiLang": {
      "US": "** The park gate will open in 20 seconds! **",
      "JP": "**公園の門は20秒後に開きます！**",
      "CN": "",
      "KR": "** 공원 정문은 20초 후에 열립니다! **",
      "TW": "** 公園大門將在20秒後打開! **"
    }
  },
  "** 走吧! 我们得守住公园，直到找到出路! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Let's go! We have to defend the park until we find a way out! **",
      "JP": "**行こう！出口が見つかるまで公園を守らなきゃ！**",
      "CN": "",
      "KR": "** 가자! 우리가 탈출구를 찾을 때까지 공원을 지켜야 해! **",
      "TW": "** 走吧! 我們得守住公園，直到找到出路! **"
    }
  },
  "** We could call a Penis-UFO and split the fare... **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ペニスUFOを呼んで、運賃を折半しよう…**",
      "CN": "**我们可以叫一辆阴茎UFO，然后分摊费用……**",
      "KR": "** 자위 비행선을 호출해 타인을 탔을 수도 있지만... **",
      "TW": "** 我們可以叫陰莖UFO來，然後分擔費用... **"
    }
  },
  "** 快了！ Penis-UFO is coming! 坚持住 !!! **": {
    "translation": "",
    "MultiLang": {
      "US": "** Almost! Penis-UFO is coming! Hold on!!! **",
      "JP": "**もうすぐ！ペニスUFOが来る！耐えろ！！**",
      "CN": "快了！Penis-UFO就要来了!!! 坚持住!!!",
      "KR": "** 거의 다 됐어요! 자위 비행선이 도착합니다! 버티세요 !!! **",
      "TW": "** 快了! 陰莖UFO 正在趕來! 堅持住 !!! **"
    }
  },
  "** GO! The penis UFO 的门开了，快进来!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "** GO! The door to the penis UFO is open, get in!!! **",
      "JP": "**GO! ペニスUFOのドアが開いた、中にはいれ！！！**",
      "CN": "** GO! 阴茎 UFO 的门开了，快进来!!! **",
      "KR": "** GO! 자위 비행선문이 열렸습니다, 빨리 들어오세요!!! **",
      "TW": "** GO! 陰莖UFO 的門開了，快進來!!! **"
    }
  },
  "** 坚守20秒!!! **": {
