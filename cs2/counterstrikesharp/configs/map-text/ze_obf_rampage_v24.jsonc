  "<<<Good luck.>>>": {
    "translation": "<<<祝你好运。>>>",
    "MultiLang": {
      "US": "",
      "JP": "<<<幸運を。>>>",
      "CN": "祝好运。",
      "KR": "<<<행운을 빕니다.>>>",
      "TW": "祝您好運。"
    }
  },
  "<<<No one is more deserving of a rest, all the effort in the world would have gone to waste.>>>": {
    "translation": "<<<没有人比你们更值得休息，否则整个世界的努力都将白费。>>>",
    "MultiLang": {
      "US": "<<No one deserves a rest more, all the effort in the world would have gone to waste.>>",
      "JP": "休養に値するのは、誰よりも君だ。すべての努力が水の泡になることを許しはしない。",
      "CN": "没有人比您更值得休息，世间的努力若付诸东流便毫无意义。",
      "KR": "그 누구보다 휴식이 필요한 당신, 세상의 모든 노력이 헛되지 않도록 하죠.",
      "TW": "沒人比您更該得到休息，若不然，世間所有的努力都將白費。"
    }
  },
  "<<<Rise and shine, Soldiers with burning heart.>>>": {
    "translation": "<<<剑该出鞘了，怀揣着赤子之心的战士们。>>>",
    "MultiLang": {
      "US": "",
      "JP": "起きたまえ、燃える心を持つ戦士たちよ。",
      "CN": "醒醒吧，战士们，燃烧你们的心！",
      "KR": "일어나세요, 타는 듯한 열정을 지닌 병사들이여.",
      "TW": "醒來吧，擁有熾熱之心的士兵們！"
    }
  },
  "<<<The right man in the wrong place can make all the difference in the world.>>>": {
    "translation": "<<<正确的人在错误的地方引起了世界线的变动。>>>",
    "MultiLang": {
      "US": "",
      "JP": "間違った場所の正しい人物こそ、世の中を変えうるのだ。",
      "CN": "对的人处于错的位置，也能让整个世界发生天翻地覆的变化。",
      "KR": "잘못된 장소에 있는 올바른 사람이 세상의 차이를 만들 수 있습니다.",
      "TW": "正確的人員與錯誤的位置，往往能決定世界的走向。"
    }
  },
  "<<<Wake up and smell the Ashes.>>>": {
    "translation": "<<<醒来吧，嗅到灰烬的气息。>>>",
    "MultiLang": {
      "US": "",
      "JP": "目覚めて、灰の香りをかぐのだ。",
      "CN": "醒醒吧，尝尝灰烬的味道吧。",
      "KR": "눈을 뜨고 재의 냄새를 맡으세요.",
      "TW": "醒醒吧，聞聞灰燼的味道。"
    }
  },
  "<<<your hour is come again.>>>": {
    "translation": "<<<变革的时机来临了。>>>",
    "MultiLang": {
      "US": "",
      "JP": "再びお前の時が訪れた。",
      "CN": "你的时刻再次降临。",
      "KR": "당신의 시간이 다시 찾아왔습니다.",
      "TW": "您的時刻再度來臨。"
    }
  },
  "Bad feelings...": {
    "translation": "不祥的预感...",
