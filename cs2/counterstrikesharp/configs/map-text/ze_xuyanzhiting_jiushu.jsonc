{
  "群星灿烂 海洋汹涌 大地沉默": {
    "translation": "",
    "MultiLang": {
      "US": "Stars shine brightly, oceans surge, and the earth remains silent",
      "JP": "群星は輝き、海は荒れ狂い、大地は沈黙する",
      "CN": "",
      "KR": "별들이 찬란하게 빛나고, 바다는 거세게 출렁이며, 대지는 고요하다.",
      "TW": "群星燦爛 海洋洶湧 大地沉默"
    }
  },
  "一切有序如常 与昨日并无区别": {
    "translation": "",
    "MultiLang": {
      "US": "Everything is orderly as usual, indistinguishable from yesterday",
      "JP": "すべての事物は平常通りであり、昨日と何ら変わりはない",
      "CN": "",
      "KR": "모든 것이 평소처럼 질서 정연하게 흐르고, 어제와 다를 바 없다.",
      "TW": "一切有序如常 與昨日並無區別"
    }
  },
  "旅途还未结束...": {
    "translation": "",
    "MultiLang": {
      "US": "The journey has not yet ended...",
      "JP": "旅はまだ終わらない……",
      "CN": "",
      "KR": "여정 아직 끝나지 않았다...",
      "TW": "旅途還未結束..."
    }
  },
