  "** The internal gate will open in 10 seconds **": {
    "translation": "** 内部大门将在 10 秒后打开 **",
    "MultiLang": {
      "US": "",
      "JP": "** 内部の門が10秒後に開きます **",
      "CN": "**内部门将在10秒后打开**",
