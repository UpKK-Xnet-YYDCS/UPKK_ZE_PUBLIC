{
  "<<关卡一>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<Level 1>>",
      "JP": "<<レベル1>>",
      "CN": "",
      "KR": "<<클래스 1>>",
      "TW": "<<第一關>>"
    }
  },
  "<<路将在30秒后打开>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<The path will open in 30 seconds>>",
      "JP": "<<道は30秒後に開きます>>",
      "CN": "",
      "KR": "<<로드가 30초 후 열립니다>>",
      "TW": "<<\"路將在30秒後打開>>"
    }
  },
  "“卡丁车已经准备好了，但是我们少了一个轮子”": {
    "translation": "",
    "MultiLang": {
      "US": "\"The kart is ready, but we're missing a wheel.\"",
      "JP": "\"カートは準備できていますが、タイヤが1つ足りません\"",
      "CN": "",
      "KR": "\"카트가 준비되었지만, 바퀴 하나가 없습니다.\"",
      "TW": "\"卡丁車已經準備好了，但我們少了一個輪子\""
    }
  },
  "“请在广场上找到它并安装上去”": {
    "translation": "",
    "MultiLang": {
      "US": "\"Please find it in the square and install it.\"",
      "JP": "\"広場でそれを見つけて取り付けてください\"",
      "CN": "",
      "KR": "\"광장에서 그것을 찾아서 장착해 주세요.\"",
      "TW": "\"請在廣場上找到它並安裝上去\""
    }
  },
  "<<路将在20秒后开启>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<The path will open in 20 seconds>>",
      "JP": "<<道は20秒後に開きます>>",
      "CN": "",
      "KR": "<<로드가 20초 후 열립니다>>",
      "TW": "<<路將在20秒後開啟>>"
    }
  },
  "“成功找到了轮胎，现在让我们把它给装上”": {
    "translation": "",
    "MultiLang": {
      "US": "\"Successfully found the tire. Now, let's install it.\"",
      "JP": "\"タイヤが見つかりました。今度はこれを取り付けましょう\"",
      "CN": "",
      "KR": "\"타이어를 찾았으니, 이제 장착해 봅시다.\"",
      "TW": "\"成功找到了輪胎，現在讓我們把它給裝上\""
    }
  },
  "“起飞！”": {
    "translation": "",
    "MultiLang": {
      "US": "\"Take off!\"",
      "JP": "\"離陸！\"",
      "CN": "",
      "KR": "\"이륙!\"",
      "TW": "\"起飛！\""
    }
  },
  "<<僵尸将在10秒后传送>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<Zombies will teleport in 10 seconds>>",
      "JP": "<<ゾンビは10秒後にテレポートします>>",
      "CN": "",
      "KR": "<<좀비가 10초 후 전송됩니다>>",
      "TW": "<<殭屍將在10秒後傳送>>"
    }
  },
  "<<门将在30秒后打开>>": {
    "translation": "",
    "MultiLang": {
      "US": "The door will open in 30 seconds",
      "JP": "<<30秒後に門が開きます>>",
      "CN": "",
      "KR": "<<게이트가 30초 후 열립니다>>",
      "TW": "<<門將在30秒後打開>>"
    }
  }
}
