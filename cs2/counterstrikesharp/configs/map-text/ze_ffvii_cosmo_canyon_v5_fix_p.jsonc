{
  "**ZE_FFVII_COSMO_CANYON**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ZE_FFVII_COSMO_CANYON**",
      "CN": "**ZE_FFVII_COSMO_CANYON**",
      "KR": "**ZE_FFVII_COSMO_CANYON**",
      "TW": "**ZE_FFVII_COSMO_CANYON**"
    }
  },
  "**Map by Headshooter.SC & HaRyDe**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**Map by Headshooter.SC & HaRyDe**",
      "CN": "地图由Headshooter.SC与HaRyDe制作",
      "KR": "**Map by Headshooter.SC & HaRyDe**",
      "TW": "地圖由 Headshooter.SC 和 HaRyDe 製作"
    }
  },
  "**A player has picked up HEAL materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーが回復マテリアを拾った",
      "CN": "玩家已拾取恢复魔晶石",
      "KR": "플레이어가 치유 마테리아를 수집했습니다",
      "TW": "一名玩家拾取了 HP 魔晶石"
    }
  },
  "The rock will explode in 20 seconds": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "この岩は20秒後に爆発する",
      "CN": "岩石将在20秒后爆炸",
      "KR": "바위가 20초 후에 폭발합니다",
      "TW": "岩石將在 20 秒後爆炸"
    }
  },
  "Our suppliers are delivering TNT, so wait some time": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "仕入先からTNTが配送されているので、しばらく待ってください",
      "CN": "供应商正在运送TNT，请稍等片刻",
      "KR": "공급업체가 TNT를 배달 중이니 잠시만 기다려 주세요",
      "TW": "我們的供應商正在送達 TNT，請稍等片刻"
    }
  },
  "Oh shit, fucking jihadist blew himself up instead of giving us TNT": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ああだめだ、テロリストがTNTを渡す代わりに自爆した",
      "CN": "操，该死的圣战分子自爆了，而不是把TNT交给我们",
      "KR": "시발, 그 좆같은 이슬람 광신이 TNT를 대신 우리에게 주느라 자폭하고 말았군",
      "TW": "該死，個聖戰份子把自己炸飛了，而不是把 TNT 給我們"
    }
  },
  "So try another way, maybe break this rock with fists?": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "では別の方法を試してみよう。もしかして拳でこの岩を壊せるか？",
      "CN": "所以试试别的办法吧，也许用拳头砸开这块岩石？",
      "KR": "그럼 다른 방법을 시도해 보자. 아마도 이 바위를 주먹으로 부술 수 있겠지?",
      "TW": "所以試試其他方法吧，也許用拳頭打碎這塊岩石？"
    }
  },
  "** Teleporter will be ready in 20 seconds! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**传送门が20秒後に準備完了！**",
      "CN": "**传送门将在20秒后就绪！**",
      "KR": "**Teleporter will be ready in 20 seconds! **",
      "TW": "**傳送門將在 20 秒後就緒！**"
    }
  },
  "** Oh shit, we copypasted so much from westersand **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ああ、西部砂漠からコピペしすぎだ",
      "CN": "** 啊靠，我们从西域沙漠里复制粘贴得实在太多了 **",
      "KR": "** 와 shit, 위터샌드에서 너무 많이 복사했어 **",
      "TW": "該死，我們從西部沙漠複製貼了這麼多"
    }
  },
  "** Teleporter will be ready in 5 seconds! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "テレポート装置が5秒後に準備完了します！",
      "CN": "** 传送门将在5秒后就绪！**",
      "KR": "** 텔레포터가 5초 후에 준비됩니다! **",
      "TW": "傳送門將在5秒後就緒！"
    }
  },
  "** I told fucking HaRyDe to clean up the traces **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ハリーデに痕跡消去を頼んだはずだ",
      "CN": "** 我早就他妈告诉哈瑞德把痕迹清理干净了 **",
      "KR": "** 내가 해리데한테 흔적을 없애라고 말한 거야, 저 자식아 **",
      "TW": "我他媽告訴過 HaRyDe 去清除痕跡"
    }
  },
  "** But he is blind as hell **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "でも彼は目が見えないらしい",
      "CN": "** 但他瞎得像鬼一样 **",
      "KR": "** 하지만 그는 눈이 멀까 봐 너무 못 봐 **",
      "TW": "但他瞎得一塌糊塗"
    }
  },
  "** And Slayerdragon is on the way to find and kill us **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "スレイヤードラゴンが我々の居場所を突き止めて追跡中だ",
      "CN": "** 而 Slayerdragon 正在赶来找我们并杀了我们 **",
      "KR": "** 그리고 슬레이어드래곤은 우리를 찾아 죽이러 가는 중이야 **",
      "TW": "而 Slayerdragon 正在趕來找我們並殺死我們"
    }
  },
  "**A player has picked up EARTH materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーがEARTHマテリアを受け取りました",
      "CN": "** 一名玩家拾取了 EARTH 魔石**",
      "KR": "** 플레이어가 Earth 마테리아를 획득했습니다 **",
      "TW": "一名玩家拾取了地之魔晶石"
    }
  },
  "**A player has picked up GRAVITY materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーがGRAVITYマテリアを受け取りました",
      "CN": "** 一名玩家拾取了 GRAVITY 魔石**",
      "KR": "** 플레이어가 Gravity 마테리아를 획득했습니다 **",
      "TW": "一名玩家拾取了重力魔晶石"
    }
  },
  "**A player has picked up WIND materia**": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "プレイヤーがWINDマテリアを受け取りました",
      "CN": "** 一名玩家拾取了 WIND 魔石**",
      "KR": "** 플레이어가 Wind 마테리아를 획득했습니다 **",
      "TW": "一名玩家拾取了風之魔晶石"
    }
  }
