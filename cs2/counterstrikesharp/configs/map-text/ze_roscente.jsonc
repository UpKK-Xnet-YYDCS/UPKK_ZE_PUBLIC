  "** FOOLISH HUMAN. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 愚かな人間よ。 **",
      "CN": "** 愚蠢的人类。 **",
      "KR": "** 바보 같은 인간.**",
      "TW": "** 愚蠢的人類。**"
    }
  },
  "** TO THINK YOU CAN ESCAPE THAT VILLAGE. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** その村から逃げられると思ったのか。 **",
      "CN": "** 以为你能逃出那个村子。 **",
      "KR": "** 그리도 너는 그 마을에서 도망칠 수 있을 거라고 생각했군.**",
      "TW": "** 以為你能逃離那個村莊。**"
    }
  },
  "** HA. HA. HA. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ハッハッハ。 **",
      "CN": "** 呵。呵。呵。 **",
      "KR": "** 하. 하. 하. **",
      "TW": "** 哈。哈。哈。**"
    }
  },
  "** NOT LIKE YOU CAN DEFEAT ME. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 私に勝てる訳がないだろうが。 **",
      "CN": "** 你以为你能打败我吗。 **",
      "KR": "** 너는 나를 이길 수 없어.**",
      "TW": "** 以你當然是無法擊敗我的。**"
    }
  },
  "** Roscente. The Cosmic Wisp has awoken! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ロゼント。コスミック・ウィスプが覚醒した！ **",
      "CN": "** 罗森特。宇宙之光已苏醒！ **",
      "KR": "** 로센테. 우주 빛줄기가 깨어났다! **",
      "TW": "** 羅斯琴特。宇宙精靈甦醒了！**"
    }
  },
  "** REFRACTION SPLITTER **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 分光スプリッター **",
      "CN": "** 折射分光镜 **",
      "KR": "** 굴절 분할기 **",
      "TW": "** 折射分光器**"
    }
  },
  "** REALITY SLASHER **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** レイヤーカッター **",
      "CN": "** 现实斩击 **",
      "KR": "** 현실 가르기 **",
      "TW": "** 現實利刃**"
    }
  },
  "** SUNSTRIKE **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** サンストライク **",
      "CN": "** 阳光突袭 **",
      "KR": "** 태양 타격 **",
      "TW": "** 日冕風暴**"
    }
  },
  "** Roscente. The Cosmic Wisp has been defeated!  **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ロゼント。コスミック・ウィスプが倒された！ **",
      "CN": "** Roscente.宇宙光精已被击败！ **",
      "KR": "** 로센테. 우주 빛줄기가 패배했다! **",
      "TW": "** 羅斯琴特。宇宙精靈已被打敗！**"
    }
  },
