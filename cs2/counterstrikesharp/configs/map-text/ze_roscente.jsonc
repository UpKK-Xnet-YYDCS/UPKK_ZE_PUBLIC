  "** THIS ISNT MY FINAL FORM YET. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** これは私の最終形態ではない。 **",
      "CN": "** 这还不是我的最终形态。**",
      "KR": "** 이것就是我的 최종 형태는 아직 아니다. **",
      "TW": "** 這還不是我最終的形態。**"
    }
  },
  "** WORLD CHASM **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 世界欠陥 **",
      "CN": "** 世界深渊 **",
      "KR": "** 세계 심연 **",
      "TW": "** 世界裂縫**"
    }
  },
  "** CATACLYSM **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 大壊滅 **",
      "CN": "** 大灾变 **",
      "KR": "** 대재앙 **",
      "TW": "** 大災變**"
    }
  },
  "** SPACE WARP **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**スペースワープ**",
      "CN": "** 空间扭曲 **",
      "KR": "** 공간 왜곡 **",
      "TW": "** 空間扭曲 **"
    }
  },
  "** RISING GALE **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**ライジングゲール**",
      "CN": "** 狂风骤起 **",
      "KR": "** 상승하는 강풍 **",
      "TW": "** 颶風崛起 **"
    }
  },
  "** YOU SHOULD HAVE STAYED ON THAT VILLAGE.  **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**あの村に留まるべきだった。**",
      "CN": "**你本不该离开那个村庄。**",
      "KR": "** 당신이라면 그 마을에 남아 있었을 거야. **",
      "TW": "** 你應該留在那個村莊裡。**"
    }
  },
  "** WHO WOULD HAVE THOUGHT THAT YOU ARE STRONG.  **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**お前が如此まで強いとは誰が予想しただろうか。**",
      "CN": "**谁能想到你如此强大。**",
      "KR": "** 당신이 이렇게 강하리라 누가 생각했으리오. **",
      "TW": "** 誰會想到你會這麼強壯。**"
    }
  },
  "** I MIGHT BE FOOLISH BUT THIS IS NOT THE END. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**私は愚か者かもしれないが、これが終わりではない。**",
      "CN": "**我或许愚笨，但这并非终结。**",
      "KR": "** 나는 어리석을지 모르지만 이것은 끝이 아니다. **",
      "TW": "** 我可能很愚蠢，但這並非結局。**"
    }
  },
  "** I WILL BE BACK. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**必ず戻ってくる。**",
      "CN": "**我会回来的。**",
      "KR": "** 다시 돌아오겠다. **",
      "TW": "** 我會回來的。**"
    }
  },
  "** THE END. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "**エンディング。**",
      "CN": "**游戏结束。**",
      "KR": "**终幕. **",
      "TW": "** 結局。**"
    }
  },
