      "TW": "**再撐 15 秒。**"
    }
  },
  "** 15 seconds left! **": {
    "translation": "**还有15秒！**",
    "MultiLang": {
      "US": "",
      "JP": "残り15秒！",
      "CN": "** 剩余 15 秒！**",
