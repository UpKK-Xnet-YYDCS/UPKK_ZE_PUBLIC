{
  "\"Map created by MSR / Bart\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "MSR / Bart 作成のマップ",
      "CN": "地图由 MSR / Bart 创建",
      "KR": "MSR / Bart 제작 맵",
      "TW": "由 MSR / Bart 製作的地圖"
    }
  },
  "\"DOOR WILL BREAK IN 15 SECONDS\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアは15秒後に破壊される",
      "CN": "门将在15秒后破碎",
      "KR": "문 깨짐 15초 전",
      "TW": "門將於 15 秒後毀損"
    }
  },
  "\"DOOR IS OPEN!\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアは開いている！",
      "CN": "门已打开！",
      "KR": "문이 열렸습니다!",
      "TW": "門已打開！"
    }
  },
  "\"DEFEAT ALL THE POKEMONS IN THIS AREA TO UNLOCK THE PATH\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "このエリアのすべてのポケモンを撃破して道を開け",
      "CN": "击败该区域的所有精灵以解锁路径",
      "KR": "이 지역의 모든 포켓몬을 처치하여 길을 여세요",
      "TW": "擊敗此區域內的所有寶可夢以解鎖路径"
    }
  },
  "\"ZOMBIES WILL TELEPORT IN 10 SECONDS!\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビは10秒後にテレポートする！",
      "CN": "僵尸将在10秒后传送！",
      "KR": "좀비 teleporation 10초 전!",
      "TW": "殭屍將於 10 秒後傳送！"
    }
  },
  "\"ALL POKEMONS HAVE BEEN KILLED, PATH WILL OPEN IN 25 SECONDS\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "すべてのポケモンを倒した。道は25秒後に開く",
      "CN": "所有精灵已被消灭，路径将在25秒后开启",
      "KR": "모든 포켓몬이 처치되었습니다, 길이 25초 후 열립니다",
      "TW": "所有寶可夢已被擊殺，路径將於 25 秒後開啟"
    }
  },
  "\"PATH IS OPEN\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "道は開いている",
      "CN": "路径已开启",
      "KR": "길이 열렸습니다",
      "TW": "路径已開啟"
    }
  },
  "\"SNORLAX IS BLOCKING OUR WAY, KILL HIM!\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "スリープが道を塞いでいる、倒せ！",
      "CN": "卡比挡住了我们的去路，消灭它！",
      "KR": "스노락이 길을 막고 있습니다, 저를 처치하세요!",
      "TW": "小卡比獸擋住了去路，擊殺它！"
    }
  },
  "\"SNORLAX IS USING SNORE\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "スリープを使っている",
      "CN": "卡比兽正在使用睡觉",
      "KR": "카비곤 코골이를 사용 중",
      "TW": "小拳石正在睡覺"
    }
  },
  "\"SNORLAX HAVE BEEN KILLED\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "スリープは倒された",
      "CN": "卡比兽已被击败",
      "KR": "카비고가 쓰러졌다",
      "TW": "小拳石已被擊殺"
    }
  },
  "\"POKEMON CENTER HAVE OPENED\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ポケモンセンターがオープンした",
      "CN": "宝可梦中心已开放",
      "KR": "포켓몬센터가 개장되었다",
      "TW": "寶可夢中心已開啟"
    }
  },
  "\"YOU CAN HEAL UP AT THE POKEMON CENTER\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ポケモンセンターで回復できる",
      "CN": "您可以在宝可梦中心恢复体力",
      "KR": "포켓몬센터에서HP를 회복할 수 있다",
      "TW": "你可以在寶可夢中心恢復體力"
    }
  },
  "\"DEFEAT ALL THE POKEMONS IN THIS AREA TO UNLOCK THE GUARD DOOR\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "このエリアのすべてのポケモンを倒すとガードドアが開く",
      "CN": "击败此区域的所有宝可梦以解锁守卫门",
      "KR": "이 지역의 모든 포켓몬을 물리쳐 가드 도어를 잠금 해제하라",
      "TW": "擊敗此區域內的所有寶可夢以解除守衛門的封印"
    }
  },
  "\"ZOMBIES WILL TELEPORT IN 10 SECONDS\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビーが10秒以内にテレポートする",
      "CN": "僵尸将在10秒后传送出现",
      "KR": "10초 후에 좀비가 텔레포트한다",
      "TW": "殭屍將在10秒後進行傳送"
    }
  },
  "\"ALL POKEMONS HAVE BEEN KILLED,GUARD  DOOR WILL OPEN IN 30 SECONDS\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "すべてのポケモンが倒された、30秒後にガードドアが開く",
      "CN": "所有宝可梦已被击败，守卫门将在30秒后开启",
      "KR": "모든 포켓몬이 쓰러졌다, 가드 도어가 30초 후에 열린다",
      "TW": "所有寶可夢已被擊殺，守衛門將在30秒後開啟"
    }
  },
  "\"GUARD DOOR IS OPEN\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ガードドアが開いた",
      "CN": "守卫门已开启",
      "KR": "가드 도어 열림",
      "TW": "守衛門已開啟"
    }
  },
  "\"GYM WILL OPEN IN 30 SECONDS!\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ジムが30秒後に開放されます！",
      "CN": "体育馆将在30秒后开放！",
      "KR": "30초 안에 체육관이 개방됩니다!",
      "TW": "道館將在30秒後開放！"
    }
  },
  "\"REMEMBER TO HEAL UP AT THE POKEMON CENTER\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ポケモンセンターでHPを回復することを忘れずに",
      "CN": "记得去宝可梦中心恢复体力。",
      "KR": "포켓몬 센터에서 HP를 회복하는 것을 잊지 마세요",
      "TW": "記得去寶可夢中心治療宝可夢"
    }
  },
  "\"GYM IS OPEN\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ジムが開放されました",
      "CN": "体育馆已开放",
      "KR": "체육관 개방!",
      "TW": "道館已開放"
    }
  },
  "\"HOLD FOR 20 SECONDS\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "20秒間押し続ける",
      "CN": "保持20秒",
      "KR": "20초 동안 유지하세요",
      "TW": "請持續按下按鈕20秒"
    }
  },
  "\"FALKNER IS CHALLENGING YOU\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "フォークンが挑戦してきた",
      "CN": "阿笔向你发起挑战",
      "KR": "팔커너가 당신을 도전자로 맞이합니다",
      "TW": "小勝正在挑戰你"
    }
  },
  "\"FALKNER IS PICKING PIDGEOTTO\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "フォークンはピジョンを選んだ",
      "CN": "阿笔选择了大比鸟",
      "KR": "팔커너는 피지otto를 선택했습니다",
      "TW": "小勝選擇了強顎雞黃蟹"
    }
  },
  "\"PIDGEOTTO IS USING WIND ATTACK. HOLD W\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ピジョンがかまいつずきを使う。Ｗボタンを押し続ける",
      "CN": "大比鸟使用顺风攻击。按住W键",
      "KR": "피지otto가 바람 공격을 사용합니다. W를 누르세요",
      "TW": "強顎雞黃蟹使用風暴！請持續按下W鍵"
    }
  },
  "\"PIDGEOTTO IS USING WING ATTACK\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ピジョンがはね攻めを使う",
      "CN": "大比鸟使用羽栖攻击",
      "KR": "피지otto가 날개공격을 사용합니다",
      "TW": "強顎雞黃蟹使用羽擊"
    }
  },
  "\"PIDGEOTTO IS DEFEATED\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ピジョンオーが倒れた",
      "CN": "比雕倒下",
      "KR": "\"삐죳토가 쓰러졌다\"",
      "TW": "比卡丘被擊敗"
    }
  },
  "\"STAGE COMPLETE, MORE WILL BE ADDED IN THE FUTURE\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ステージクリア。今後さらに追加予定",
      "CN": "关卡完成，后续将追加更多内容",
      "KR": "\"스테이지 클리어. 추후 업데이트 예정\"",
      "TW": "階段完成，未來將新增更多內容"
    }
  },
  "\"MAP IS OVER, RTV\"": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "マップ終了、RTV",
      "CN": "地图结束，投降吧",
      "KR": "\"맵을 벗어나겠습니다. RTV\"",
      "TW": "地圖已結束，請投降"
    }
