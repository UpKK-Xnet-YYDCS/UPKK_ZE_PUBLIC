    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "値 1",
      "CN": "值 1",
      "KR": "값 1",
      "TW": "數值 1"
    }
  },
  "value 0": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "値 0",
      "CN": "值 0",
      "KR": "값 0",
      "TW": "數值 0"
    }
  },
  "切换单路成功": {
    "translation": "",
    "MultiLang": {
      "US": "Switched to single lane successfully",
      "JP": "単一パスの切り替えに成功しました",
      "CN": "",
      "KR": "단일 경로 전환 성공",
      "TW": "切換單線成功"
    }
  },
  "传送点2": {
    "translation": "",
    "MultiLang": {
      "US": "Teleport Point 2",
      "JP": "テレポートポイント2",
      "CN": "",
      "KR": "이동 지점 2",
      "TW": "傳送點2"
    }
  },
  "传送点1": {
    "translation": "",
    "MultiLang": {
      "US": "Teleport Point 1",
      "JP": "テレポートポイント1",
      "CN": "",
      "KR": "이동 지점 1",
      "TW": "傳送點1"
    }
  },
  "*大门将在15秒后开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The gate will open in 15 seconds*",
      "JP": "*巨大な扉は15秒後に開きます*",
      "CN": "",
      "KR": "*대문이 15초 후에 열립니다*",
      "TW": "*大門將在15秒後開啟*"
    }
  },
  "*门将在20秒后破碎*": {
    "translation": "",
    "MultiLang": {
      "US": "*The door will shatter in 20 seconds*",
      "JP": "*ドアは20秒後に砕けます*",
      "CN": "*守门员在20秒后破碎*",
      "KR": "*문은 20초 후에 부서집니다*",
      "TW": "*門將在20秒後破碎*"
    }
  },
  "*幸存者？不对，去捡起那把火箭发射器，或许对我们有用...*": {
    "translation": "",
    "MultiLang": {
      "US": "*Survivor? No, go pick up that rocket launcher; it might be useful to us.*",
      "JP": "*生存者？違う、あのロケットランチャーを拾うんだ。もしかしたら役立つかもしれない...*",
      "CN": "",
      "KR": "*생존자? 아니다. 로켓 발사기를 줍자. 우리에게 도움이 될 거야...*",
      "TW": "*倖存者？不對，去捡起那把火箭發射器，或許對我們有用...*"
    }
  },
  "*下一个门将在10秒后开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The next gate will open in 10 seconds*",
      "JP": "*次の扉は10秒後に開きます*",
      "CN": "",
      "KR": "*다음 문이 10초 후에 열립니다*",
      "TW": "下一扇門將在10秒後開啟"
    }
  },
  "*一楼实验室门已开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*First floor lab door has been opened*",
      "JP": "*1階の研究室のドアが開きました*",
      "CN": "",
      "KR": "*1층 연구소 문이 열렸습니다*",
      "TW": "一樓實驗室門已開啟"
    }
  },
  "*拿上这件防护服！他搭载了科研部研发的补给系统*": {
    "translation": "",
    "MultiLang": {
      "US": "*Take this suit! It's equipped with a supply system developed by the Science Division.*",
      "JP": "*この防護服を持って！科研部が開発した補給システムを搭載しています*",
      "CN": "",
      "KR": "*이 방호복을 입으십시오! 연구부에서 개발한 보급 시스템을 탑재했습니다*",
      "TW": "穿戴這件防護服！它搭載了科研部研發的補給系統"
    }
  },
  "*地下实验室大门已开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The underground laboratory gate has opened.*",
      "JP": "*地下研究室の大门が開きました*",
      "CN": "",
      "KR": "*지하 연구소 정문이 열렸습니다*",
      "TW": "地下實驗室大門已開啟"
    }
  },
  "*大门将在10秒后开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The gate will open in 10 seconds.*",
      "JP": "*扉は10秒後に開きます*",
      "CN": "",
      "KR": "*본관이 10초 후에 열립니다*",
      "TW": "大門將在10秒後開啟"
    }
  },
  "*通向车站的门将在10秒后开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The door to the station will open in 10 seconds.*",
      "JP": "*駅への扉は10秒後に開きます*",
      "CN": "",
      "KR": "*역으로 가는 문이 10초 후에 열립니다*",
      "TW": "通往車站的門將在10秒後開啟"
    }
  },
  "*小心！这辆车失控了！快过桥！*": {
    "translation": "",
    "MultiLang": {
      "US": "*Caution! This vehicle is out of control! Cross the bridge now!*",
      "JP": "*注意！この車両の制御が効きません！すぐに橋を渡ってください*",
      "CN": "",
      "KR": "*조심하세요! 이 차가 조종 불가능해졌습니다! 빠르게 다리를 건너세요!*",
      "TW": "小心！這輛車失控了！快過橋！"
    }
  },
  "*通往排水系统的门将在10秒后破碎*": {
    "translation": "",
    "MultiLang": {
      "US": "*The door to the drainage system will break in 10 seconds.*",
      "JP": "*排水管への扉は10秒後に壊れます*",
      "CN": "",
      "KR": "*배수 시스템으로 가는 문이 10초 후에 깨어집니다*",
      "TW": "通往排水系統的門將在10秒後破碎"
    }
  },
  "*通往电梯的门将在10秒后开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The door to the elevator will open in 10 seconds.*",
      "JP": "*エレベーターへの扉は10秒後に開きます*",
      "CN": "",
      "KR": "*엘리베이터로 가는 문이 10초 후에 열립니다*",
      "TW": "*通往電梯的門將在10秒後開啟*"
    }
  },
  "*电梯门将在10秒后开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The elevator doors will open in 10 seconds.*",
      "JP": "*エレベーターの扉は10秒後に開きます*",
      "CN": "",
      "KR": "*엘리베이터 문이 10초 후에 열립니다*",
      "TW": "*電梯門將在10秒後開啟*"
    }
  },
  "指挥部：你们将在蓄水系统控制站处短暂汇合，之后你们必须同时清理排风系统与水下观测站内的感染者，确保两处系统能够正常运转。": {
    "translation": "",
    "MultiLang": {
      "US": "Command: You will briefly rendezvous at the Reservoir Control Station. Afterward, you must simultaneously eliminate infected in both the Ventilation System and the Underwater Observation Station to ensure both systems are operational.",
      "JP": "指揮本部：給水システム管理ステーションで一旦合流後、換気系統と水下観測施設の感染者を同時に除去し、両施設の正常な稼働を保証してください。",
      "CN": "",
      "KR": "사령부: 여러분은 저수 시스템 통제 관에서 잠시 합류한 후, 배기 시스템과 수중 관측실의 감염자를 동시에 처리하여 두 시스템이 정상 작동하도록 보장해야 합니다.",
      "TW": "指揮部：你們將在蓄水系統控制站處短暫匯合，之後你們必須同時清理排風系統與水下觀測站內的感染者，確保兩處系統能夠正常運轉。"
    }
  },
  "*通往排风系统的大门将在15秒后开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The door to the Ventilation System will open in 15 seconds.*",
      "JP": "*換気系統への扉は15秒後に開きます*",
      "CN": "",
      "KR": "*배기 시스템으로 가는 문이 15초 후에 열립니다*",
      "TW": "*通往排風系統的大門將在15秒後開啟*"
    }
  },
  "*排风系统好像失控了，赶快离开这里！（15秒）*": {
    "translation": "",
    "MultiLang": {
      "US": "*The Ventilation System seems to be malfunctioning. Leave immediately! (15s)*",
      "JP": "*換気系統の制御が失われています、速やかにここを離れてください！（15秒）*",
      "CN": "",
      "KR": "*배기 시스템이 오류가 발생했습니다! 여기를 신속히撤离하십시오! (15초)*",
      "TW": "*排風系統好像失控了，趕快離開這裡！（15秒）*"
    }
  },
  "*通往下一个区域的大门将在15秒后开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The door to the next area will open in 15 seconds.*",
      "JP": "*次のエリアへの扉は15秒後に開きます*",
      "CN": "",
      "KR": "*다음 지역으로 가는 문이 15초 후에 열립니다*",
      "TW": "*通往下一個區域的大門將在15秒後開啟*"
    }
  },
  "指挥部：对你们而言简直轻而易举": {
    "translation": "",
    "MultiLang": {
      "US": "Command: Piece of cake for you.",
      "JP": "指揮本部：あなたたちにとって簡単な作業だ",
      "CN": "指挥部：对于你们来说简直轻而易举",
      "KR": "사령부: 귀하에게겐 아주 쉬운 일입니다",
      "TW": "指揮部：對你們而言簡直輕而易舉"
    }
  },
  "*通往下一个区域的大门将在10秒后开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The door to the next area will open in 10 seconds.*",
      "JP": "*次のエリアへの扉は10秒後に開きます*",
      "CN": "",
      "KR": "*다음 지역으로 가는 문이 10초 후에 열립니다*",
      "TW": "*通往下一個區域的大門將在10秒後開啟*"
    }
  },
  "*对面的门打不开！我在地板上安置了粘性炸药，马上就能炸开一条路*": {
    "translation": "",
    "MultiLang": {
      "US": "*The door on the other side won't open! I've placed adhesive explosives on the floor; it will blow a path open momentarily.*",
      "JP": "*向こうの扉が開かない！床に粘着式爆薬を仕掛けたから、すぐに爆破して道を開けるよ*",
      "CN": "",
      "KR": "*맞은편 문이 열리지 않네요! 바닥에 접착성 폭발물을 설치했으니 곧 길을 뚫을 수 있습니다.*",
      "TW": "*對面的門打不開！我在地板上安置了黏性炸藥，馬上就能炸開一條路*"
    }
  },
  "*第二小队通往列车的大门已经开启*": {
    "translation": "",
    "MultiLang": {
      "US": "*The door to the train for Squad Two has opened.*",
      "JP": "*第2小隊用列車の扉が開いた*",
      "CN": "",
      "KR": "*제2소대 열차 도어가 이미 개방되었습니다.*",
      "TW": "*第二小隊通往列車的大門已經開啟*"
    }
  },
  "*你们听到什么声音了吗？*": {
    "translation": "",
    "MultiLang": {
      "US": "*Did you hear that sound?*",
      "JP": "*何か音聞こえた？*",
      "CN": "",
      "KR": "*뭔가 소리가 들리지 않나요?*",
      "TW": "*你們聽到什麼聲音了嗎？*"
    }
  },
  "*我去！另一辆列车要和我们相撞了！快下车！*": {
    "translation": "",
    "MultiLang": {
      "US": "*Damn it! Another train is heading straight for us! Get off immediately!*",
      "JP": "*きゃっ！もう一本の列車と激突する！急いで降りて！",
      "CN": "*我去！又有1列列车要和我们相撞了！快下车！*",
      "KR": "씨발! 다른 열차가 우리랑 충돌할 거야! 얼른 내려!",
      "TW": "我去！另一列列車要和我們相撞了！快下車！*"
    }
  },
  "*我依稀记得基地内有一处发射井，那里安置着AFTERGLOW（余晖）卫星系统的终端，应该可以取得与外界的联系...*": {
    "translation": "",
    "MultiLang": {
      "US": "*I faintly remember there’s a launch silo within the base, housing the terminal for the AFTERGLOW satellite system. It should allow us to establish contact with the outside world...*",
      "JP": "*基地内に発射井があったはずだ…そこでAFTERGLOW（余晖）衛星システムの端末にアクセスすれば、外部と連絡が取れるかも…*",
      "CN": "",
      "KR": "*기지에 발사정이 하나 있던 것 같은데요, 거기에 AFTERGLOW(아터글로) 위성 시스템의 단말기가 있어서 외부와 연락할 수 있을 것 같아요...*",
      "TW": "*我依稀記得基地內有一處發射井，那裡安置著 AFTERGLOW（餘暉）衛星系統的終端，應該可以取得與外界的联系...*"
    }
  },
  "*不过，我们必须穿过科研设施，那里危机四伏，可能存在着未知的威胁。*": {
    "translation": "",
    "MultiLang": {
      "US": "*However, we must cross the research facility. It’s fraught with danger and may harbor unknown threats.*",
      "JP": "*ただし、研究施設を通り抜ける必要がある。危険がいっぱいで、未知の脅威が潜んでいる可能性もあるんだ。*",
      "CN": "",
      "KR": "*하지만 연구 시설을 통과해야 하는데, 위기가 도사리고 있고 알 수 없는 위협이 있을 수도 있습니다.*",
      "TW": "*不過，我們必須穿過科研設施，那裡危機四伏，可能存在著未知的威脅。*"
    }
  },
  "*愿武运昌隆...*": {
    "translation": "",
    "MultiLang": {
      "US": "*May fortune favor you...*",
      "JP": "*武運を祈る…*",
      "CN": "",
      "KR": "*무운을 빕니다...*",
      "TW": "*願武運昌隆...*"
    }
  },
  "*Hammond队长！终于见到你了！你们是否也与指挥部失去了联系...*": {
    "translation": "",
    "MultiLang": {
      "US": "Captain Hammond! It’s about time I saw you! Have you also lost contact with command...*",
      "JP": "*ハモンド隊長！ようやく会えた！お前たちも司令部と連絡が途絶えてるか…*",
      "CN": "哈蒙德队长！终于见到你了！你们是否也与指挥部失去联系...",
      "KR": "해몬드 대장! 드디어 발견했네요! 혹시指挥部와 연락이 끊기셨나요...",
      "TW": "*Hammond 隊長！終於見到你瞭！你們是否也與指揮部失去了聯繫...*"
    }
  },
  "*快上电梯！*": {
    "translation": "",
    "MultiLang": {
      "US": "*Hurry, get on the elevator!*",
      "JP": "*エレベータに乗って早く！*",
      "CN": "",
      "KR": "*빨리 엘리베이터로 가!*",
      "TW": "*快上電梯！*"
    }
  },
  "*这是什么？AURORA在研究这种生物？他看似不属于这个世界...*": {
    "translation": "",
    "MultiLang": {
      "US": "*What is this? AURORA was studying this creature? It appears to not belong to our world...*",
      "JP": "これは何か？オーロラがこれを研究しているのか？この生物は、どうやらこの世界出身ではないようだ…",
      "CN": "",
      "KR": "이건 뭐지? 오로라가 이 생물을 연구중인가? 그는 분명 이 세계의 존재가 아닌 것 같군...",
      "TW": "*這是什麼？AURORA在研究這種生物？他看似不屬於這個世界……*"
    }
  },
  "*快看！他似乎没有陷入沉睡...他似乎在蓄力预谋着什么...！！！他要攻击我们！！快趴下！*": {
    "translation": "",
    "MultiLang": {
      "US": "*Look! He doesn't seem to be in a deep sleep... He appears to be charging up for something premeditated...!!! He's going to attack us!! Get down quickly!*",
      "JP": "見て！彼は眠り落ちていない…エネルギーを溜めて何かを狙っている…！！！私たちに襲いかかってくる！早く伏せ！",
      "CN": "",
      "KR": "조심해! 그는 잠들지 않은 것 같아... 뭔가 모으고 있는 듯해...!!! 우리를 공격하려 해! 엎드려!",
      "TW": "*快看！他似乎沒有陷入沉睡……他似乎在蓄力預謀著什麼……！！！他要攻擊我們！！快趴下！*"
    }
  },
  "*这里好冷，应该是冷冻室，左边有控制电力的系统，不过那里的水好像泄露了...*": {
    "translation": "",
    "MultiLang": {
      "US": "It's so cold here, it must be a cryogenic chamber. There's an electrical control system on the left, but it seems like water has leaked there...",
      "JP": "ここはすごく冷たい。冷凍室だね。左側に電力制御システムがあるけど、あの場所の水量が漏れ出してるみたい…",
      "CN": "",
      "KR": "여기 너무나 춥군, 냉동실 같은데. 왼쪽에 전력 제어 시스템이 있어. 그런데 거기서 물이 새어나오는 것 같아...",
      "TW": "*這裡好冷，應該是冷凍室，左邊有控制電力的系統，不過那裡的水好像洩漏了……*"
    }
  },
  "（滋滋声）“指挥部”：衔尾蛇，收到请回应...": {
    "translation": "",
    "MultiLang": {
      "US": "Static noise) \"Command\": Ouroboros, copy? Please respond...",
      "JP": "（チチ音）『コマンド』：オーロボーロス、受信確認を……",
      "CN": "",
      "KR": "(지직거리는 소리) \"지휘본부\": 명목상 타오우베이는, 응답을 바랍니다...",
      "TW": "（滋滋聲）「指揮部」：銜尾蛇，收到請回應……"
    }
  },
  "指挥部”：你们必须去往核心区域，摧毁那里的中控系统，抑制核心的能量过载...": {
    "translation": "",
    "MultiLang": {
      "US": "\"Command\": You must head to the core area and destroy the central control system there to suppress the core's energy overload...",
      "JP": "\"指揮所\"：あなたは核心区域へ向かい、那里的中央制御システムを破壊し、コアのエネルギー過負荷を抑制しなければならない...",
      "CN": "",
      "KR": "\"지휘본부\": 당신은 핵심구역으로 가야합니다. 그곳의 중앙 제어 시스템을 파괴하여 코어의 에너지 과부하를 억제하십시오...",
      "TW": "「指揮部」：你們必須前往核心區域，摧毀那裡的中控系統，抑制核心的能量過載……"
    }
  },
  "*指挥部！连接恢复了吗，我们原本还想去发射井...*": {
    "translation": "",
    "MultiLang": {
      "US": "*Command, is the connection restored? We originally planned to go to the launch silo...*",
      "JP": "指揮部！接続は回復しましたか？当初は发射井へ向かおうとしていましたが…",
      "CN": "*指挥部！连接恢复了吗？我们本来还想发射...*",
      "KR": "*지휘본부! 연결이 복구되었나요? 원래 우리는 발사장으로 향하려고 했어...*",
      "TW": "*指揮部！連接恢復了嗎，我們原本還想去發射井……*"
    }
  },
  "“指挥部”：立刻向核心区域进发，我们的卫星会实时向我们汇报能量波动参数，务必将其恢复到常态区间...（结束通话）": {
    "translation": "",
    "MultiLang": {
      "US": "\"Command\": Proceed to the core area immediately. Our satellites will report energy fluctuation parameters in real-time. You must restore them to the normal range... (Transmission ends)",
      "JP": "「指揮所」：直ちにコアエリアへ進軍せよ。衛星がエネルギー変動パラメータをリアルタイムで報告する。必ず平常値範囲へ回復させろ…（通話終了）",
      "CN": "",
      "KR": "\"지휘본부\": 즉시 핵심구역으로 이동하십시오. 우리는 위성이 에너지 변동 매개변수를 실시간으로 보고할 것입니다. 반드시 정상 범위 안으로 복귀시킵니다... (전송 종료)",
      "TW": "「指揮部」：立即向核心區域進發，我們的衛星會實時回報能量波動參數，務必將其恢復到常態區間……（結束通話）"
    }
  },
  "*...收到，立刻执行...*": {
    "translation": "",
    "MultiLang": {
      "US": "...Copy that. Executing immediately...",
      "JP": "……了解、ただちに実行……",
      "CN": "",
      "KR": "*...수령, 즉시 실행...*",
      "TW": "*...收到，立即執行...*"
    }
  }
}
