  "还有10秒": {
    "translation": "",
    "MultiLang": {
      "US": "10 seconds left",
      "JP": "残り10秒",
      "CN": "",
      "KR": "남은 시간 10초",
      "TW": "還有10秒。"
    }
  },
  "行动开始": {
    "translation": "",
    "MultiLang": {
      "US": "Action commences now",
      "JP": "作戦開始",
      "CN": "",
      "KR": "작전 개시",
      "TW": "行動開始。"
    }
  },
  "坚守60秒": {
    "translation": "",
    "MultiLang": {
      "US": "Hold for 60 seconds",
      "JP": "60秒間の防衛",
      "CN": "",
      "KR": "60초 버텨내기",
      "TW": "堅守60秒。"
    }
  },
  "门开了快走！！！": {
    "translation": "",
    "MultiLang": {
      "US": "The door is open. Move out!",
      "JP": "扉が開いた！速やかに移動！！！",
      "CN": "",
      "KR": "문이 열렸습니다.赶紧 빠르세요!!!",
      "TW": "門開了，快走！"
    }
  },
  "坚守65秒！！！撑住我们才刚刚开始": {
    "translation": "",
    "MultiLang": {
      "US": "Hold for 65 seconds! Hang in there, we've only just begun",
      "JP": "65秒間耐え切れ！！！我々の戦いはまだ始まったばかりだ",
      "CN": "",
      "KR": "65초 버텨내기!!! 끝이 아닙니다, 우리는 시작뿐입니다",
      "TW": "堅守65秒！！撐住，我們才剛剛開始。"
    }
  },
  "门开了撤退": {
    "translation": "",
    "MultiLang": {
      "US": "The door is open. Retreat.",
      "JP": "扉が開き退却",
      "CN": "",
      "KR": "문이 열렸습니다. 철수하세요.",
      "TW": "門開了，撤退。"
    }
  },
  "快跳上去！": {
    "translation": "",
    "MultiLang": {
      "US": "Jump up quickly!",
      "JP": "早く上に！",
      "CN": "",
      "KR": "빨리 뛰어올라요!",
      "TW": "快跳上去！"
    }
  },
  "找到三个按钮": {
    "translation": "",
    "MultiLang": {
      "US": "Find three buttons",
      "JP": "3つのボタンを見つける",
      "CN": "",
      "KR": "세 개의 버튼을 찾아라",
      "TW": "找到三個按鈕"
    }
  },
  "快滑还有105秒": {
    "translation": "",
    "MultiLang": {
      "US": "The glide has 105 seconds left",
      "JP": "スライド開始まで残り105秒",
      "CN": "",
      "KR": "슬라이드까지 105초 남았음",
      "TW": "快滑還有105秒"
    }
  },
  "喜欢刷？那就刷他  还有1分30秒": {
    "translation": "",
    "MultiLang": {
      "US": "Like gliding? Then keep going. 1 minute 30 seconds remaining.",
      "JP": "スキルが気に入った？じゃあこれ！残り1分30秒",
      "CN": "",
      "KR": "미끄러지는 게 좋니? 미끄러라, 1분 30초 남았음",
      "TW": "喜歡刷？那就刷他  還有1分30秒"
    }
  },
  "温馨小提示不去后面是不会触发传送的": {
    "translation": "",
    "MultiLang": {
      "US": "Heads up: If you don't go to the back, the teleport won't trigger.",
      "JP": "ちょっとしたヒント：後ろに行かないとテレポートは発動しません",
      "CN": "",
      "KR": "작은 팁: 뒤로 가지 않으면 텔레포테이션이 발동되지 않습니다",
      "TW": "溫馨小提示不去後面是不會觸發傳送的"
    }
  },
  "不要偷跑哦~~~": {
    "translation": "",
    "MultiLang": {
      "US": "Don't start early~~~",
      "JP": "先を急がないでね~~~",
      "CN": "",
      "KR": "달려가지 마세요~~~",
      "TW": "不要偷跑哦~~~"
    }
  },
  "门开了快走": {
    "translation": "",
    "MultiLang": {
      "US": "The door is open, let's move.",
      "JP": "ドアが開いた！早く行って！",
      "CN": "",
      "KR": "문이 열렸습니다, 빨리 가세요",
      "TW": "門開了快走"
    }
  },
  "欣赏一下校长的花园吧马上就要撤离了": {
    "translation": "",
    "MultiLang": {
      "US": "Enjoy the principal's garden. Evacuation is imminent.",
      "JP": "校長の庭園を堪能してください。もう間もなく撤退です",
      "CN": "",
      "KR": "총장님의 정원을 감상하세요. 곧 대피합니다",
      "TW": "欣賞一下校長的花園吧马上就要撤離了"
    }
  },
  "对了坚持50秒哦~": {
    "translation": "",
    "MultiLang": {
      "US": "By the way, hold on for 50 seconds~",
      "JP": "あと、50秒は耐えてね~",
      "CN": "",
      "KR": "그리고 50초 버티세요~",
      "TW": "對了堅持50秒哦~"
    }
  },
  "最后一个！坚持40秒！": {
    "translation": "",
    "MultiLang": {
      "US": "Last one! Hold out for 40 seconds!",
      "JP": "最後の一息！40秒持ち堪えろ！",
      "CN": "",
      "KR": "마지막이다! 40초 버텨내!",
      "TW": "最後一個！堅持40秒！"
    }
  },
  "道具全交！！！！！！！守住！！！！": {
    "translation": "",
    "MultiLang": {
      "US": "Give all your items!!!!!! Hold the line!!!!",
      "JP": "アイテム全開放！！！！！守り通せ！！！！！",
      "CN": "",
      "KR": "모든 아이템 사용해!!!!!!! 지켜내!!!!",
      "TW": "道具全交！！！！！！！守住！！！！"
    }
  },
  "我们安全了欢迎回家": {
    "translation": "",
    "MultiLang": {
      "US": "We're safe. Welcome home.",
      "JP": "安全確保完了。お帰りなさい。",
      "CN": "",
      "KR": "안전해졌어. 집으로 돌아오신 걸 환영합니다.",
      "TW": "我們安全了歡迎回家"
    }
  },
  "感谢大家游玩作者：一只秋": {
    "translation": "",
    "MultiLang": {
      "US": "Thanks for playing! Developer: Yi Zhi Qiu",
      "JP": "ごプレイありがとうございます。制作：一匹の秋",
      "CN": "",
      "KR": "모두께 감사드립니다. 작가: 한 마리의 가을",
      "TW": "感謝大家遊玩作者：一隻秋"
    }
  },
  "感谢常正类人": {
    "translation": "",
    "MultiLang": {
      "US": "Special thanks to Chang Zheng Lei Ren",
      "JP": "感謝常正類人",
      "CN": "",
      "KR": "창정 류인에게 감사를 드립니다.",
      "TW": "感謝常正類人"
    }
  },
  "琪亚娜": {
    "translation": "",
    "MultiLang": {
      "US": "Kiana",
      "JP": "キアナ",
      "CN": "",
      "KR": "키아나",
      "TW": "琪亞娜"
    }
  },
  "一曲悲歌照幽梦": {
    "translation": "",
    "MultiLang": {
      "US": "A mournful song echoes through dark dreams.",
      "JP": "一曲の悲歌、幽かな夢を照らす",
      "CN": "",
      "KR": "슬픈 노래가 어둠 속 꿈에 비추네",
      "TW": "一曲悲歌照幽夢"
    }
  },
  "香香阿花": {
    "translation": "",
    "MultiLang": {
      "US": "Xiangxiang Ahua",
      "JP": "香香アーファ",
      "CN": "",
      "KR": "샹샹 아화",
      "TW": "香香阿花"
    }
  },
  "科比布莱恩": {
    "translation": "",
    "MultiLang": {
      "US": "Kobe Bryant",
      "JP": "コービー・ブライアント",
      "CN": "",
      "KR": "코비 브라이언트",
      "TW": "科比·布萊恩"
    }
  },
  "炫叽歪": {
    "translation": "",
    "MultiLang": {
      "US": "Xuanjiwai",
      "JP": "せんぎわい",
      "CN": "",
      "KR": "현지위",
      "TW": "炫叽歪"
    }
  },
  "樱落": {
    "translation": "",
    "MultiLang": {
      "US": "Sakura Fall",
      "JP": "さくらおとる",
      "CN": "",
      "KR": "영락",
      "TW": "櫻落"
    }
  },
  "柑龙": {
    "translation": "",
    "MultiLang": {
      "US": "Ganlong",
      "JP": "かんりゅう",
      "CN": "",
      "KR": "귤룡",
      "TW": "柑龍"
    }
  },
  "接下来出发吧": {
    "translation": "",
    "MultiLang": {
      "US": "Let's set off now.",
      "JP": "次は出発だ",
      "CN": "",
      "KR": "자, 출발하자.",
      "TW": "接下來出發吧"
    }
  },
  "等等你们队友不要抛弃他们": {
    "translation": "",
    "MultiLang": {
      "US": "Wait, don't abandon your teammates.",
      "JP": "待って、チームメイトを見捨てないでください",
      "CN": "",
      "KR": "잠깐, 팀원들을 버리지 마라.",
      "TW": "等等你們隊友不要拋棄他們"
    }
  },
  "有人触发了！！！": {
    "translation": "",
    "MultiLang": {
      "US": "Someone triggered it!!!",
      "JP": "誰かがトリガーを発動させた！",
      "CN": "",
      "KR": "누군가 트리거를 발동시켰다!!!",
      "TW": "有人觸發了！！！"
    }
  },
  "还有40秒": {
    "translation": "",
    "MultiLang": {
      "US": "40 seconds remaining",
      "JP": "残り40秒",
      "CN": "",
      "KR": "남은 시간 40초",
      "TW": "還有40秒"
    }
  },
  "僵尸10秒传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies teleport in 10 seconds",
      "JP": "ゾンビは10秒後にテレポート",
      "CN": "",
      "KR": "좀비 10초 후 텔레포트",
      "TW": "殭屍将在10秒後傳送"
    }
  },
  "门开了不要上去等等队友": {
    "translation": "",
    "MultiLang": {
      "US": "Door opened. Wait for teammates before entering.",
      "JP": "ドアが開いても上がらず、チームメイトを待て",
      "CN": "",
      "KR": "문이 열려도 올라가지 말고 팀원 기다리기",
      "TW": "門打開時不要靠近，請等待隊友"
    }
  },
  "快滑坚守60秒": {
    "translation": "",
    "MultiLang": {
      "US": "Hold the point for 60 seconds!",
      "JP": "素早くスライドして60秒間耐えろ",
      "CN": "",
      "KR": "빠르게 회전하며 60초간 버텨내기",
      "TW": "快速擊殺並堅守60秒"
    }
  },
  "僵尸还有20秒传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies teleport in 20 seconds",
      "JP": "ゾンビは20秒後にテレポート",
      "CN": "",
      "KR": "좀비 20초 후 텔레포트",
      "TW": "殭屍将在20秒後傳送"
    }
  },
  "僵尸传送了": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies have teleported!",
      "JP": "ゾンビがテポートした",
      "CN": "",
      "KR": "좀비가 텔레포트했습니다",
      "TW": "殭屍已傳送"
    }
  },
  "门开了": {
    "translation": "",
    "MultiLang": {
      "US": "Door opened",
      "JP": "ドアが開いた",
      "CN": "",
      "KR": "문이 열렸습니다",
      "TW": "門打開了"
    }
  },
  "喜欢刷？那就刷他  还有120秒": {
    "translation": "",
    "MultiLang": {
      "US": "Want to spawn more? Go ahead. 120 seconds remaining.",
      "JP": "刷るのが好き？じゃぁそれやれ。あと120秒だ",
      "CN": "",
      "KR": "刷을 좋아해? 그럼刷하자  120초 남음",
      "TW": "喜歡刷怪嗎？那就繼續刷，還剩120秒"
    }
  },
  "偷偷告诉你们有人说不够刷所以改了": {
    "translation": "",
    "MultiLang": {
      "US": "Just a heads up: some people complained there weren't enough spawns, so we've changed it.",
      "JP": "内緒だけど、刷りが足りないってことで設定を変えたよ",
      "CN": "",
      "KR": "\" secretly\" 말해주는데,刷이 부족해서 수정됐대",
      "TW": "偷偷告訴你們，因為有人說刷怪不夠多，所以已經修改了設定"
    }
  },
  "门开了丢道具": {
    "translation": "",
    "MultiLang": {
      "US": "Open door drop items",
      "JP": "ドアが開いてアイテムが出現",
      "CN": "",
      "KR": "문이 열리고 아이템이 떨어집니다",
      "TW": "門開啟後掉落道具"
    }
  },
  "最后50秒": {
    "translation": "",
    "MultiLang": {
      "US": "Last 50 seconds",
      "JP": "残り50秒",
      "CN": "",
      "KR": "마지막 50초",
      "TW": "最後50秒"
    }
  },
  "门碎了": {
    "translation": "",
    "MultiLang": {
      "US": "Door broke",
      "JP": "门が割れた",
      "CN": "",
      "KR": "문이 깨졌습니다",
      "TW": "門碎裂"
    }
  },
  "门还有20秒开了": {
    "translation": "",
    "MultiLang": {
      "US": "Door opens in 20 seconds",
      "JP": "ドアはあと20秒で開く",
      "CN": "",
      "KR": "문이 20초 뒤에 열립니다",
      "TW": "門將在20秒後開啟"
    }
  },
  "喜欢刷？那就刷他  还有100秒": {
    "translation": "",
    "MultiLang": {
      "US": "Like farming? Go farm it. 100 seconds left.",
      "JP": "刷るのが好き？なら刷れ 残り100秒",
      "CN": "",
      "KR": "刷ing 좋으면 더刷으세요! 100초 남았습니다",
      "TW": "喜歡刷嗎？那就刷他！還有100秒"
    }
  },
  "ps：那个墙上的粉毛是作者": {
    "translation": "",
    "MultiLang": {
      "US": "Note: The pink-haired character on the wall is the author.",
      "JP": "ps：壁のピンク髪は作者",
      "CN": "",
      "KR": "참고: 벽에 있는 분홍머리 캐릭터는 개발자입니다",
      "TW": "PS：牆上的粉毛是作者本人"
    }
  },
  "超级老板：纯鲨比  阿撒馄饨": {
    "translation": "",
    "MultiLang": {
      "US": "Boss: Pure shark comparison. Asa wontons.",
      "JP": "スーパーボス：純豚アサコンフン",
      "CN": "",
      "KR": "슈퍼 보스: 순수 상어  아사만두",
      "TW": "超級老闆：純鯊比 阿撒燉餃子"
    }
  }
}
