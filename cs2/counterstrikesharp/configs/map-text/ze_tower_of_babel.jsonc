  "还有10秒": {
    "translation": "",
    "MultiLang": {
      "US": "10 seconds remaining.",
      "JP": "あと10秒",
      "CN": "",
      "KR": "남은 시간 10초",
      "TW": "还有10秒。"
    }
  },
  "行动开始": {
    "translation": "",
    "MultiLang": {
      "US": "Action begins.",
      "JP": "行動開始",
      "CN": "",
      "KR": "작전 시작",
      "TW": "行动开始。"
    }
  },
  "坚守60秒": {
    "translation": "",
    "MultiLang": {
      "US": "Hold out for 60 seconds.",
      "JP": "60秒間、守り抜く",
      "CN": "",
      "KR": "60초 방어",
      "TW": "坚守60秒。"
    }
  },
  "门开了快走！！！": {
    "translation": "",
    "MultiLang": {
      "US": "The door is open! Run quickly!!!",
      "JP": "ドアが開いた、早く逃げろ！！！",
      "CN": "",
      "KR": "문이 열렸다 빨리 들어와!！！",
      "TW": "门开了，快跑！！！"
    }
  },
  "坚守65秒！！！撑住我们才刚刚开始": {
    "translation": "",
    "MultiLang": {
      "US": "Hold out for 65 seconds!!! Hang in there, we're just getting started.",
      "JP": "65秒間、守り抜く！！！耐えろ、我々の戦いはまだ始まったばかりだ",
      "CN": "",
      "KR": "65초 방어!！！ 버텨, 우리는 이제 막 시작했어",
      "TW": "坚守65秒！！！撑住，我们才刚刚开始。"
    }
  },
  "门开了撤退": {
    "translation": "",
    "MultiLang": {
      "US": "The door is open, retreat.",
      "JP": "ドアが開いた、撤退",
      "CN": "",
      "KR": "문이 열렸다 철수",
      "TW": "门开了，撤退。"
    }
  },
  "快跳上去！": {
    "translation": "",
    "MultiLang": {
      "US": "Jump up quickly!",
      "JP": "早く跳び乗れ！",
      "CN": "",
      "KR": "빨리 올라와!",
      "TW": "快跳上去！"
    }
  },
  "找到三个按钮": {
    "translation": "",
    "MultiLang": {
      "US": "Find the three buttons.",
      "JP": "3つのボタンを見つけろ",
      "CN": "",
      "KR": "세 개의 버튼을 찾아라",
      "TW": "找到三個按鈕"
    }
  },
  "快滑还有105秒": {
    "translation": "",
    "MultiLang": {
      "US": "You have 105 seconds left for the quick slide.",
      "JP": "早く滑り、あと105秒",
      "CN": "",
      "KR": "빨리 미끄러져, 남은 시간 105초",
      "TW": "快速滑動，還有105秒"
    }
  },
  "喜欢刷？那就刷他  还有1分30秒": {
    "translation": "",
    "MultiLang": {
      "US": "Like grinding? Then grind away! You have 1 minute and 30 seconds left.",
      "JP": "刷りたい？じゃあ、刷り返せ！あと1分30秒",
      "CN": "",
      "KR": "스팟을 좋아하나요? 그럼 그걸 뚫어! 남은 시간 1분 30초",
      "TW": "喜歡刷嗎？那就盡情刷吧！還剩1分30秒"
    }
  },
  "温馨小提示不去后面是不会触发传送的": {
    "translation": "",
    "MultiLang": {
      "US": "A friendly reminder: You won't trigger the teleport if you don't go to the end.",
      "JP": "温かくお知らせ：後ろに行かないと、传送は発動しません",
      "CN": "",
      "KR": "따뜻한 팁: 뒤로 가지 않으면 전송이 발생하지 않아요",
      "TW": "溫馨提示：不去後面是無法觸發傳送的"
    }
  },
  "不要偷跑哦~~~": {
    "translation": "",
    "MultiLang": {
      "US": "Don't rush ahead!",
      "JP": "こっそり逃げないでよ~~~",
      "CN": "",
      "KR": "도망치지 마요~~~",
      "TW": "不要提前啟動哦~~~"
    }
  },
  "门开了快走": {
    "translation": "",
    "MultiLang": {
      "US": "The door is open, hurry!",
      "JP": "ドアが開いた、早く逃げろ",
      "CN": "",
      "KR": "문이 열렸다 빨리 들어와",
      "TW": "門打開了，快離開"
    }
  },
  "欣赏一下校长的花园吧马上就要撤离了": {
    "translation": "",
    "MultiLang": {
      "US": "Take a moment to appreciate the principal's garden, but you'll need to evacuate soon.",
      "JP": "校長の庭を堪能しておけ、すぐ撤退だ",
      "CN": "",
      "KR": "교장의 정원을 감상해보세요, 곧 철수할 거예요",
      "TW": "欣賞一下校長的花園吧，馬上就要撤離了"
    }
  },
  "对了坚持50秒哦~": {
    "translation": "",
    "MultiLang": {
      "US": "Oh, and remember to hold out for 50 seconds!",
      "JP": "あ、50秒間、頑張ってよ~",
      "CN": "",
      "KR": "그리고 50초만 버텨요~",
      "TW": "对了，坚持50秒哦~"
    }
  },
  "最后一个！坚持40秒！": {
    "translation": "",
    "MultiLang": {
      "US": "Last one! Hold on for 40 seconds!",
      "JP": "最後だ！40秒間、頑張れ！",
      "CN": "",
      "KR": "마지막이야! 40초만 버텨!",
      "TW": "最后一个！坚持40秒！"
    }
  },
  "道具全交！！！！！！！守住！！！！": {
    "translation": "",
    "MultiLang": {
      "US": "Use all the items! Defend!",
      "JP": "道具を全部渡せ！！！！！！！守れ！！！！",
      "CN": "",
      "KR": "아이템 전부 제출!!@@@! 방어해!@@@",
      "TW": "道具全部交出！！！！！！！守住！！！！"
    }
  },
  "我们安全了欢迎回家": {
    "translation": "",
    "MultiLang": {
      "US": "We are safe, welcome home.",
      "JP": "無事だ、ようこそ帰ってきた",
      "CN": "",
      "KR": "우리 안전해졌어요, 오신 걸 환영합니다",
      "TW": "我們安全了，歡迎回家。"
    }
  },
  "感谢大家游玩作者：一只秋": {
    "translation": "",
    "MultiLang": {
      "US": "Thank you for playing. Author: Qiu.",
      "JP": "皆様のプレイに感謝。作者：一只秋",
      "CN": "",
      "KR": "모두가 플레이해 주셔서 감사합니다. 작가: 한 마리 가을",
      "TW": "感謝各位遊玩，作者：一只秋。"
    }
  },
  "感谢常正类人": {
    "translation": "",
    "MultiLang": {
      "US": "Thank you, Chang Zheng.",
      "JP": "いつもありがとうございます",
      "CN": "",
      "KR": "항상 고마워요",
      "TW": "感謝常正類人。"
    }
  },
  "琪亚娜": {
    "translation": "",
    "MultiLang": {
      "US": "Kiana",
      "JP": "キアナ",
      "CN": "",
      "KR": "키아나",
      "TW": "琪亞娜"
    }
  },
  "一曲悲歌照幽梦": {
    "translation": "",
    "MultiLang": {
      "US": "A lament illuminates the dream.",
      "JP": "悲しみの歌が幽夢を照らす",
      "CN": "",
      "KR": "비극의 노래가 어둠 속 꿈을 비춘다",
      "TW": "一曲悲歌照幽夢"
    }
  },
  "香香阿花": {
    "translation": "",
    "MultiLang": {
      "US": "Xiang Xiang Ah Hua",
      "JP": "シャンシャンアーハア",
      "CN": "",
      "KR": "향향 아화",
      "TW": "香香阿花"
    }
  },
  "科比布莱恩": {
    "translation": "",
    "MultiLang": {
      "US": "Kobe Bryant",
      "JP": "コービー・ブライアント",
      "CN": "",
      "KR": "코비 브라이언트",
      "TW": "科比·布萊恩"
    }
  },
  "炫叽歪": {
    "translation": "",
    "MultiLang": {
      "US": "Xuan Jiewai",
      "JP": "シンギワイ",
      "CN": "",
      "KR": "현지위",
      "TW": "炫叽歪"
    }
  },
  "樱落": {
    "translation": "",
    "MultiLang": {
      "US": "Cherry Blossom",
      "JP": "サクララク",
      "CN": "",
      "KR": "영락",
      "TW": "櫻落"
    }
  },
  "柑龙": {
    "translation": "",
    "MultiLang": {
      "US": "Citrus Dragon",
      "JP": "カンリュウ",
      "CN": "",
      "KR": "감룡",
      "TW": "柑龍"
    }
  },
  "接下来出发吧": {
    "translation": "",
    "MultiLang": {
      "US": "Let's go!",
      "JP": "次は出発だ",
      "CN": "",
      "KR": "다음으로 출발해요",
      "TW": "接下來出發吧"
    }
  },
  "等等你们队友不要抛弃他们": {
    "translation": "",
    "MultiLang": {
      "US": "Wait, don't abandon your teammates!",
      "JP": "仲間を置いていかないで待って",
      "CN": "",
      "KR": "팀원들을 버리지 말고 기다려요",
      "TW": "等等，你們的隊友不要拋棄他們"
    }
  },
  "有人触发了！！！": {
    "translation": "",
    "MultiLang": {
      "US": "Someone triggered it!!!",
      "JP": "誰かがトリガーを引いた！！！",
      "CN": "",
      "KR": "누군가 트리거를 눌렀어요! ! ! !",
      "TW": "有人觸發了！！！"
    }
  },
  "还有40秒": {
    "translation": "",
    "MultiLang": {
      "US": "40 seconds remaining.",
      "JP": "あと40秒",
      "CN": "",
      "KR": "남은 시간 40초",
      "TW": "還有40秒"
    }
  },
  "僵尸10秒传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies will teleport in 10 seconds.",
      "JP": "ゾンビ10秒でトランスファー",
      "CN": "",
      "KR": "좀비 10초 후 전송",
      "TW": "僵尸将在10秒后传送。"
    }
  },
  "门开了不要上去等等队友": {
    "translation": "",
    "MultiLang": {
      "US": "The door is open, don't go up yet, wait for your teammates.",
      "JP": "ドアが開いた、上がらないで仲間を待って",
      "CN": "",
      "KR": "문이 열렸어요, 올라가지 말고 팀원들을 기다려요",
      "TW": "门已打开，请勿上前，等待队友。"
    }
  },
  "快滑坚守60秒": {
    "translation": "",
    "MultiLang": {
      "US": "Quickly slide and hold your position for 60 seconds.",
      "JP": "早く滑って60秒守り",
      "CN": "",
      "KR": "빨리 슬라이드, 60초 방어해요",
      "TW": "快速滑行，坚守60秒。"
    }
  },
  "僵尸还有20秒传送": {
    "translation": "",
    "MultiLang": {
      "US": "Zombies will teleport in 20 seconds.",
      "JP": "ゾンビあと20秒でトランスファー",
      "CN": "",
      "KR": "좀비는 20초 후 전송",
      "TW": "僵尸将在20秒后传送。"
    }
  },
  "僵尸传送了": {
    "translation": "",
    "MultiLang": {
      "US": "The zombies have teleported.",
      "JP": "ゾンビがトランスファーした",
      "CN": "",
      "KR": "좀비 전송 완료",
      "TW": "僵尸已传送。"
    }
  },
  "门开了": {
    "translation": "",
    "MultiLang": {
      "US": "The door is open.",
      "JP": "ドアが開いた",
      "CN": "",
      "KR": "문이 열렸어요",
      "TW": "门已打开。"
    }
  },
  "喜欢刷？那就刷他  还有120秒": {
    "translation": "",
    "MultiLang": {
      "US": "Do you like grinding? Then grind away! There are 120 seconds left.",
      "JP": "刷りたい？じゃあ刷ってみろ あと120秒",
      "CN": "",
      "KR": "스킵 좋아하세요? 그럼 스킵해요, 남은 시간 120초",
      "TW": "喜欢刷吗？那就来刷！还有120秒。"
    }
  },
  "偷偷告诉你们有人说不够刷所以改了": {
    "translation": "",
    "MultiLang": {
      "US": "Just a heads-up: someone said it wasn't enough grinding, so we've made a change.",
      "JP": "こっそり教えよう、誰かが刷りが足りないって言ってて変えたんだよ",
      "CN": "",
      "KR": "조용히 말해줄게, 누군가 스킵이 부족하다고 해서 바꿨어요",
      "TW": "偷偷告诉大家，有人说不够刷，所以我们进行了修改。"
    }
  },
  "门开了丢道具": {
    "translation": "",
    "MultiLang": {
      "US": "The door opened, dropping items.",
      "JP": "ドアが開いた、道具を投げろ",
      "CN": "",
      "KR": "문이 열렸어요, 아이템을 버려요",
      "TW": "門打開會掉落道具"
    }
  },
  "最后50秒": {
    "translation": "",
    "MultiLang": {
      "US": "Last 50 seconds.",
      "JP": "あと50秒",
      "CN": "",
      "KR": "마지막 50초",
      "TW": "最後50秒"
    }
  },
  "门碎了": {
    "translation": "",
    "MultiLang": {
      "US": "The door shattered.",
      "JP": "ドアが壊れた",
      "CN": "",
      "KR": "문이 부서졌어요",
      "TW": "門被擊碎"
    }
  },
  "门还有20秒开了": {
    "translation": "",
    "MultiLang": {
      "US": "The door will open in 20 seconds.",
      "JP": "ドアは20秒後に開く",
      "CN": "",
      "KR": "문이 20초 후에 열릴 거야",
      "TW": "門還剩20秒會打開"
    }
  },
  "喜欢刷？那就刷他  还有100秒": {
    "translation": "",
    "MultiLang": {
      "US": "Do you like grinding? Then grind away! Only 100 seconds left.",
      "JP": "スクラップが好き？じゃあスクラップだ  残り100秒",
      "CN": "",
      "KR": "스팟 좋아해? 그럼 스팟이나 해  아직 100초 남았어",
      "TW": "喜歡刷嗎？那就刷吧！還剩100秒"
    }
  },
  "ps：那个墙上的粉毛是作者": {
    "translation": "",
    "MultiLang": {
      "US": "P.S.: The pink creature on the wall is the author.",
      "JP": "ps：壁のピンクの髪は作者だ",
      "CN": "",
      "KR": "ps: 벽에 붙은 분홍 머리카락은 작가야",
      "TW": "PS：牆上的粉毛是作者"
    }
  },
  "超级老板：纯鲨比  阿撒馄饨": {
    "translation": "",
    "MultiLang": {
      "US": "Super Boss: Pure Sharkbi, Asah Wonton.",
      "JP": "スーパー社長：純粋なシャビ  アサタンタン",
      "CN": "",
      "KR": "슈퍼 레이저: 순수한 상어비  아사순饨",
      "TW": "超級老闆：純鯊比  阿撒馄饨"
    }
  }
}
