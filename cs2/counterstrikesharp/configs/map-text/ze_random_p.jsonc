{
  "***LEVEL -- BOX WITH A LIGHT IN IT***": {
    "translation": "**关卡 -- 热身**",
    "MultiLang": {
      "US": "",
      "JP": "***レベル -- 中から光が漏れる箱***",
      "CN": "***关卡 -- 发光箱子***",
      "KR": "***레벨 -- 불빛이 있는 상자***",
      "TW": "***關卡 -- 藏有燈光的箱子***"
    }
  },
  "***Hold off as the zombies spawn until you're teleport to 1 of the 9 maps!***": {
    "translation": "**拖住僵尸，直到你传送1到9随机一张地图！**",
    "MultiLang": {
      "US": "",
      "JP": "***ゾンビが出現し続けるのを耐え、9つのマップの1つにテレポートするまで待機！***",
      "CN": "***在僵尸刷出时坚持住，随后你将被传送到9张地图之一！***",
      "KR": "***좀비가 생성되는 동안 버티세요! 9개 맵 중 하나로 순간이동됩니다!***",
      "TW": "***堅持到殭屍湧出，你将被傳送到9個地圖之一！***"
    }
  },
  "***Teleporting in 20secs!***": {
    "translation": "**等待 20 秒传送！**",
    "MultiLang": {
      "US": "",
      "JP": "***テレポート開始まで20秒！***",
      "CN": "***传送将在20秒后开始！***",
      "KR": "***20초 후에 순간이동!***",
      "TW": "***傳送倒計時：20秒！***"
    }
  },
