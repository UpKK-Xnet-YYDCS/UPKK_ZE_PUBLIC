{
  "这是哪？": {
    "translation": "",
    "MultiLang": {
      "US": "Where is this?",
      "JP": "ここはどこ？",
      "CN": "",
      "KR": "이게 어디야?",
      "TW": "这是哪里？"
    }
  },
  "奇怪的地方，怎么到处都是...鸡块？不管了，找到路就行！": {
    "translation": "",
    "MultiLang": {
      "US": "A strange place, why are there chicken nuggets everywhere? Never mind, just find the way!",
      "JP": "奇妙な場所だ。どうしてこんなにチキンが落ちているんだ？まあいい、とにかく道を見つけよう！",
      "CN": "",
      "KR": "이상한 곳인데, 왜 여기저기... 치킨 조각이야? 어쨌든 길만 찾으면 돼!",
      "TW": "奇怪的地方，怎么到处都是...鸡块？ 算了，找到路就好！"
    }
  },
  "门会在30秒后打开！": {
    "translation": "",
    "MultiLang": {
      "US": "The door will open in 30 seconds!",
      "JP": "扉は30秒後に開きます！",
      "CN": "",
      "KR": "문이 30초 후에 열릴 거야!",
      "TW": "门将在30秒后打开！"
    }
  },
  "电梯在5秒内离开": {
    "translation": "",
    "MultiLang": {
      "US": "The elevator will leave in 5 seconds.",
      "JP": "エレベーターは5秒後に発車します。",
      "CN": "",
      "KR": "엘리베이터가 5초 내에 떠날 거야",
      "TW": "电梯将在5秒内离开。"
    }
  },
  "僵尸侧路在15后打开": {
    "translation": "",
    "MultiLang": {
      "US": "The zombie path will open in 15 seconds.",
      "JP": "ゾンビの迂回路は15秒後に開きます。",
      "CN": "",
      "KR": "좀비 측로가 15초 후에 열릴 거야",
      "TW": "侧面的僵尸通道将在15秒后打开。"
    }
  },
  "这是什么鬼玩意？！": {
    "translation": "",
    "MultiLang": {
      "US": "What the heck is this?!",
      "JP": "これは一体何だ！？",
      "CN": "",
      "KR": "이게 뭐야?!",
      "TW": "这是什么鬼东西？！"
    }
  },
  "板子会在15后离开！": {
    "translation": "",
    "MultiLang": {
      "US": "The platform will disappear in 15 seconds!",
      "JP": "板は15秒後に取り除かれます！",
      "CN": "",
      "KR": "보드가 15초 후에 떠날 거야!",
      "TW": "平台将在15秒后离开！"
    }
  },
  "看起来我们找到了路，守住这！": {
    "translation": "",
    "MultiLang": {
      "US": "Looks like we found the way, defend this!",
      "JP": "どうやら道を見つけたようだ。ここは守り抜こう！",
      "CN": "",
      "KR": "길을 찾은 것 같아, 이거 지켜!",
      "TW": "看来我们找到了路，守住这里！"
    }
  },
  "这又是什么地方？": {
    "translation": "",
    "MultiLang": {
      "US": "Where is this place?",
      "JP": "ここはどこだ？",
      "CN": "",
      "KR": "또 어디야?",
      "TW": "这是什么地方？"
    }
  },
  "看来是个快餐店？去门口守住,等着上车！": {
    "translation": "",
    "MultiLang": {
      "US": "Looks like a fast-food restaurant. Go to the entrance and wait for the car!",
      "JP": "どうやらファストフード店のようだ。入口で待ち構え、車が到着するのを待て！",
      "CN": "",
      "KR": "패스트푸드점 같아? 문가에서 지켜, 차 타기 기다려!",
      "TW": "看来是一家快餐店？去门口守住，等待上车！"
    }
  },
  "地板在30s后碎裂": {
    "translation": "",
    "MultiLang": {
      "US": "The floor will shatter in 30 seconds.",
      "JP": "床は30秒後に破壊される",
      "CN": "",
      "KR": "바닥이 30초 후에 깨질 거야",
      "TW": "地板会在30秒后碎裂。"
    }
  },
  "将在35秒后全体传送！": {
    "translation": "",
    "MultiLang": {
      "US": "Everyone will be teleported in 35 seconds!",
      "JP": "35秒後に全員テレポートします！",
      "CN": "",
      "KR": "35초 후에 전부 텔레포트될 거야!",
      "TW": "全体将在35秒后传送！"
    }
  },
  "这玩意怎么跑脸上来了？看来只能消灭它了！（boss战在10s后开启）": {
    "translation": "",
    "MultiLang": {
      "US": "How did this thing get here? Looks like I have to destroy it! (Boss battle will start in 10 seconds).",
      "JP": "こいつは一体どうやってここに来たんだ？どうやら、消滅させるしかないようだ！ (ボス戦は10秒後に開始)",
      "CN": "",
      "KR": "이게 왜 얼굴에 붙었어? 어쩔 수 없이 제거해야겠어! (보스전 10초 후 시작)",
      "TW": "这东西怎么跑到脸上来了？看来只能消灭它了！（Boss战将在10秒后开启）"
    }
  },
  "看来这玩意死了，应该结束了！": {
    "translation": "",
    "MultiLang": {
      "US": "Looks like it's over now that this thing is dead!",
      "JP": "どうやら、これで終わりだ！",
      "CN": "",
      "KR": "이 녀석 죽은 것 같아, 다 끝났겠어!",
      "TW": "看来这东西死了，应该结束了！"
    }
  },
  "侧路会在10秒后开放": {
    "translation": "",
    "MultiLang": {
      "US": "The side path will open in 10 seconds.",
      "JP": "脇道は10秒後に開かれる",
      "CN": "",
      "KR": "측면 길이 10초 후에 열립니다",
      "TW": "侧路将在10秒后开放。"
    }
  }
}
