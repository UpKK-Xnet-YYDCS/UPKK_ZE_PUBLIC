  },
  "The keypad is stuck.": {
    "translation": "键盘卡住了",
    "MultiLang": {
      "US": "",
      "JP": "キーパッドが固着している",
      "CN": "键盘卡住了。",
      "KR": "키패드가 작동하지 않는다.",
      "TW": "密碼盤卡住了。"
    }
  },
  "There's zombies below": {
    "translation": "下面有僵尸",
    "MultiLang": {
      "US": "",
      "JP": "下にゾンビがいる",
      "CN": "下面有僵尸。",
      "KR": "아래층에 좀비들이 있다.",
      "TW": "下面有殭屍。"
    }
  },
  "They are here!": {
    "translation": "他们来了！",
    "MultiLang": {
      "US": "",
      "JP": "奴らがここにいる！",
      "CN": "他们来了！",
      "KR": "그들이 나타났다!",
      "TW": "他們來了！"
    }
  },
  "They're coming.": {
    "translation": "他们来了",
    "MultiLang": {
      "US": "",
      "JP": "接近してきた。",
      "CN": "他们来了。",
      "KR": "적들이 다가온다.",
      "TW": "他們來了。"
    }
  },
  "This door is open really slow, defend the line!": {
    "translation": "这扇门打开得很慢，防住这条线！",
    "MultiLang": {
      "US": "",
      "JP": "このドアはかなりゆっくり開くよ、陣形を守れ！",
      "CN": "这扇门开得很慢，守住防线！",
      "KR": "이 문이 느리게 열리고 있다, 방어선을 유지해라!",
      "TW": "這扇門開得非常慢，守好陣線！"
    }
  },
  "This facility is on the edge of collapsing.": {
    "translation": "这个设施即将崩溃",
    "MultiLang": {
      "US": "",
      "JP": "この施設は倒壊の危機にさらされている。",
      "CN": "这个设施濒临崩溃。",
      "KR": "이 시설은 붕괴 위기에 처해 있다.",
      "TW": "這座設施即將倒塌。"
    }
  },
  "This is it. ": {
    "translation": "就是这里",
    "MultiLang": {
      "US": "",
      "JP": "ここだ。",
      "CN": "就是这里。",
      "KR": "거기다.",
      "TW": "就是這裡。"
    }
  },
  "This is it. The Control Room before the reactor.": {
    "translation": "就是这里反应堆前的控制室",
    "MultiLang": {
      "US": "",
      "JP": "ここだ。原子炉手前の管制室。",
      "CN": "就是这里，反应堆前的控制室。",
      "KR": "거기야. 원자로 앞의 제어실이지.",
      "TW": "就是這裡。反應堆前的控制室。"
    }
  },
  "This is the entrance to the Core!": {
    "translation": "这是核心的入口！",
    "MultiLang": {
      "US": "",
      "JP": "ここがコアへの入り口だ！",
      "CN": "这是核心入口！",
      "KR": "핵심 부서의 진입구야!",
      "TW": "這是進入核心！的入口！"
    }
  },
  "This thing is gonna be loud once it starts warming up.": {
    "translation": "一旦开始升温，这个东西会很吵",
    "MultiLang": {
      "US": "",
      "JP": "暖房が始まったら相当な音量になるぞ。",
      "CN": "一旦开始升温，这东西动静会很大。",
      "KR": "이 장치가 가열되면 꽤 시끄러울 거야.",
      "TW": "一旦開始升溫，這東西會很吵。"
    }
  },
  "Try to look around for one.": {
    "translation": "尽量四处寻找一下",
    "MultiLang": {
      "US": "",
      "JP": "周りを捜索して、一つ見つけてみてくれ。",
      "CN": "试着周围找找看有没有。",
      "KR": "하나쯤은 찾아보도록 해.",
      "TW": "試著四處找找看。"
    }
  },
  "Turn the valves to destabilize the core!": {
    "translation": "转动阀门使核心不稳定！",
    "MultiLang": {
      "US": "",
      "JP": "バルブを回してコアのバランスを崩せ！",
      "CN": "旋转阀门，破坏核心平衡！",
      "KR": "밸브를 돌려 코어를 불안정하게 만드세요!",
      "TW": "轉動閥門以破壞核心穩定性！"
    }
  },
  "Watch out the falling debris from the top of the reactor!": {
    "translation": "小心从反应堆顶部掉落的碎片！",
    "MultiLang": {
      "US": "Beware of the falling debris from the top of the reactor!",
      "JP": "炉頂から落下する破片に気をつけろ！",
      "CN": "小心反应器顶部落下的碎片！",
      "KR": "원자로 상부에서 떨어지는 파편에 주의하세요!",
      "TW": "注意反應爐頂部掉落的水泥碎片！"
    }
  },
  "Watch out the pipe!": {
    "translation": "小心管道！",
    "MultiLang": {
      "US": "",
      "JP": "配管に気をつけろ！",
      "CN": "小心管道！",
      "KR": "配管에 주의하세요!",
      "TW": "小心管道！"
    }
  },
  "We are almost on the other side.": {
    "translation": "我们快到另一边了",
    "MultiLang": {
      "US": "",
      "JP": "もうあと少しで反対側だ。",
      "CN": "我们几乎就要到另一侧了。",
      "KR": "거의 반대편에 도달했습니다.",
      "TW": "我們即將到達另一端。"
    }
  },
  "We just need to cross the cliffside and reach the elevator to go to the labs below.": {
    "translation": "我们只需要穿过悬崖，抵达电梯去下面的实验室",
    "MultiLang": {
      "US": "",
      "JP": "断崖を渡ってエレベーターで下の研究棟に行けばいいんだ。",
      "CN": "只需越过悬崖峭壁，到达通往下方实验室的电梯即可。",
      "KR": "절벽을 건너 아래 연구소로 가는 엘리베이터에 닿기만 하면 됩니다.",
      "TW": "我們只需要穿過懸崖，到達电梯，即可前往下方的實驗室。"
    }
  },
  "We must disable the security systems before we can open the door however.": {
    "translation": "不过，我们必须在打开门之前禁用安全系统",
    "MultiLang": {
      "US": "",
      "JP": "ただ、ドアを開ける前にセキュリティシステムを無効化する必要があるぞ。",
      "CN": "然而，我们必须在开门前禁用安全系统。",
      "KR": "하지만 문을 열기 전에 보안 시스템을 비활성화해야 합니다.",
      "TW": "不過，在我們能開門之前，必須先停用安全系統。"
    }
  },
  "We must find and destroy the main labs as soon as possible.": {
    "translation": "我们必须尽快找到并摧毁主实验室",
    "MultiLang": {
      "US": "",
      "JP": "できるだけ早く主要研究棟を見つけて破壊しなければならない。",
      "CN": "我们必须尽快找到并摧毁主实验室。",
      "KR": "최대한 빨리 주요 연구소를 찾아 파괴해야 합니다.",
      "TW": "我們必須盡快找到並摧毀主要實驗室。"
    }
  },
  "We need some time to take down the ladder.": {
    "translation": "我们需要一些时间来拆掉梯子",
    "MultiLang": {
      "US": "",
      "JP": "ハシラを倒すのに時間を要する。",
      "CN": "我们需要一点时间来拆下梯子。",
      "KR": "사다리를 내려잡는 데 시간이 필요합니다.",
      "TW": "我們需要一些時間來拆除梯子。"
    }
  },
  "We need to configuration both side panel": {
    "translation": "我们需要配置两侧面板",
    "MultiLang": {
      "US": "",
      "JP": "両サイドのパネルを設定する必要があります",
      "CN": "我们需要配置两侧的边栏",
      "KR": "양쪽 패널 모두 설정해야 합니다.",
      "TW": "我們需要設定兩個側面板。"
    }
  },
  "We need to find a way to repair it": {
    "translation": "我们需要找到修复的方法",
    "MultiLang": {
      "US": "",
      "JP": "修理する方法を見つけなければなりません",
      "CN": "我们需要找到修复它的方法",
      "KR": "수리할 방법을 찾아야 합니다.",
      "TW": "我們得想辦法修復它。"
    }
  },
  "We're almost out of the Storage & Maintenance Wing of the Facility": {
    "translation": "我们快要离开设施的存储与维护区了",
    "MultiLang": {
      "US": "",
      "JP": "施設の保管・保守区域からほぼ出ました",
      "CN": "我们即将离开设施的储物与维护区",
      "KR": "시설의 저장 및 유지보수 관을 거의 벗어났습니다.",
      "TW": "我們即將抵達設施的儲存與維修翼區。"
    }
  },
  "We're safe here.": {
    "translation": "我们在这里很安全",
    "MultiLang": {
      "US": "",
      "JP": "ここなら安全です。",
      "CN": "这里很安全。",
      "KR": "여기는 안전합니다.",
      "TW": "這裡很安全。"
    }
  },
  "Well. It seems safe here. Take a time to rest before..": {
    "translation": "嗯，这里似乎安全，休息一下再……",
    "MultiLang": {
      "US": "",
      "JP": "なるほど。ここは安全のようです。……する前に、少し休んでください。",
      "CN": "嗯，这里似乎很安全。先休息一下吧……",
      "KR": "음, 여기는 안전해 보입니다. 쉴 시간을 가져보세요..",
      "TW": "看來這裡是安全的。先休息一下再說吧。"
    }
  },
  "You'll have to go to the Maintenance Area to turn off the power first however.": {
    "translation": "不过，你得先去维护区关闭电源",
    "MultiLang": {
      "US": "",
      "JP": "ただし、まず保守区域に赴いて電源を切る必要があります。",
      "CN": "不过，你必須先去维护区切断电源。",
      "KR": "먼저 유지보수 구역으로 가서 전원을 끄셔야 합니다.",
      "TW": "不過，你必須先前往維修區關閉電源。"
    }
  }
}
