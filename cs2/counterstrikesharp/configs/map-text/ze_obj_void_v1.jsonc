      "US": "",
      "JP": "扉が動きません…",
      "CN": "门似乎卡住了……",
      "KR": "문이 걸린 것 같습니다...",
      "TW": "門似乎卡住了……"
    }
  },
  "The Door will open in 30s": {
    "translation": "门将在30秒后打开",
