{
  "所有人类有50%概率获得发光沙漏": {
    "translation": "",
    "MultiLang": {
      "US": "All humans have a 50% chance of receiving the Glowing Hourglass",
      "JP": "全人類に50%の確率で発光する砂時計が付与されます",
      "CN": "",
      "KR": "모든 인간은 50% 확률로 발광 모래시계를 획득합니다",
      "TW": "所有人類有50%機率獲得發光沙漏"
    }
  },
  "(在即将触发机关时消耗并传送至外场)": {
    "translation": "",
    "MultiLang": {
      "US": "(Consume and teleport to the outer field when a mechanism is about to trigger)",
      "JP": "(トリガー発動直前に消費し、外場へテレポート)",
      "CN": "",
      "KR": "(트랩이 발동되기 직전 소모하여 외측으로 전송)",
      "TW": "(在即將觸發機關時消耗並傳送至外場)"
    }
  },
  "所有人类有20%概率获得终末天启": {
    "translation": "",
    "MultiLang": {
      "US": "All humans have a 20% chance of receiving the Final Apocalypse",
      "JP": "全人類に20%の確率で終末の天啓が付与されます",
      "CN": "",
      "KR": "모든 인간은 20% 확률로 종말의 암흑천사를 획득합니다",
      "TW": "所有人類有20%機率獲得終末天啟"
    }
  },
  "(触碰圣甲虫时不触发机关)": {
    "translation": "",
    "MultiLang": {
      "US": "(Does not trigger mechanism upon touching the Scarab)",
      "JP": "聖甲虫に触れてもトリガーが作動しない\")",
      "CN": "(触摸圣甲虫时不会触发机关)",
      "KR": "(성스러운 메뚜기를 만져도 트랩이 발동되지 않습니다)",
      "TW": "(觸碰聖甲蟲時不觸發機關)"
    }
  },
  "ze_MkZk_Scarab 重置版": {
    "translation": "",
    "MultiLang": {
      "US": "ze_MkZk_Scarab Reboot",
      "JP": "ze_MkZk_Scarab 再バージョン",
      "CN": "",
      "KR": "ze_MkZk_Scarab 리메이크 버전",
      "TW": "ze_MkZk_Scarab 重置版"
    }
  },
  "进入大门，跟随眼睛的指引找到古代传送门": {
    "translation": "",
    "MultiLang": {
      "US": "Enter the gate and follow the guidance of the eyes to find the Ancient Portal",
      "JP": "扉を開け、目の導きに従って古代の転送門を見つけてください",
      "CN": "",
      "KR": "대문을 열고 눈의 지시를 따라 고대의 포트를 찾습니다",
      "TW": "進入大門，跟隨眼睛的指引找到古代傳送門"
    }
  },
  "但需要注意...": {
    "translation": "",
    "MultiLang": {
      "US": "But beware...",
      "JP": "ただし注意が必要です...",
      "CN": "",
      "KR": "하지만 주의해야 합니다...",
      "TW": "但需要注意..."
    }
  },
  "...死亡会降临到那些看不到圣甲虫的人身上": {
    "translation": "",
    "MultiLang": {
      "US": "...death will fall upon those who cannot see the Scarab",
      "JP": "...聖甲虫が見えない者たちには死が訪れます",
      "CN": "...死亡将降临于未能看到神圣 dung beetle者身上",
      "KR": "...눈이 성스러운 메뚜기를 볼 수 없는 자에게는 죽음이 찾아옵니다",
      "TW": "...死亡會降臨到那些看不到聖甲蟲的人身上"
    }
  },
  "Sector 1 reached.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "セクター1到達。",
      "CN": "已到达第一区域。",
      "KR": "구역 1 도달",
      "TW": "已到達第一區。"
    }
  },
  "请设置僵尸在开局45秒后尸变": {
    "translation": "",
    "MultiLang": {
      "US": "Set zombies to turn 45 seconds after the match starts.",
      "JP": "ゲーム開始45秒後にゾンビが変異するように設定",
      "CN": "请设置僵尸在开局45秒后转生",
      "KR": "초반 45초 이후 좀비가 시체로 변하도록 설정",
      "TW": "請設定殭屍在開局45秒後尸變。"
    }
  },
  "所有人类有20%概率获得神圣屏障": {
    "translation": "",
    "MultiLang": {
      "US": "All humans have a 20% chance to receive a Holy Barrier.",
      "JP": "全人類に聖なるバリア獲得確率20%を付与",
      "CN": "",
      "KR": "모든 인간은 20% 확률로 신성한 장막을 얻습니다",
      "TW": "所有玩家有20%機率獲得神聖屏障。"
    }
  },
  "(在即将触发机关时消耗并传送至安全区域)": {
    "translation": "",
    "MultiLang": {
      "US": "(Consumes an item and teleports to the safe area right before triggering a trap.)",
      "JP": "(机关が起動する直前に消費し、安全な区域へテレポート)",
      "CN": "",
      "KR": "(트리거가 발동하기 직전에 소모하여 안전 지역으로 순간 이동)",
      "TW": "(在即將觸發機關時消耗並傳送至安全區域)"
    }
  },
