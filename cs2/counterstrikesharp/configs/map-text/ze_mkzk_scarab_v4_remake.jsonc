  "当前难度：简单": {
    "translation": "",
    "MultiLang": {
      "US": "Current Difficulty: Easy",
      "JP": "現在の難易度：簡単",
      "CN": "",
      "KR": "현재 난이도: 쉬움",
      "TW": "當前難度：簡單"
    }
  },
  "请设置僵尸在开局30秒后尸变": {
    "translation": "",
    "MultiLang": {
      "US": "Set zombies to turn 30 seconds after the match starts.",
      "JP": "プレイ開始30秒後にゾンビをプレイヤー化してください。",
      "CN": "",
      "KR": "게임 시작 30초 후 좀비가 사망자가 되도록 설정하십시오.",
      "TW": "設定30秒後生成殭屍"
    }
  },
  "正在投放追捕者！跳跃即可成为追捕者！": {
    "translation": "",
    "MultiLang": {
      "US": "A Chaser is spawning! Jump to become a Chaser!",
      "JP": "ハンターを投入しています！ジャンプでハンターに！",
      "CN": "",
      "KR": "추적자 투하 중! 점프하면 즉시 추적자가 됩니다!",
      "TW": "即將投放追殺者！跳躍即可成為追殺者！"
    }
  },
  "一名僵尸成为了新的追捕者！": {
    "translation": "",
    "MultiLang": {
      "US": "One zombie has turned into a new Chaser!",
      "JP": "ゾンビが新たなハンターになりました！",
      "CN": "",
      "KR": "좀비 한 명이 새로운 추적자가 되었습니다!",
      "TW": "一名殭屍已轉職為新的追殺者！"
    }
  },
  "有追捕者叛变为了人类！跳跃即可成为新追捕者！": {
    "translation": "",
    "MultiLang": {
      "US": "A Chaser defected to the human side! Jump to become the new Chaser!",
      "JP": "ハンターがヒューマンに寝返りました！ジャンプで新たなハンターに！",
      "CN": "",
      "KR": "추적자 한 명이 인간 측으로 전향했습니다! 점프하면 새로운 추적자가 됩니다!",
      "TW": "有追殺者叛變成為人類！跳躍即可成為新的追殺者！"
    }
  },
  "最后十五秒!": {
    "translation": "",
    "MultiLang": {
      "US": "Last 15 seconds!",
      "JP": "最後の15秒！",
      "CN": "",
      "KR": "마지막 15초!",
      "TW": "最後十五秒！"
    }
  },
  "内场全军覆没，我们失败了...": {
    "translation": "",
    "MultiLang": {
      "US": "Inner area wiped out. We failed...",
      "JP": "内場メンバー全滅、失敗です...",
      "CN": "",
      "KR": "내부 팀이 전멸하여 패배했습니다...",
