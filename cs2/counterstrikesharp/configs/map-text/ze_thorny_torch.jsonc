      "KR": "헬기 구조대가 이동 중입니다",
      "TW": "直升機救援正在趕來途中"
    }
  },
  "战舰的炮火无法支援你们": {
    "translation": "",
    "MultiLang": {
      "US": "The battleship's fire cannot support you.",
      "JP": "戦艦の砲撃は君たちを支援できない",
      "CN": "",
      "KR": "전함의 포격은 아군을 지원할 수 없습니다",
      "TW": "戰艦的炮火無法提供支援"
    }
  },
  "坚持住": {
    "translation": "",
    "MultiLang": {
      "US": "Hold on.",
      "JP": "頑張れ",
      "CN": "",
      "KR": "버텨주세요",
      "TW": "堅持住"
    }
  },
  "直升机到了": {
    "translation": "",
    "MultiLang": {
      "US": "The helicopter has arrived.",
      "JP": "ヘリコプター到着",
      "CN": "",
      "KR": "헬기가 도착했다",
      "TW": "直升機到了"
    }
  },
  "快挂上安全绳": {
    "translation": "",
    "MultiLang": {
      "US": "Quick, strap in your safety harness!",
      "JP": "安全ロープを着けて",
      "CN": "",
      "KR": "안전 로프를 조기에 고정해라",
      "TW": "快掛上安全繩"
