{
  "我们中出了叛徒": {
    "translation": "",
    "MultiLang": {
      "US": "We have a traitor among us.",
      "JP": "私たちの間で裏切り者が現れた",
      "CN": "",
      "KR": "우리 중 한 명이 배신자다",
      "TW": "我們中出了叛徒"
    }
  },
  "先遣部队被骗了": {
    "translation": "",
    "MultiLang": {
      "US": "The vanguard was deceived.",
      "JP": "先遣隊は騙された",
      "CN": "",
      "KR": "선봉대가 속아넘어갔다",
      "TW": "先遣部隊上當了"
    }
  },
  "我集结了所有支援部队": {
    "translation": "",
    "MultiLang": {
      "US": "I have gathered all support units.",
      "JP": "すべての支援部隊を集めた",
      "CN": "",
      "KR": "나的所有 후송대를 집결시켰다",
      "TW": "我集結了所有支援部隊"
    }
  },
  "现在你们直属联盟军": {
    "translation": "",
    "MultiLang": {
      "US": "You are now part of the direct allied forces.",
      "JP": "現在、あなたは直属の連合軍だ",
      "CN": "",
      "KR": "이제 너희는 직속 연맹군이다",
      "TW": "現在你們直屬聯盟軍"
    }
  },
  "你们是来自各地的军队组成的一支队伍": {
    "translation": "",
    "MultiLang": {
      "US": "Your team consists of soldiers from various regions.",
      "JP": "あなたは各地から集まった軍隊で構成された部隊だ",
      "CN": "",
      "KR": "너희는 각지에서 모여든 군사들로 구성된 부대다",
      "TW": "你們是由來自各地的軍隊組成的一支隊伍"
    }
  },
  "去完成任务吧,带回先遣部队收集的材料": {
    "translation": "",
    "MultiLang": {
      "US": "Go complete your mission and retrieve the materials collected by the vanguard.",
      "JP": "任務を遂行し、先遣隊が集めた資料を持って帰れ",
      "CN": "",
      "KR": "임무를 수행하라, 선봉대가 모은 자료들을 가져오도록 하라",
      "TW": "去完成任務吧，帶回先遣部隊收集的材料"
    }
  },
  "这座设施建立在山体之间": {
    "translation": "",
    "MultiLang": {
      "US": "This facility is built within a mountain range.",
      "JP": "この施設は山々に建設されている",
      "CN": "",
      "KR": "이 시설은 산맥 사이에 자리 잡고 있다",
      "TW": "這座設施建立在山體之間"
    }
  },
  "穿过这座设施,联合军舰在哪里等着你们": {
    "translation": "",
    "MultiLang": {
      "US": "Cross through this facility; the allied warships are waiting for you.",
      "JP": "この施設を抜けると、連合軍艦隊が待っている",
      "CN": "",
      "KR": "이 시설을 통과하면 연합 전함이 너희를 기다리고 있다",
      "TW": "穿過這座設施，聯合軍艦在哪裡等著你們"
    }
  },
  "祝你们好运小伙子们": {
    "translation": "",
    "MultiLang": {
      "US": "Good luck, boys.",
      "JP": "男たち、幸運を祈る",
      "CN": "",
      "KR": "형들을 위해 행운을 빕니다, 친구들아",
      "TW": "祝你們好運，小子們"
    }
  },
  "这个门锁住了": {
    "translation": "",
    "MultiLang": {
      "US": "This door is locked.",
      "JP": "この扉はロックされている",
      "CN": "",
      "KR": "이 문은 잠겨 있어요",
      "TW": "這扇門鎖住了"
    }
  },
  "开枪打碎它": {
    "translation": "",
    "MultiLang": {
      "US": "Shoot it to break it.",
      "JP": "撃って壊せ",
      "CN": "",
      "KR": "총을 쏴서 부수세요",
      "TW": "開槍打碎它"
    }
  },
  "操作里面的电脑打开设施内部的门": {
    "translation": "",
    "MultiLang": {
      "US": "Hack the computer inside to open the facility's internal door.",
      "JP": "中のコンピューターを操作して施設内の扉を開けろ",
      "CN": "",
      "KR": "컴퓨터를 조작하여 시설 내부 문을 여세요",
      "TW": "操作裡面的電腦打開設施內部的門"
    }
  },
  "已经激活电脑正在开启": {
    "translation": "",
    "MultiLang": {
      "US": "Computer activated. Door is opening.",
      "JP": "コンピューターがアクティブになり、扉が開く中だ",
      "CN": "",
      "KR": "컴퓨터 작동을 확인 중입니다. 문이 열리고 있습니다.",
      "TW": "電腦已激活，正在開啟"
    }
  },
  "10秒": {
    "translation": "",
    "MultiLang": {
      "US": "10 seconds",
      "JP": "10秒",
      "CN": "",
      "KR": "10초",
      "TW": "10秒"
    }
  },
  "20秒后门开": {
    "translation": "",
    "MultiLang": {
      "US": "Door opens in 20 seconds.",
      "JP": "20秒後に扉が開く",
      "CN": "",
      "KR": "20초 후 문이 열립니다",
      "TW": "20秒後門開"
    }
  },
  "已经成功进入设施外围": {
    "translation": "",
    "MultiLang": {
      "US": "Successfully entered the facility perimeter.",
      "JP": "施設外縁への侵入に成功",
      "CN": "",
      "KR": "시설 외부 구획 진입 성공",
      "TW": "已成功進入設施外圍"
    }
  },
  "正在排查....": {
    "translation": "",
    "MultiLang": {
      "US": "Investigating...",
      "JP": "調査中...",
      "CN": "",
      "KR": "수리를 추진 중입니다...",
      "TW": "正在進行排查…"
    }
  },
  "他们太多了...": {
    "translation": "",
    "MultiLang": {
      "US": "There are too many of them...",
      "JP": "相手が多すぎる…",
      "CN": "",
      "KR": "数量가 너무 많아요…",
      "TW": "他們的數量太多了……"
    }
  },
  "窗户要碎了!": {
    "translation": "",
    "MultiLang": {
      "US": "The window is about to shatter!",
      "JP": "窓が割れそう！",
      "CN": "",
      "KR": "창문이 깨질 것 같아!",
      "TW": "窗戶快破了！"
    }
  },
  "那就到处开枪": {
    "translation": "",
    "MultiLang": {
      "US": "Then just fire at everything.",
      "JP": "なら、そこ中で撃て",
      "CN": "",
      "KR": "그럼 이리저리 사격하는 거야.",
      "TW": "那就到處開槍"
    }
  },
  "下面是蒸汽管道": {
    "translation": "",
    "MultiLang": {
      "US": "Below are the steam pipes.",
      "JP": "ここは蒸気配管だ",
      "CN": "",
      "KR": "아래는 증기 파이프입니다.",
      "TW": "下面是蒸氣管道"
    }
  },
  "我们必须要走这里": {
    "translation": "",
    "MultiLang": {
      "US": "We must go this way.",
      "JP": "ここでいくしかない",
      "CN": "",
      "KR": "우리는 여기서 통과해야 합니다.",
      "TW": "我們必須從這裡通過"
    }
  },
  "下去以后我们必须尽快找到开关": {
    "translation": "",
    "MultiLang": {
      "US": "Once down, we need to find the switch as soon as possible.",
      "JP": "下に行ったら、すぐにスイッチを見つけないと",
      "CN": "",
      "KR": "내려간 후에는 빨리 스위치를 찾아야 합니다.",
      "TW": "下去以後，我們必須儘快找到開關"
    }
  },
  "不然我们都会死在下面": {
    "translation": "",
    "MultiLang": {
      "US": "Otherwise, we'll all die down here.",
      "JP": "さもないと、全員ここで死ぬ",
      "CN": "",
      "KR": "그렇지 않으면 우리는 모두 아래에서 죽게 됩니다.",
      "TW": "否則我們會全部死在下面"
    }
  },
  "找到了": {
    "translation": "",
    "MultiLang": {
      "US": "Found it.",
      "JP": "見つけた",
      "CN": "",
      "KR": "찾았다",
      "TW": "找到了"
    }
  },
  "正在开通道路": {
    "translation": "",
    "MultiLang": {
      "US": "Clearing a path...",
      "JP": "経路を確保中",
      "CN": "",
      "KR": "길을 열어주는 중",
      "TW": "正在開通道路"
    }
  },
  "马上就能出去了": {
    "translation": "",
    "MultiLang": {
      "US": "Just about out.",
      "JP": "すぐに外に出られる",
      "CN": "",
      "KR": "곧 나갈 수 있다",
      "TW": "馬上就能出去了"
    }
  },
  "20秒后开启": {
    "translation": "",
    "MultiLang": {
      "US": "Opens in 20 seconds.",
      "JP": "20秒後に開放",
      "CN": "",
      "KR": "20초 후 개방",
      "TW": "20秒後開啟"
    }
  },
  "马上到达下个通道区域了": {
    "translation": "",
    "MultiLang": {
      "US": "Almost to the next sector.",
      "JP": "次のチャンネルエリアにすぐ到着",
      "CN": "",
      "KR": "다음 통로 구역에 곧 도착한다",
      "TW": "馬上到達下個通道區域了"
    }
  },
  "不知道下个区域通道是否开启": {
    "translation": "",
    "MultiLang": {
      "US": "No idea if the next exit is open.",
      "JP": "次のエリアの通路が開放されるかどうか不明",
      "CN": "",
      "KR": "다음 구역의 통로가 열렸는지 모르겠다",
      "TW": "不知道下個區域通道是否開啟"
    }
  },
  "再给我一些时间": {
    "translation": "",
    "MultiLang": {
      "US": "Just a little more time.",
      "JP": "もう少しいい時間をください",
      "CN": "",
      "KR": "조금만 더 시간을 달라",
      "TW": "再給我一些時間"
    }
  },
  "还有10秒": {
    "translation": "",
    "MultiLang": {
      "US": "10 seconds left.",
      "JP": "残り10秒",
      "CN": "",
      "KR": "10초 남음",
      "TW": "還有10秒"
    }
  },
  "道路被阻挡了": {
    "translation": "",
    "MultiLang": {
      "US": "The path is blocked.",
      "JP": "道路がふさがっている",
      "CN": "",
      "KR": "도로가 막혔다",
      "TW": "道路受阻"
    }
  },
  "开枪打碎障碍": {
    "translation": "",
    "MultiLang": {
      "US": "Shoot the obstacle to break it.",
      "JP": "障害物を撃って壊せ",
      "CN": "",
      "KR": "총으로 장애물을 부부서라",
      "TW": "開槍擊碎障礙物"
    }
  },
  "下个区域马上也要沦陷了": {
    "translation": "",
    "MultiLang": {
      "US": "This area will fall soon too.",
      "JP": "次のエリアもまもなく陥落する",
      "CN": "",
      "KR": "다음 지역도 곧 함락될 거야",
      "TW": "下一個區域即將淪陷"
    }
  },
  "赶快!!": {
    "translation": "",
    "MultiLang": {
      "US": "Hurry!!",
      "JP": "急げ!!",
      "CN": "",
      "KR": "빨리!!",
      "TW": "趕快！！"
    }
  },
  "道路畅通了": {
    "translation": "",
    "MultiLang": {
      "US": "The path is clear.",
      "JP": "道路が通れるようになった",
      "CN": "",
      "KR": "길이 뚫렸다",
      "TW": "道路已暢通"
    }
  },
  "这里有些不对劲": {
    "translation": "",
    "MultiLang": {
      "US": "Something feels off here.",
      "JP": "どこか変だ",
      "CN": "",
      "KR": "여기가 좀 이상해",
      "TW": "這裡有些不對勁"
    }
  },
  "先找地方休整一下": {
    "translation": "",
    "MultiLang": {
      "US": "Find a place to rest first.",
      "JP": "先に休養場所を見つけよう",
      "CN": "",
      "KR": "일단 쉴 장소를 찾아보자",
      "TW": "先找個地方休整一下"
    }
  },
  "就在此休息片刻": {
    "translation": "",
    "MultiLang": {
      "US": "Rest here for a moment.",
      "JP": "ここで少し休もう",
      "CN": "",
      "KR": "여기서 잠시 쉬자",
      "TW": "就在此休息片刻"
    }
  },
  "准备行动,小伙子们": {
    "translation": "",
    "MultiLang": {
      "US": "Get ready, boys",
      "JP": "準備しろ、ヤツら",
      "CN": "",
      "KR": "준비해, 청년들이여",
      "TW": "準備行動，小伙子們"
    }
  },
  "行动!": {
    "translation": "",
    "MultiLang": {
      "US": "Action!",
      "JP": "行動だ！",
      "CN": "",
      "KR": "돌격!",
      "TW": "行動！"
    }
  },
  "立刻到下个区域去": {
    "translation": "",
    "MultiLang": {
      "US": "Move to the next area immediately",
      "JP": "ただちに次のエリアへ移動しろ",
      "CN": "",
      "KR": "바로 다음 구역으로 이동해",
      "TW": "立刻前往下一個區域"
    }
  },
  "新一批的感染者马上就会被放出来": {
    "translation": "",
    "MultiLang": {
      "US": "A new batch of infected will be released soon",
      "JP": "新一批の感染者がすぐに放出されるだろう",
      "CN": "",
      "KR": "새로운 감염자들이 곧 방출될 거야",
      "TW": "新一批感染者即將被釋放"
    }
  },
  "正在慢慢破解下个区域的门": {
    "translation": "",
    "MultiLang": {
      "US": "Cracking the door to the next area...",
      "JP": "次のエリアのドアを徐々に解読中",
      "CN": "",
      "KR": "다음 구역 문을 해독 중",
      "TW": "正在逐步破解下一個區域的大門"
    }
  },
  "他们来了!": {
    "translation": "",
    "MultiLang": {
      "US": "They're here!",
      "JP": "連中が来た！",
      "CN": "",
      "KR": "저들이 왔다!",
      "TW": "他們來了！"
    }
  },
  "5秒": {
    "translation": "",
    "MultiLang": {
      "US": "5 seconds",
      "JP": "5秒",
      "CN": "",
      "KR": "5초",
      "TW": "5秒"
    }
  },
  "正在破解电梯": {
    "translation": "",
    "MultiLang": {
      "US": "Cracking the elevator...",
      "JP": "エレベーターの解読中",
      "CN": "",
      "KR": "엘리베이터 해독 중",
      "TW": "正在破解電梯"
    }
  },
  "快走,下一批感染者马上就到了": {
    "translation": "",
    "MultiLang": {
      "US": "Move out! The next batch of infected is arriving soon.",
      "JP": "急いで、次の感染者はもうすぐ到着する",
      "CN": "",
      "KR": "빨리 가, 다음 패치의 감염자들이 곧 도착해",
      "TW": "快走，下一批感染者馬上就到了"
    }
  },
  "电梯还有五秒破解": {
    "translation": "",
    "MultiLang": {
      "US": "The elevator will be breached in 5 seconds.",
      "JP": "エレベーターの解除まであと5秒",
      "CN": "",
      "KR": "엘리베이터 해킹 5초 남음",
      "TW": "電梯還有五秒破解"
    }
  },
  "给我10秒": {
    "translation": "",
    "MultiLang": {
      "US": "Give me 10 seconds.",
      "JP": "10秒くれ",
      "CN": "",
      "KR": "10초만 줘",
      "TW": "給我10秒"
    }
  },
  "马上就能打开玻璃了": {
    "translation": "",
    "MultiLang": {
      "US": "The glass will be open any second now.",
      "JP": "ガラスが開くよ",
      "CN": "",
      "KR": "유리 문이 곧 열려",
      "TW": "馬上就能打開玻璃了"
    }
  },
  "还剩10秒": {
    "translation": "",
    "MultiLang": {
      "US": "10 seconds remaining.",
      "JP": "残り10秒",
      "CN": "",
      "KR": "10초 남음",
      "TW": "還剩10秒"
    }
  },
  "下个点是?": {
    "translation": "",
    "MultiLang": {
      "US": "What's the next stop?",
      "JP": "次の目的地は？",
      "CN": "",
      "KR": "다음 목적지는?",
      "TW": "下個點是？"
    }
  },
  "核心区域?": {
    "translation": "",
    "MultiLang": {
      "US": "Core zone?",
      "JP": "コアエリア？",
      "CN": "",
      "KR": "핵심 구역?",
      "TW": "核心區域？"
    }
  },
  "这帮怪物太疯狂了": {
    "translation": "",
    "MultiLang": {
      "US": "These monsters are insane.",
      "JP": "この怪物たちは狂ってる",
      "CN": "",
      "KR": "이 괴물들이 너무 미친 듯이 몰려온다",
      "TW": "這幫怪物太瘋狂了"
    }
  },
  "坚持守住就有办法": {
    "translation": "",
    "MultiLang": {
      "US": "Hold your ground, and a way out will appear.",
      "JP": "耐え忍べば抜け道が見つかる",
      "CN": "",
      "KR": "지키다 보면 돌파구가 생길 거야",
      "TW": "堅守就有辦法"
    }
  },
  "在给我10秒!!": {
    "translation": "",
    "MultiLang": {
      "US": "Give me 10 more seconds!!",
      "JP": "あと10秒だけお願い!!",
      "CN": "",
      "KR": "나는 10초만 더 줄게!!",
      "TW": "再給我10秒！！"
    }
  },
  "到达了第二十区的上面": {
    "translation": "",
    "MultiLang": {
      "US": "Reached the upper level of District 20.",
      "JP": "第20地区の上部に到達した",
      "CN": "",
      "KR": "제20구역 상단에 도달했어",
      "TW": "到達了第二十區的頂部"
    }
  },
  "想办法下去,我们才能进行下一步": {
    "translation": "",
    "MultiLang": {
      "US": "We need to figure out how to descend so we can proceed.",
      "JP": "どうやって下へ降りるか考えるんだ。その先へ行けるように",
      "CN": "",
      "KR": "아래로 내려가는 방법을 찾아야 해. 그래야 다음 단계로 나아갈 수 있어.",
      "TW": "要想辦法下去，我們才能進行下一步"
    }
  },
  "门后面好像情况不太对?": {
    "translation": "",
    "MultiLang": {
      "US": "Something seems off behind the door?",
      "JP": "扉の向こう、何かおかしいな？",
      "CN": "",
      "KR": "문 너머 상황이 좀 이상한데?",
      "TW": "門後面好像情況不太對？"
    }
  },
  "无线电:这里是紧急支援小组": {
    "translation": "",
    "MultiLang": {
      "US": "Radio: This is the Emergency Response Team.",
      "JP": "無線：こちら緊急支援班",
      "CN": "",
      "KR": "무전기: 비상 지원팀입니다",
      "TW": "無線電：這裡是緊急支援小組"
    }
  },
  "无线电:我们第二十二区沦陷了": {
    "translation": "",
    "MultiLang": {
