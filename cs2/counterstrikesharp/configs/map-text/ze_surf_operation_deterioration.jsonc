    }
  },
  "[俺たちしか描けない音に(鳴らせ)]": {
    "translation": "",
    "MultiLang": {
      "US": "[Let's make the sounds only we can write (play it)]",
      "JP": "",
      "CN": "[奏响只有我们才能谱写的旋律（奏响吧）]",
      "KR": "[우리들만이 그리는 소리를 (울리게)]",
      "TW": "[只有我們能譜寫的音樂（奏響吧）]"
    }
  },
  "[幻想を委ねてる]": {
    "translation": "",
    "MultiLang": {
      "US": "[Entrusting myself to fantasy]",
      "JP": "",
      "CN": "[托付给幻想]",
      "KR": "[환상에 몸을 맡기고]",
      "TW": "[託付給幻想之中]"
    }
  },
  "[勘違いとか自惚れと]": {
    "translation": "",
    "MultiLang": {
      "US": "[Misunderstandings and arrogance,]",
      "JP": "",
      "CN": "[与误解和自傲（对立）]",
      "KR": "[오해나 오만과]",
      "TW": "[誤解與自負交織之間]"
    }
  },
  "[誰もがまだIdolaと笑う]": {
    "translation": "",
    "MultiLang": {
      "US": "[Everyone still laughs at Idola.]",
      "JP": "",
      "CN": "[众人仍在嘲笑Idola]",
      "KR": "[아직도 누구나 Idola라고 웃어]",
      "TW": "[眾人都仍稱呼其為 Idola]"
    }
  },
  "[そんな積もった毒が]": {
    "translation": "",
    "MultiLang": {
      "US": "[That accumulated poison,]",
      "JP": "",
      "CN": "[那堆积聚的怨气]",
      "KR": "[그런 쌓인 독이]",
      "TW": "[那些沉積的毒液]"
    }
  },
  "[信じられないけどあれから]": {
    "translation": "",
    "MultiLang": {
      "US": "[I can't believe it, but since then,]",
      "JP": "",
      "CN": "[难以置信，但从那以后……]",
      "KR": "[믿을 수는 없지만 그 이후로]",
      "TW": "[儘管難以置信，但自那日起]"
    }
  },
  "[少し大人になってしまったと]": {
    "translation": "",
    "MultiLang": {
      "US": "[I've become a little more grown-up.]",
      "JP": "",
      "CN": "[似乎有些过于成熟了]",
      "KR": "[조금씩 성인이 되어 버린](으)다",
      "TW": "[稍微長大成人了一些]"
    }
  },
  "[Idola 言い訳を生んでく]": {
    "translation": "",
    "MultiLang": {
      "US": "[Idola Let It Make Excuses]",
      "JP": "",
      "CN": "[Idola 滋生出各种借口]",
      "KR": "Idola 변명을 만들어 내]",
      "TW": "[Idola 滋生著藉口]"
    }
  },
  "[今を壊して]": {
    "translation": "",
    "MultiLang": {
      "US": "[Destroy the Present]",
      "JP": "",
      "CN": "[将当下破坏殆尽]",
      "KR": "[지금 깨부수는]",
      "TW": "[破壞當下]"
    }
  },
  "[ファンファーレ]": {
    "translation": "",
    "MultiLang": {
      "US": "[Fanfare]",
      "JP": "",
      "CN": "[欢送曲]",
      "KR": "[ファンファーレ]",
      "TW": "[凱旋曲]"
    }
  },
  "[俺たちしか描けない音に]": {
    "translation": "",
    "MultiLang": {
      "US": "[To the Sounds Only We Can Draw]",
      "JP": "",
      "CN": "[只有我们所能描绘的声音]",
      "KR": "[우리들만 그려낼 수 있는 소리에]",
      "TW": "[唯有我們能譜寫的樂音]"
    }
  },
  "队长：运输机开始启动了，我们马上就可以走了！": {
    "translation": "",
    "MultiLang": {
      "US": "Captain: The transport aircraft is starting up. We can leave immediately!",
      "JP": "隊長：輸送機が開始しました、すぐに離脱できます！",
      "CN": "",
      "KR": "captain: 수송기가 이제 이동을 시작합니다. 금방 갈 수 있습니다!",
      "TW": "隊長：運輸機已開始啟動，我們馬上就能出發！"
    }
  },
  "队长：呼叫指挥部，deterioration小队已经成功撤离，请求下一步指示": {
    "translation": "",
    "MultiLang": {
      "US": "Captain: Command, this is Team Deterioration. Successful evacuation confirmed. Awaiting further instructions.",
      "JP": "隊長：指揮本部へ、deterioration小隊は撤退完了、次の指示を求めます",
      "CN": "",
      "KR": "captain: 본부에 연락드립니다. deterioration 소대가 성공적으로 철수했음을 보고하며, 다음 지시를 요청합니다.",
      "TW": "隊長：呼叫指揮部，deterioration 小隊已成功撤離，請求下一步指示。"
    }
  },
  "指挥部：干得很好，下一步需要你们接应o******tion小队，他们的麻烦可不小": {
    "translation": "",
    "MultiLang": {
      "US": "Command: Good work. Next, you need to provide support for Team O******tion. They're in quite a bit of trouble.",
      "JP": "指揮本部：よくやった、次はo******tion小隊の救援をお願いします、彼らは厄介ごとを抱えています",
      "CN": "",
      "KR": "headquarters: 잘했다. 다음은 o******tion 소대를 지원해야 합니다. 그들의麻烦은 꽤 크군.",
      "TW": "指揮部：做得很好，下一步需要你們接應 o******tion 小隊，他們的麻煩可不小。"
    }
  },
  "队长：收到，我们这就前往该小队所在地": {
    "translation": "",
    "MultiLang": {
      "US": "Captain: Copy that. We're moving to their location now.",
      "JP": "隊長：了解、そちらの小隊へ移動します",
      "CN": "",
      "KR": "captain: 알겠습니다. 즉시 해당 소대 위치로 이동하겠습니다.",
      "TW": "隊長：收到，我們这就前往該小隊所在地。"
    }
  },
