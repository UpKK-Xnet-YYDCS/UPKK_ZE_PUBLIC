{
  "*** Deadly gas launched! 10 seconds until glass door is sealed! ***": {
    "translation": "***致命毒气发射！10秒后玻璃门将被封闭！！***",
    "MultiLang": {
      "US": "",
      "JP": "*** 有害ガス発射！ 硝子扉封鎖まで10秒！ ***",
      "CN": "***剧毒气体已释放！距离玻璃门关闭还有10秒！***",
      "KR": "*** 치명적인 가스가 발사되었습니다! 유리문이 닫히기까지 10초! ***",
      "TW": "*** 致命氣體已發射！距玻璃門封閉僅剩 10 秒！***"
    }
  },
  "*** Final glass window will open in 50 seconds... ***": {
    "translation": "***最后一个玻璃窗将在50秒后开启...***",
    "MultiLang": {
      "US": "",
      "JP": "*** 最後の硝子窓が50秒後に開きます... ***",
      "CN": "***最后一扇玻璃窗将在50秒后开启...***",
      "KR": "*** 마지막 유리창이 50초 후에 열립니다... ***",
      "TW": "*** 最後一扇玻璃窗將在 50 秒後開啟...***"
    }
  },
  "*** Get going before the platform breaks! Hurry! ***": {
    "translation": "***快走，平台就要崩溃了！快点！***",
    "MultiLang": {
      "US": "",
      "JP": "*** プラットフォーム崩壊前にお逃げください！ 急いで！ ***",
      "CN": "***在平台碎裂前离开！快！***",
      "KR": "*** 플랫폼이 부서지기 전에 서두르세요! 빨리! ***",
      "TW": "*** 在平台崩壞前快點離開！著急！***"
    }
  },
  "*** Get in the center! ***": {
    "translation": "***站到中间去！***",
    "MultiLang": {
      "US": "",
      "JP": "*** 中央へ集まりなさい！ ***",
      "CN": "***到中心去！***",
      "KR": "*** 중앙으로 모여라! ***",
      "TW": "*** 到中央去！***"
    }
  },
  "*** Glass window is opening in 15 seconds. ***": {
    "translation": "***玻璃窗将在15秒后开启。***",
    "MultiLang": {
      "US": "",
      "JP": "*** 硝子窓が15秒後に開きます。 ***",
      "CN": "***玻璃窗将在15秒后开启。***",
      "KR": "*** 유리창이 15초 후에 열립니다. ***",
      "TW": "*** 玻璃窗將於 15 秒後開啟。***"
    }
  },
  "*** Glass window is opening in 5 seconds! Get ready! ***": {
    "translation": "***玻璃窗将在5秒后开启！准备好！***",
    "MultiLang": {
      "US": "",
      "JP": "*** 硝子窓が5秒後に開きます！ 準備しろ！ ***",
      "CN": "***玻璃窗将在5秒后开启！准备！***",
      "KR": "*** 유리창이 5초 후에 열립니다! 준비하십시오! ***",
      "TW": "*** 玻璃窗將於 5 秒後開啟！準備好！***"
    }
  },
  "*** Move! ***": {
    "translation": "***动起来！翻译：Asteri3m***",
    "MultiLang": {
      "US": "",
      "JP": "*** 動け！ ***",
      "CN": "***移动！***",
      "KR": "*** 움직이자! ***",
      "TW": "*** 移動！***"
    }
  },
  "*** Platforms will begin rising in 15 seconds! ***": {
    "translation": "***平台将在15秒后开始升起！***",
    "MultiLang": {
      "US": "",
      "JP": "*** プラットフォーム上昇開始まで15秒！ ***",
      "CN": "***平台将在15秒后开始上升！***",
      "KR": "*** 플랫폼이 15초 후에 상승을 시작합니다! ***",
      "TW": "*** 平台將於 15 秒後開始上升！***"
    }
  },
  "*** Second teleport in 20 seconds! Don't stay behind. ***": {
    "translation": "***第二次传送将在20秒后进行！不要落后。***",
    "MultiLang": {
      "US": "",
      "JP": "*** 20秒以内に二度目のテレポート！取り残されないように。***",
      "CN": "*** 20秒后再次传送！别留在后面。***",
      "KR": "*** 20초 후 두 번째 텔레포트! 뒤에 남지 마세요. ***",
      "TW": "***20秒內再次傳送！別掉隊。***"
    }
  },
  "*** Slowpoke teleport in 15 seconds.***": {
    "translation": "***慢吞吞的传送将在15秒后进行。***",
    "MultiLang": {
      "US": "",
      "JP": "*** 15秒以内にのろのろテレポート。***",
      "CN": "*** 缓慢传送15秒后即将执行。***",
      "KR": "*** 느린 텔레포트 15초 후.***",
      "TW": "***慢吞吞15秒內傳送。***"
    }
  },
  "*** Wall breaks in 20 seconds. ***": {
    "translation": "***墙将在20秒后破裂。***",
    "MultiLang": {
      "US": "",
      "JP": "*** 20秒以内に壁が崩壊します。***",
      "CN": "*** 墙体将在20秒后破碎。***",
      "KR": "*** 벽이 20초 뒤에 파괴됩니다. ***",
      "TW": "***20秒後牆壁消失。***"
    }
  }
}
