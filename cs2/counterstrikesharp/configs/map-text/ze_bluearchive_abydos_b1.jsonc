  "阿罗娜<<竟然把学校破坏成这样...>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<How did they destroy the school to this extent...>>",
      "JP": "アロナ<<なぜ学校をこれほどまでに破壊したのか...>>",
      "CN": "",
      "KR": "아로나<<학원이 이렇게 파괴될 줄은 몰랐습니다...>>",
      "TW": "阿羅娜<<竟然把學校破壞成這樣...>>"
    }
  },
  "<<20s>>": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<20秒>>",
      "CN": "<<20秒>>",
      "KR": "<<20대>>",
      "TW": "<<20s>>"
    }
  },
  "阿罗娜<<请小心，侦测到一名钢盔团成员躲在后面>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<Be careful. One member of the Steel Helm Unit has been detected hiding behind you.>>",
      "JP": "アロナ<<Sensei、気をつけて。スチールヘルメットの隊員の一人が背後に隠れています>>",
      "CN": "",
      "KR": "아로나<<조심하세요. 강철 갑옷 팀원 한 명이 뒤쪽에 숨어 있습니다>>",
      "TW": "阿羅娜：「請小心，偵測到一名鋼盔團成員躲在後面。」"
    }
  },
  "阿罗娜<<就从这里破墙而入吧>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<Let's breach through the wall from here.>>",
      "JP": "アロナ<<ここから壁を突破しましょう>>",
      "CN": "",
      "KR": "아로나<<여기서 벽을 부수고 진입합시다>>",
      "TW": "阿羅娜：「就從這裡破牆而入吧。」"
    }
  },
  "阿罗娜<<这里的门又被反锁了>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<The door here is locked again.>>",
      "JP": "アロナ<<ここはまた鍵がかかっています>>",
      "CN": "",
      "KR": "아로나<<여기의 문은 다시 잠겼습니다>>",
      "TW": "阿羅娜：「這裡的門又被反鎖了。」"
    }
  },
  "阿罗娜<<sensei清远离这里，马上要爆炸了>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<Sensei, get away from here! It's about to explode>>",
      "JP": "アロナ<<Sensei、ここから離れてください。まもなく爆発します>>",
      "CN": "阿罗娜<<老师清远离这里，马上要爆炸了>>",
      "KR": "아로나<<sensei, 여기서 멀리 떨어져주세요. 곧 폭발합니다>>",
      "TW": "阿羅娜：「sensei請遠離這裡，馬上要爆炸了。」"
    }
  },
  "阿罗娜<<请等待一下sensei>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<Please wait, Sensei>>",
      "JP": "アロナ<<お待ちください、Sensei>>",
      "CN": "阿罗娜<<等待一下，老师>>",
      "KR": "아로나<<sensei, 잠시만 기다려주세요>>",
      "TW": "阿羅娜：「請等待一下sensei。」"
    }
  },
  "阿罗娜<<好，打开了！>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<Okay, open!>>",
      "JP": "アロナ<<よし、開きました！>>",
      "CN": "阿罗娜<<打开了！>>",
      "KR": "아로나<<좋습니다. 열었습니다!>>",
      "TW": "阿羅娜：「好，打開了！」"
    }
  },
  "阿罗娜<<这里有个梯子能通往三楼>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<There's a ladder here leading to the third floor>>",
      "JP": "アロナ<<ここには3階につながる梯子があります>>",
      "CN": "",
      "KR": "아로나<<여기에 3층으로 이어지는 사다리가 있습니다>>",
      "TW": "阿羅娜：「這裡有個梯子能通往三樓。」"
    }
  },
  "阿罗娜<<请稍等sensei>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<Please wait, Sensei>>",
      "JP": "アロナ<<お待ちくださいませ、センシ>>",
      "CN": "阿罗娜《请稍等，老师》",
      "KR": "아로나<<잠시만요 선생님>>",
      "TW": "阿羅娜<<請稍等，Sensei>>"
    }
  },
