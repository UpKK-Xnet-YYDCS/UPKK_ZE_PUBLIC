{
  "阿罗娜<<钢盔团和PMC集团合作占领了阿拜多斯学校>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<The Steel Helm Unit and the PMC Group have jointly occupied Abydos High School.>>",
      "JP": "アロナ<<ヘルメット団とPMC集团が協力してアビドス学校を占領しました>>",
      "CN": "",
      "KR": "아로나<<강철단과 PMC 그룹이 협동하여 아비도스 학원을 점령했습니다>>",
      "TW": "阿羅娜<<鋼盔團與PMC集團合作，佔領了阿拜多斯學院>>"
    }
  },
  "阿罗娜<<比纳不知为何也来到了阿拜多斯学校>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<Bina came to Abydos High School for some reason.>>",
      "JP": "アロナ<<ビリナはどうやら訳もあってか、アビドス学校に現れました>>",
      "CN": "",
      "KR": "아로나<<비나는 무슨 일인지 아비도스 학원에 도착했습니다>>",
      "TW": "阿羅娜<<不知為何，比奈也來到了阿拜多斯學院>>"
    }
  },
  "阿罗娜<<好在星野她们已经安全撤出学校了>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<Fortunately, Hoshino and the others have already safely evacuated the school.>>",
      "JP": "アロナ<<ほっとしたことに、星野達はすでに学校から安全に撤退しました>>",
      "CN": "",
      "KR": "아로나<<다행히 성희 자석들은 이미 학원에서 안전하게 철수했습니다>>",
      "TW": "阿羅娜<<幸好星野她們已經安全撤離了學院>>"
    }
  },
  "阿罗娜<<sensei，我们得想办法把学校夺回来>>": {
    "translation": "",
    "MultiLang": {
      "US": "Arona <<Sensei, we need to find a way to take the school back.>>",
      "JP": "アロナ<<先生、我々は学校を取り戻す方法を考えねばなりません>>",
      "CN": "阿罗娜<<<老师，我们需要想办法夺回学校>>>",
      "KR": "아로나<<선생님, 저희는 학원을 되찾기 위한 방법을 찾아야 합니다>>",
      "TW": "阿羅娜<<sensei，我們得想辦法把學校奪回來>>"
    }
  },
  "<<30s>>": {
