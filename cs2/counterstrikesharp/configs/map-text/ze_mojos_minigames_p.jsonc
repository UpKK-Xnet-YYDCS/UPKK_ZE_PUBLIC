      "KR": "* * * 문이 5초 후에 닫힙니다. * * *",
      "TW": "* * * 門將在 5 秒後關閉 * * *"
    }
  },
  "* * * Time for the mandatory LASERS!* * *": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "* * * 必須のレーザータイム！ * * *",
      "CN": "* * * 现在是强制性的激光时间！* * *",
      "KR": "* * * 이제 필수로 등장하는 레이저! * * *",
      "TW": "* * * 現在是強制性的雷射時間！* * *"
    }
  },
  "* * * Humans get x3 HP - if you lose it you die! * * *": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "* * * 人間はHPがx3 - 失ったら即死！ * * *",
      "CN": "* * * 人物拥有x3生命值 - 如果损失了，你就会死亡！* * *",
      "KR": "* * * 인간은 체력 x3 - 체력이 다 떨어지면 즉사합니다! * * *",
      "TW": "* * * 人類擁有 x3 的生命值 - 如果你失去了它，你就會死亡！ * * *"
    }
  },
