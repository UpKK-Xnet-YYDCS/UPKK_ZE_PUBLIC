  },
  "\u0002[\u0007MOJOHINT\u0002]\u0005 Keep an eye on the SKY!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "\u0002[\u0007MOJOHINT\u0002]\u0005 空をよく見てください！",
