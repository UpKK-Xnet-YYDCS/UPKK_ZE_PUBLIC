    }
  },
  "\u0002[\u0007MOJOHINT\u0002]\u0005 Use your KNIFE on the platforms to CRUMBLE them.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "\u0002[\u0007MOJOHINT\u0002]\u0005 ナイフを使って、プラットフォームを破壊し、崩落させましょう。",
      "CN": "\u0002[\u0007MOJOHINT\u0002]\u0005 使用你的匕首破坏平台。",
      "KR": "",
      "TW": "\u0002[\u0007MOJOHINT\u0002]\u0005 使用你的刀子攻擊平台，使其崩塌。"
    }
  },
  "* * * 15 platforms more to win! * * *": {
    "translation": "",
    "MultiLang": {
