    }
  },
  "门碎了": {
    "translation": "",
    "MultiLang": {
      "US": "Door broken",
      "JP": "门碎了",
      "CN": "",
      "KR": "문이 산산조각났다",
      "TW": "門碎了"
    }
  },
  "门将于15s后关闭": {
    "translation": "",
    "MultiLang": {
      "US": "Door will close in 15s",
      "JP": "门将于15s后关闭",
      "CN": "",
      "KR": "문은 15초 후 폐쇄된다",
      "TW": "門將於15秒後關閉"
    }
  },
  "他最后说的话是什么意思，什么叫我们还会再见？": {
    "translation": "",
    "MultiLang": {
      "US": "What did he mean by his last words? What do you mean 'we'll meet again'?",
      "JP": "他最后说的话是什么意思，什么叫我们还会再见？",
      "CN": "",
      "KR": "그가 마지막으로 한 말은 무슨 뜻일까? 우리는 또 만난다는 것이 무슨 소리인가?",
      "TW": "他最後的話是什麼意思，怎麼說我們還會再見？"
    }
  },
  "mapped by 冰灵li": {
    "translation": "",
    "MultiLang": {
      "US": "Mapped by Binglingli",
      "JP": "mapped by 冰灵li",
      "CN": "",
      "KR": "mapped by Ice Spirit (Bing Ling li)",
      "TW": "由冰灵li製作"
    }
  },
  "感谢所有在我做图过程中提供帮助的大佬": {
    "translation": "",
    "MultiLang": {
      "US": "Thanks to all the helpers who assisted me during map creation.",
      "JP": "感谢所有在我做图过程中提供帮助的大佬",
      "CN": "",
      "KR": "맵 제작 과정에서 도움을 준 모든 분들에게 감사드립니다",
      "TW": "感謝所有在製作過程中提供幫助的大佬"
    }
  },
  "核爆还有10秒": {
    "translation": "",
    "MultiLang": {
      "US": "Nuclear explosion in 10 seconds",
      "JP": "核爆まであと10秒",
      "CN": "",
      "KR": "핵폭발 10초 전",
      "TW": "核爆剩餘10秒"
    }
  },
  "这是我的第一个作品，还存在许多问题，欢迎提出问题": {
    "translation": "",
    "MultiLang": {
      "US": "This is my first work, and there are still many issues. Feel free to provide feedback.",
      "JP": "これは私の初めての作品です。まだまだ不具合があるかもしれませんので、ご意見・ご指摘を歓迎します。",
      "CN": "",
      "KR": "저의 첫 번째 작품입니다. 많은 부분이 아직 미비하지만, 피드백은 언제든지 환영합니다.",
      "TW": "這是我的第一個作品，仍存在許多問題，歡迎提出建議。"
    }
  },
  "感谢大家的游玩!!!!": {
    "translation": "",
    "MultiLang": {
      "US": "Thank you for playing!!!!",
      "JP": "みなさん、プレイしていただき本当にありがとうございました!!!!",
      "CN": "",
      "KR": "모두들 놀아주셔서 감사합니다!!!!",
      "TW": "感謝大家遊玩！！！！"
    }
  },
  "谢谢大家喵~": {
    "translation": "",
    "MultiLang": {
      "US": "Thank you, meow~",
      "JP": "ありがとうご家族〜",
      "CN": "",
      "KR": "감사합니다喵~",
      "TW": "謝謝大家喵～"
    }
  },
