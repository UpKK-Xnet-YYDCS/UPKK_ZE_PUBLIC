  "** Bring the core to the root of the sky tree **": {
    "translation": "** 把核心带到天穹树的树根 **",
    "MultiLang": {
      "US": "",
      "JP": "** コアを天空樹の根元へ運ぶ **",
      "CN": "**将核心带到天树的根部**",
      "KR": "** 코어를 하늘 나무의 뿌리로 가져오세요**",
      "TW": "** 將核心帶到天空樹的根部 **"
    }
  },
  "** Finally escaped **": {
    "translation": "** 终于逃出来了 **",
    "MultiLang": {
      "US": "",
      "JP": "最終的に脱出した",
      "CN": "** 终于逃脱了 **",
      "KR": "** 마침내 탈출 완료 **",
      "TW": "**終於逃脫**"
    }
  },
  "** Hold 15 second to remove the magic array **": {
    "translation": "** 防守15秒移除魔法阵 **",
    "MultiLang": {
      "US": "",
      "JP": "魔法陣を解除するには15秒間押す",
      "CN": "** 按住15秒移除魔法阵 **",
      "KR": "** 마법 진 15초 간 유지하여 해제 **",
      "TW": "**按住魔法陣15秒即可解除**"
    }
  },
  "** Hold 20 second **": {
    "translation": "** 防守20秒 **",
    "MultiLang": {
      "US": "** Hold for 20 seconds **",
      "JP": "20秒間押す",
      "CN": "** 按住20秒 **",
      "KR": "** 20초 간 유지 **",
      "TW": "**保持按住20秒**"
    }
  },
  "** Hold 20 second, we're almost at the sky tree **": {
    "translation": "** 防守20秒，我们快到天穹树了 **",
    "MultiLang": {
      "US": "",
      "JP": "20秒間押すと、空中の木に近づきます",
      "CN": "** 按住20秒，我们即将抵达天空树 **",
      "KR": "** 하늘 나무에 거의 도달한 상태, 20초 간 유지 **",
      "TW": "**保持按住20秒，我們幾乎到達天空之樹**"
    }
  },
  "** Hold 25 second to clear the tree **": {
    "translation": "** 防守25秒清理树木 **",
    "MultiLang": {
      "US": "",
      "JP": "木を消すには25秒間押す",
