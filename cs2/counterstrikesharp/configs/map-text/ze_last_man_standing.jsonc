  "士兵已拾取 - 右键放置或回收": {
    "translation": "",
    "MultiLang": {
      "US": "Soldier equipped - Right-click to place or recycle",
      "JP": "兵士が拾取しました - 右クリックで設置または回収",
      "CN": "",
      "KR": "병사가 수거함 - 오른쪽 버튼으로 배치하거나 회수",
      "TW": "士兵已拾取 - 右鍵放置或回收"
    }
  },
  "哨戒炮台已拾取 - 按E放置或回收炮台": {
    "translation": "",
    "MultiLang": {
      "US": "Turret Pickup - Press E to Deploy or Retrieve",
      "JP": "哨戒砲台を取得しました - Eキーで設置または回収",
      "CN": "",
      "KR": "감시 타워를 주웠습니다 - E를 눌러 설치하거나 회수합니다",
      "TW": "哨戒炮台已拾取 - 按 E 放置或回收炮台"
    }
  },
  "旋风枪已拾取 - 按E发射旋风推开僵尸": {
    "translation": "",
    "MultiLang": {
      "US": "Whirlwind Gun Pickup - Press E to Fire and Repel Zombies",
      "JP": "旋風銃を取得しました - Eキーで旋風を発射してゾンビを吹き飛ばす",
      "CN": "",
      "KR": "회오리 건을 주웠습니다 - E를 눌러 회오리를 발사하여 좀비를 밀어냅니다",
      "TW": "旋風槍已拾取 - 按 E 發射旋風推開殭屍"
    }
  },
  "零重力枪已拾取 - 按E使用浮空僵尸 - 冷却时间: 30秒": {
    "translation": "",
    "MultiLang": {
      "US": "Zero-G Gun Pickup - Press E to Float Zombies - Cooldown: 30s",
      "JP": "無重力銃を取得しました - Eキーで浮遊するゾンビを使用 - クールタイム: 30秒",
      "CN": "",
      "KR": "무중력 건을 주웠습니다 - E를 사용하여浮空 좀비를 처리합니다 - 쿨타임: 30초",
      "TW": "零重力槍已拾取 - 按 E 使用浮空殭屍 - 冷卻時間：30秒"
    }
  },
  "*** 右侧按钮激活 ***": {
    "translation": "",
    "MultiLang": {
      "US": "*** Right Button Active ***",
      "JP": "*** 右側ボタンが有効化されました ***",
      "CN": "",
      "KR": "*** 오른쪽 버튼 활성화 ***",
      "TW": "*** 右側按鈕已啟用 ***"
    }
  },
  "*** 左侧按钮激活 ***": {
