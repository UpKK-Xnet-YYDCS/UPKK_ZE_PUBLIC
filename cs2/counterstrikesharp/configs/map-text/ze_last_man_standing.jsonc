  "士兵已拾取 - 右键放置或回收": {
    "translation": "",
    "MultiLang": {
      "US": "Soldier picked up - Right-click to place or recycle",
      "JP": "兵士が回収されました - 右クリックで配置または回収",
      "CN": "",
      "KR": "병사 획득 - 마우스 오른쪽 버튼으로 배치 또는 회수",
      "TW": "士兵已拾取 - 右鍵放置或回收"
    }
  },
  "哨戒炮台已拾取 - 按E放置或回收炮台": {
    "translation": "",
    "MultiLang": {
      "US": "Guard turret acquired - Press E to deploy or reclaim the turret.",
      "JP": "パトロール砲台を回収しました - Eキーを押して砲台を設置または回収します。",
      "CN": "",
      "KR": "경계 포탑을 획득했습니다. E 키를 눌러 포탑을 설치하거나 회수하세요.",
      "TW": "哨戒炮台已拾取 - 按E放置或回收炮台"
    }
  },
  "旋风枪已拾取 - 按E发射旋风推开僵尸": {
    "translation": "",
    "MultiLang": {
      "US": "Spinning gun acquired - Press E to fire and push back zombies.",
      "JP": "旋風銃を回収しました - Eキーを押して旋風を放ち、ゾンビを吹き飛ばします。",
      "CN": "",
      "KR": "회오리총을 획득했습니다. E 키를 눌러 회오리 바람을 일으켜 좀비들을 밀어내세요.",
      "TW": "旋风枪已拾取 - 按E发射旋风推开僵尸"
    }
  },
  "零重力枪已拾取 - 按E使用浮空僵尸 - 冷却时间: 30秒": {
    "translation": "",
    "MultiLang": {
      "US": "Zero-gravity gun acquired - Press E to use and levitate zombies - Cooldown: 30 seconds.",
      "JP": "重力制御銃を回収しました - Eキーを押して使用すると、ゾンビを浮遊させます - クールダウン: 30秒",
      "CN": "",
      "KR": "무중력총을 획득했습니다. E 키를 눌러 좀비를 공중에 띄우세요. 쿨다운: 30초",
      "TW": "零重力枪已拾取 - 按E使用，使僵尸漂浮 - 冷却时间: 30秒"
    }
  },
  "*** 右侧按钮激活 ***": {
    "translation": "",
    "MultiLang": {
      "US": "*** Activate the right button.***",
      "JP": "***右側のボタンでアクティベート***",
      "CN": "",
      "KR": "*** 오른쪽 버튼 활성화 ***",
      "TW": "*** 右侧按钮激活 ***"
    }
  },
  "*** 左侧按钮激活 ***": {
    "translation": "",
    "MultiLang": {
      "US": "*** Activate the left button.***",
      "JP": "***左側のボタンでアクティベート***",
      "CN": "",
      "KR": "*** 왼쪽 버튼 활성화 ***",
      "TW": "*** 左侧按钮激活 ***"
    }
  },
  "*** 最右侧按钮激活 ***": {
    "translation": "",
    "MultiLang": {
      "US": "*** Activate the button on the far right.***",
      "JP": "***一番右のボタンでアクティベート***",
      "CN": "",
      "KR": "*** 가장 오른쪽 버튼 활성화 ***",
      "TW": "*** 最右侧按钮激活 ***"
    }
  },
  "*** 最左侧按钮激活 ***": {
    "translation": "",
    "MultiLang": {
      "US": "*** Activate the button on the far left.***",
      "JP": "***一番左のボタンでアクティベート***",
      "CN": "",
      "KR": "*** 가장 왼쪽 버튼 활성화 ***",
      "TW": "*** 最左侧按钮激活 ***"
    }
  },
  "超越极限已拾起 - 按E使用使人类获得巨额加速与血量提升": {
    "translation": "",
    "MultiLang": {
      "US": "Beyond Limit acquired - Press E to use and grant humans a massive speed and health boost.",
      "JP": "限界突破を回収しました - Eキーを押して使用すると、人間は大幅な加速と体力を得られます。",
      "CN": "",
      "KR": "극한 초월을 획득했습니다. E 키를 눌러 인간에게 엄청난 속도 증가와 체력 상승 효과를 부여하세요.",
      "TW": "超越极限已拾起 - 按E使用，使人类获得巨额加速与血量提升"
    }
  },
  "特感坦克加入游戏 - 靠近废车右键打铁": {
    "translation": "",
    "MultiLang": {
      "US": "Special Tank added to the game - Right-click near the wrecked vehicle to activate.",
      "JP": "特殊感が伝わる戦車がゲームに登場 - 廃車に近づき、右クリックで鉄槌を叩く",
      "CN": "",
      "KR": "특수 능력 탱크가 게임에 추가되었습니다. - 버려진 차량 근처에서 우클릭으로 강철을 생성합니다.",
      "TW": "特殊感应坦克加入游戏 - 靠近废车，右键点击进行操作。"
    }
  },
  "地雷已拾取 - 按E放置地雷 - 靠近地雷以回收": {
    "translation": "",
    "MultiLang": {
      "US": "Mine picked up - Press E to place the mine - Approach the mine to reclaim it.",
      "JP": "地雷を拾得しました - Eキーで地雷を設置 - 地雷に近づくと回収できます",
      "CN": "",
      "KR": "지뢰를 획득했습니다. - E 키를 눌러 지뢰를 설치합니다. - 지뢰 근처에서 E 키를 눌러 회수합니다.",
      "TW": "地雷已拾取 - 按E放置地雷 - 靠近地雷以回收。"
    }
  },
  "M60机枪已拾取 - 按E切换开火": {
    "translation": "",
    "MultiLang": {
      "US": "M60 machine gun picked up - Press E to switch to fire mode.",
      "JP": "M60機関銃を拾得しました - Eキーで発射を切り替えます",
      "CN": "",
      "KR": "M60 기관총을 획득했습니다. - E 키를 눌러 발사 모드를 전환합니다.",
      "TW": "M60机枪已拾取 - 按E切换开火。"
    }
  },
  "高斯枪已拾取 - 按E释放毁灭射线": {
    "translation": "",
    "MultiLang": {
      "US": "Gauss rifle picked up - Press E to unleash the devastating beam.",
      "JP": "ガウスライフルを拾得しました - Eキーで破壊光線を放ちます",
      "CN": "",
      "KR": "가우스 권총을 획득했습니다. - E 키를 눌러 파괴 광선을 발사합니다.",
      "TW": "高斯枪已拾取 - 按E释放毁灭射线。"
    }
  },
  "冲击狗加入游戏 - 右键推开人类和僵尸": {
    "translation": "",
    "MultiLang": {
      "US": "Shock Dog added to the game - Right-click to push back humans and zombies.",
      "JP": "衝撃犬がゲームに登場 - 右クリックで人間やゾンビを吹き飛ばします",
      "CN": "",
      "KR": "충격견이 게임에 추가되었습니다. - 우클릭으로 인간과 좀비를 밀어냅니다.",
      "TW": "冲击犬加入游戏 - 右键推开人类和僵尸。"
    }
  },
  "飞扑者加入游戏 - 右键向前冲刺": {
    "translation": "",
    "MultiLang": {
      "US": "Leaper added to the game - Right-click to dash forward.",
      "JP": "飛びつき攻撃者がゲームに登場 - 右クリックで前方に突進します",
      "CN": "",
      "KR": "돌진병이 게임에 추가되었습니다. - 우클릭으로 전방으로 돌진합니다.",
      "TW": "飞扑者加入游戏 - 右键向前冲刺。"
    }
  },
  "免疫装置已拾起 - 按E使用使人类免疫感染20秒": {
    "translation": "",
    "MultiLang": {
      "US": "Immunity Device picked up - Press E to use, granting humans immunity to infection for 20 seconds.",
      "JP": "耐性装置を拾得しました - Eキーで使用し、人間を20秒間感染から保護します",
      "CN": "",
      "KR": "면역 장치를 획득했습니다. - E 키를 눌러 사용하면 인간이 20초 동안 감염으로부터 보호됩니다.",
      "TW": "免疫装置已拾起 - 按E使用，使人类免疫感染20秒。"
    }
  },
  "启用免疫装置 - 人类将在20秒内免疫感染": {
    "translation": "",
    "MultiLang": {
      "US": "Activate Immunity Device - Humans will be immune to infection for 20 seconds.",
      "JP": "耐性装置を有効化 - 人間は20秒間、感染から保護されます",
      "CN": "",
      "KR": "면역 장치 활성화 - 인간은 20초 동안 감염으로부터 보호됩니다.",
      "TW": "启用免疫装置 - 人类将在20秒内免疫感染。"
    }
  },
  "黑洞巫师加入游戏 - 右键放置传送黑洞": {
    "translation": "",
    "MultiLang": {
      "US": "Black Hole Wizard added to the game - Right-click to place a teleportation black hole.",
      "JP": "ブラックホールウィザードがゲームに登場 - 右クリックでブラックホールを設置",
      "CN": "",
      "KR": "블랙홀 마법사가 게임에 추가되었습니다 - 마우스 오른쪽 버튼으로 블랙홀을 생성합니다.",
      "TW": "黑洞法师加入游戏 - 右键放置传送黑洞"
    }
  },
  "弗地冈人加入游戏 - 右键将人类拉至身前": {
    "translation": "",
    "MultiLang": {
      "US": "Verdian added to the game - Right-click to pull a human towards you.",
      "JP": "フレディゴンがゲームに登場 - 右クリックで人間を自分の前に引き寄せる",
      "CN": "",
      "KR": "프디곤족이 게임에 추가되었습니다 - 마우스 오른쪽 버튼으로 인간을 끌어당깁니다.",
      "TW": "弗地冈人加入游戏 - 右键将人类拉至身前"
    }
  },
  "*** 僵尸已逃脱! ***": {
    "translation": "",
    "MultiLang": {
      "US": "*** Zombies have escaped! ***",
      "JP": "警告：ゾンビが脱走しました！",
      "CN": "",
      "KR": "*** 좀비가 탈출했습니다! ***",
      "TW": "*** 僵尸已逃脱! ***"
    }
  },
  "*** 僵尸触发了开关! ***": {
    "translation": "",
    "MultiLang": {
      "US": "*** Zombies triggered a switch! ***",
      "JP": "警告：ゾンビがスイッチを作動させました！",
      "CN": "",
      "KR": "*** 좀비가 스위치를 작동시켰습니다! ***",
      "TW": "*** 僵尸触发了开关! ***"
    }
  },
  "免疫枪已拾取 - 按E发射免疫光线": {
    "translation": "",
    "MultiLang": {
      "US": "Immunity Gun picked up - Press E to fire an immunity beam.",
      "JP": "免疫銃を拾得 - Eキーで免疫光線を放つ",
      "CN": "",
      "KR": "내성 총을 획득했습니다 - E 키를 눌러 내성 광선을 발사합니다.",
      "TW": "免疫枪已拾取 - 按E发射免疫光线"
    }
  },
  "基因背包已拾取 - 按E放置基因改造药物 - 小心毒药": {
    "translation": "",
    "MultiLang": {
      "US": "Gene Backpack picked up - Press E to place gene modification drugs - Beware of poisons.",
      "JP": "遺伝子パックを拾得 - Eキーで遺伝子改造薬を設置 - 毒に注意",
      "CN": "",
      "KR": "유전자 백팩을 획득했습니다 - E 키를 눌러 유전자 변형 약물을 사용합니다 - 독에 주의하세요.",
      "TW": "基因背包已拾取 - 按E放置基因改造药物 - 小心毒药"
    }
  },
  "突变基因: 速度x0.9": {
    "translation": "",
    "MultiLang": {
      "US": "Mutation Gene: Speed x0.9",
      "JP": "突然変異遺伝子：速度 x 0.9",
      "CN": "",
      "KR": "돌연변이 유전자: 속도 x0.9",
      "TW": "突变基因：速度 x 0.9"
    }
  },
  "突变基因: 速度x0.75": {
    "translation": "",
    "MultiLang": {
      "US": "Mutation Gene: Speed x0.75",
      "JP": "突然変異遺伝子：速度 x 0.75",
      "CN": "",
      "KR": "돌연변이 유전자: 속도 x0.75",
      "TW": "突变基因：速度 x 0.75"
    }
  },
  "突变基因: 太空漫步": {
    "translation": "",
    "MultiLang": {
      "US": "Mutation: Space Walk",
      "JP": "変異遺伝子: スペースウォーク",
      "CN": "",
      "KR": "돌연변이 유전자: 우주 유영",
      "TW": "突变基因：太空漫步"
    }
  },
  "突变基因: 速度x1.25": {
    "translation": "",
    "MultiLang": {
      "US": "Mutation: Speed x1.25",
      "JP": "変異遺伝子: スピード x1.25",
      "CN": "",
      "KR": "돌연변이 유전자: 속도 x1.25",
      "TW": "突变基因：速度x1.25"
    }
  },
  "阿尔玛加入游戏 - 右键缴械人类并杀死他们": {
    "translation": "",
    "MultiLang": {
      "US": "Alma joins the game - Right-click to disarm and kill humans",
      "JP": "アルマがゲームに参加 - 右クリックで武装を奪い、人間を殺害します",
      "CN": "",
      "KR": "알마 플레이어 접속 - 마우스 오른쪽 버튼으로 무기를 버리고 인간을 처치합니다.",
      "TW": "阿尔玛加入游戏 - 右键缴械人类并杀死他们"
    }
  },
  "传送枪已拾取 - 按E放置或回收传送门": {
    "translation": "",
    "MultiLang": {
      "US": "Teleporter picked up - Press E to place or retrieve the teleporter",
      "JP": "テレポートガンを拾いました - Eキーでテレポートポータルを設置または回収します",
      "CN": "",
