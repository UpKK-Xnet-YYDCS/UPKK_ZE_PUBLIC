  "** We need to resist! The park's door will open in 20 seconds! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 抵抗せよ！公園のドアが20秒後に開く！**",
      "CN": "** 我们必须抵抗！公园大门将在20秒后开启！ **",
      "KR": "** 저항해야 해! 공원 문이 20초 후에 열려! **",
      "TW": "** 我們必須抵禦！公園大門將在 20 秒後開啟！**"
    }
  },
  "** RESIST! Last 5 seconds! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 抵抗せよ！残り5秒！**",
      "CN": "** 抵抗！最后5秒！ **",
      "KR": "** 저항해! 마지막 5초! **",
      "TW": "** 抵禦！倒數 5 秒！**"
    }
  },
  "** Hold the broken wall! The door will open in 25 seconds! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 壊れた壁を保て！ドアが25秒後に開く！**",
      "CN": "** 守住破损的墙壁！大门将在25秒后开启！ **",
      "KR": "** 무너지는 벽을 버텨! 문이 25초 후에 열려! **",
      "TW": "** 守住殘缺的牆壁！門將在 25 秒後開啟！**"
    }
  },
  "** Resist! 10 more seconds! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 抵抗せよ！残り10秒！**",
      "CN": "** 抵抗！还有10秒！ **",
      "KR": "** 저항해! 10초 더! **",
      "TW": "** 抵禦！再撐 10 秒！**"
    }
  },
  "** CHECKPOINT REACHED: STAY ON THE WHITE CIRCLES TO KEEP GOING. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** チェックポイント到達：先に進むためには白い円の上に留まれ。**",
      "CN": "** 已到达检查点：停留在白色圆圈内即可继续前进。 **",
      "KR": "** 체크포인트 도달: 계속 진행하려면 흰색 원 위에 머물러라. **",
      "TW": "** 已到達檢查點：停留在白色圓圈上即可繼續前進。**"
    }
  },
  "** THE CHECKPOINT HAS BEEN ENABLED! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** チェックポイントが有効化されました！ **",
      "CN": "** 检查点已启用！ **",
      "KR": "** 체크포인트가 활성화되었습니다! **",
      "TW": "** 檢查點已啟用！**"
    }
  },
  "** AFK AND SLOW WOBBLES WILL BE TELEPORTED TO IT IN 20 SECONDS. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** AFKおよび低速の揺れは20秒後にテレポートされます。 **",
      "CN": "** 挂机与缓慢摇晃将在20秒后传送至此。 **",
      "KR": "** 20초 후에 AFK 및 느린 흔들림이 해당 위치로 텔레포트됩니다. **",
      "TW": "** 在無人狀態或行動緩慢超過 20 秒後，將被傳送至此處。**"
    }
  },
  "** HOLD! The doors will open in 15 seconds!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 停止！ 15秒後にドアが開きます！！！ **",
      "CN": "** 坚持！大门将于15秒后开启！！！ **",
      "KR": "** 멈춰! 문이 15초 후에 열립니다!!! **",
      "TW": "** 待命！門將在 15 秒後開啟！！！**"
    }
  },
  "** RESIST! 5 seconds left!!! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 抵抗！ 残り5秒！！！ **",
      "CN": "** 抵抗！剩余5秒！！！ **",
      "KR": "** 저항하세요! 5초 남았습니다!!! **",
      "TW": "** 堅守！距離結束剩 5 秒！！！**"
    }
  },
