    }
  },
  "**RUN RUN RUN!!!**": {
    "translation": "**快跑 快跑 快跑！！！**",
    "MultiLang": {
      "US": "",
      "JP": "走れ、走れ、走れ！！！",
      "CN": "快跑！！！",
