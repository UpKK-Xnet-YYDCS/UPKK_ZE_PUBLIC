  "*** Just one minute! RESIST!!! ***": {
    "translation": "*** 只剩60秒！防守住！！！ ***",
    "MultiLang": {
      "US": "",
      "JP": "*** あと1分！耐えろ！！！ ***",
      "CN": "*** 坚持一分钟！抵抗到底！***",
      "KR": "*** 잠시만! 버텨주세요!!! ***",
      "TW": "*** 堅持一分钟！ resist!!! ***"
    }
  },
  "*** Keep defending! We have to resist until the whole bridge is destroyed! ***": {
    "translation": "*** 继续防守！我们必须防守到整个桥被摧毁为止！ ***",
    "MultiLang": {
      "US": "",
      "JP": "*** 防御を続けろ！橋が完全に破壊されるまで耐えなければならない！ ***",
      "CN": "*** 继续防守！我们要坚守到整座大桥被摧毁！ ***",
      "KR": "*** 저항하세요! 교량이 완전히 파괴될 때까지 버텨야 합니다! ***",
      "TW": "*** 繼續防守！我們必須堅持到整座橋被摧毀為止！***"
    }
  },
  "*** Keep it! 30 seconds until the next earthquake!! ***": {
    "translation": "*** 防守住！距离下次地震还有30秒！！ ***",
    "MultiLang": {
      "US": "",
      "JP": "*** 耐えて！次の地震まで30秒！ ***",
      "CN": "*** 保持状态！距离下一次地震还有30秒！！ ***",
      "KR": "*** 다음 지진까지 30초! 유지하세요! ***",
      "TW": "*** 堅持住！距離下一次地震還有30秒！！***"
    }
