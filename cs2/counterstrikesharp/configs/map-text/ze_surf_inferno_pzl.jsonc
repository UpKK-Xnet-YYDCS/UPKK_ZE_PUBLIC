  "** Staff of Fire Stats: Cooldown: 40 seconds, Damage: 1000, Speed Multiplier: 0.5, Duration: 11 ": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "スタッフ・オブ・ファイア ステータス：クールダウン: 40秒, ダメージ: 1000, スピード倍率: 0.5, 持続時間: 11",
      "CN": "** 火焰法杖属性：冷却时间：40 秒，伤害：1000，速度倍率：0.5，持续时间：11",
      "KR": "불의 지팡이 능력치: 재사용 대기시간: 40초, 데미지: 1000, 속도 배율: 0.5, 지속 시간: 11",
      "TW": "** 火焰法杖屬性：冷卻時間：40 秒，傷害：1000，速度倍率：0.5，持續時間：11"
    }
  },
  "** Doors has been opened!": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ドアが開いた！",
      "CN": "** 门已打开！",
      "KR": "** 문이 열렸습니다!",
      "TW": "** 門已打開！"
