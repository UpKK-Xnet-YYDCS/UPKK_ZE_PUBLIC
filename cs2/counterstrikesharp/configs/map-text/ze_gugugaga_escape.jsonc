  "有人想跟随木子米飞升？！": {
    "translation": "",
    "MultiLang": {
      "US": "Does anyone want to ascend with Muzi Mi?!",
      "JP": "木子米に従って昇天を試みる者が？！",
      "CN": "",
      "KR": "누가 무조미 승천을 따라하자는 걸까?!",
      "TW": "有人想跟隨木子米飛升？！"
    }
  },
  "快点打掉咕咕嘎嘎！我们要被他糖丸了！": {
    "translation": "",
    "MultiLang": {
      "US": "Hurry up and defeat the 'Gu Gu Ga Ga'! We're about to be turned into candy pills!",
      "JP": "とにかくぐぐががを倒せ！砂糖粒でやられるぞ！",
      "CN": "",
      "KR": "구구자가를 빠르게 처치합시다! 타액으로 뒤범벅이 됩니다!",
      "TW": "快點打倒咕咕嘎嘎！我們要被他糖化了！"
    }
  },
  "gugugaga被打败了": {
    "translation": "",
    "MultiLang": {
      "US": "The 'Gu Gu Ga Ga' has been defeated.",
      "JP": "ぐぐがが撃破",
      "CN": "",
      "KR": "구구자가 무너졌습니다.",
      "TW": "咕咕嘎嘎被打敗了"
    }
  },
  "感谢游玩！下次再见！": {
    "translation": "",
    "MultiLang": {
      "US": "Thanks for playing! See you next time!",
      "JP": "プレイありがとうございました。またお会いしましょう！",
      "CN": "",
      "KR": "게임을 플레이해 주셔서 감사합니다! 다음에 봐요!",
      "TW": "感謝遊玩！下次再見！"
    }
  },
