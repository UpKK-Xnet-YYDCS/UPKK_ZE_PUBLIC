  "有人想跟随木子米飞升？！": {
    "translation": "",
    "MultiLang": {
      "US": "Anyone want to ascend with MuziMiku?!",
      "JP": "誰か木子米に追従して昇天を試みる者！？",
      "CN": "",
      "KR": "木子米飞升跟随者あり？！",
      "TW": "有人想跟隨木子米飛升？！"
    }
  },
  "快点打掉咕咕嘎嘎！我们要被他糖丸了！": {
    "translation": "",
    "MultiLang": {
      "US": "Hurry up and defeat the gugugagas! We're about to get coated in their sugar pills!",
      "JP": "急いでググガガを倒せ！あの Sugar Pill で弾かれてしまう！",
      "CN": "",
      "KR": "快点打掉咕咕嘎嘎！我们要被他糖丸了！",
      "TW": "快點打掉咕咕嘎嘎！我們要被他的糖丸擊中了！"
    }
  },
  "gugugaga被打败了": {
