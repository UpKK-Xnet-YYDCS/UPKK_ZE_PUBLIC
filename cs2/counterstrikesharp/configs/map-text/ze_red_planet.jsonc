{
  ">>>MAP BY BREAD<<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>MAP BY BREAD<<<",
      "CN": "地图制作者：BREAD",
      "KR": "BREAD가 제작",
      "TW": "由 Bread 製作"
    }
  },
  "Escape from the Red Planet. The last Ravensclaw is located at the Orbital Station.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "赤い惑星からの脱出。最後のレイヴンクロウは軌道ステーションに居る。",
      "CN": "逃离红色星球。最后的Ravensclaw位于空间站。",
      "KR": "레드 플래닛에서 탈출하세요. 마지막 레븐스클로우는 궤도 기지에 있습니다.",
      "TW": "逃離紅星。最後一隻渡鸦堡隊員位於太空站。"
    }
  },
  "Door unlocks in 30 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "30秒でドアがアンロックされます。",
      "CN": "门锁将在30秒后解锁。",
      "KR": "문 30초 후 잠금 해제",
      "TW": "門鎖將在 30 秒後解除。"
    }
  },
  "Zombie Teleport Loading...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ザンベテレポーテーションを読み込み中...",
      "CN": "僵尸传送加载...",
      "KR": "좀비 텔레포트 로딩...",
      "TW": "殭屍空間跳躍載入中..."
    }
  },
  "Door unlocks in 40 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "40秒でドアがアンロックされます。",
      "CN": "门锁将在40秒后解锁。",
      "KR": "문 40초 후 잠금 해제",
      "TW": "門鎖將在 40 秒後解除。"
    }
  },
  "Fall back immediately when the door is open.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアが開いたら即座に後退せよ。",
      "CN": "门打开后立即撤退。",
      "KR": "문이 열리면 즉시 철수하세요.",
      "TW": "門一打開就立即撤退。"
    }
  },
  "10 seconds remaining.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り10秒。",
      "CN": "剩余时间10秒。",
      "KR": "남은 시간 10초",
      "TW": "剩餘 10 秒。"
    }
  },
  "Zombie Teleports Loading...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ザンベテレポーターを読み込み中...",
      "CN": "僵尸传送加载...",
      "KR": "좀비 텔레포트 로딩...",
      "TW": "殭屍空間跳躍載入中..."
    }
  },
  "Elevator leaves in 25 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーター、25秒後に出発します。",
      "CN": "电梯将在25秒后离开。",
      "KR": "엘리베이터가 25초 후 출발합니다.",
      "TW": "電梯二十五秒後啟程。"
    }
  },
  "Nightmare Mode Activated.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ナイトメアモード開始。",
      "CN": "已激活噩梦模式。",
      "KR": "나이트메어 모드 활성화.",
      "TW": "地獄模式啟動。"
    }
  },
  "Communications disabled. Zombie Teleports will not be announced.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "通信機能無効化。ゾンビテレポートが通知されません。",
      "CN": "通讯已禁用。不会播报僵尸传送信息。",
      "KR": "통신 비활성화. 좀비 순간 이동 안내가 이루어지지 않습니다.",
      "TW": "通訊已禁用，無法通告殭屍傳送。"
    }
  },
  "Door unlocks in 10 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドア、10秒後に解錠します。",
      "CN": "门锁将在10秒后开启。",
      "KR": "문이 10초 후 잠금 해제됩니다.",
      "TW": "門鎖十分鐘後開啟。"
    }
  },
  "The way is blocked. Defend until we move the boxes.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "経路が遮断されています。箱を移動するまで防衛してください。",
      "CN": "道路受阻。坚守直到我们移开箱子。",
      "KR": "길이 막혔습니다. 박스를 이동할 때까지 방어하세요.",
      "TW": "前方受阻，防禦至我們移動箱子為止。"
    }
  },
  "More boxes ahead. We can move them quickly, so prepare to fall back.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "先に段ボールがあります。すぐに移動できるので、撤退に備えてください。",
      "CN": "前方有更多箱子。我们可以快速移动它们，请准备撤退。",
      "KR": "앞으로 더 많은 박스가 있습니다. 신속하게 옮길 수 있으므로 후퇴 준비를 하십시오.",
      "TW": "前方有更多的箱子，我們可以快速地移動它們，請準備後撤。"
    }
  },
  "The way is blocked again. Defend.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "経路が再び遮断されました。防衛してください。",
      "CN": "道路再次被堵死。坚守阵地。",
      "KR": "길이 다시 막혔습니다. 방어하세요.",
      "TW": "前方再次受阻，防禦！"
    }
  },
  "Ground Exit unlocks in 30 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "地上出口、30秒後に解錠します。",
      "CN": "地面出口将在30秒后开启。",
      "KR": "지면 출구가 30초 후 잠금 해제됩니다.",
      "TW": "地面出口三十秒後解鎖。"
    }
  },
  "Defend until the Teleporter is activated.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "テレポーターが作動するまで防衛せよ。",
      "CN": "在传送门激活前坚守阵地。",
      "KR": "텔레포터가 활성화될 때까지 방어하라.",
      "TW": "守衛至傳送器啟動。"
    }
  },
  ">>> RING 4 ACTIVATED <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>> リング4 作動 <<<",
      "CN": ">>> 第四环已激活 <<<",
      "KR": ">>> 링 4 가동 <<<",
      "TW": ">>> 環形區 4 已啟動 <<<"
    }
  },
  ">>> RING 3 ACTIVATED <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>> リング3 作動 <<<",
      "CN": ">>> 第三环已激活 <<<",
      "KR": ">>> 링 3 가동 <<<",
      "TW": ">>> 環形區 3 已啟動 <<<"
    }
  },
  ">>> RING 2 ACTIVATED <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>> リング2 作動 <<<",
      "CN": ">>> 第二环已激活 <<<",
      "KR": ">>> 링 2 가동 <<<",
      "TW": ">>> 環形區 2 已啟動 <<<"
    }
  },
  "Communications enabled. Zombie Teleports Loading...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "通信有効化。ゾンビテレポーター読み込み中...",
      "CN": "通信已启用。正在加载僵尸传送程序...",
      "KR": "통신 기능 활성화. 좀비 텔레포트 로딩 중...",
      "TW": "通訊已啟用。殭屍傳送載入中..."
    }
  },
  ">>> RING 1 ACTIVATED <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>> リング1 作動 <<<",
      "CN": ">>> 第一环已激活 <<<",
      "KR": ">>> 링 1 가동 <<<",
      "TW": ">>> 環形區 1 已啟動 <<<"
    }
  },
  "The Zombie are infiltrating the Orbital Station. Stop them.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビが軌道ステーションに侵入中だ。阻止せよ。",
      "CN": "僵尸正在潜入轨道空间站。阻止它们。",
      "KR": "좀비들이 궤도 기지로 침투하고 있다. 저들을 막아라.",
      "TW": "殭屍正滲入軌道站。阻止他們。"
    }
  },
  "Side Door unlocks in 20 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "サイドドア解放まで20秒",
      "CN": "侧门将在20秒后解锁。",
      "KR": "측면 문이 20초 후 개방됩니다.",
      "TW": "側門將在 20 秒後解鎖。"
    }
  },
  "Door 6836 unlocks in 20 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアー 6836 は20秒後に開く。",
      "CN": "6836号门将在20秒后开启。",
      "KR": "6836번문이 20초 후에 잠금 해제됩니다.",
      "TW": "6836號門將在20秒後解鎖。"
    }
  },
  "A strange barrier blocks our path. Find a way to disable it.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "奇妙なバリアが道の遮断している。無効化する方法を見つけよ。",
      "CN": "前方有奇怪屏障阻挡去路，请找到解除它的方法。",
      "KR": "낯선 장벽이 길을 막고 있습니다. 이를 비활성화할 방법을 찾으세요.",
      "TW": "一道奇怪的屏障阻擋了我們的去路。請想辦法解除它。"
    }
  },
  "The trigger has been found. The barrier will be disabled.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "トリガーを発見した。バリアが無効になるだろう。",
      "CN": "已发现触发器，屏障将被解除。",
      "KR": "트리거가 발견되었습니다. 장벽이 비활성화됩니다.",
      "TW": "已發現觸發器。屏障將被解除。"
    }
  },
  "Control Station Exit unlocks in 10 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "コントロールステーション出口は10秒後に開く。",
      "CN": "控制站出口将在10秒后开启。",
      "KR": "Control Station",
      "TW": "控制站出口將在10秒後解鎖。"
    }
  },
  "The barrier will be disabled in 10 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バリアは10秒後になくなる。",
      "CN": "屏障将在10秒后解除。",
      "KR": "장벽이 10초 후 비활성화됩니다.",
      "TW": "屏障將在10秒後解除。"
    }
  },
  "The Ravensclaw will be departing in 90 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "レイヴンズクロウは90秒後に離港する。",
      "CN": "渡鸦之翼号将于90秒后离港。",
      "KR": "Ravensclaw가 90초 후 출항합니다.",
      "TW": "渡鴉之爪號將在90秒後離港。"
    }
  },
  "60 seconds remaining.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り60秒。",
      "CN": "剩余60秒。",
      "KR": "남은 시간 60초.",
      "TW": "剩餘60秒。"
    }
  },
  "The Zombies have control of the Ravensclaw.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビがレイヴンズクロウを掌握している。",
      "CN": "控制渡鸦之翼号的是僵尸。",
      "KR": "좀비들이 Ravensclaw를 장악했습니다.",
      "TW": "殭屍已控制渡鴉之爪號。"
    }
  },
  ">>>YOU LOSE<<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>YOU LOSE<<<",
      "CN": "<<<你输了<<<",
      "KR": ">>>YOU LOSE<<<",
      "TW": "你輸了"
    }
  },
  "The Zombies destroyed the Control Station.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビがコントロールステーションを破壊した。",
      "CN": "僵尸摧毁了控制站。",
      "KR": "좀비가 제어 스테이션을 파괴했습니다.",
      "TW": "殭屍摧毀了控制中心。"
    }
  }
}
