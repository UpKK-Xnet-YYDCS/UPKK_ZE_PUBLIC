{
  ">>>MAP BY BREAD<<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>MAP BY BREAD<<<",
      "CN": ">>>地图：面包<<<",
      "KR": ">>>맵 (브레드 제작)<<<",
      "TW": ">>>地圖由麵包製作<<<"
    }
  },
  "Escape from the Red Planet. The last Ravensclaw is located at the Orbital Station.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "赤い惑星からの脱出。最後のレイブンズクロウは、軌道ステーションにあります。",
      "CN": "逃离红色星球。最后的 Ravenclaw 位于轨道空间站。",
      "KR": "붉은 행성에서 탈출하세요. 마지막 레이븐스클로는 오비탈 스테이션에 있습니다.",
      "TW": "從紅色星球逃脫。最後一個雷文斯克勞位於軌道站。"
    }
  },
  "Door unlocks in 30 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアは30秒後に開きます。",
      "CN": "门将在 30 秒后打开。",
      "KR": "문이 30초 후에 열립니다.",
      "TW": "門將在 30 秒後開啟。"
    }
  },
  "Zombie Teleport Loading...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビのテレポートを読み込み中...",
      "CN": "僵尸传送加载中...",
      "KR": "좀비 순간이동 로딩 중...",
      "TW": "殭屍傳送中，請稍候..."
    }
  },
  "Door unlocks in 40 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアは40秒後に開きます。",
      "CN": "门将在 40 秒后打开。",
      "KR": "문이 40초 후에 열립니다.",
      "TW": "門將在 40 秒後開啟。"
    }
  },
  "Fall back immediately when the door is open.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアが開いたら、すぐに後退してください。",
      "CN": "当门打开时，立即撤退。",
      "KR": "문이 열리면 즉시 후퇴하세요.",
      "TW": "當門開啟時，立即撤退。"
    }
  },
  "10 seconds remaining.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り10秒。",
      "CN": "剩余 10 秒。",
      "KR": "10초 남았습니다.",
      "TW": "剩餘 10 秒。"
    }
  },
  "Zombie Teleports Loading...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビのテレポートを読み込み中...",
      "CN": "僵尸传送加载中...",
      "KR": "좀비 순간이동 로딩 중...",
      "TW": "殭屍傳送中，請稍候..."
    }
  },
  "Elevator leaves in 25 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "エレベーターは25秒後に発車します。",
      "CN": "电梯将在25秒后离开。",
      "KR": "엘리베이터는 25초 후에 출발합니다.",
      "TW": "電梯在25秒後啟動。"
    }
  },
  "Nightmare Mode Activated.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ナイトメアモードが起動しました。",
      "CN": "噩梦模式已激活。",
      "KR": "악몽 모드 활성화.",
      "TW": "噩夢模式已啟動。"
    }
  },
  "Communications disabled. Zombie Teleports will not be announced.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "通信が遮断されました。ゾンビのテレポートは予告されません。",
      "CN": "通讯已禁用。僵尸传送不会有提示。",
      "KR": "통신이 차단되었습니다. 좀비 순간이동은 알림 없이 진행됩니다.",
      "TW": "通訊已禁用。殭屍傳送將不會發出提示。"
    }
  },
  "Door unlocks in 10 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドアは10秒後に開きます。",
      "CN": "门将在10秒后解锁。",
      "KR": "문이 10초 후에 열립니다.",
      "TW": "門將在10秒後解鎖。"
    }
  },
  "The way is blocked. Defend until we move the boxes.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "進路が遮断されています。箱を移動するまで防衛してください。",
      "CN": "通道被阻挡。请防御，直到我们移动这些箱子。",
      "KR": "통로가 막혔습니다. 상자를 옮길 때까지 방어하십시오.",
      "TW": "通道被阻擋。請堅守，直到我們搬走箱子。"
    }
  },
  "More boxes ahead. We can move them quickly, so prepare to fall back.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "前方にもっと多くの箱があります。素早く移動できるので、後退の準備をしてください。",
      "CN": "前方有更多的箱子。我们可以快速移动它们，所以准备好撤退。",
      "KR": "앞에 더 많은 상자가 있습니다. 빠르게 옮길 수 있으니, 후퇴할 준비를 하십시오.",
      "TW": "前方還有更多箱子。我們可以快速移動它們，所以準備撤退。"
    }
  },
  "The way is blocked again. Defend.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "再び進路が遮断されました。防衛。",
      "CN": "通道再次被阻挡。请防御。",
      "KR": "다시 통로가 막혔습니다. 방어하십시오.",
      "TW": "通道再次被阻擋。請堅守。"
    }
  },
  "Ground Exit unlocks in 30 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "地上への脱出口は30秒後に開きます。",
      "CN": "地面出口将在30秒后解锁。",
      "KR": "지상 출구가 30초 후에 열립니다.",
      "TW": "地底出口將在30秒後解鎖。"
    }
  },
  "Defend until the Teleporter is activated.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "テレポート装置が起動するまで、防衛を維持してください。",
      "CN": "坚持防御，直到传送器激活。",
      "KR": "텔레포터가 활성화될 때까지 방어하십시오.",
      "TW": "守住陣地，直到传送器被激活。"
    }
  },
  ">>> RING 4 ACTIVATED <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>リング4 作動中<<<",
      "CN": ">>> 第 4 个环已激活 <<<",
      "KR": ">>> 링 4 활성화 <<<",
      "TW": ">>> 环 4 已激活 <<<"
    }
  },
  ">>> RING 3 ACTIVATED <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>リング3 作動中<<<",
      "CN": ">>> 第 3 个环已激活 <<<",
      "KR": ">>> 링 3 활성화 <<<",
      "TW": ">>> 环 3 已激活 <<<"
    }
  },
  ">>> RING 2 ACTIVATED <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>リング2 作動中<<<",
      "CN": ">>> 第 2 个环已激活 <<<",
      "KR": ">>> 링 2 활성화 <<<",
      "TW": ">>> 环 2 已激活 <<<"
    }
  },
  "Communications enabled. Zombie Teleports Loading...": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "通信を開始しました。ゾンビのテレポート読み込み中...",
      "CN": "通讯已启用。 僵尸传送加载中...",
      "KR": "통신 활성화. 좀비 텔레포트 로딩 중...",
      "TW": "通讯已启用。 僵尸传送器正在加载..."
    }
  },
  ">>> RING 1 ACTIVATED <<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": ">>>リング1 作動中<<<",
      "CN": ">>> 第 1 个环已激活 <<<",
      "KR": ">>> 링 1 활성화 <<<",
      "TW": ">>> 环 1 已激活 <<<"
    }
  },
  "The Zombie are infiltrating the Orbital Station. Stop them.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビが軌道ステーションに侵入しています。阻止してください。",
      "CN": "僵尸正在渗透轨道空间站。阻止他们。",
      "KR": "좀비들이 궤도 기지에 침투하고 있습니다. 막으십시오.",
      "TW": "僵尸正在入侵轨道站。阻止他们。"
    }
  },
  "Side Door unlocks in 20 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "サイドドアが20秒後に開きます。",
      "CN": "侧门将在 20 秒后解锁。",
      "KR": "측면 문이 20초 후에 열립니다.",
      "TW": "侧门将在 20 秒后解锁。"
    }
  },
  "Door 6836 unlocks in 20 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ドア6836は20秒後に開きます。",
      "CN": "6836号门将在20秒后解锁。",
      "KR": "6836번 문이 20초 후에 열립니다.",
      "TW": "6836號門將在20秒後開啟。"
    }
  },
  "A strange barrier blocks our path. Find a way to disable it.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "奇妙なバリアが道を塞いでいます。無効にする方法を見つけてください。",
      "CN": "一个奇怪的屏障挡住了我们的道路。找到一种方法来禁用它。",
      "KR": "기이한 장벽이 저희의 길을 막고 있습니다. 이를 해제할 방법을 찾아보세요.",
      "TW": "一個奇怪的屏障阻擋了我們的道路。找到方法使其失效。"
    }
  },
  "The trigger has been found. The barrier will be disabled.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "トリガーが見つかりました。バリアが無効になります。",
      "CN": "已找到触发器。屏障将被禁用。",
      "KR": "작동 장치를 찾았습니다. 장벽이 해제됩니다.",
      "TW": "已找到觸發裝置。屏障將會失效。"
    }
  },
  "Control Station Exit unlocks in 10 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "コントロールステーションの出口は10秒後に開きます。",
      "CN": "控制站出口将在10秒后解锁。",
      "KR": "컨트롤 스테이션 출구가 10초 후에 열립니다.",
      "TW": "控制站出口將在10秒後開啟。"
    }
  },
  "The barrier will be disabled in 10 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "バリアは10秒後に無効になります。",
      "CN": "屏障将在10秒后被禁用。",
      "KR": "장벽이 10초 후에 해제됩니다.",
      "TW": "屏障將在10秒後失效。"
    }
  },
  "The Ravensclaw will be departing in 90 seconds.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "レイブンズクロウは90秒後に出発します。",
      "CN": "“渡鸦”号将在90秒后起飞。",
      "KR": "래번스클로가 90초 후에 출발합니다.",
      "TW": "拉文斯克號將在90秒後起航。"
    }
  },
  "60 seconds remaining.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "残り60秒です。",
      "CN": "剩余60秒。",
      "KR": "60초 남았습니다.",
      "TW": "剩餘60秒。"
    }
  },
  "The Zombies have control of the Ravensclaw.": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビたちがレイブンズクロウを占拠しています。",
      "CN": "僵尸控制了“渡鸦”号。",
      "KR": "좀비들이 래번스클로를 장악했습니다.",
      "TW": "殭屍已控制了拉文斯克號。"
    }
  },
  ">>>YOU LOSE<<<": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "<<<ゲームオーバー>>>",
      "CN": ">>>你输了<<<",
      "KR": ">>>패배했습니다<<<",
      "TW": "<<<你输了>>>"
    }
  }
}
