      "KR": "그런데 블루는 어디에 있는지는 몰라",
      "TW": "但我們不知道藍色在哪裡"
    }
  },
  "We escaped..": {
    "translation": "我们逃出来了..",
    "MultiLang": {
      "US": "",
      "JP": "逃げ出した…",
      "CN": "我们逃出来了……",
      "KR": "도망쳤어..",
      "TW": "我們逃脫了……"
    }
  },
  "We got Green and Yellow's power": {
    "translation": "我们得到了绿和黄的力量",
