  "TIP: Helicopter departs in 10 seconds!": {
    "translation": "提示：直升机将在10秒后起飞！",
    "MultiLang": {
      "US": "",
      "JP": "ヒント：ヘリコプターは10秒後に離陸します！",
      "CN": "提示：直升机将于10秒后起飞！",
      "KR": "팁: 헬리콥터가 10초 후에 떠납니다!",
      "TW": "提示：直升機將在 10 秒後起飛！"
    }
  },
  "TIP: Prepare to fall back. Helicopter leaves in 20 seconds.": {
    "translation": "提示：准备撤退，直升机将在20秒后起飞。",
    "MultiLang": {
      "US": "",
      "JP": "ヒント：後退の準備をしてください。ヘリコプターは20秒後に離陸します。",
      "CN": "提示：准备撤退。直升机将在20秒后离开。",
      "KR": "팁: 후퇴 준비를 하세요. 헬리콥터가 20초 후에 떠납니다.",
      "TW": "提示：準備撤退。直升機將在 20 秒後離開。"
    }
  },
  "TIP: Roof entry is now open. Defend for 50 seconds!": {
    "translation": "提示：屋顶入口现在开放，防守50秒！",
    "MultiLang": {
      "US": "",
      "JP": "ヒント：屋上へのアクセスが可能になりました。50秒間守り抜いてください！",
      "CN": "提示：屋顶入口已开放。坚守50秒！",
      "KR": "팁: 지붕 진입이 개방되었습니다. 50초간 방어하세요!",
      "TW": "提示：屋頂入口已開啟。防守 50 秒！"
    }
  },
  "TIP: You should go to the roof in less than 30 seconds.": {
    "translation": "提示：你应该在30秒内到达屋顶。",
    "MultiLang": {
      "US": "TIP: Go to the roof in less than 30 seconds.",
      "JP": "ヒント：30秒以内で屋上へ向かってください。",
      "CN": "提示：请在30秒内前往屋顶。",
      "KR": "팁: 30초 이내에 지붕으로 이동해야 합니다.",
      "TW": "提示：你應在 30 秒內前往屋頂。"
    }
  }
