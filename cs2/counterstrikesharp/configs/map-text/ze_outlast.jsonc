  "* *DON'T LET THE ZOMBIES GO INSIDE THE BASEMENT* *": {
    "translation": "* *不要让僵尸进入地下室* *",
    "MultiLang": {
      "US": "",
      "JP": "* *ゾンビが地下室に入れないように防げ* *",
      "CN": "* *别让丧尸进入地下室* *",
      "KR": "* *좀비들이 지하실로 들어오지 못하게 하라* *",
      "TW": "* *別讓殭屍進入地下室* *"
    }
  },
  "* *DON'T TRY TO FIGHT HIM, HIDE IN THE LOCKER* *": {
    "translation": "* *不要跟他打，躲在储物柜里！* *",
    "MultiLang": {
      "US": "***DON'T TRY TO FIGHT HIM, HIDE IN THE Locker***",
      "JP": "* *彼と戦おうとするな、ロッカーに隠れろ* *",
      "CN": "* *别跟他打，躲进储物柜里* *",
      "KR": "* *그와 맞서 싸우지 말고 사물함에 숨어라* *",
      "TW": "* *別跟他打，躲進儲物櫃* *"
    }
  },
  "* *DOOR IS LOCKED FIND THE KEY* *": {
    "translation": "* *门锁了，去找钥匙！* *",
    "MultiLang": {
      "US": "",
      "JP": "* *鍵を探してドアを施錠* *",
      "CN": "门已上锁，请寻找钥匙",
      "KR": "* *문을 잠그려면 열쇠를 찾아라* *",
      "TW": "* *門已上鎖，請尋找鑰匙* *"
    }
  },
  "* *DOOR OPEN AT 5 SECONDS* *": {
    "translation": "* *门将在5秒后打开* *",
