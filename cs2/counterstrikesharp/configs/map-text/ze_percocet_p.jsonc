{
  "***  Find two buttons to open the sewer gates!!! ***": {
    "translation": "***找到两个按钮以打开下水道大门！！！***",
    "MultiLang": {
      "US": "",
      "JP": "*** 下水道の扉を開けるための2つのボタンを見つけろ！！！ ***",
      "CN": "*** 找出两个按钮以打开下水道闸门！！！***",
      "KR": "*** 하수구 문을 여는 두 개의 버튼을 찾아라!!! ***",
      "TW": "*** 找到兩個按鈕來打開排水道大閘！ ***"
    }
  },
  "*** Both buttons pressed ***": {
    "translation": "***两个按钮都已按下***",
    "MultiLang": {
      "US": "",
      "JP": "*** 両方のボタンが押された ***",
