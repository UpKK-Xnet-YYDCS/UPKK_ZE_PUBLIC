  "A cube sitting in both of the fountain": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "両方の噴水についてる立方体",
      "CN": "有一个方块坐落在这座喷泉里",
      "KR": "분수대에 자리한 큐브 한 개",
      "TW": "兩個噴泉中都坐落著方塊"
    }
  },
  "I will touch it": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "これを触れるよ",
      "CN": "我会去触碰它",
      "KR": "내가 그걸 만질 거야",
      "TW": "我將觸碰它"
    }
  },
  "The big gate seems to open": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "大きな扉が開くようだ",
      "CN": "大门似乎打开了",
      "KR": "큰 문이 열리는 것 같습니다",
      "TW": "巨大的城門似乎已經開啟"
    }
  },
  "I really should keep going": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "やはり進まねばならない",
      "CN": "我确实应该继续前进",
      "KR": "계속 나아가야겠어요",
      "TW": "我確實應該繼續前行"
    }
  },
  "A weird shaped gate blocking our way": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "不可解な形状の扉が道を塞いでいる",
      "CN": "一扇形状奇怪的门挡住了我们的去路",
      "KR": "길을 막는 이상한 모양의 문",
      "TW": "一道形狀怪異的大門阻擋住去路"
    }
  },
  "The door seems to open": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "扉が開く気配がある",
      "CN": "门似乎打开了",
      "KR": "문이 열리는 것 같습니다",
      "TW": "這扇門似乎已經開啟"
    }
  },
  "It knows that we are present": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "我々の存在を感知しているらしい",
      "CN": "它知道我们就在此处",
      "KR": "우리가 존재한다는 것을 알고 있습니다",
      "TW": "它知道我們在此"
    }
  }
}
