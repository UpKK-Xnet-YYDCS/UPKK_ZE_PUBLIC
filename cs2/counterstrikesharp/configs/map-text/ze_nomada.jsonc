  },
  "A cube sitting in both of the fountain": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "キューブが両方の噴水の中にあります",
      "CN": "一个立方体位于两个喷泉中",
      "KR": "두 개의 분수대에 각각 큐브가 놓여 있습니다.",
      "TW": "一個方塊靜靜地放置在兩個噴泉中"
    }
  },
  "I will touch it": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "触ってみます",
      "CN": "我会去碰它",
      "KR": "제가 그걸 만져볼게요.",
      "TW": "我會觸碰它的"
    }
  },
  "The big gate seems to open": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "大きな門が開きそうな気がします。",
      "CN": "大门似乎要打开了。",
      "KR": "큰 문이 열리는 것 같습니다.",
      "TW": "大門似乎正在打開。"
    }
  },
  "I really should keep going": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "やはり、進むべきでしょう。",
      "CN": "我真的应该继续前进。",
      "KR": "정말 계속 가야겠어요.",
      "TW": "我真的應該繼續前進。"
    }
  },
  "A weird shaped gate blocking our way": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "奇妙な形をした門が道を塞いでいます。",
      "CN": "一个形状奇特的门挡住了我们的去路。",
      "KR": "이상한 모양의 문이 우리 길을 막고 있습니다.",
      "TW": "一個形狀奇特的門擋住了我們的去路。"
    }
  },
  "The door seems to open": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "扉が開きそうなようです。",
      "CN": "门似乎要打开了。",
      "KR": "문이 열리는 것 같습니다.",
      "TW": "這扇門似乎正在打開。"
    }
  },
  "It knows that we are present": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "我々がここにいることを認識しているようです。",
      "CN": "它知道我们在这里。",
      "KR": "우리가 여기에 있다는 것을 알고 있습니다.",
      "TW": "它知道我們在這裡。"
    }
  }
}
