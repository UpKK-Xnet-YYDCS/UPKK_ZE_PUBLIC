  "a White cube": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "白い立方体",
      "CN": "一个白立方体",
      "KR": "흰색 큐브",
      "TW": "白色立方體"
    }
  },
  "Maybe i should touch it": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "もしかして、これを触れ",
      "CN": "也许我该碰一下它",
      "KR": "아마도 내가 그것을 만져야 할 것 같다",
      "TW": "也許我該觸碰它"
    }
  },
  "The cube is moving up": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "立方体が上へ動いてる",
      "CN": "方块正在向上移动",
      "KR": "큐브가 위로 이동하고 있다",
      "TW": "方塊正在向上移動"
    }
  },
  "The gate is opening": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートが開く",
      "CN": "大门正在打开",
      "KR": "게이트가 열리고 있다",
      "TW": "門正在開啟"
    }
  },
  "The way is split into three": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "道が三つに分かれる",
      "CN": "前方有三条路可供选择",
      "KR": "길은 세 갈래로 나뉜다",
      "TW": "道路分為三岔"
    }
  },
  "You hear a voice from above": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "上から声が聞こえる",
      "CN": "你听到来自上方的声音",
      "KR": "위에서 목소리가 들린다",
      "TW": "你聽到一個來自上方的聲音"
    }
  },
  "Dont give up when you hit rock bottom": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "底辺でくじけないでよ",
      "CN": "在谷底时不要放弃",
      "KR": "바닥에 닿았을 때 포기하지 마라",
      "TW": "在谷底時不要放棄"
    }
  },
