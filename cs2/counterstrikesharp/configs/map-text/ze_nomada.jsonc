  "Gate is opening in 15 second": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートは15秒後に開きます",
      "CN": "大门将在15秒后打开。",
      "KR": "게이트가 15초 후에 열립니다.",
      "TW": "大門在15秒後開啟。"
    }
  },
  "a White cube": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "白い立方体",
      "CN": "一个白色立方体",
      "KR": "흰색 큐브",
      "TW": "一個白色立方體。"
    }
  },
  "Maybe i should touch it": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "たぶん、触ってみるべきだ",
      "CN": "也许我应该碰一下它",
      "KR": "아마 제가 그걸 만져봐야 할 것 같아요.",
      "TW": "或許我應該觸碰它"
    }
  },
  "The cube is moving up": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "キューブが上に移動しています",
      "CN": "立方体正在向上移动",
      "KR": "큐브가 위로 움직이고 있습니다.",
      "TW": "方塊正在向上移動"
    }
  },
  "The gate is opening": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "ゲートが開いています",
      "CN": "大门正在打开",
      "KR": "문이 열리고 있습니다.",
      "TW": "大門正在打開"
    }
  },
  "The way is split into three": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "道が3つに分かれています",
      "CN": "道路分成了三条",
      "KR": "길이 세 갈래로 나뉩니다.",
      "TW": "道路被分成了三條"
    }
  },
  "You hear a voice from above": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "上から声が聞こえます",
      "CN": "你从上方听到一个声音",
      "KR": "위에서 목소리가 들립니다.",
      "TW": "你聽到來自上方的聲音"
    }
  },
  "Dont give up when you hit rock bottom": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "どん底にいるときは、諦めないで",
      "CN": "当你陷入绝境时，不要放弃",
      "KR": "가장 힘든 순간에도 포기하지 마세요.",
      "TW": "當你處於絕境時，不要放棄"
    }
  },
  "< Bottom Gate >": {
