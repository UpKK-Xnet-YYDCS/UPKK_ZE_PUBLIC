  "--Survive 30 seconds!--": {
    "translation": "--生存30秒！--",
    "MultiLang": {
      "US": "",
      "JP": "--30秒間生存してください!--",
      "CN": "--存活30秒！--",
      "KR": "--30초 생존!--",
      "TW": "--存活30秒！--"
    }
  },
  "--Thanks for Playing!--": {
    "translation": "--感谢游玩！--",
    "MultiLang": {
      "US": "",
      "JP": "--プレイありがとうございます!--",
      "CN": "--感谢您的游玩！--",
      "KR": "--플레이해주셔서 감사합니다!--",
      "TW": "--感謝遊玩！--"
    }
  },
  "--That was a quick answer! Patience is a virtue--": {
    "translation": "--那是一个快速的回答！耐心是一种美德--",
    "MultiLang": {
      "US": "",
      "JP": "--すばらしい回答ですね！忍耐もまた美徳です--",
      "CN": "--回答得真快！耐心是一种美德--",
      "KR": "--정답이 빠르다! 인내는 미덕이다--",
      "TW": "---answer得真快！耐心是一種美德--"
    }
  },
  "--We are trying to escape from zombies! And we adore the companion cube--": {
    "translation": "--我们正试图逃离僵尸！而且我们崇拜同伴方块--",
    "MultiLang": {
      "US": "",
      "JP": "--私たちはゾンビから逃げています！そしてコンパニオンキューブが大好きです--",
      "CN": "--我们正试图逃离僵尸！而且我们深爱同伴立方体--",
      "KR": "--우리는 좀비들에게서 도망치고 있다! 그리고 컴패니언 큐브를 사랑한다--",
      "TW": "--我們正在逃離殭屍！而且我們很愛同伴方塊--"
    }
  },
  "--We hope you have enjoyed your stay at Aperture Science!--": {
    "translation": "--我们希望你在光圈科技度过愉快的时光！--",
    "MultiLang": {
      "US": "",
      "JP": "--アペチュア・サイエンスへようこそ。ご滞在を心よりお楽しみください--",
      "CN": "--希望您享受在光圈科学公司的停留！--",
      "KR": "--아퍼처 사이언스에서의 체류가 즐거웠기를 바란다!--",
      "TW": "--希望您喜歡在光圈科學的停留！--"
    }
  },
  "--Welcome to the Aperture Science Center--": {
    "translation": "--欢迎来到光圈科技中心--",
    "MultiLang": {
      "US": "",
      "JP": "--アペチュア・サイエンスセンターへようこそ--",
      "CN": "--欢迎来到光圈科学研究中心--",
      "KR": "--아퍼처 사이언스 센터에 오신 것을 환영한다--",
      "TW": "--歡迎光臨光圈科學中心--"
    }
  },
  "--What is the rush? Did the Companion Cube said something bad?--": {
    "translation": "--为什么这么着急？同伴方块说了什么不好的话吗？--",
    "MultiLang": {
      "US": "",
      "JP": "--なぜそんなに焦るのですか？コンパニオンキューブに何か言われましたか？--",
      "CN": "--这么着急干什么？是同伴立方体说了什么坏话吗？--",
      "KR": "--어떻게 된 일인가? 컴패니언 큐브가 나쁜 말을 했나?--",
      "TW": "--這麼匆忙是為什麼？同伴方塊說了什麼不好的話嗎？--"
    }
  },
  "--YES _X_--": {
    "translation": "--是 _X_--",
    "MultiLang": {
