      "JP": "--それこそがあなたの望みなら--",
      "CN": "--如果你真的想要的话--",
      "KR": "--정말 원하신다면요--",
      "TW": "--如果那真的是你所追求的--"
    }
  },
  "--Lift doors open in 10 seconds!--": {
    "translation": "--电梯门在10秒内打开！--",
    "MultiLang": {
      "US": "",
      "JP": "--10秒以内に lifts が開きます！--",
      "CN": "门将在10秒后打开！--",
      "KR": "--층문 10초 후 개방!--",
      "TW": "--門口即將開啟！剩餘時間：10秒！--"
    }
  },
  "--Lift has now left Aperture Science--": {
    "translation": "--电梯现已离开光圈科技--",
