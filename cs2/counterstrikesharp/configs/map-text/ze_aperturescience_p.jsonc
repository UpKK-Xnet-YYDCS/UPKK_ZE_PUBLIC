  },
  "--GLaDOS is exploding! Take cover!--": {
    "translation": "--基因生命体磁盘操作系统正在爆炸！躲起来！--",
    "MultiLang": {
      "US": "",
      "JP": "--GLaDOSが爆発します！掩護を取ってください！",
      "CN": "--GLaDOS即将爆炸！寻找掩体！--",
      "KR": "--GLaDOS 폭발! 대피하세요!--",
      "TW": "--GLaDOS 正在爆炸！快找掩蔽處！--"
    }
  },
  "--Hold this position from any zombies--": {
    "translation": "--守住这个位置，防止任何僵尸进入--",
    "MultiLang": {
      "US": "",
      "JP": "--ゾンビからこの位置を守ってください--",
      "CN": "--从任何僵尸手中坚守这个位置--",
      "KR": "--좀비들로부터 이 위치를 지켜내세요--",
      "TW": "--守在此處，抵擋喪屍！--"
    }
  },
  "--If thats what you REALLY want--": {
    "translation": "--如果那真的是你想要的--",
    "MultiLang": {
