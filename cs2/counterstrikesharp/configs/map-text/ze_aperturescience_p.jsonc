      "KR": "엘리베이터 2호, 2초 후 상행 개시",
      "TW": "--電梯2將在2秒後上樓--"
    }
  },
  "--Elevator 2 leaving in 10 seconds--": {
    "translation": "--电梯2将在10秒内离开--",
    "MultiLang": {
      "US": "",
      "JP": "--エレベーター2番号、発車まで10秒--",
      "CN": "--2号电梯将在10秒后离开--",
      "KR": "엘리베이터 2호, 10초 후 출발",
      "TW": "--電梯2將在10秒後離開--"
