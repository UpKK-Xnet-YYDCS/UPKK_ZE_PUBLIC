  "--Escape lift doors closing in 10 seconds--": {
    "translation": "--逃生电梯门在10秒内关闭--",
    "MultiLang": {
      "US": "",
      "JP": "--避難用エレベーター扉、閉鎖まで10秒--",
      "CN": "--逃生梯门将在10秒后关闭--",
      "KR": "탈출용 엘리베이터 문 10초 후 닫힘",
      "TW": "--逃生電梯門將在10秒後關閉--"
    }
  },
  "--Fighting GLaDOS--": {
    "translation": "--正在与基因生命体磁盘操作系统战斗--",
    "MultiLang": {
      "US": "",
      "JP": "--GLaDOSとの決戦--",
      "CN": "--与GLaDOS的战斗--",
