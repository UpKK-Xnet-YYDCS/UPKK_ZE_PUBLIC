  },
  "--Protect yourself from the zombies for 60 seconds!--": {
    "translation": "--60秒内保护自己免受僵尸攻击！--",
    "MultiLang": {
      "US": "",
      "JP": "--60秒間ゾンビから身を守ってください!--",
      "CN": "--在60秒内保护自己免受僵尸攻击！--",
      "KR": "--60초 동안 좀비로부터 자신을 보호하세요!--",
      "TW": "--在60秒內抵禦殭屍的攻擊！--"
    }
  },
  "--Sponsored by ]HeLL[ Clan--": {
    "translation": "--由]HeLL[ Clan赞助--",
    "MultiLang": {
