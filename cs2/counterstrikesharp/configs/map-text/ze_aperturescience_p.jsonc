  "--YES____      NO_____--": {
    "translation": "--是____      否_____--",
    "MultiLang": {
      "US": "",
      "JP": "--YES____      NO_____--",
      "CN": "--是的____      不____--",
      "KR": "--네____      아니오_____--",
      "TW": "--是的____      否_____--"
    }
  },
  "--You love an inanimate object! How silly!--": {
    "translation": "--你爱上了一个无生命的物体！多么愚蠢！--",
    "MultiLang": {
      "US": "",
      "JP": "--あなたは無生物に恋をしています！なんておバカな--",
      "CN": "--你居然爱上了一堆没有生命的物体！真是可笑！--",
      "KR": "--정체를 알 수 없는 사물을 사랑하다니! 바보 같은 짓이다!--",
      "TW": "--你愛上一個無生命的物體！真可笑！--"
    }
  },
  "--Zombie teleport in 25 secs!--": {
    "translation": "--25秒后僵尸传送！--",
    "MultiLang": {
      "US": "",
      "JP": "ゾンビが25秒後にテレポートする——",
      "CN": "--僵尸将在25秒后传送！--",
      "KR": "--좀비 텔레포트 25초 후--",
      "TW": "--殭屍將在25秒內傳送至--"
    }
  }
