  },
  "** 未获得许可 等待.. **": {
    "translation": "",
    "MultiLang": {
      "US": "** Unauthorized. Waiting..**",
      "JP": "** 許可未取得 待機中.. **",
      "CN": "",
      "KR": "**승인 대기 중..**",
      "TW": "未獲授權 等待中.."
    }
  },
  "<<< 前方未知，但我们只能继续前进>>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<< Unknown ahead, but we must proceed >>>",
      "JP": "<<< 先は未知なるものだが、進むしかない >>>",
      "CN": "",
      "KR": "<<앞은 미지이지만, 우리는 계속 진격해야 한다>>",
      "TW": "前方未知，但我們只能繼續前進"
    }
  },
  "** 已准许，可进入 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Authorized. Entry permitted.**",
      "JP": "** 許可済み、進入可 **",
      "CN": "",
      "KR": "**승인 완료, 진입 가능**",
      "TW": "已獲授權，可通行"
    }
  },
  "** 20s后大门打开 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Main gate opens in 20s **",
      "JP": "** 20秒後に大門開放 **",
      "CN": "20秒后大门打开",
      "KR": "**20초 후 대문 개방**",
      "TW": "20秒後大門開啟"
    }
  },
  "<<< 该死，我们被包围了 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<< Damn, we're surrounded >>>",
      "JP": "<<< った、我々は包囲された >>>",
      "CN": ">>> 拦路虎，我们被包围了 >>>",
      "KR": "<<저런, 우리는 포위당했다>>",
      "TW": "該死，我們被包圍了"
    }
  },
  "** 第一开关按下，解锁大门 **": {
    "translation": "",
    "MultiLang": {
      "US": "** First switch pressed, gate unlocked **",
      "JP": "** 第一スイッチ押下、大門解除 **",
      "CN": "",
      "KR": "**제1 스위치 작동, 대문 잠금 해제**",
      "TW": "第一開關已觸發，門已解鎖"
    }
  },
  "** 大门即将锁闭，阻挡他们 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Gate closing soon, blocking them off **",
      "JP": "** 大門閉鎖間近、彼らを遮れ **",
      "CN": "",
      "KR": "**대문 폐쇄 임박, 그들을 막아라**",
      "TW": "大門即將關閉，阻擋他們"
    }
  },
  "<<< 整顿装备，向岛屿出发 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<< Gear up and head to the island >>>",
      "JP": "装備を整え、島へ出发しよう",
      "CN": "",
      "KR": "<< 장비를 정비하고 섬으로 출격합니다 >>",
      "TW": "整裝待發，前往島嶼"
    }
  },
  "** WAD+右键施展地震波，击飞面前的僵尸 **": {
    "translation": "",
    "MultiLang": {
      "US": "** WAD + Right-click to cast Seismic Wave, launching nearby zombies **",
      "JP": "** WAD+右键で地震波を発動し、手前のゾンミを吹き飛ばす **",
      "CN": "*** 使用WAD+右键施放地震波，击飞前方的僵尸 ***",
      "KR": "** WAD+우클릭: 지진파 발사, 앞의 좀비 날려버리기 **",
      "TW": "** WAD+右鍵發動地震波，擊飛前方的殭屍 **"
    }
  },
  "<< 这个山洞有些危险，等待兵力集结一并进入吧 >>": {
    "translation": "",
    "MultiLang": {
      "US": "<< This cave is dangerous. Wait for reinforcements before entering. >>",
      "JP": "<< この洞窟は危険なようだ。兵力が集まるのを待って、一緒に进入しよう >>",
      "CN": "",
      "KR": "<< 이 동굴은 다소 위험합니다. 병력이 집결할 때까지 기다렸다 진입합시다 >>",
      "TW": "<< 這個山洞充滿危險，請等待兵力集結後再一同進入 >>"
    }
