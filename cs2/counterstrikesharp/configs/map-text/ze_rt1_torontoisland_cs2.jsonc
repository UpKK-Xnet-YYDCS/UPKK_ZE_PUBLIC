    "MultiLang": {
      "US": "<< Chapter 3 >",
      "JP": "<<< 第三章 >>>",
      "CN": "",
      "KR": "*** 제3장 ***",
      "TW": "<b>第三章</b>"
    }
  },
  "<<< 因为恶魔的出现，我们的计划被彻底打乱 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<< The appearance of the demons has completely disrupted our plans. >",
      "JP": "<<< 悪魔の出現により、私たちの計画は完全に狂ってしまった >>>",
      "CN": "",
      "KR": "*** 악마의 등장으로 인해 우리 계획은 완전히 무너졌다 ***",
      "TW": "因為惡魔的出現，我們的計劃被徹底打亂"
    }
  },
  "<<< 那家伙一定和这次的异变有关，十分危险 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<< That individual must be connected to this anomaly; they are highly dangerous. >",
      "JP": "<<< あいつは今回の異変に関与しているはずだ。非常に危険 >>>",
      "CN": "",
      "KR": "*** 저 자들은 이번 기이한 사건과 관련이 있을 거야. 매우 위험해 ***",
      "TW": "那傢伙一定和這次的異變有關，十分危險"
    }
  },
  "<<< 我们放弃回到洛丹伦，再次来到这里 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<< We have abandoned our return to Lordaeron and returned here. >",
      "JP": "ロードァーレンへの帰還を諦め、再びこの地を訪れた",
      "CN": "",
      "KR": "우리는 로데론으로의 귀국을 포기하고, 다시 이곳에 모였다.",
      "TW": "我們放棄回到洛丹倫，再次來到這裡。"
    }
  },
  "<<< 根据情报，恶魔就盘踞在岛屿的地下城内 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<< Intelligence suggests the demons are hiding in the underground city beneath the island. >",
      "JP": "情報によると、デーモンは島の地下洞窟に潜んでいる",
      "CN": "根据情报，恶魔就在岛屿的地牢 underground城里",
      "KR": "정보에 따르면 악마들이 섬의 지하 동굴에 몸을 숨기고 있다.",
      "TW": "根據情報，惡魔就盤踞在島嶼的地下城內。"
    }
  },
  "<<< 我们要发动攻击，击败恶魔 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<< We must launch an attack and defeat the demons. >",
      "JP": "攻撃を開始し、デーモンを撃破する",
      "CN": "",
      "KR": "공격을 개시하여 악마들을 물리치자!",
      "TW": "我們要發動攻擊，擊敗惡魔。"
    }
  },
  "<<< 但愿这是最后一战，为了洛丹伦 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<< May this be our final battle, for Lordaeron. >",
      "JP": "これが最後の戦いでありますように、ロードァーレンのために",
      "CN": "",
      "KR": "로데론을 위해, 이번이 마지막 전투이길 바란다.",
      "TW": "但願這是最後一站，為了洛丹倫。"
    }
  },
  "** 坚守45s **": {
    "translation": "",
    "MultiLang": {
      "US": "**Hold for 45s**",
      "JP": "** 45秒間維持 **",
      "CN": "",
      "KR": "** 45초 내내 방어 유지 **",
      "TW": "** 堅守45s **"
    }
  },
  "** 双子大门15s后打开**": {
    "translation": "",
    "MultiLang": {
      "US": "**Twin doors open in 15s**",
      "JP": "** 双子の門は15秒後に開く **",
      "CN": "",
      "KR": "** 쌍둥이 문, 15초 후 개장 **",
      "TW": "** 雙子大門15s後打開**"
    }
  },
  "<<< 废弃的地下城仍在运行 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<< The abandoned dungeon is still operational >>>",
      "JP": "放棄された地下洞窟はなお稼働している",
      "CN": "废弃的地牢仍然运作",
      "KR": "폐허가 된 지하 동굴이 여전히 작동 중이다.",
      "TW": "「廢棄的地下城仍在運行」"
    }
  },
  "<<< 不安.. >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<< Unease.. >>>",
      "JP": "不安だ…",
      "CN": "",
      "KR": "불안...",
      "TW": "「不安..」"
    }
  },
  "** 20s铁门打开 **": {
    "translation": "",
    "MultiLang": {
