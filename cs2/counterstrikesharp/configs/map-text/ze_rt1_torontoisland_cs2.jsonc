  "** 访问成功，大门10s后开启 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Access granted, gate opens in 10s **",
      "JP": "アクセス成功、10秒後に扉が開く",
      "CN": "",
      "KR": "** 방문 성공, 10초 후 문 열림 **",
      "TW": "** 訪問成功，門將於10秒後開啟 **"
    }
  },
  "<<< 道路被切断了，这是个阴谋 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<< Path cut off. This is a conspiracy. >>>",
      "JP": "<<< 道路が寸断された、これは阴谋だ >>>",
      "CN": "",
      "KR": "<<道路가 막혔다, 이는 음모이다>>",
      "TW": "道路中斷，這是一場陰謀"
