{
  "<<< 多伦岛发生了异变，情况不明 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "Something strange has happened on Doran Island, but the situation is unclear.",
      "JP": "多倫島で異変が発生、状況は不明",
      "CN": "",
      "KR": "<<< 두론島에 이상 징후가 발생했으며, 상황은 불분명합니다 >>>",
      "TW": "多倫島發生異變，情況不明"
    }
  },
  "<<< 洛丹伦命令我部前来查看 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "Lordaeron commanded me to come and check on this matter.",
      "JP": "ロザリット公より視察の命を受けて参りました",
      "CN": "",
      "KR": "<<< 로더론이 저의 부대를 파견하여 조사하라고 명했습니다 >>>",
      "TW": "洛丹倫命令我部前來查看"
    }
  },
  "<<< 我们将以这座神庙为据点 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "We will make this temple our headquarters.",
      "JP": "この神殿を拠点とします",
      "CN": "",
      "KR": "<<< 우리는 이 신전을 거점으로 삼겠습니다 >>>",
      "TW": "我們將以這座神廟為據點"
    }
  },
