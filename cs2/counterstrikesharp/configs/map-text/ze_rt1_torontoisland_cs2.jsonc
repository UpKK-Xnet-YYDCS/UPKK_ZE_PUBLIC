  "** 增益者提升范围内恶灵的能力，强化身体体能  **": {
    "translation": "",
    "MultiLang": {
      "US": "** The booster enhances the abilities of Ghosts within range, strengthening physical capabilities. **",
      "JP": "** バフアイテムは範囲内の悪霊のパワーを高め、体機能を強化する **",
      "CN": "",
      "KR": "** 버프 아이템은 사거리 내의 악령 능력을 강화하며, 체력 및 신체 능력도 향상시킵니다 **",
      "TW": "** 增益道具會強化範圍內惡靈的能力，增強其身體素質 **"
    }
  },
  "** 第二开关已按下，解锁大门 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Second switch activated, gate unlocked **",
      "JP": "** 第2スイッチが押され、門が開いた **",
      "CN": "",
      "KR": "** 두 번째 스위치 작동 완료, 관문 개방**",
      "TW": "** 第二個開關已啟動，大門解鎖 **"
    }
  },
  "** 不要让他们穿过大门，坚持 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Don't let them pass through the gate. Hold on **",
      "JP": "** 敵がゲートを越えないように、粘り強く戦え **",
      "CN": "",
      "KR": "** 그들을 문 너머로 보내지 마라, 버티세요 **",
      "TW": "** 不要讓他們穿過大門，堅持 **"
    }
  },
  "** 大门5s后开启 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Gate opens in 5s **",
      "JP": "** ゲートは5秒後に開く **",
      "CN": "",
      "KR": "** 5초 후 문이 열립니다 **",
      "TW": "** 大門5秒後開啟 **"
    }
  },
  "** 感谢miluli提供的模型**": {
    "translation": "",
    "MultiLang": {
      "US": "** Thanks to miluli for providing the model **",
      "JP": "** Miluliによるモデル提供に感謝 **",
      "CN": "",
      "KR": "** miluli가 제공한 모델에 감사드립니다**",
      "TW": "** 感謝miluli提供的模型**"
    }
  },
  "** 前 **": {
    "translation": "",
    "MultiLang": {
      "US": "** Before **",
      "JP": "前 **",
      "CN": "",
      "KR": "** 전방 **",
      "TW": "** 前 **"
    }
  },
  "** 右 **": {
    "translation": "",
    "MultiLang": {
      "US": "Right",
      "JP": "右 **",
      "CN": "",
      "KR": "** 우측 **",
      "TW": "** 右 **"
    }
  },
  "<<< 他消失了，但我们仍被他玩弄于鼓掌之中 >>>": {
    "translation": "",
    "MultiLang": {
      "US": "<<< He vanished, yet he still plays us like puppets on his palm. >>>",
      "JP": "<<< 彼は姿を消したが、それでも我々は彼の掌の中で操り人形のように弄ばれ続けていた。 >>>",
      "CN": "",
      "KR": "<<< 그는 사라졌지만, 우리는 여전히 그의 손바닥 위에서 장난감처럼 놀리고 있습니다 >>>",
      "TW": "<<< 他消失了，但我們仍被他玩弄於股掌之中 >>>"
    }
  },
  "** 5s后传送 **": {
    "translation": "",
    "MultiLang": {
      "US": "Teleport in 5s",
      "JP": "** 5秒後にテレポート **",
      "CN": "5秒后传送",
      "KR": "** 5초 후 텔레포트 **",
      "TW": "** 5秒後傳送 **"
    }
  },
  "** 25s后开启传送 **": {
    "translation": "",
    "MultiLang": {
      "US": "Portal opens in 25s",
      "JP": "** 25秒後にテレポート開始 **",
