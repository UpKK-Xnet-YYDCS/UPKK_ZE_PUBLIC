{
  "***A Player has picked up Heal***": {
    "translation": "***一名玩家拾取了奶***",
    "MultiLang": {
      "US": "",
      "JP": "***プレイヤーが回復アイテムを獲得***",
      "CN": "***有玩家拾取了治疗道具***",
      "KR": "***플레이어가 회복 아이템을 획득했습니다***",
      "TW": "***一名玩家拾取了回覆道具***"
    }
  },
  "***Anyway I need to get out of here.***": {
    "translation": "***不管怎样，我得离开这里。***",
    "MultiLang": {
      "US": "",
      "JP": "***とにかくここから逃げ出す必要がある。***",
      "CN": "***不管怎样，我必须离开这里。***",
      "KR": "***아무튼 여기부터는 빠져나와야 해.***",
      "TW": "***不管怎样，我必須離開這裡。***"
    }
  },
  "***DEFEND 30 SECONDS***": {
