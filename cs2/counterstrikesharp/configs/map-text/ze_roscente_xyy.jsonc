  "** FOOLISH HUMAN. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 愚かな人間め。 **",
      "CN": "** 愚蠢的人类。 **",
      "KR": "** 어리석은 인간. **",
      "TW": "** 愚蠢的人類。**"
    }
  },
  "** TO THINK YOU CAN ESCAPE THAT VILLAGE. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** あの村から脱出できるとでも思ったか。 **",
      "CN": "** 竟妄想逃离那个村庄。 **",
      "KR": "** 그 마을에서 도망칠 수 있다고 생각하다니. **",
      "TW": "** 竟以為能逃離那個村莊。**"
    }
  },
  "** HA. HA. HA. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ハ。ハ。ハ。 **",
      "CN": "** 哈。哈。哈。 **",
      "KR": "** 하. 하. 하. **",
      "TW": "** 哈。哈。哈。**"
    }
  },
  "** NOT LIKE YOU CAN DEFEAT ME. **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** 貴様如きに私が倒せるわけがない。 **",
      "CN": "** 别想打败我。 **",
      "KR": "** 네가 나를 이길 수 있을 것 같나. **",
      "TW": "** 你也打不敗我。**"
    }
  },
  "** Roscente. The Cosmic Wisp has awoken! **": {
    "translation": "",
    "MultiLang": {
      "US": "",
      "JP": "** ロッセンテ。コズミック・ウィスプが目覚めた！ **",
